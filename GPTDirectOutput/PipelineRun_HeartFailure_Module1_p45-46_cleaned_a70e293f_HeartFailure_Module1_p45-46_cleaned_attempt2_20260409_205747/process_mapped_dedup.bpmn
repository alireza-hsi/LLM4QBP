<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_Acute_Heart_Failure_Risk_Stratification" name="Episode of Care for Acute Heart Failure - Module 1 Risk Stratification" isExecutable="false">
    <startEvent id="StartEvent_AcuteHFPresentation" name="Patient presents to ED with acute heart failure"><outgoing>Flow_1</outgoing></startEvent>
    <task id="Task_StandardizedRiskAssessment" name="Risk stratification&#10;(e.g., EHMRG)"><incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <parallelGateway id="Gateway_InvestigationsSplit"><incoming>Flow_2</incoming><outgoing>Flow_3</outgoing><outgoing>Flow_4</outgoing><outgoing>Flow_5</outgoing><outgoing>Flow_6</outgoing><outgoing>Flow_7</outgoing><outgoing>Flow_8</outgoing><outgoing>Flow_9</outgoing></parallelGateway>
    <task id="Task_SerumCreatinineElectrolytes" name="Serum creatinine and electrolyte levels"><incoming>Flow_3</incoming><outgoing>Flow_10</outgoing></task>
    <task id="Task_TroponinMeasurements" name="Troponin measurements"><incoming>Flow_4</incoming><outgoing>Flow_11</outgoing></task>
    <task id="Task_CompleteBloodCount" name="Complete blood count"><incoming>Flow_5</incoming><outgoing>Flow_12</outgoing></task>
    <task id="Task_Electrocardiogram" name="Perform electrocardiogram"><incoming>Flow_6</incoming><outgoing>Flow_13</outgoing></task>
    <task id="Task_ChestXRay" name="Chest x-ray"><incoming>Flow_7</incoming><outgoing>Flow_14</outgoing></task>
    <exclusiveGateway id="Gateway_RecentEchoAvailable" name="Recent echocardiogram available?"><incoming>Flow_8</incoming><outgoing>Flow_15</outgoing><outgoing>Flow_16</outgoing></exclusiveGateway>
    <task id="Task_Echocardiogram" name="Echocardiogram"><incoming>Flow_16</incoming><outgoing>Flow_17</outgoing></task>
    <exclusiveGateway id="Gateway_EchoDecisionMerge"><incoming>Flow_15</incoming><incoming>Flow_17</incoming><outgoing>Flow_18</outgoing></exclusiveGateway>
    <task id="Task_MonitorVitalsUntilStabilized" name="Monitor heart rate, blood pressure, oxygen saturation until stabilized">
      <standardLoopCharacteristics />
    <incoming>Flow_9</incoming><outgoing>Flow_19</outgoing></task>
    <parallelGateway id="Gateway_InvestigationsJoin"><incoming>Flow_10</incoming><incoming>Flow_11</incoming><incoming>Flow_12</incoming><incoming>Flow_13</incoming><incoming>Flow_14</incoming><incoming>Flow_18</incoming><incoming>Flow_19</incoming><outgoing>Flow_20</outgoing></parallelGateway>
    <task id="Task_AssessTreatmentResponse" name="Check responsiveness to Diuresis"><incoming>Flow_20</incoming><outgoing>Flow_21</outgoing></task>
    <task id="Task_CalculateEHMRG" name="Risk stratification&#10;(e.g., EHMRG)"><incoming>Flow_21</incoming><outgoing>Flow_23</outgoing></task>
    <exclusiveGateway id="Gateway_VentilationOrICURequired" name="Ventilation or ICU required?"><incoming>Flow_23</incoming><outgoing>Flow_24</outgoing><outgoing>Flow_25</outgoing></exclusiveGateway>
    <exclusiveGateway id="Gateway_HigherLevelProviderNeeded" name="Need transfer to higher level provider?"><incoming>Flow_25</incoming><outgoing>Flow_26</outgoing><outgoing>Flow_28</outgoing></exclusiveGateway>
    <task id="Task_TransferToHigherLevelProvider" name="Transfer patient to higher level provider"><incoming>Flow_26</incoming><outgoing>Flow_27</outgoing></task>
    <endEvent id="EndEvent_Transferred" name="Transferred to higher level provider"><incoming>Flow_27</incoming></endEvent>
    <task id="Task_ProvideVentilationOrAdmitToICU" name="Admit to ICU (high nurse-to-patient staffing)"><incoming>Flow_28</incoming><outgoing>Flow_29</outgoing></task>
    <endEvent id="EndEvent_HighIntensityCare" name="High-intensity care initiated"><incoming>Flow_29</incoming></endEvent>
    <exclusiveGateway id="Gateway_LowRiskDischargeEligible" name="Low-risk discharge eligible?"><incoming>Flow_24</incoming><outgoing>Flow_30</outgoing><outgoing>Flow_33</outgoing></exclusiveGateway>
    <task id="Task_ArrangePCPFollowUp" name="Arrange follow-up (within days) with primary care"><incoming>Flow_30</incoming><outgoing>Flow_31</outgoing></task>
    <task id="Task_DischargeHomeFromED" name="Discharge home"><incoming>Flow_31</incoming><outgoing>Flow_32</outgoing></task>
    <endEvent id="EndEvent_DischargeHome" name="Discharged home with follow-up arranged"><incoming>Flow_32</incoming></endEvent>
    <task id="Task_AdmitToInpatientCare" name="Admit to inpatient care (normal nurse-to-patient staffing)"><incoming>Flow_33</incoming><outgoing>Flow_34</outgoing></task>
    <endEvent id="EndEvent_InpatientAdmission" name="Admitted to inpatient care"><incoming>Flow_34</incoming></endEvent>

    <sequenceFlow id="Flow_1" sourceRef="StartEvent_AcuteHFPresentation" targetRef="Task_StandardizedRiskAssessment" />
    <sequenceFlow id="Flow_2" sourceRef="Task_StandardizedRiskAssessment" targetRef="Gateway_InvestigationsSplit" />
    <sequenceFlow id="Flow_3" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_SerumCreatinineElectrolytes" />
    <sequenceFlow id="Flow_4" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_TroponinMeasurements" />
    <sequenceFlow id="Flow_5" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_CompleteBloodCount" />
    <sequenceFlow id="Flow_6" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_Electrocardiogram" />
    <sequenceFlow id="Flow_7" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_ChestXRay" />
    <sequenceFlow id="Flow_8" sourceRef="Gateway_InvestigationsSplit" targetRef="Gateway_RecentEchoAvailable" />
    <sequenceFlow id="Flow_9" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_MonitorVitalsUntilStabilized" />
    <sequenceFlow id="Flow_10" sourceRef="Task_SerumCreatinineElectrolytes" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_11" sourceRef="Task_TroponinMeasurements" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_12" sourceRef="Task_CompleteBloodCount" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_13" sourceRef="Task_Electrocardiogram" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_14" sourceRef="Task_ChestXRay" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_15" name="Yes" sourceRef="Gateway_RecentEchoAvailable" targetRef="Gateway_EchoDecisionMerge" />
    <sequenceFlow id="Flow_16" name="No" sourceRef="Gateway_RecentEchoAvailable" targetRef="Task_Echocardiogram" />
    <sequenceFlow id="Flow_17" sourceRef="Task_Echocardiogram" targetRef="Gateway_EchoDecisionMerge" />
    <sequenceFlow id="Flow_18" sourceRef="Gateway_EchoDecisionMerge" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_19" sourceRef="Task_MonitorVitalsUntilStabilized" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_20" sourceRef="Gateway_InvestigationsJoin" targetRef="Task_AssessTreatmentResponse" />
    <sequenceFlow id="Flow_21" sourceRef="Task_AssessTreatmentResponse" targetRef="Task_CalculateEHMRG" />
    <sequenceFlow id="Flow_23" sourceRef="Task_CalculateEHMRG" targetRef="Gateway_VentilationOrICURequired" />
    <sequenceFlow id="Flow_24" name="No" sourceRef="Gateway_VentilationOrICURequired" targetRef="Gateway_LowRiskDischargeEligible" />
    <sequenceFlow id="Flow_25" name="Yes" sourceRef="Gateway_VentilationOrICURequired" targetRef="Gateway_HigherLevelProviderNeeded" />
    <sequenceFlow id="Flow_26" name="Yes" sourceRef="Gateway_HigherLevelProviderNeeded" targetRef="Task_TransferToHigherLevelProvider" />
    <sequenceFlow id="Flow_27" sourceRef="Task_TransferToHigherLevelProvider" targetRef="EndEvent_Transferred" />
    <sequenceFlow id="Flow_28" name="No" sourceRef="Gateway_HigherLevelProviderNeeded" targetRef="Task_ProvideVentilationOrAdmitToICU" />
    <sequenceFlow id="Flow_29" sourceRef="Task_ProvideVentilationOrAdmitToICU" targetRef="EndEvent_HighIntensityCare" />
    <sequenceFlow id="Flow_30" name="Yes" sourceRef="Gateway_LowRiskDischargeEligible" targetRef="Task_ArrangePCPFollowUp" />
    <sequenceFlow id="Flow_31" sourceRef="Task_ArrangePCPFollowUp" targetRef="Task_DischargeHomeFromED" />
    <sequenceFlow id="Flow_32" sourceRef="Task_DischargeHomeFromED" targetRef="EndEvent_DischargeHome" />
    <sequenceFlow id="Flow_33" name="No" sourceRef="Gateway_LowRiskDischargeEligible" targetRef="Task_AdmitToInpatientCare" />
    <sequenceFlow id="Flow_34" sourceRef="Task_AdmitToInpatientCare" targetRef="EndEvent_InpatientAdmission" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Acute_Heart_Failure">
    <bpmndi:BPMNPlane id="BPMNPlane_Acute_Heart_Failure" bpmnElement="Process_Acute_Heart_Failure_Risk_Stratification">
