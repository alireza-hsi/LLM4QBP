      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_High_Intensity_Join_di" bpmnElement="Gateway_High_Intensity_Join">
        <dc:Bounds x="2270" y="445" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_High_Intensity_Local_di" bpmnElement="EndEvent_High_Intensity_Local">
