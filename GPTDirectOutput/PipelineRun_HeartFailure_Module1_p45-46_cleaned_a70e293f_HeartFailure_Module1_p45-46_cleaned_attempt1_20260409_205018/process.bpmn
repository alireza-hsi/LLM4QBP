      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Provide_Ventilation_di" bpmnElement="Task_Provide_Ventilation">
        <dc:Bounds x="1930" y="380" width="220" height="80"/>
      </bpmndi:BPMNShape>
