      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Discharge_Home_ED_di" bpmnElement="Task_Discharge_Home_ED">
        <dc:Bounds x="1690" y="100" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Arrange_PCP_Followup_di" bpmnElement="Task_Arrange_PCP_Followup">
        <dc:Bounds x="1910" y="100" width="230" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Low_Intensity_di" bpmnElement="EndEvent_Low_Intensity">
        <dc:Bounds x="2180" y="122" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Admit_Inpatient_Normal_Staffing_di" bpmnElement="Task_Admit_Inpatient_Normal_Staffing">
        <dc:Bounds x="1690" y="270" width="280" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Average_Intensity_di" bpmnElement="EndEvent_Average_Intensity">
