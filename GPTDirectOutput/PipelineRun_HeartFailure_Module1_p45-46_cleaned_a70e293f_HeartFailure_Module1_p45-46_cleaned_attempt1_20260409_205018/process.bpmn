<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_AHF_Episode_Risk_Stratification" name="Acute Heart Failure Episode of Care - Module 1 Risk Stratification" isExecutable="false">
    <startEvent id="StartEvent_AHF_Presentation" name="Patient presents to ED with acute heart failure">
      <outgoing>Flow_01</outgoing>
    </startEvent>

    <task id="Task_Standardized_Risk_Assessment" name="Perform standardized risk assessment and stratification">
      <incoming>Flow_01</incoming>
      <outgoing>Flow_02</outgoing>
    </task>

    <parallelGateway id="Gateway_Initial_Workup_Split" gatewayDirection="Diverging">
      <incoming>Flow_02</incoming>
      <outgoing>Flow_03</outgoing>
      <outgoing>Flow_04</outgoing>
      <outgoing>Flow_05</outgoing>
      <outgoing>Flow_06</outgoing>
      <outgoing>Flow_07</outgoing>
      <outgoing>Flow_08</outgoing>
    </parallelGateway>

    <task id="Task_Initial_ED_Treatment_and_Diuresis" name="Provide initial ED treatment including diuresis">
      <incoming>Flow_03</incoming>
      <outgoing>Flow_13</outgoing>
    </task>

    <task id="Task_Laboratory_Tests" name="Obtain serum creatinine, electrolytes, troponin, and complete blood count">
      <incoming>Flow_04</incoming>
      <outgoing>Flow_14</outgoing>
    </task>

    <task id="Task_ECG" name="Perform electrocardiogram">
      <incoming>Flow_05</incoming>
      <outgoing>Flow_15</outgoing>
    </task>

    <task id="Task_Chest_Xray" name="Perform chest x-ray examination">
      <incoming>Flow_06</incoming>
      <outgoing>Flow_16</outgoing>
    </task>

    <exclusiveGateway id="Gateway_Recent_Echo_Available" name="Recent echocardiogram available?" gatewayDirection="Diverging">
      <incoming>Flow_07</incoming>
      <outgoing>Flow_09</outgoing>
      <outgoing>Flow_10</outgoing>
    </exclusiveGateway>

    <task id="Task_Perform_Echocardiogram" name="Perform echocardiogram">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_11</outgoing>
    </task>

    <exclusiveGateway id="Gateway_Echo_Merge" gatewayDirection="Converging">
      <incoming>Flow_09</incoming>
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </exclusiveGateway>

    <task id="Task_Monitor_Vitals_Until_Stabilized" name="Measure heart rate, blood pressure, and oxygen saturation until stabilized">
      <incoming>Flow_08</incoming>
      <outgoing>Flow_17</outgoing>
    </task>

    <parallelGateway id="Gateway_Initial_Workup_Join" gatewayDirection="Converging">
      <incoming>Flow_12</incoming>
      <incoming>Flow_13</incoming>
      <incoming>Flow_14</incoming>
      <incoming>Flow_15</incoming>
      <incoming>Flow_16</incoming>
      <incoming>Flow_17</incoming>
      <outgoing>Flow_18</outgoing>
    </parallelGateway>

    <task id="Task_Assess_Response_High_Risk_Markers" name="Assess responsiveness to diuresis and high-risk markers">
      <incoming>Flow_18</incoming>
      <outgoing>Flow_19</outgoing>
    </task>

    <task id="Task_Calculate_AHF_Risk_Score" name="Calculate acute heart failure risk score (e.g., EHMRG)">
      <incoming>Flow_19</incoming>
      <outgoing>Flow_20</outgoing>
    </task>

    <exclusiveGateway id="Gateway_Determine_Intensity_Disposition" name="Determine intensity group and disposition" gatewayDirection="Diverging">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_21</outgoing>
      <outgoing>Flow_24</outgoing>
      <outgoing>Flow_26</outgoing>
    </exclusiveGateway>

    <task id="Task_Discharge_Home_ED" name="Discharge home from ED">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>

    <task id="Task_Arrange_PCP_Followup" name="Arrange follow-up visit with primary care provider within days">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_23</outgoing>
    </task>

    <endEvent id="EndEvent_Low_Intensity" name="Discharged home with follow-up arranged">
      <incoming>Flow_23</incoming>
    </endEvent>

    <task id="Task_Admit_Inpatient_Normal_Staffing" name="Admit to inpatient care with normal nurse-to-patient staffing">
      <incoming>Flow_24</incoming>
      <outgoing>Flow_25</outgoing>
    </task>

    <endEvent id="EndEvent_Average_Intensity" name="Admitted to inpatient care">
      <incoming>Flow_25</incoming>
    </endEvent>

    <exclusiveGateway id="Gateway_Higher_Level_Provider_Required" name="Higher-level provider required?" gatewayDirection="Diverging">
      <incoming>Flow_26</incoming>
      <outgoing>Flow_27</outgoing>
      <outgoing>Flow_28</outgoing>
    </exclusiveGateway>

    <inclusiveGateway id="Gateway_High_Intensity_Split" name="Select high-intensity interventions" gatewayDirection="Diverging">
      <incoming>Flow_27</incoming>
      <outgoing>Flow_29</outgoing>
      <outgoing>Flow_30</outgoing>
    </inclusiveGateway>

    <task id="Task_Provide_Ventilation" name="Provide noninvasive or invasive ventilation">
      <incoming>Flow_29</incoming>
      <outgoing>Flow_31</outgoing>
    </task>

    <task id="Task_Admit_ICU_Higher_Staffing" name="Admit to intensive care unit with higher nurse-to-patient staffing">
      <incoming>Flow_30</incoming>
      <outgoing>Flow_32</outgoing>
    </task>

    <inclusiveGateway id="Gateway_High_Intensity_Join" gatewayDirection="Converging">
      <incoming>Flow_31</incoming>
      <incoming>Flow_32</incoming>
      <outgoing>Flow_33</outgoing>
    </inclusiveGateway>

    <endEvent id="EndEvent_High_Intensity_Local" name="Local high-intensity care initiated">
      <incoming>Flow_33</incoming>
    </endEvent>

    <task id="Task_Transfer_Higher_Level_Provider" name="Transfer patient to higher-level provider">
      <incoming>Flow_28</incoming>
      <outgoing>Flow_34</outgoing>
    </task>

    <endEvent id="EndEvent_High_Intensity_Transfer" name="Transferred to higher-level provider">
      <incoming>Flow_34</incoming>
    </endEvent>

    <sequenceFlow id="Flow_01" sourceRef="StartEvent_AHF_Presentation" targetRef="Task_Standardized_Risk_Assessment"/>
    <sequenceFlow id="Flow_02" sourceRef="Task_Standardized_Risk_Assessment" targetRef="Gateway_Initial_Workup_Split"/>
    <sequenceFlow id="Flow_03" sourceRef="Gateway_Initial_Workup_Split" targetRef="Task_Initial_ED_Treatment_and_Diuresis"/>
    <sequenceFlow id="Flow_04" sourceRef="Gateway_Initial_Workup_Split" targetRef="Task_Laboratory_Tests"/>
    <sequenceFlow id="Flow_05" sourceRef="Gateway_Initial_Workup_Split" targetRef="Task_ECG"/>
    <sequenceFlow id="Flow_06" sourceRef="Gateway_Initial_Workup_Split" targetRef="Task_Chest_Xray"/>
    <sequenceFlow id="Flow_07" sourceRef="Gateway_Initial_Workup_Split" targetRef="Gateway_Recent_Echo_Available"/>
    <sequenceFlow id="Flow_08" sourceRef="Gateway_Initial_Workup_Split" targetRef="Task_Monitor_Vitals_Until_Stabilized"/>
    <sequenceFlow id="Flow_09" name="Recent echocardiogram available" sourceRef="Gateway_Recent_Echo_Available" targetRef="Gateway_Echo_Merge"/>
    <sequenceFlow id="Flow_10" name="No recent echocardiogram" sourceRef="Gateway_Recent_Echo_Available" targetRef="Task_Perform_Echocardiogram"/>
    <sequenceFlow id="Flow_11" sourceRef="Task_Perform_Echocardiogram" targetRef="Gateway_Echo_Merge"/>
    <sequenceFlow id="Flow_12" sourceRef="Gateway_Echo_Merge" targetRef="Gateway_Initial_Workup_Join"/>
    <sequenceFlow id="Flow_13" sourceRef="Task_Initial_ED_Treatment_and_Diuresis" targetRef="Gateway_Initial_Workup_Join"/>
    <sequenceFlow id="Flow_14" sourceRef="Task_Laboratory_Tests" targetRef="Gateway_Initial_Workup_Join"/>
    <sequenceFlow id="Flow_15" sourceRef="Task_ECG" targetRef="Gateway_Initial_Workup_Join"/>
    <sequenceFlow id="Flow_16" sourceRef="Task_Chest_Xray" targetRef="Gateway_Initial_Workup_Join"/>
    <sequenceFlow id="Flow_17" sourceRef="Task_Monitor_Vitals_Until_Stabilized" targetRef="Gateway_Initial_Workup_Join"/>
    <sequenceFlow id="Flow_18" sourceRef="Gateway_Initial_Workup_Join" targetRef="Task_Assess_Response_High_Risk_Markers"/>
    <sequenceFlow id="Flow_19" sourceRef="Task_Assess_Response_High_Risk_Markers" targetRef="Task_Calculate_AHF_Risk_Score"/>
    <sequenceFlow id="Flow_20" sourceRef="Task_Calculate_AHF_Risk_Score" targetRef="Gateway_Determine_Intensity_Disposition"/>
    <sequenceFlow id="Flow_21" name="Low intensity: low risk, responded to ED treatment, no other considerations" sourceRef="Gateway_Determine_Intensity_Disposition" targetRef="Task_Discharge_Home_ED"/>
    <sequenceFlow id="Flow_22" sourceRef="Task_Discharge_Home_ED" targetRef="Task_Arrange_PCP_Followup"/>
    <sequenceFlow id="Flow_23" sourceRef="Task_Arrange_PCP_Followup" targetRef="EndEvent_Low_Intensity"/>
    <sequenceFlow id="Flow_24" name="Average intensity" sourceRef="Gateway_Determine_Intensity_Disposition" targetRef="Task_Admit_Inpatient_Normal_Staffing"/>
    <sequenceFlow id="Flow_25" sourceRef="Task_Admit_Inpatient_Normal_Staffing" targetRef="EndEvent_Average_Intensity"/>
    <sequenceFlow id="Flow_26" name="High intensity" sourceRef="Gateway_Determine_Intensity_Disposition" targetRef="Gateway_Higher_Level_Provider_Required"/>
    <sequenceFlow id="Flow_27" name="No transfer required" sourceRef="Gateway_Higher_Level_Provider_Required" targetRef="Gateway_High_Intensity_Split"/>
    <sequenceFlow id="Flow_28" name="Transfer required" sourceRef="Gateway_Higher_Level_Provider_Required" targetRef="Task_Transfer_Higher_Level_Provider"/>
    <sequenceFlow id="Flow_29" name="Ventilation required" sourceRef="Gateway_High_Intensity_Split" targetRef="Task_Provide_Ventilation"/>
    <sequenceFlow id="Flow_30" name="ICU admission required" sourceRef="Gateway_High_Intensity_Split" targetRef="Task_Admit_ICU_Higher_Staffing"/>
    <sequenceFlow id="Flow_31" sourceRef="Task_Provide_Ventilation" targetRef="Gateway_High_Intensity_Join"/>
    <sequenceFlow id="Flow_32" sourceRef="Task_Admit_ICU_Higher_Staffing" targetRef="Gateway_High_Intensity_Join"/>
    <sequenceFlow id="Flow_33" sourceRef="Gateway_High_Intensity_Join" targetRef="EndEvent_High_Intensity_Local"/>
    <sequenceFlow id="Flow_34" sourceRef="Task_Transfer_Higher_Level_Provider" targetRef="EndEvent_High_Intensity_Transfer"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_AHF">
    <bpmndi:BPMNPlane id="BPMNPlane_AHF" bpmnElement="Process_AHF_Episode_Risk_Stratification">
