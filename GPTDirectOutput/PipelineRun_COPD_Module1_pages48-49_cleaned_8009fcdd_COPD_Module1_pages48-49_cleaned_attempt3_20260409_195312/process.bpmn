<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn" id="Definitions_COPD_Module_1">
  <process id="Process_COPD_Module_1" name="Module 1 Initial Presentation and Assessment" isExecutable="false">
    <startEvent id="StartEvent_PatientPresentation" name="Patient presents or is directly admitted with suspected COPD exacerbation"/>
    <exclusiveGateway id="Gateway_ResuscitationNeeded" name="Immediate resuscitation required at ED presentation?" default="Flow_NoImmediateResuscitation"/>
    <task id="Task_TrialImmediateResuscitation" name="Trial immediate resuscitation"/>
    <exclusiveGateway id="Gateway_PostResuscitationMerge"/>
    <parallelGateway id="Gateway_InitialAssessmentSplit"/>
    <task id="Task_CheckVitalSigns" name="Check vital signs, respiratory status, consciousness, oxygen saturation, and sputum"/>
    <task id="Task_PerformPhysicalExamination" name="Perform physical examination"/>
    <task id="Task_CheckPatientHistory" name="Check patient history"/>
    <task id="Task_ReconcileMedications" name="Document and reconcile current medications"/>
    <task id="Task_PerformChestXRay" name="Perform chest x-ray as appropriate"/>
    <task id="Task_ConductBaselineBloodWork" name="Conduct baseline blood work"/>
    <task id="Task_PerformECG" name="Perform electrocardiogram"/>
    <parallelGateway id="Gateway_InitialAssessmentJoin"/>
    <inclusiveGateway id="Gateway_AdditionalDiagnostics" name="Additional diagnostics needed?" default="Flow_NoAdditionalDiagnostics"/>
    <task id="Task_CheckArterialBloodGases" name="Check arterial blood gases"/>
    <task id="Task_DrawBloodCultures" name="Draw blood cultures"/>
    <task id="Task_ExamineCardiacMarkers" name="Examine cardiac markers"/>
    <task id="Task_PerformOtherDiagnostics" name="Perform other diagnostic interventions as appropriate"/>
    <inclusiveGateway id="Gateway_AdditionalDiagnosticsJoin"/>
    <task id="Task_IdentifyGoalsOfCare" name="Identify goals of care and code status"/>
    <task id="Task_AssessLevelOfCare" name="Assess level of care required"/>
    <exclusiveGateway id="Gateway_AdmissionRequired" name="Hospital admission or inpatient care required?"/>
    <exclusiveGateway id="Gateway_AdmitSpirometryDecision" name="No prior objective COPD documentation through spirometry?" default="Flow_Admit_NoSpirometry"/>
    <task id="Task_PerformSpirometry_Admit" name="Perform spirometry once stabilized"/>
    <endEvent id="EndEvent_InpatientCareRequired" name="Admission or inpatient care required"/>
    <exclusiveGateway id="Gateway_NoAdmitSpirometryDecision" name="No prior objective COPD documentation through spirometry?" default="Flow_NoAdmit_NoSpirometry"/>
    <task id="Task_PerformSpirometry_NoAdmit" name="Perform spirometry once stabilized"/>
    <endEvent id="EndEvent_LowerLevelOfCare" name="Outpatient or lower level of care required"/>

    <sequenceFlow id="Flow_Start_To_ResuscitationGateway" sourceRef="StartEvent_PatientPresentation" targetRef="Gateway_ResuscitationNeeded"/>
    <sequenceFlow id="Flow_ImmediateResuscitation" name="Yes" sourceRef="Gateway_ResuscitationNeeded" targetRef="Task_TrialImmediateResuscitation"/>
    <sequenceFlow id="Flow_NoImmediateResuscitation" name="No" sourceRef="Gateway_ResuscitationNeeded" targetRef="Gateway_PostResuscitationMerge"/>
    <sequenceFlow id="Flow_Resuscitation_To_Merge" sourceRef="Task_TrialImmediateResuscitation" targetRef="Gateway_PostResuscitationMerge"/>
    <sequenceFlow id="Flow_Merge_To_AssessmentSplit" sourceRef="Gateway_PostResuscitationMerge" targetRef="Gateway_InitialAssessmentSplit"/>
    <sequenceFlow id="Flow_Split_To_CheckVitalSigns" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_CheckVitalSigns"/>
    <sequenceFlow id="Flow_Split_To_PhysicalExam" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_PerformPhysicalExamination"/>
    <sequenceFlow id="Flow_Split_To_CheckHistory" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_CheckPatientHistory"/>
    <sequenceFlow id="Flow_Split_To_ReconcileMedications" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_ReconcileMedications"/>
    <sequenceFlow id="Flow_Split_To_ChestXRay" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_PerformChestXRay"/>
    <sequenceFlow id="Flow_Split_To_BaselineBloodWork" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_ConductBaselineBloodWork"/>
    <sequenceFlow id="Flow_Split_To_ECG" sourceRef="Gateway_InitialAssessmentSplit" targetRef="Task_PerformECG"/>
    <sequenceFlow id="Flow_CheckVitalSigns_To_Join" sourceRef="Task_CheckVitalSigns" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_PhysicalExam_To_Join" sourceRef="Task_PerformPhysicalExamination" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_CheckHistory_To_Join" sourceRef="Task_CheckPatientHistory" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_ReconcileMedications_To_Join" sourceRef="Task_ReconcileMedications" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_ChestXRay_To_Join" sourceRef="Task_PerformChestXRay" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_BaselineBloodWork_To_Join" sourceRef="Task_ConductBaselineBloodWork" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_ECG_To_Join" sourceRef="Task_PerformECG" targetRef="Gateway_InitialAssessmentJoin"/>
    <sequenceFlow id="Flow_AssessmentJoin_To_AdditionalDiagnostics" sourceRef="Gateway_InitialAssessmentJoin" targetRef="Gateway_AdditionalDiagnostics"/>
    <sequenceFlow id="Flow_NeedABG" name="Low oxygen saturation or acute respiratory failure suspected" sourceRef="Gateway_AdditionalDiagnostics" targetRef="Task_CheckArterialBloodGases"/>
    <sequenceFlow id="Flow_NeedBloodCultures" name="Pneumonia or suspected sepsis" sourceRef="Gateway_AdditionalDiagnostics" targetRef="Task_DrawBloodCultures"/>
    <sequenceFlow id="Flow_NeedCardiacMarkers" name="Suspected cardiac disorder" sourceRef="Gateway_AdditionalDiagnostics" targetRef="Task_ExamineCardiacMarkers"/>
    <sequenceFlow id="Flow_NeedOtherDiagnostics" name="Other diagnoses or comorbidities suspected" sourceRef="Gateway_AdditionalDiagnostics" targetRef="Task_PerformOtherDiagnostics"/>
    <sequenceFlow id="Flow_NoAdditionalDiagnostics" name="No additional diagnostics" sourceRef="Gateway_AdditionalDiagnostics" targetRef="Gateway_AdditionalDiagnosticsJoin"/>
    <sequenceFlow id="Flow_ABG_To_AdditionalDiagnosticsJoin" sourceRef="Task_CheckArterialBloodGases" targetRef="Gateway_AdditionalDiagnosticsJoin"/>
    <sequenceFlow id="Flow_BloodCultures_To_AdditionalDiagnosticsJoin" sourceRef="Task_DrawBloodCultures" targetRef="Gateway_AdditionalDiagnosticsJoin"/>
    <sequenceFlow id="Flow_CardiacMarkers_To_AdditionalDiagnosticsJoin" sourceRef="Task_ExamineCardiacMarkers" targetRef="Gateway_AdditionalDiagnosticsJoin"/>
    <sequenceFlow id="Flow_OtherDiagnostics_To_AdditionalDiagnosticsJoin" sourceRef="Task_PerformOtherDiagnostics" targetRef="Gateway_AdditionalDiagnosticsJoin"/>
    <sequenceFlow id="Flow_AdditionalDiagnosticsJoin_To_GoalsOfCare" sourceRef="Gateway_AdditionalDiagnosticsJoin" targetRef="Task_IdentifyGoalsOfCare"/>
    <sequenceFlow id="Flow_GoalsOfCare_To_AssessLevelOfCare" sourceRef="Task_IdentifyGoalsOfCare" targetRef="Task_AssessLevelOfCare"/>
    <sequenceFlow id="Flow_AssessLevelOfCare_To_AdmissionGateway" sourceRef="Task_AssessLevelOfCare" targetRef="Gateway_AdmissionRequired"/>
    <sequenceFlow id="Flow_AdmissionRequired" name="Yes" sourceRef="Gateway_AdmissionRequired" targetRef="Gateway_AdmitSpirometryDecision"/>
    <sequenceFlow id="Flow_NoAdmissionRequired" name="No" sourceRef="Gateway_AdmissionRequired" targetRef="Gateway_NoAdmitSpirometryDecision"/>
    <sequenceFlow id="Flow_Admit_SpirometryNeeded" name="Yes" sourceRef="Gateway_AdmitSpirometryDecision" targetRef="Task_PerformSpirometry_Admit"/>
    <sequenceFlow id="Flow_Admit_NoSpirometry" name="No" sourceRef="Gateway_AdmitSpirometryDecision" targetRef="EndEvent_InpatientCareRequired"/>
    <sequenceFlow id="Flow_Spirometry_Admit_To_End" sourceRef="Task_PerformSpirometry_Admit" targetRef="EndEvent_InpatientCareRequired"/>
    <sequenceFlow id="Flow_NoAdmit_SpirometryNeeded" name="Yes" sourceRef="Gateway_NoAdmitSpirometryDecision" targetRef="Task_PerformSpirometry_NoAdmit"/>
    <sequenceFlow id="Flow_NoAdmit_NoSpirometry" name="No" sourceRef="Gateway_NoAdmitSpirometryDecision" targetRef="EndEvent_LowerLevelOfCare"/>
    <sequenceFlow id="Flow_Spirometry_NoAdmit_To_End" sourceRef="Task_PerformSpirometry_NoAdmit" targetRef="EndEvent_LowerLevelOfCare"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_COPD_Module_1">
    <bpmndi:BPMNPlane id="BPMNPlane_COPD_Module_1" bpmnElement="Process_COPD_Module_1">
