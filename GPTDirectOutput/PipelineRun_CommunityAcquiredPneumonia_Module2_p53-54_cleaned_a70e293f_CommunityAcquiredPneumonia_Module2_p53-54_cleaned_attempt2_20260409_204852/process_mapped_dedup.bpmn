<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_Diagnostic_Testing" name="Module 2 Diagnostic Testing" isExecutable="false">
    <startEvent id="StartEvent_CAP_Testing" name="Patient with suspected CAP under evaluation" />
    <task id="Task_Chest_Xray" name="Perform chest x-ray" />
    <task id="Task_Oxygen_Saturation" name="oxygen saturation" />
    <parallelGateway id="ParallelGateway_Diagnostic_Split" />
    <exclusiveGateway id="ExclusiveGateway_Sepsis_Decision" name="Sepsis present?" />
    <task id="Task_Wait_Xray_Results" name="wait for results of&#10;chest x-ray" />
    <exclusiveGateway id="ExclusiveGateway_Sepsis_Merge" />
    <exclusiveGateway id="ExclusiveGateway_Admission_Decision" name="Patient admitted to hospital?" />
    <parallelGateway id="ParallelGateway_Admission_Tests_Split" />
    <task id="Task_Routine_Blood_Work" name="Routine blood work: CBC," />
    <exclusiveGateway id="ExclusiveGateway_CRB65_Decision" name="More than 2 CRB-65 criteria?" />
    <task id="Task_Consider_Advanced_Labs" name="Blood gases" />
    <exclusiveGateway id="ExclusiveGateway_CRB65_Merge" />
    <exclusiveGateway id="ExclusiveGateway_Sputum_Sample_Decision" name="Adequate sputum sample obtainable?" />
    <task id="Task_Consider_Sputum_Culture" name="Sputum culture" />
    <exclusiveGateway id="ExclusiveGateway_Sputum_Obtained_Decision" name="Sputum culture obtained?" />
    <task id="Task_Consider_Gram_Stain" name="Gram staining" />
    <exclusiveGateway id="ExclusiveGateway_Sputum_Merge" />
    <parallelGateway id="ParallelGateway_Admission_Tests_Join" />
    <exclusiveGateway id="ExclusiveGateway_Admission_Merge" />
    <inclusiveGateway id="InclusiveGateway_Blood_Culture_Split" name="Blood culture indication present?" />
    <inclusiveGateway id="InclusiveGateway_Blood_Culture_Join" />
    <task id="Task_Obtain_Blood_Cultures" name="Obtain blood cultures" />
    <exclusiveGateway id="ExclusiveGateway_Blood_Culture_Merge" />
    <inclusiveGateway id="InclusiveGateway_Urine_Antigen_Split" name="Urine antigen indication present?" />
    <inclusiveGateway id="InclusiveGateway_Urine_Antigen_Join" />
    <task id="Task_Urine_Antigen_Test" name="Urine antigen testing" />
    <exclusiveGateway id="ExclusiveGateway_Urine_Antigen_Merge" />
    <exclusiveGateway id="ExclusiveGateway_Intubated_Decision" name="Intubated patient?" />
    <task id="Task_Consider_PCR_Legionella" name="PCR testing for Legionella" />
    <exclusiveGateway id="ExclusiveGateway_PCR_Merge" />
    <parallelGateway id="ParallelGateway_Diagnostic_Join" />
    <endEvent id="EndEvent_Diagnostic_Complete" name="Diagnostic testing complete" />

    <sequenceFlow id="Flow_Start_to_ChestXray" sourceRef="StartEvent_CAP_Testing" targetRef="Task_Chest_Xray" />
    <sequenceFlow id="Flow_ChestXray_to_Oxygen" sourceRef="Task_Chest_Xray" targetRef="Task_Oxygen_Saturation" />
    <sequenceFlow id="Flow_Oxygen_to_DiagnosticSplit" sourceRef="Task_Oxygen_Saturation" targetRef="ParallelGateway_Diagnostic_Split" />

    <sequenceFlow id="Flow_DiagnosticSplit_to_SepsisDecision" sourceRef="ParallelGateway_Diagnostic_Split" targetRef="ExclusiveGateway_Sepsis_Decision" />
    <sequenceFlow id="Flow_Sepsis_Yes" name="Yes" sourceRef="ExclusiveGateway_Sepsis_Decision" targetRef="ExclusiveGateway_Sepsis_Merge" />
    <sequenceFlow id="Flow_Sepsis_No" name="No" sourceRef="ExclusiveGateway_Sepsis_Decision" targetRef="Task_Wait_Xray_Results" />
    <sequenceFlow id="Flow_WaitXray_to_SepsisMerge" sourceRef="Task_Wait_Xray_Results" targetRef="ExclusiveGateway_Sepsis_Merge" />

    <sequenceFlow id="Flow_DiagnosticSplit_to_AdmissionDecision" sourceRef="ParallelGateway_Diagnostic_Split" targetRef="ExclusiveGateway_Admission_Decision" />
    <sequenceFlow id="Flow_Admission_Yes" name="Yes" sourceRef="ExclusiveGateway_Admission_Decision" targetRef="ParallelGateway_Admission_Tests_Split" />
    <sequenceFlow id="Flow_Admission_No" name="No" sourceRef="ExclusiveGateway_Admission_Decision" targetRef="ExclusiveGateway_Admission_Merge" />

    <sequenceFlow id="Flow_AdmissionTestsSplit_to_RoutineBlood" sourceRef="ParallelGateway_Admission_Tests_Split" targetRef="Task_Routine_Blood_Work" />
    <sequenceFlow id="Flow_RoutineBlood_to_AdmissionTestsJoin" sourceRef="Task_Routine_Blood_Work" targetRef="ParallelGateway_Admission_Tests_Join" />

    <sequenceFlow id="Flow_AdmissionTestsSplit_to_CRB65Decision" sourceRef="ParallelGateway_Admission_Tests_Split" targetRef="ExclusiveGateway_CRB65_Decision" />
    <sequenceFlow id="Flow_CRB65_Yes" name="Yes" sourceRef="ExclusiveGateway_CRB65_Decision" targetRef="Task_Consider_Advanced_Labs" />
    <sequenceFlow id="Flow_CRB65_No" name="No" sourceRef="ExclusiveGateway_CRB65_Decision" targetRef="ExclusiveGateway_CRB65_Merge" />
    <sequenceFlow id="Flow_AdvancedLabs_to_CRB65Merge" sourceRef="Task_Consider_Advanced_Labs" targetRef="ExclusiveGateway_CRB65_Merge" />
    <sequenceFlow id="Flow_CRB65Merge_to_AdmissionTestsJoin" sourceRef="ExclusiveGateway_CRB65_Merge" targetRef="ParallelGateway_Admission_Tests_Join" />

    <sequenceFlow id="Flow_AdmissionTestsSplit_to_SputumSampleDecision" sourceRef="ParallelGateway_Admission_Tests_Split" targetRef="ExclusiveGateway_Sputum_Sample_Decision" />
    <sequenceFlow id="Flow_SputumSample_Yes" name="Yes" sourceRef="ExclusiveGateway_Sputum_Sample_Decision" targetRef="Task_Consider_Sputum_Culture" />
    <sequenceFlow id="Flow_SputumSample_No" name="No" sourceRef="ExclusiveGateway_Sputum_Sample_Decision" targetRef="ExclusiveGateway_Sputum_Merge" />
    <sequenceFlow id="Flow_ConsiderSputum_to_ObtainedDecision" sourceRef="Task_Consider_Sputum_Culture" targetRef="ExclusiveGateway_Sputum_Obtained_Decision" />
    <sequenceFlow id="Flow_SputumObtained_Yes" name="Yes" sourceRef="ExclusiveGateway_Sputum_Obtained_Decision" targetRef="Task_Consider_Gram_Stain" />
    <sequenceFlow id="Flow_SputumObtained_No" name="No" sourceRef="ExclusiveGateway_Sputum_Obtained_Decision" targetRef="ExclusiveGateway_Sputum_Merge" />
    <sequenceFlow id="Flow_GramStain_to_SputumMerge" sourceRef="Task_Consider_Gram_Stain" targetRef="ExclusiveGateway_Sputum_Merge" />
    <sequenceFlow id="Flow_SputumMerge_to_AdmissionTestsJoin" sourceRef="ExclusiveGateway_Sputum_Merge" targetRef="ParallelGateway_Admission_Tests_Join" />

    <sequenceFlow id="Flow_AdmissionTestsJoin_to_AdmissionMerge" sourceRef="ParallelGateway_Admission_Tests_Join" targetRef="ExclusiveGateway_Admission_Merge" />

    <sequenceFlow id="Flow_DiagnosticSplit_to_BloodCultureSplit" sourceRef="ParallelGateway_Diagnostic_Split" targetRef="InclusiveGateway_Blood_Culture_Split" />
    <sequenceFlow id="Flow_BloodCulture_SIRS" name="More than 2 SIRS criteria" sourceRef="InclusiveGateway_Blood_Culture_Split" targetRef="InclusiveGateway_Blood_Culture_Join" />
    <sequenceFlow id="Flow_BloodCulture_ICU" name="ICU admission required" sourceRef="InclusiveGateway_Blood_Culture_Split" targetRef="InclusiveGateway_Blood_Culture_Join" />
    <sequenceFlow id="Flow_BloodCulture_None" name="No indication" sourceRef="InclusiveGateway_Blood_Culture_Split" targetRef="ExclusiveGateway_Blood_Culture_Merge" />
    <sequenceFlow id="Flow_BloodCultureJoin_to_Task" sourceRef="InclusiveGateway_Blood_Culture_Join" targetRef="Task_Obtain_Blood_Cultures" />
    <sequenceFlow id="Flow_BloodCultures_to_Merge" sourceRef="Task_Obtain_Blood_Cultures" targetRef="ExclusiveGateway_Blood_Culture_Merge" />

    <sequenceFlow id="Flow_DiagnosticSplit_to_UrineSplit" sourceRef="ParallelGateway_Diagnostic_Split" targetRef="InclusiveGateway_Urine_Antigen_Split" />
    <sequenceFlow id="Flow_Urine_HighSeverity" name="High severity" sourceRef="InclusiveGateway_Urine_Antigen_Split" targetRef="InclusiveGateway_Urine_Antigen_Join" />
    <sequenceFlow id="Flow_Urine_Surveillance" name="Enhanced surveillance directive on Legionella" sourceRef="InclusiveGateway_Urine_Antigen_Split" targetRef="InclusiveGateway_Urine_Antigen_Join" />
    <sequenceFlow id="Flow_Urine_Nonresponse" name="No response after 48-72 hours" sourceRef="InclusiveGateway_Urine_Antigen_Split" targetRef="InclusiveGateway_Urine_Antigen_Join" />
    <sequenceFlow id="Flow_Urine_PeakSeason" name="Inpatient during peak season" sourceRef="InclusiveGateway_Urine_Antigen_Split" targetRef="InclusiveGateway_Urine_Antigen_Join" />
    <sequenceFlow id="Flow_Urine_None" name="No indication" sourceRef="InclusiveGateway_Urine_Antigen_Split" targetRef="ExclusiveGateway_Urine_Antigen_Merge" />
    <sequenceFlow id="Flow_UrineJoin_to_Task" sourceRef="InclusiveGateway_Urine_Antigen_Join" targetRef="Task_Urine_Antigen_Test" />
    <sequenceFlow id="Flow_UrineTask_to_Merge" sourceRef="Task_Urine_Antigen_Test" targetRef="ExclusiveGateway_Urine_Antigen_Merge" />

    <sequenceFlow id="Flow_DiagnosticSplit_to_IntubatedDecision" sourceRef="ParallelGateway_Diagnostic_Split" targetRef="ExclusiveGateway_Intubated_Decision" />
    <sequenceFlow id="Flow_Intubated_Yes" name="Yes" sourceRef="ExclusiveGateway_Intubated_Decision" targetRef="Task_Consider_PCR_Legionella" />
    <sequenceFlow id="Flow_Intubated_No" name="No" sourceRef="ExclusiveGateway_Intubated_Decision" targetRef="ExclusiveGateway_PCR_Merge" />
    <sequenceFlow id="Flow_PCRTask_to_Merge" sourceRef="Task_Consider_PCR_Legionella" targetRef="ExclusiveGateway_PCR_Merge" />

    <sequenceFlow id="Flow_SepsisMerge_to_DiagnosticJoin" sourceRef="ExclusiveGateway_Sepsis_Merge" targetRef="ParallelGateway_Diagnostic_Join" />
    <sequenceFlow id="Flow_AdmissionMerge_to_DiagnosticJoin" sourceRef="ExclusiveGateway_Admission_Merge" targetRef="ParallelGateway_Diagnostic_Join" />
    <sequenceFlow id="Flow_BloodCultureMerge_to_DiagnosticJoin" sourceRef="ExclusiveGateway_Blood_Culture_Merge" targetRef="ParallelGateway_Diagnostic_Join" />
    <sequenceFlow id="Flow_UrineMerge_to_DiagnosticJoin" sourceRef="ExclusiveGateway_Urine_Antigen_Merge" targetRef="ParallelGateway_Diagnostic_Join" />
    <sequenceFlow id="Flow_PCRMerge_to_DiagnosticJoin" sourceRef="ExclusiveGateway_PCR_Merge" targetRef="ParallelGateway_Diagnostic_Join" />
    <sequenceFlow id="Flow_DiagnosticJoin_to_End" sourceRef="ParallelGateway_Diagnostic_Join" targetRef="EndEvent_Diagnostic_Complete" />
  </process>

