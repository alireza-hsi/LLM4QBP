      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_LowIntensity" bpmnElement="EndEvent_LowIntensity">
        <dc:Bounds x="2350" y="442" width="36" height="36" />
      </bpmndi:BPMNShape>

