      <bpmndi:BPMNEdge id="BPMNEdge_Flow_AdmitInpatient_to_EndAverageIntensity" bpmnElement="Flow_AdmitInpatient_to_EndAverageIntensity">
        <di:waypoint x="2080" y="280" />
