<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_AcuteHeartFailure" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_AcuteHeartFailure_RiskStratification" name="Episode of Care for Acute Heart Failure - Risk Stratification" isExecutable="false">
    <startEvent id="StartEvent_PatientPresentation" name="Patient presents to emergency department with acute heart failure" />
    <task id="Task_RiskAssessment" name="Risk stratification&#10;(e.g., EHMRG)" />
    <parallelGateway id="Gateway_InvestigationsSplit" />
    <task id="Task_BloodTests" name="Obtain serum creatinine, electrolyte, troponin, and complete blood count results" />
    <task id="Task_ECG" name="Perform electrocardiogram" />
    <task id="Task_ChestXRay" name="Chest x-ray" />
    <exclusiveGateway id="Gateway_RecentEchoAvailable" name="Recent echocardiogram available?" />
    <task id="Task_Echocardiogram" name="Echocardiogram" />
    <exclusiveGateway id="Gateway_EchoMerge" />
    <task id="Task_MonitorVitals" name="Monitor heart rate, blood pressure, oxygen saturation until stabilized" />
    <task id="Task_InitialEDTreatment" name="Treat in ED" />
    <parallelGateway id="Gateway_InvestigationsJoin" />
    <task id="Task_CalculateHFScore" name="Risk stratification&#10;(e.g., EHMRG)" />
    <task id="Task_AssessMarkers" name="Check responsiveness to Diuresis" />
    <exclusiveGateway id="Gateway_DetermineIntensity" name="Determine patient intensity group" default="Flow_DetermineIntensity_to_AdmitInpatient" />
    <exclusiveGateway id="Gateway_TransferRequired" name="Transfer to higher level provider required?" default="Flow_TransferRequired_to_HighIntensityCare" />
    <task id="Task_TransferHigherLevel" name="Transfer patient to higher level provider" />
    <task id="Task_HighIntensityCare" name="Admit to ICU (high nurse-to-patient staffing)" />
    <endEvent id="EndEvent_HighIntensity" name="High-intensity care initiated" />
    <task id="Task_AdmitInpatient" name="Admit to inpatient care (normal nurse-to-patient staffing)" />
    <endEvent id="EndEvent_AverageIntensity" name="Average-intensity admission initiated" />
    <task id="Task_DischargeHome" name="Discharge home" />
    <task id="Task_ArrangeFollowUp" name="Arrange follow-up (within days) with primary care" />
    <endEvent id="EndEvent_LowIntensity" name="Patient discharged with follow-up arranged" />

    <sequenceFlow id="Flow_Start_to_RiskAssessment" sourceRef="StartEvent_PatientPresentation" targetRef="Task_RiskAssessment" />
    <sequenceFlow id="Flow_RiskAssessment_to_InvestigationsSplit" sourceRef="Task_RiskAssessment" targetRef="Gateway_InvestigationsSplit" />
    <sequenceFlow id="Flow_InvestigationsSplit_to_BloodTests" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_BloodTests" />
    <sequenceFlow id="Flow_InvestigationsSplit_to_ECG" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_ECG" />
    <sequenceFlow id="Flow_InvestigationsSplit_to_ChestXRay" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_ChestXRay" />
    <sequenceFlow id="Flow_InvestigationsSplit_to_RecentEchoAvailable" sourceRef="Gateway_InvestigationsSplit" targetRef="Gateway_RecentEchoAvailable" />
    <sequenceFlow id="Flow_InvestigationsSplit_to_MonitorVitals" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_MonitorVitals" />
    <sequenceFlow id="Flow_InvestigationsSplit_to_InitialEDTreatment" sourceRef="Gateway_InvestigationsSplit" targetRef="Task_InitialEDTreatment" />
    <sequenceFlow id="Flow_RecentEchoAvailable_to_EchoMerge" name="Yes" sourceRef="Gateway_RecentEchoAvailable" targetRef="Gateway_EchoMerge" />
    <sequenceFlow id="Flow_RecentEchoAvailable_to_Echocardiogram" name="No" sourceRef="Gateway_RecentEchoAvailable" targetRef="Task_Echocardiogram" />
    <sequenceFlow id="Flow_Echocardiogram_to_EchoMerge" sourceRef="Task_Echocardiogram" targetRef="Gateway_EchoMerge" />
    <sequenceFlow id="Flow_BloodTests_to_InvestigationsJoin" sourceRef="Task_BloodTests" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_ECG_to_InvestigationsJoin" sourceRef="Task_ECG" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_ChestXRay_to_InvestigationsJoin" sourceRef="Task_ChestXRay" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_EchoMerge_to_InvestigationsJoin" sourceRef="Gateway_EchoMerge" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_MonitorVitals_to_InvestigationsJoin" sourceRef="Task_MonitorVitals" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_InitialEDTreatment_to_InvestigationsJoin" sourceRef="Task_InitialEDTreatment" targetRef="Gateway_InvestigationsJoin" />
    <sequenceFlow id="Flow_InvestigationsJoin_to_CalculateHFScore" sourceRef="Gateway_InvestigationsJoin" targetRef="Task_CalculateHFScore" />
    <sequenceFlow id="Flow_CalculateHFScore_to_AssessMarkers" sourceRef="Task_CalculateHFScore" targetRef="Task_AssessMarkers" />
    <sequenceFlow id="Flow_AssessMarkers_to_DetermineIntensity" sourceRef="Task_AssessMarkers" targetRef="Gateway_DetermineIntensity" />
    <sequenceFlow id="Flow_DetermineIntensity_to_TransferRequired" name="High intensity" sourceRef="Gateway_DetermineIntensity" targetRef="Gateway_TransferRequired" />
    <sequenceFlow id="Flow_DetermineIntensity_to_AdmitInpatient" name="Average intensity" sourceRef="Gateway_DetermineIntensity" targetRef="Task_AdmitInpatient" />
    <sequenceFlow id="Flow_DetermineIntensity_to_DischargeHome" name="Low intensity" sourceRef="Gateway_DetermineIntensity" targetRef="Task_DischargeHome" />
    <sequenceFlow id="Flow_TransferRequired_to_TransferHigherLevel" name="Yes" sourceRef="Gateway_TransferRequired" targetRef="Task_TransferHigherLevel" />
    <sequenceFlow id="Flow_TransferRequired_to_HighIntensityCare" name="No" sourceRef="Gateway_TransferRequired" targetRef="Task_HighIntensityCare" />
    <sequenceFlow id="Flow_TransferHigherLevel_to_HighIntensityCare" sourceRef="Task_TransferHigherLevel" targetRef="Task_HighIntensityCare" />
    <sequenceFlow id="Flow_HighIntensityCare_to_EndHighIntensity" sourceRef="Task_HighIntensityCare" targetRef="EndEvent_HighIntensity" />
    <sequenceFlow id="Flow_AdmitInpatient_to_EndAverageIntensity" sourceRef="Task_AdmitInpatient" targetRef="EndEvent_AverageIntensity" />
    <sequenceFlow id="Flow_DischargeHome_to_ArrangeFollowUp" sourceRef="Task_DischargeHome" targetRef="Task_ArrangeFollowUp" />
    <sequenceFlow id="Flow_ArrangeFollowUp_to_EndLowIntensity" sourceRef="Task_ArrangeFollowUp" targetRef="EndEvent_LowIntensity" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_AcuteHeartFailure">
    <bpmndi:BPMNPlane id="BPMNPlane_AcuteHeartFailure" bpmnElement="Process_AcuteHeartFailure_RiskStratification">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_PatientPresentation" bpmnElement="StartEvent_PatientPresentation">
        <dc:Bounds x="100" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_RiskAssessment" bpmnElement="Task_RiskAssessment">
        <dc:Bounds x="180" y="240" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_InvestigationsSplit" bpmnElement="Gateway_InvestigationsSplit">
        <dc:Bounds x="370" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_BloodTests" bpmnElement="Task_BloodTests">
        <dc:Bounds x="470" y="20" width="250" height="80" />
