        <di:waypoint x="720" y="60" />
        <di:waypoint x="780" y="60" />
        <di:waypoint x="780" y="280" />
        <di:waypoint x="1030" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_ECG_to_InvestigationsJoin" bpmnElement="Flow_ECG_to_InvestigationsJoin">
        <di:waypoint x="720" y="160" />
        <di:waypoint x="800" y="160" />
        <di:waypoint x="800" y="280" />
        <di:waypoint x="1030" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_ChestXRay_to_InvestigationsJoin" bpmnElement="Flow_ChestXRay_to_InvestigationsJoin">
        <di:waypoint x="720" y="260" />
        <di:waypoint x="820" y="260" />
        <di:waypoint x="820" y="280" />
        <di:waypoint x="1030" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_EchoMerge_to_InvestigationsJoin" bpmnElement="Flow_EchoMerge_to_InvestigationsJoin">
