      <bpmndi:BPMNShape id="BPMNShape_Task_Echocardiogram" bpmnElement="Task_Echocardiogram">
        <dc:Bounds x="680" y="320" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_EchoMerge" bpmnElement="Gateway_EchoMerge">
        <dc:Bounds x="930" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_MonitorVitals" bpmnElement="Task_MonitorVitals">
        <dc:Bounds x="470" y="440" width="250" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_InitialEDTreatment" bpmnElement="Task_InitialEDTreatment">
        <dc:Bounds x="470" y="550" width="250" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_InvestigationsJoin" bpmnElement="Gateway_InvestigationsJoin">
        <dc:Bounds x="1030" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_CalculateHFScore" bpmnElement="Task_CalculateHFScore">
        <dc:Bounds x="1130" y="240" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_AssessMarkers" bpmnElement="Task_AssessMarkers">
        <dc:Bounds x="1360" y="240" width="250" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_DetermineIntensity" bpmnElement="Gateway_DetermineIntensity">
        <dc:Bounds x="1660" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_TransferRequired" bpmnElement="Gateway_TransferRequired">
        <dc:Bounds x="1790" y="75" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_TransferHigherLevel" bpmnElement="Task_TransferHigherLevel">
        <dc:Bounds x="1880" y="60" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_HighIntensityCare" bpmnElement="Task_HighIntensityCare">
        <dc:Bounds x="2110" y="60" width="290" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_HighIntensity" bpmnElement="EndEvent_HighIntensity">
        <dc:Bounds x="2440" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_AdmitInpatient" bpmnElement="Task_AdmitInpatient">
        <dc:Bounds x="1790" y="240" width="290" height="80" />
