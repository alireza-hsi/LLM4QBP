        <di:waypoint x="470" y="590" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_RecentEchoAvailable_to_EchoMerge" bpmnElement="Flow_RecentEchoAvailable_to_EchoMerge">
        <di:waypoint x="595" y="335" />
        <di:waypoint x="595" y="310" />
        <di:waypoint x="955" y="310" />
        <di:waypoint x="955" y="335" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_RecentEchoAvailable_to_Echocardiogram" bpmnElement="Flow_RecentEchoAvailable_to_Echocardiogram">
