        <di:waypoint x="445" y="280" />
        <di:waypoint x="445" y="260" />
        <di:waypoint x="470" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_InvestigationsSplit_to_RecentEchoAvailable" bpmnElement="Flow_InvestigationsSplit_to_RecentEchoAvailable">
        <di:waypoint x="395" y="305" />
        <di:waypoint x="395" y="360" />
        <di:waypoint x="570" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_InvestigationsSplit_to_MonitorVitals" bpmnElement="Flow_InvestigationsSplit_to_MonitorVitals">
        <di:waypoint x="395" y="305" />
        <di:waypoint x="395" y="480" />
        <di:waypoint x="470" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_InvestigationsSplit_to_InitialEDTreatment" bpmnElement="Flow_InvestigationsSplit_to_InitialEDTreatment">
