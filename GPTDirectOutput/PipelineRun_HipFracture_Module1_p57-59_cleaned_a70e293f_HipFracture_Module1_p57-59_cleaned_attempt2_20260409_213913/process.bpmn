<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_HipFractureEDCare" name="Care in the Emergency Department for Suspected Hip Fracture" isExecutable="false">
    <startEvent id="StartEvent_Presentation" name="Suspected hip fracture patient presents to care or is directly admitted">
      <outgoing>Flow_Start_To_ApplyHipFracturePathway</outgoing>
    </startEvent>
    <task id="Task_ApplyHipFracturePathway" name="Follow hospital hip fracture care pathway and perioperative day-of-stay goals">
      <incoming>Flow_Start_To_ApplyHipFracturePathway</incoming>
      <outgoing>Flow_ApplyHipFracturePathway_To_InitialParallelSplit</outgoing>
    </task>
    <parallelGateway id="Gateway_InitialParallelSplit">
      <incoming>Flow_ApplyHipFracturePathway_To_InitialParallelSplit</incoming>
      <outgoing>Flow_InitialParallelSplit_To_MedicalAttentionSplit</outgoing>
      <outgoing>Flow_InitialParallelSplit_To_AssessClinicalStatus</outgoing>
    </parallelGateway>
    <parallelGateway id="Gateway_MedicalAttentionSplit">
      <incoming>Flow_InitialParallelSplit_To_MedicalAttentionSplit</incoming>
      <outgoing>Flow_MedicalAttentionSplit_To_PhysicianAssessment</outgoing>
      <outgoing>Flow_MedicalAttentionSplit_To_OrthopedicConsultation</outgoing>
    </parallelGateway>
    <task id="Task_PhysicianAssessment" name="See patient by physician within 1 hour">
      <incoming>Flow_MedicalAttentionSplit_To_PhysicianAssessment</incoming>
      <outgoing>Flow_PhysicianAssessment_To_MedicalAttentionJoin</outgoing>
    </task>
    <task id="Task_OrthopedicConsultation" name="Obtain orthopedic surgeon consultation within 2 hours">
      <incoming>Flow_MedicalAttentionSplit_To_OrthopedicConsultation</incoming>
      <outgoing>Flow_OrthopedicConsultation_To_MedicalAttentionJoin</outgoing>
    </task>
    <parallelGateway id="Gateway_MedicalAttentionJoin">
      <incoming>Flow_PhysicianAssessment_To_MedicalAttentionJoin</incoming>
      <incoming>Flow_OrthopedicConsultation_To_MedicalAttentionJoin</incoming>
      <outgoing>Flow_MedicalAttentionJoin_To_AdditionalConsultDecision</outgoing>
    </parallelGateway>
    <exclusiveGateway id="Gateway_AdditionalConsultDecision" name="Additional anesthesiologist or internist consultation needed?" default="Flow_AdditionalConsultDecision_No">
      <incoming>Flow_MedicalAttentionJoin_To_AdditionalConsultDecision</incoming>
      <outgoing>Flow_AdditionalConsultDecision_Yes</outgoing>
      <outgoing>Flow_AdditionalConsultDecision_No</outgoing>
    </exclusiveGateway>
    <task id="Task_AdditionalMedicalConsultation" name="Notify anesthesiologist or internist and obtain consultation as needed">
      <incoming>Flow_AdditionalConsultDecision_Yes</incoming>
      <outgoing>Flow_AdditionalMedicalConsultation_To_AdditionalConsultMerge</outgoing>
    </task>
    <exclusiveGateway id="Gateway_AdditionalConsultMerge">
      <incoming>Flow_AdditionalConsultDecision_No</incoming>
      <incoming>Flow_AdditionalMedicalConsultation_To_AdditionalConsultMerge</incoming>
      <outgoing>Flow_AdditionalConsultMerge_To_InitialParallelJoin</outgoing>
    </exclusiveGateway>
    <task id="Task_AssessClinicalStatus" name="Assess and document fall reason, fluid balance, hydration, nutrition, pain, temperature, pressure sore risk, and collateral injuries">
      <incoming>Flow_InitialParallelSplit_To_AssessClinicalStatus</incoming>
      <outgoing>Flow_AssessClinicalStatus_To_PerformDiagnostics</outgoing>
    </task>
    <task id="Task_PerformDiagnostics" name="Order and complete appropriate blood work and X-rays">
      <incoming>Flow_AssessClinicalStatus_To_PerformDiagnostics</incoming>
      <outgoing>Flow_PerformDiagnostics_To_AssessComorbiditiesAndDrugTherapy</outgoing>
    </task>
    <task id="Task_AssessComorbiditiesAndDrugTherapy" name="Assess comorbid conditions and current drug therapy including anticoagulants">
      <incoming>Flow_PerformDiagnostics_To_AssessComorbiditiesAndDrugTherapy</incoming>
      <outgoing>Flow_AssessComorbiditiesAndDrugTherapy_To_AssessFunctionCognitionAndSocialSupport</outgoing>
    </task>
    <task id="Task_AssessFunctionCognitionAndSocialSupport" name="Assess continence, pre-fracture function and mobility, physical and functional level, mental state with a validated tool, and social circumstances">
      <incoming>Flow_AssessComorbiditiesAndDrugTherapy_To_AssessFunctionCognitionAndSocialSupport</incoming>
      <outgoing>Flow_AssessFunctionCognitionAndSocialSupport_To_MedicationReconciliation</outgoing>
    </task>
    <task id="Task_MedicationReconciliation" name="Complete medication reconciliation using a standardized form">
      <incoming>Flow_AssessFunctionCognitionAndSocialSupport_To_MedicationReconciliation</incoming>
      <outgoing>Flow_MedicationReconciliation_To_ManageHydrationPainDeliriumPressureSoreRisk</outgoing>
    </task>
    <task id="Task_ManageHydrationPainDeliriumPressureSoreRisk" name="Manage hydration, pain, delirium risk, and pressure sore risk in the ED">
      <incoming>Flow_MedicationReconciliation_To_ManageHydrationPainDeliriumPressureSoreRisk</incoming>
      <outgoing>Flow_ManageHydrationPainDeliriumPressureSoreRisk_To_InitialParallelJoin</outgoing>
    </task>
    <parallelGateway id="Gateway_InitialParallelJoin">
      <incoming>Flow_AdditionalConsultMerge_To_InitialParallelJoin</incoming>
      <incoming>Flow_ManageHydrationPainDeliriumPressureSoreRisk_To_InitialParallelJoin</incoming>
      <outgoing>Flow_InitialParallelJoin_To_AdmitWithin4Hours</outgoing>
    </parallelGateway>
    <task id="Task_AdmitWithin4Hours" name="Admit patient to inpatient care within 4 hours spent in the ED">
      <incoming>Flow_InitialParallelJoin_To_AdmitWithin4Hours</incoming>
      <outgoing>Flow_AdmitWithin4Hours_To_SurgicalHospitalDecision</outgoing>
    </task>
    <exclusiveGateway id="Gateway_SurgicalHospitalDecision" name="Presenting hospital has surgical capability?" default="Flow_SurgicalHospitalDecision_No">
      <incoming>Flow_AdmitWithin4Hours_To_SurgicalHospitalDecision</incoming>
      <outgoing>Flow_SurgicalHospitalDecision_Yes</outgoing>
      <outgoing>Flow_SurgicalHospitalDecision_No</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_Admitted" name="Patient admitted at surgical hospital">
      <incoming>Flow_SurgicalHospitalDecision_Yes</incoming>
    </endEvent>
    <task id="Task_MedicallyStabilizeForTransfer" name="Medically stabilize patient while awaiting expeditious transfer">
      <incoming>Flow_SurgicalHospitalDecision_No</incoming>
      <outgoing>Flow_MedicallyStabilizeForTransfer_To_TransferToSurgicalHospital</outgoing>
    </task>
    <task id="Task_TransferToSurgicalHospital" name="Transfer patient to a surgical hospital for operation under formal transfer and repatriation protocol">
      <incoming>Flow_MedicallyStabilizeForTransfer_To_TransferToSurgicalHospital</incoming>
      <outgoing>Flow_TransferToSurgicalHospital_To_EnsureSurgeryWithin48Hours</outgoing>
    </task>
    <task id="Task_EnsureSurgeryWithin48Hours" name="Ensure surgery within 48 hours of initial presentation">
      <incoming>Flow_TransferToSurgicalHospital_To_EnsureSurgeryWithin48Hours</incoming>
      <outgoing>Flow_EnsureSurgeryWithin48Hours_To_EndTransferred</outgoing>
    </task>
    <endEvent id="EndEvent_Transferred" name="Patient transferred for surgery">
      <incoming>Flow_EnsureSurgeryWithin48Hours_To_EndTransferred</incoming>
    </endEvent>

    <sequenceFlow id="Flow_Start_To_ApplyHipFracturePathway" sourceRef="StartEvent_Presentation" targetRef="Task_ApplyHipFracturePathway"/>
    <sequenceFlow id="Flow_ApplyHipFracturePathway_To_InitialParallelSplit" sourceRef="Task_ApplyHipFracturePathway" targetRef="Gateway_InitialParallelSplit"/>
    <sequenceFlow id="Flow_InitialParallelSplit_To_MedicalAttentionSplit" sourceRef="Gateway_InitialParallelSplit" targetRef="Gateway_MedicalAttentionSplit"/>
    <sequenceFlow id="Flow_InitialParallelSplit_To_AssessClinicalStatus" sourceRef="Gateway_InitialParallelSplit" targetRef="Task_AssessClinicalStatus"/>
    <sequenceFlow id="Flow_MedicalAttentionSplit_To_PhysicianAssessment" sourceRef="Gateway_MedicalAttentionSplit" targetRef="Task_PhysicianAssessment"/>
    <sequenceFlow id="Flow_MedicalAttentionSplit_To_OrthopedicConsultation" sourceRef="Gateway_MedicalAttentionSplit" targetRef="Task_OrthopedicConsultation"/>
    <sequenceFlow id="Flow_PhysicianAssessment_To_MedicalAttentionJoin" sourceRef="Task_PhysicianAssessment" targetRef="Gateway_MedicalAttentionJoin"/>
    <sequenceFlow id="Flow_OrthopedicConsultation_To_MedicalAttentionJoin" sourceRef="Task_OrthopedicConsultation" targetRef="Gateway_MedicalAttentionJoin"/>
    <sequenceFlow id="Flow_MedicalAttentionJoin_To_AdditionalConsultDecision" sourceRef="Gateway_MedicalAttentionJoin" targetRef="Gateway_AdditionalConsultDecision"/>
    <sequenceFlow id="Flow_AdditionalConsultDecision_Yes" name="Yes" sourceRef="Gateway_AdditionalConsultDecision" targetRef="Task_AdditionalMedicalConsultation"/>
    <sequenceFlow id="Flow_AdditionalConsultDecision_No" name="No" sourceRef="Gateway_AdditionalConsultDecision" targetRef="Gateway_AdditionalConsultMerge"/>
    <sequenceFlow id="Flow_AdditionalMedicalConsultation_To_AdditionalConsultMerge" sourceRef="Task_AdditionalMedicalConsultation" targetRef="Gateway_AdditionalConsultMerge"/>
    <sequenceFlow id="Flow_AdditionalConsultMerge_To_InitialParallelJoin" sourceRef="Gateway_AdditionalConsultMerge" targetRef="Gateway_InitialParallelJoin"/>
    <sequenceFlow id="Flow_AssessClinicalStatus_To_PerformDiagnostics" sourceRef="Task_AssessClinicalStatus" targetRef="Task_PerformDiagnostics"/>
    <sequenceFlow id="Flow_PerformDiagnostics_To_AssessComorbiditiesAndDrugTherapy" sourceRef="Task_PerformDiagnostics" targetRef="Task_AssessComorbiditiesAndDrugTherapy"/>
    <sequenceFlow id="Flow_AssessComorbiditiesAndDrugTherapy_To_AssessFunctionCognitionAndSocialSupport" sourceRef="Task_AssessComorbiditiesAndDrugTherapy" targetRef="Task_AssessFunctionCognitionAndSocialSupport"/>
    <sequenceFlow id="Flow_AssessFunctionCognitionAndSocialSupport_To_MedicationReconciliation" sourceRef="Task_AssessFunctionCognitionAndSocialSupport" targetRef="Task_MedicationReconciliation"/>
    <sequenceFlow id="Flow_MedicationReconciliation_To_ManageHydrationPainDeliriumPressureSoreRisk" sourceRef="Task_MedicationReconciliation" targetRef="Task_ManageHydrationPainDeliriumPressureSoreRisk"/>
    <sequenceFlow id="Flow_ManageHydrationPainDeliriumPressureSoreRisk_To_InitialParallelJoin" sourceRef="Task_ManageHydrationPainDeliriumPressureSoreRisk" targetRef="Gateway_InitialParallelJoin"/>
    <sequenceFlow id="Flow_InitialParallelJoin_To_AdmitWithin4Hours" sourceRef="Gateway_InitialParallelJoin" targetRef="Task_AdmitWithin4Hours"/>
    <sequenceFlow id="Flow_AdmitWithin4Hours_To_SurgicalHospitalDecision" sourceRef="Task_AdmitWithin4Hours" targetRef="Gateway_SurgicalHospitalDecision"/>
    <sequenceFlow id="Flow_SurgicalHospitalDecision_Yes" name="Yes" sourceRef="Gateway_SurgicalHospitalDecision" targetRef="EndEvent_Admitted"/>
    <sequenceFlow id="Flow_SurgicalHospitalDecision_No" name="No" sourceRef="Gateway_SurgicalHospitalDecision" targetRef="Task_MedicallyStabilizeForTransfer"/>
    <sequenceFlow id="Flow_MedicallyStabilizeForTransfer_To_TransferToSurgicalHospital" sourceRef="Task_MedicallyStabilizeForTransfer" targetRef="Task_TransferToSurgicalHospital"/>
    <sequenceFlow id="Flow_TransferToSurgicalHospital_To_EnsureSurgeryWithin48Hours" sourceRef="Task_TransferToSurgicalHospital" targetRef="Task_EnsureSurgeryWithin48Hours"/>
    <sequenceFlow id="Flow_EnsureSurgeryWithin48Hours_To_EndTransferred" sourceRef="Task_EnsureSurgeryWithin48Hours" targetRef="EndEvent_Transferred"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_HipFractureEDCare">
    <bpmndi:BPMNPlane id="BPMNPlane_HipFractureEDCare" bpmnElement="Process_HipFractureEDCare">
      <bpmndi:BPMNShape id="StartEvent_Presentation_di" bpmnElement="StartEvent_Presentation">
        <dc:Bounds x="40" y="282" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyHipFracturePathway_di" bpmnElement="Task_ApplyHipFracturePathway">
        <dc:Bounds x="120" y="260" width="220" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InitialParallelSplit_di" bpmnElement="Gateway_InitialParallelSplit">
        <dc:Bounds x="380" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MedicalAttentionSplit_di" bpmnElement="Gateway_MedicalAttentionSplit">
        <dc:Bounds x="500" y="90" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PhysicianAssessment_di" bpmnElement="Task_PhysicianAssessment">
        <dc:Bounds x="620" y="40" width="210" height="80"/>
