        <dc:Bounds x="990" y="90" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdditionalMedicalConsultation_di" bpmnElement="Task_AdditionalMedicalConsultation">
        <dc:Bounds x="1110" y="20" width="260" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdditionalConsultMerge_di" bpmnElement="Gateway_AdditionalConsultMerge">
        <dc:Bounds x="1410" y="90" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessClinicalStatus_di" bpmnElement="Task_AssessClinicalStatus">
        <dc:Bounds x="500" y="250" width="270" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PerformDiagnostics_di" bpmnElement="Task_PerformDiagnostics">
        <dc:Bounds x="820" y="260" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessComorbiditiesAndDrugTherapy_di" bpmnElement="Task_AssessComorbiditiesAndDrugTherapy">
        <dc:Bounds x="1050" y="250" width="260" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessFunctionCognitionAndSocialSupport_di" bpmnElement="Task_AssessFunctionCognitionAndSocialSupport">
        <dc:Bounds x="1360" y="240" width="330" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MedicationReconciliation_di" bpmnElement="Task_MedicationReconciliation">
        <dc:Bounds x="1730" y="260" width="220" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManageHydrationPainDeliriumPressureSoreRisk_di" bpmnElement="Task_ManageHydrationPainDeliriumPressureSoreRisk">
        <dc:Bounds x="2000" y="250" width="280" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InitialParallelJoin_di" bpmnElement="Gateway_InitialParallelJoin">
        <dc:Bounds x="2330" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdmitWithin4Hours_di" bpmnElement="Task_AdmitWithin4Hours">
        <dc:Bounds x="2430" y="260" width="220" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SurgicalHospitalDecision_di" bpmnElement="Gateway_SurgicalHospitalDecision">
        <dc:Bounds x="2690" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Admitted_di" bpmnElement="EndEvent_Admitted">
        <dc:Bounds x="2810" y="282" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MedicallyStabilizeForTransfer_di" bpmnElement="Task_MedicallyStabilizeForTransfer">
        <dc:Bounds x="2810" y="420" width="230" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TransferToSurgicalHospital_di" bpmnElement="Task_TransferToSurgicalHospital">
        <dc:Bounds x="3080" y="410" width="270" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsureSurgeryWithin48Hours_di" bpmnElement="Task_EnsureSurgeryWithin48Hours">
        <dc:Bounds x="3390" y="420" width="230" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Transferred_di" bpmnElement="EndEvent_Transferred">
        <dc:Bounds x="3660" y="442" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ApplyHipFracturePathway_di" bpmnElement="Flow_Start_To_ApplyHipFracturePathway">
        <di:waypoint x="76" y="300"/>
        <di:waypoint x="120" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ApplyHipFracturePathway_To_InitialParallelSplit_di" bpmnElement="Flow_ApplyHipFracturePathway_To_InitialParallelSplit">
        <di:waypoint x="340" y="300"/>
        <di:waypoint x="380" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_InitialParallelSplit_To_MedicalAttentionSplit_di" bpmnElement="Flow_InitialParallelSplit_To_MedicalAttentionSplit">
        <di:waypoint x="405" y="275"/>
        <di:waypoint x="405" y="115"/>
        <di:waypoint x="500" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_InitialParallelSplit_To_AssessClinicalStatus_di" bpmnElement="Flow_InitialParallelSplit_To_AssessClinicalStatus">
        <di:waypoint x="430" y="300"/>
        <di:waypoint x="500" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MedicalAttentionSplit_To_PhysicianAssessment_di" bpmnElement="Flow_MedicalAttentionSplit_To_PhysicianAssessment">
        <di:waypoint x="525" y="90"/>
        <di:waypoint x="525" y="80"/>
        <di:waypoint x="620" y="80"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MedicalAttentionSplit_To_OrthopedicConsultation_di" bpmnElement="Flow_MedicalAttentionSplit_To_OrthopedicConsultation">
        <di:waypoint x="525" y="140"/>
        <di:waypoint x="525" y="180"/>
        <di:waypoint x="620" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PhysicianAssessment_To_MedicalAttentionJoin_di" bpmnElement="Flow_PhysicianAssessment_To_MedicalAttentionJoin">
        <di:waypoint x="830" y="80"/>
        <di:waypoint x="855" y="80"/>
        <di:waypoint x="855" y="115"/>
        <di:waypoint x="880" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_OrthopedicConsultation_To_MedicalAttentionJoin_di" bpmnElement="Flow_OrthopedicConsultation_To_MedicalAttentionJoin">
        <di:waypoint x="840" y="180"/>
        <di:waypoint x="855" y="180"/>
        <di:waypoint x="855" y="115"/>
        <di:waypoint x="880" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MedicalAttentionJoin_To_AdditionalConsultDecision_di" bpmnElement="Flow_MedicalAttentionJoin_To_AdditionalConsultDecision">
        <di:waypoint x="930" y="115"/>
        <di:waypoint x="990" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdditionalConsultDecision_Yes_di" bpmnElement="Flow_AdditionalConsultDecision_Yes">
        <di:waypoint x="1015" y="90"/>
        <di:waypoint x="1015" y="60"/>
        <di:waypoint x="1110" y="60"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdditionalConsultDecision_No_di" bpmnElement="Flow_AdditionalConsultDecision_No">
        <di:waypoint x="1040" y="115"/>
        <di:waypoint x="1410" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdditionalMedicalConsultation_To_AdditionalConsultMerge_di" bpmnElement="Flow_AdditionalMedicalConsultation_To_AdditionalConsultMerge">
        <di:waypoint x="1370" y="60"/>
        <di:waypoint x="1390" y="60"/>
        <di:waypoint x="1390" y="115"/>
        <di:waypoint x="1410" y="115"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdditionalConsultMerge_To_InitialParallelJoin_di" bpmnElement="Flow_AdditionalConsultMerge_To_InitialParallelJoin">
        <di:waypoint x="1460" y="115"/>
        <di:waypoint x="2355" y="115"/>
        <di:waypoint x="2355" y="275"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessClinicalStatus_To_PerformDiagnostics_di" bpmnElement="Flow_AssessClinicalStatus_To_PerformDiagnostics">
        <di:waypoint x="770" y="300"/>
        <di:waypoint x="820" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PerformDiagnostics_To_AssessComorbiditiesAndDrugTherapy_di" bpmnElement="Flow_PerformDiagnostics_To_AssessComorbiditiesAndDrugTherapy">
        <di:waypoint x="1000" y="300"/>
        <di:waypoint x="1050" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessComorbiditiesAndDrugTherapy_To_AssessFunctionCognitionAndSocialSupport_di" bpmnElement="Flow_AssessComorbiditiesAndDrugTherapy_To_AssessFunctionCognitionAndSocialSupport">
        <di:waypoint x="1310" y="300"/>
        <di:waypoint x="1360" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessFunctionCognitionAndSocialSupport_To_MedicationReconciliation_di" bpmnElement="Flow_AssessFunctionCognitionAndSocialSupport_To_MedicationReconciliation">
        <di:waypoint x="1690" y="300"/>
        <di:waypoint x="1730" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MedicationReconciliation_To_ManageHydrationPainDeliriumPressureSoreRisk_di" bpmnElement="Flow_MedicationReconciliation_To_ManageHydrationPainDeliriumPressureSoreRisk">
        <di:waypoint x="1950" y="300"/>
        <di:waypoint x="2000" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ManageHydrationPainDeliriumPressureSoreRisk_To_InitialParallelJoin_di" bpmnElement="Flow_ManageHydrationPainDeliriumPressureSoreRisk_To_InitialParallelJoin">
        <di:waypoint x="2280" y="300"/>
        <di:waypoint x="2330" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_InitialParallelJoin_To_AdmitWithin4Hours_di" bpmnElement="Flow_InitialParallelJoin_To_AdmitWithin4Hours">
        <di:waypoint x="2380" y="300"/>
        <di:waypoint x="2430" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdmitWithin4Hours_To_SurgicalHospitalDecision_di" bpmnElement="Flow_AdmitWithin4Hours_To_SurgicalHospitalDecision">
        <di:waypoint x="2650" y="300"/>
        <di:waypoint x="2690" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SurgicalHospitalDecision_Yes_di" bpmnElement="Flow_SurgicalHospitalDecision_Yes">
        <di:waypoint x="2740" y="300"/>
        <di:waypoint x="2810" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SurgicalHospitalDecision_No_di" bpmnElement="Flow_SurgicalHospitalDecision_No">
        <di:waypoint x="2715" y="325"/>
        <di:waypoint x="2715" y="460"/>
        <di:waypoint x="2810" y="460"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MedicallyStabilizeForTransfer_To_TransferToSurgicalHospital_di" bpmnElement="Flow_MedicallyStabilizeForTransfer_To_TransferToSurgicalHospital">
        <di:waypoint x="3040" y="460"/>
