<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_Module1_Initial_Presentation_Assessment" name="Module 1: Initial Presentation and Assessment" isExecutable="false">
    <startEvent id="StartEvent_1" name="Patient presents with suspected COPD exacerbation or is admitted directly">
      <outgoing>Flow_1</outgoing>
    </startEvent>

    <task id="Task_1_Check_Vital_Signs" name="Check vital signs, consciousness, pulse oximetry, hypoventilation, and purulent sputum">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>

    <task id="Task_2_Physical_Exam" name="Perform physical examination">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>

    <task id="Task_3_Check_History" name="Check patient history">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
    </task>

    <task id="Task_4_Reconcile_Medications" name="Document and reconcile current medications">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>

    <task id="Task_5_Chest_XRay" name="Perform chest x-ray posteroanterior and lateral using expiratory view and portable x-ray">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_6</outgoing>
    </task>

    <task id="Task_6_Baseline_Blood_Work" name="Conduct baseline blood work (complete blood count, electrolytes, creatinine, and BUN if available)">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_7</outgoing>
    </task>

    <task id="Task_7_ECG" name="Consider electrocardiogram">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </task>

    <exclusiveGateway id="Gateway_1_ABG_Needed" name="Low oxygen saturation or acute respiratory failure suspected?" gatewayDirection="Diverging">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_9</outgoing>
      <outgoing>Flow_10</outgoing>
    </exclusiveGateway>

    <task id="Task_8_Check_ABG" name="Check arterial blood gases where appropriate">
      <incoming>Flow_9</incoming>
      <outgoing>Flow_11</outgoing>
    </task>

    <exclusiveGateway id="Gateway_2_ABG_Merge" gatewayDirection="Converging">
      <incoming>Flow_10</incoming>
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="Gateway_3_Blood_Cultures_Needed" name="Pneumonia or suspected sepsis?" gatewayDirection="Diverging">
      <incoming>Flow_12</incoming>
      <outgoing>Flow_13</outgoing>
      <outgoing>Flow_14</outgoing>
    </exclusiveGateway>

    <task id="Task_9_Draw_Blood_Cultures" name="Draw blood cultures">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_15</outgoing>
    </task>

    <exclusiveGateway id="Gateway_4_Blood_Cultures_Merge" gatewayDirection="Converging">
      <incoming>Flow_14</incoming>
      <incoming>Flow_15</incoming>
      <outgoing>Flow_16</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="Gateway_5_Cardiac_Markers_Needed" name="Suspected cardiac disorders?" gatewayDirection="Diverging">
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17</outgoing>
      <outgoing>Flow_18</outgoing>
    </exclusiveGateway>

    <task id="Task_10_Examine_Cardiac_Markers" name="Examine cardiac markers">
      <incoming>Flow_17</incoming>
      <outgoing>Flow_19</outgoing>
    </task>

    <exclusiveGateway id="Gateway_6_Cardiac_Markers_Merge" gatewayDirection="Converging">
      <incoming>Flow_18</incoming>
      <incoming>Flow_19</incoming>
      <outgoing>Flow_20</outgoing>
    </exclusiveGateway>

    <task id="Task_11_Identify_Goals_Of_Care" name="Identify patient wishes with respect to goals of care">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_21</outgoing>
    </task>

    <exclusiveGateway id="Gateway_7_Spirometry_Needed" name="Patient stabilized and no prior objective COPD spirometry documentation?" gatewayDirection="Diverging">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
      <outgoing>Flow_23</outgoing>
    </exclusiveGateway>

    <task id="Task_12_Perform_Spirometry" name="Perform spirometry once&#10;the patient has stabilized">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_24</outgoing>
    </task>

    <exclusiveGateway id="Gateway_8_Spirometry_Merge" gatewayDirection="Converging">
      <incoming>Flow_23</incoming>
      <incoming>Flow_24</incoming>
      <outgoing>Flow_25</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="Gateway_9_Other_Diagnostics_Needed" name="Other diagnostic interventions appropriate?" gatewayDirection="Diverging">
      <incoming>Flow_25</incoming>
      <outgoing>Flow_26</outgoing>
      <outgoing>Flow_27</outgoing>
    </exclusiveGateway>

    <task id="Task_13_Perform_Other_Diagnostics" name="Perform other diagnostic interventions as appropriate">
      <incoming>Flow_26</incoming>
      <outgoing>Flow_28</outgoing>
    </task>

    <exclusiveGateway id="Gateway_10_Other_Diagnostics_Merge" gatewayDirection="Converging">
      <incoming>Flow_27</incoming>
      <incoming>Flow_28</incoming>
      <outgoing>Flow_29</outgoing>
    </exclusiveGateway>

    <task id="Task_14_Assess_Level_Of_Care" name="Assess level of care required">
      <incoming>Flow_29</incoming>
      <outgoing>Flow_30</outgoing>
    </task>

    <exclusiveGateway id="Gateway_11_Immediate_Resuscitation_Needed" name="Immediate resuscitation needed at ED presentation?" gatewayDirection="Diverging">
      <incoming>Flow_30</incoming>
      <outgoing>Flow_31</outgoing>
      <outgoing>Flow_32</outgoing>
    </exclusiveGateway>

    <task id="Task_15_Trial_Immediate_Resuscitation" name="Trial immediate resuscitation">
      <incoming>Flow_31</incoming>
      <outgoing>Flow_33</outgoing>
    </task>

    <task id="Task_16_Reevaluate_For_Admission" name="Admit to hospital">
      <incoming>Flow_33</incoming>
      <outgoing>Flow_34</outgoing>
    </task>

    <exclusiveGateway id="Gateway_12_Resuscitation_Merge" gatewayDirection="Converging">
      <incoming>Flow_32</incoming>
      <incoming>Flow_34</incoming>
      <outgoing>Flow_35</outgoing>
    </exclusiveGateway>

    <exclusiveGateway id="Gateway_13_Admission_Required" name="Hospital admission required?" gatewayDirection="Diverging">
      <incoming>Flow_35</incoming>
      <outgoing>Flow_36</outgoing>
      <outgoing>Flow_37</outgoing>
    </exclusiveGateway>

    <endEvent id="EndEvent_1_Admit" name="Hospital admission">
      <incoming>Flow_36</incoming>
    </endEvent>

    <endEvent id="EndEvent_2_No_Admission" name="No hospital admission">
      <incoming>Flow_37</incoming>
    </endEvent>

    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1_Check_Vital_Signs" />
    <sequenceFlow id="Flow_2" sourceRef="Task_1_Check_Vital_Signs" targetRef="Task_2_Physical_Exam" />
    <sequenceFlow id="Flow_3" sourceRef="Task_2_Physical_Exam" targetRef="Task_3_Check_History" />
    <sequenceFlow id="Flow_4" sourceRef="Task_3_Check_History" targetRef="Task_4_Reconcile_Medications" />
    <sequenceFlow id="Flow_5" sourceRef="Task_4_Reconcile_Medications" targetRef="Task_5_Chest_XRay" />
    <sequenceFlow id="Flow_6" sourceRef="Task_5_Chest_XRay" targetRef="Task_6_Baseline_Blood_Work" />
    <sequenceFlow id="Flow_7" sourceRef="Task_6_Baseline_Blood_Work" targetRef="Task_7_ECG" />
    <sequenceFlow id="Flow_8" sourceRef="Task_7_ECG" targetRef="Gateway_1_ABG_Needed" />
    <sequenceFlow id="Flow_9" name="Yes" sourceRef="Gateway_1_ABG_Needed" targetRef="Task_8_Check_ABG" />
    <sequenceFlow id="Flow_10" name="No" sourceRef="Gateway_1_ABG_Needed" targetRef="Gateway_2_ABG_Merge" />
    <sequenceFlow id="Flow_11" sourceRef="Task_8_Check_ABG" targetRef="Gateway_2_ABG_Merge" />
    <sequenceFlow id="Flow_12" sourceRef="Gateway_2_ABG_Merge" targetRef="Gateway_3_Blood_Cultures_Needed" />
    <sequenceFlow id="Flow_13" name="Yes" sourceRef="Gateway_3_Blood_Cultures_Needed" targetRef="Task_9_Draw_Blood_Cultures" />
    <sequenceFlow id="Flow_14" name="No" sourceRef="Gateway_3_Blood_Cultures_Needed" targetRef="Gateway_4_Blood_Cultures_Merge" />
    <sequenceFlow id="Flow_15" sourceRef="Task_9_Draw_Blood_Cultures" targetRef="Gateway_4_Blood_Cultures_Merge" />
    <sequenceFlow id="Flow_16" sourceRef="Gateway_4_Blood_Cultures_Merge" targetRef="Gateway_5_Cardiac_Markers_Needed" />
    <sequenceFlow id="Flow_17" name="Yes" sourceRef="Gateway_5_Cardiac_Markers_Needed" targetRef="Task_10_Examine_Cardiac_Markers" />
    <sequenceFlow id="Flow_18" name="No" sourceRef="Gateway_5_Cardiac_Markers_Needed" targetRef="Gateway_6_Cardiac_Markers_Merge" />
    <sequenceFlow id="Flow_19" sourceRef="Task_10_Examine_Cardiac_Markers" targetRef="Gateway_6_Cardiac_Markers_Merge" />
    <sequenceFlow id="Flow_20" sourceRef="Gateway_6_Cardiac_Markers_Merge" targetRef="Task_11_Identify_Goals_Of_Care" />
    <sequenceFlow id="Flow_21" sourceRef="Task_11_Identify_Goals_Of_Care" targetRef="Gateway_7_Spirometry_Needed" />
    <sequenceFlow id="Flow_22" name="Yes" sourceRef="Gateway_7_Spirometry_Needed" targetRef="Task_12_Perform_Spirometry" />
    <sequenceFlow id="Flow_23" name="No" sourceRef="Gateway_7_Spirometry_Needed" targetRef="Gateway_8_Spirometry_Merge" />
    <sequenceFlow id="Flow_24" sourceRef="Task_12_Perform_Spirometry" targetRef="Gateway_8_Spirometry_Merge" />
    <sequenceFlow id="Flow_25" sourceRef="Gateway_8_Spirometry_Merge" targetRef="Gateway_9_Other_Diagnostics_Needed" />
    <sequenceFlow id="Flow_26" name="Yes" sourceRef="Gateway_9_Other_Diagnostics_Needed" targetRef="Task_13_Perform_Other_Diagnostics" />
    <sequenceFlow id="Flow_27" name="No" sourceRef="Gateway_9_Other_Diagnostics_Needed" targetRef="Gateway_10_Other_Diagnostics_Merge" />
    <sequenceFlow id="Flow_28" sourceRef="Task_13_Perform_Other_Diagnostics" targetRef="Gateway_10_Other_Diagnostics_Merge" />
    <sequenceFlow id="Flow_29" sourceRef="Gateway_10_Other_Diagnostics_Merge" targetRef="Task_14_Assess_Level_Of_Care" />
    <sequenceFlow id="Flow_30" sourceRef="Task_14_Assess_Level_Of_Care" targetRef="Gateway_11_Immediate_Resuscitation_Needed" />
    <sequenceFlow id="Flow_31" name="Yes" sourceRef="Gateway_11_Immediate_Resuscitation_Needed" targetRef="Task_15_Trial_Immediate_Resuscitation" />
    <sequenceFlow id="Flow_32" name="No" sourceRef="Gateway_11_Immediate_Resuscitation_Needed" targetRef="Gateway_12_Resuscitation_Merge" />
    <sequenceFlow id="Flow_33" sourceRef="Task_15_Trial_Immediate_Resuscitation" targetRef="Task_16_Reevaluate_For_Admission" />
    <sequenceFlow id="Flow_34" sourceRef="Task_16_Reevaluate_For_Admission" targetRef="Gateway_12_Resuscitation_Merge" />
    <sequenceFlow id="Flow_35" sourceRef="Gateway_12_Resuscitation_Merge" targetRef="Gateway_13_Admission_Required" />
    <sequenceFlow id="Flow_36" name="Yes" sourceRef="Gateway_13_Admission_Required" targetRef="EndEvent_1_Admit" />
    <sequenceFlow id="Flow_37" name="No" sourceRef="Gateway_13_Admission_Required" targetRef="EndEvent_2_No_Admission" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
