      <bpmndi:BPMNShape id="BPMNShape_Task_NotifyConsultants" bpmnElement="Task_NotifyConsultants">
        <dc:Bounds x="680" y="70" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ExclusiveGateway_ConsultNeeded" bpmnElement="ExclusiveGateway_ConsultNeeded">
        <dc:Bounds x="900" y="85" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_AdditionalConsult" bpmnElement="Task_AdditionalConsult">
        <dc:Bounds x="1000" y="70" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ExclusiveGateway_ConsultMerge" bpmnElement="ExclusiveGateway_ConsultMerge">
        <dc:Bounds x="1220" y="85" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_ComprehensiveAssessment" bpmnElement="Task_ComprehensiveAssessment">
        <dc:Bounds x="230" y="210" width="250" height="110" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_Diagnostics" bpmnElement="Task_Diagnostics">
        <dc:Bounds x="540" y="225" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_MedicationReconciliation" bpmnElement="Task_MedicationReconciliation">
        <dc:Bounds x="230" y="400" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_EDManagement" bpmnElement="Task_EDManagement">
        <dc:Bounds x="510" y="390" width="220" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ParallelGateway_CompleteConcurrentCare" bpmnElement="ParallelGateway_CompleteConcurrentCare">
        <dc:Bounds x="1310" y="240" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_Admission" bpmnElement="Task_Admission">
        <dc:Bounds x="1410" y="225" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ExclusiveGateway_NonSurgicalHospital" bpmnElement="ExclusiveGateway_NonSurgicalHospital">
        <dc:Bounds x="1630" y="240" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_AdmittedAtSurgicalHospital" bpmnElement="EndEvent_AdmittedAtSurgicalHospital">
        <dc:Bounds x="1740" y="247" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_MedicalStabilization" bpmnElement="Task_MedicalStabilization">
        <dc:Bounds x="1545" y="360" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_TransferToSurgicalHospital" bpmnElement="Task_TransferToSurgicalHospital">
        <dc:Bounds x="1815" y="360" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_Surgery" bpmnElement="Task_Surgery">
        <dc:Bounds x="2085" y="360" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_Repatriation" bpmnElement="Task_Repatriation">
        <dc:Bounds x="2335" y="360" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_TransferPathComplete" bpmnElement="EndEvent_TransferPathComplete">
        <dc:Bounds x="2615" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="76" y="265" />
        <di:waypoint x="130" y="265" />
      </bpmndi:BPMNEdge>
