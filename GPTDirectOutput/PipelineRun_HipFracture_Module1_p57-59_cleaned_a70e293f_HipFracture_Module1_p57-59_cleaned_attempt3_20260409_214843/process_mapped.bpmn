<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_HipFractureInitialAcuteCare" name="Hip Fracture Initial Acute Care Pathway" isExecutable="false">
    <startEvent id="StartEvent_PatientPresentation" name="Suspected hip fracture patient presents to ED, clinic, or acute care setting">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <parallelGateway id="ParallelGateway_StartConcurrentCare" name="Start concurrent initial care">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
      <outgoing>Flow_10</outgoing>
      <outgoing>Flow_13</outgoing>
    </parallelGateway>
    <task id="Task_PhysicianAssessment" name="Seen by physician">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="Task_OrthopedicConsult" name="Consultation with orthopaedic surgeon">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
    </task>
    <task id="Task_NotifyConsultants" name="Notify anesthesiologist or internist of the patient">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <exclusiveGateway id="ExclusiveGateway_ConsultNeeded" name="Additional anesthesiologist or internist consultation needed?">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_6</outgoing>
      <outgoing>Flow_7</outgoing>
    </exclusiveGateway>
    <task id="Task_AdditionalConsult" name="Consultation with anesthesiologists">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
    <exclusiveGateway id="ExclusiveGateway_ConsultMerge">
      <incoming>Flow_7</incoming>
      <incoming>Flow_8</incoming>
      <outgoing>Flow_9</outgoing>
    </exclusiveGateway>
    <task id="Task_ComprehensiveAssessment" name="Assess physical, functional level">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    <task id="Task_Diagnostics" name="Issue appropriate blood work">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    <task id="Task_MedicationReconciliation" name="Perform medication reconciliation within the ED">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_14</outgoing>
    </task>
    <task id="Task_EDManagement" name="Manage patients pain, risk  within the ED">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_15</outgoing>
    </task>
    <parallelGateway id="ParallelGateway_CompleteConcurrentCare" name="Complete initial care">
      <incoming>Flow_9</incoming>
      <incoming>Flow_12</incoming>
      <incoming>Flow_15</incoming>
      <outgoing>Flow_16</outgoing>
    </parallelGateway>
    <task id="Task_Admission" name="Admit patient">
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
    <exclusiveGateway id="ExclusiveGateway_NonSurgicalHospital" name="Is the hospital non-surgical?">
      <incoming>Flow_17</incoming>
      <outgoing>Flow_18</outgoing>
      <outgoing>Flow_19</outgoing>
    </exclusiveGateway>
    <endEvent id="EndEvent_AdmittedAtSurgicalHospital" name="Patient admitted at surgical hospital">
      <incoming>Flow_18</incoming>
    </endEvent>
    <task id="Task_MedicalStabilization" name="Medically stabilize">
      <incoming>Flow_19</incoming>
      <outgoing>Flow_20</outgoing>
    </task>
    <task id="Task_TransferToSurgicalHospital" name="expeditious transfer to a surgical hospital for operation based on formal protocol">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_21</outgoing>
    </task>
    <task id="Task_Surgery" name="Perform surgery within 48 hours of initial presentation">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>
    <task id="Task_Repatriation" name="Repatriate patient to the local hospital after surgery">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_23</outgoing>
    </task>
    <endEvent id="EndEvent_TransferPathComplete" name="Patient repatriated after surgery">
      <incoming>Flow_23</incoming>
    </endEvent>

    <sequenceFlow id="Flow_1" sourceRef="StartEvent_PatientPresentation" targetRef="ParallelGateway_StartConcurrentCare" />
    <sequenceFlow id="Flow_2" sourceRef="ParallelGateway_StartConcurrentCare" targetRef="Task_PhysicianAssessment" />
    <sequenceFlow id="Flow_3" sourceRef="Task_PhysicianAssessment" targetRef="Task_OrthopedicConsult" />
    <sequenceFlow id="Flow_4" sourceRef="Task_OrthopedicConsult" targetRef="Task_NotifyConsultants" />
    <sequenceFlow id="Flow_5" sourceRef="Task_NotifyConsultants" targetRef="ExclusiveGateway_ConsultNeeded" />
    <sequenceFlow id="Flow_6" name="yes" sourceRef="ExclusiveGateway_ConsultNeeded" targetRef="Task_AdditionalConsult" />
    <sequenceFlow id="Flow_7" name="no" sourceRef="ExclusiveGateway_ConsultNeeded" targetRef="ExclusiveGateway_ConsultMerge" />
    <sequenceFlow id="Flow_8" sourceRef="Task_AdditionalConsult" targetRef="ExclusiveGateway_ConsultMerge" />
    <sequenceFlow id="Flow_9" sourceRef="ExclusiveGateway_ConsultMerge" targetRef="ParallelGateway_CompleteConcurrentCare" />
    <sequenceFlow id="Flow_10" sourceRef="ParallelGateway_StartConcurrentCare" targetRef="Task_ComprehensiveAssessment" />
    <sequenceFlow id="Flow_11" sourceRef="Task_ComprehensiveAssessment" targetRef="Task_Diagnostics" />
    <sequenceFlow id="Flow_12" sourceRef="Task_Diagnostics" targetRef="ParallelGateway_CompleteConcurrentCare" />
    <sequenceFlow id="Flow_13" sourceRef="ParallelGateway_StartConcurrentCare" targetRef="Task_MedicationReconciliation" />
    <sequenceFlow id="Flow_14" sourceRef="Task_MedicationReconciliation" targetRef="Task_EDManagement" />
    <sequenceFlow id="Flow_15" sourceRef="Task_EDManagement" targetRef="ParallelGateway_CompleteConcurrentCare" />
    <sequenceFlow id="Flow_16" sourceRef="ParallelGateway_CompleteConcurrentCare" targetRef="Task_Admission" />
    <sequenceFlow id="Flow_17" sourceRef="Task_Admission" targetRef="ExclusiveGateway_NonSurgicalHospital" />
    <sequenceFlow id="Flow_18" name="no" sourceRef="ExclusiveGateway_NonSurgicalHospital" targetRef="EndEvent_AdmittedAtSurgicalHospital" />
    <sequenceFlow id="Flow_19" name="yes" sourceRef="ExclusiveGateway_NonSurgicalHospital" targetRef="Task_MedicalStabilization" />
    <sequenceFlow id="Flow_20" sourceRef="Task_MedicalStabilization" targetRef="Task_TransferToSurgicalHospital" />
    <sequenceFlow id="Flow_21" sourceRef="Task_TransferToSurgicalHospital" targetRef="Task_Surgery" />
    <sequenceFlow id="Flow_22" sourceRef="Task_Surgery" targetRef="Task_Repatriation" />
    <sequenceFlow id="Flow_23" sourceRef="Task_Repatriation" targetRef="EndEvent_TransferPathComplete" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_HipFractureInitialAcuteCare">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_PatientPresentation" bpmnElement="StartEvent_PatientPresentation">
        <dc:Bounds x="40" y="247" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ParallelGateway_StartConcurrentCare" bpmnElement="ParallelGateway_StartConcurrentCare">
        <dc:Bounds x="130" y="240" width="50" height="50" />
      </bpmndi:BPMNShape>
