        <di:waypoint x="1000" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_7" bpmnElement="Flow_7">
        <di:waypoint x="925" y="135" />
        <di:waypoint x="925" y="180" />
        <di:waypoint x="1245" y="180" />
        <di:waypoint x="1245" y="135" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_8" bpmnElement="Flow_8">
        <di:waypoint x="1180" y="110" />
        <di:waypoint x="1220" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_9" bpmnElement="Flow_9">
