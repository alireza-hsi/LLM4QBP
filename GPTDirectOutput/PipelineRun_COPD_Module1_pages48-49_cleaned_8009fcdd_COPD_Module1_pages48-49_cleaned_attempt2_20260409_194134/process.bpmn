<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn" id="Definitions_COPD_Module_1">
  <process id="Process_Module_1_Initial_Presentation_Assessment" name="Module 1 Initial Presentation and Assessment" isExecutable="false">
    <startEvent id="StartEvent_Presentation" name="Patient presents with suspected COPD exacerbation"/>
    <task id="Task_Check_Vital_Signs" name="Check vital signs, consciousness, oxygen saturation, hypoventilation, and purulent sputum"/>
    <exclusiveGateway id="Gateway_Resuscitation_Needed" name="Immediate resuscitation needed at ED?"/>
    <task id="Task_Trial_Immediate_Resuscitation" name="Trial immediate resuscitation"/>
    <exclusiveGateway id="Gateway_Post_Resuscitation_Merge"/>
    <parallelGateway id="Gateway_Initial_Assessment_Split"/>
    <task id="Task_Perform_Physical_Examination" name="Perform physical examination"/>
    <task id="Task_Check_Patient_History" name="Check patient history"/>
    <task id="Task_Reconcile_Medications" name="Document and reconcile current medications"/>
    <task id="Task_Identify_Goals_Of_Care" name="Identify goals of care and code status"/>
    <task id="Task_Perform_Chest_Xray" name="Perform chest x-ray"/>
    <task id="Task_Conduct_Baseline_Blood_Work" name="Conduct baseline blood work"/>
    <task id="Task_Perform_Electrocardiogram" name="Perform electrocardiogram"/>
    <parallelGateway id="Gateway_Initial_Assessment_Join"/>
    <exclusiveGateway id="Gateway_ABG_Indicated" name="Low oxygen saturation or acute respiratory failure suspected?"/>
    <task id="Task_Check_Arterial_Blood_Gases" name="Check arterial blood gases"/>
    <exclusiveGateway id="Gateway_Blood_Cultures_Indicated" name="Pneumonia or suspected sepsis?"/>
    <task id="Task_Draw_Blood_Cultures" name="Draw blood cultures"/>
    <exclusiveGateway id="Gateway_Cardiac_Markers_Indicated" name="Suspected cardiac disorder?"/>
    <task id="Task_Examine_Cardiac_Markers" name="Examine cardiac markers"/>
    <exclusiveGateway id="Gateway_Other_Diagnostics_Indicated" name="Other diagnoses or comorbidities suspected?"/>
    <task id="Task_Perform_Other_Diagnostic_Interventions" name="Perform other diagnostic interventions"/>
    <task id="Task_Assess_Level_Of_Care" name="Assess or re-evaluate level of care using clinical judgment and NICE/GOLD criteria"/>
    <exclusiveGateway id="Gateway_Admission_Required" name="Hospital admission required?"/>
    <task id="Task_Admit_Patient_To_Hospital" name="Admit patient to hospital"/>
    <exclusiveGateway id="Gateway_Post_Disposition_Merge"/>
    <exclusiveGateway id="Gateway_Spirometry_Indicated" name="Stabilized and no prior spirometry documentation?"/>
    <task id="Task_Perform_Spirometry_Once_Stabilized" name="Perform spirometry once stabilized if no prior COPD documentation"/>
    <endEvent id="EndEvent_Assessment_Completed" name="Initial assessment and disposition completed"/>

    <sequenceFlow id="Flow_Start_To_Vitals" sourceRef="StartEvent_Presentation" targetRef="Task_Check_Vital_Signs"/>
    <sequenceFlow id="Flow_Vitals_To_Resuscitation_Gateway" sourceRef="Task_Check_Vital_Signs" targetRef="Gateway_Resuscitation_Needed"/>
    <sequenceFlow id="Flow_Resuscitation_Yes" sourceRef="Gateway_Resuscitation_Needed" targetRef="Task_Trial_Immediate_Resuscitation"/>
    <sequenceFlow id="Flow_Resuscitation_No" sourceRef="Gateway_Resuscitation_Needed" targetRef="Gateway_Post_Resuscitation_Merge"/>
    <sequenceFlow id="Flow_Resuscitation_Task_To_Merge" sourceRef="Task_Trial_Immediate_Resuscitation" targetRef="Gateway_Post_Resuscitation_Merge"/>
    <sequenceFlow id="Flow_Merge_To_Assessment_Split" sourceRef="Gateway_Post_Resuscitation_Merge" targetRef="Gateway_Initial_Assessment_Split"/>
    <sequenceFlow id="Flow_Split_To_Physical" sourceRef="Gateway_Initial_Assessment_Split" targetRef="Task_Perform_Physical_Examination"/>
    <sequenceFlow id="Flow_Split_To_History" sourceRef="Gateway_Initial_Assessment_Split" targetRef="Task_Check_Patient_History"/>
    <sequenceFlow id="Flow_Split_To_Xray" sourceRef="Gateway_Initial_Assessment_Split" targetRef="Task_Perform_Chest_Xray"/>
    <sequenceFlow id="Flow_Physical_To_Join" sourceRef="Task_Perform_Physical_Examination" targetRef="Gateway_Initial_Assessment_Join"/>
    <sequenceFlow id="Flow_History_To_Meds" sourceRef="Task_Check_Patient_History" targetRef="Task_Reconcile_Medications"/>
    <sequenceFlow id="Flow_Meds_To_Goals" sourceRef="Task_Reconcile_Medications" targetRef="Task_Identify_Goals_Of_Care"/>
    <sequenceFlow id="Flow_Goals_To_Join" sourceRef="Task_Identify_Goals_Of_Care" targetRef="Gateway_Initial_Assessment_Join"/>
    <sequenceFlow id="Flow_Xray_To_BloodWork" sourceRef="Task_Perform_Chest_Xray" targetRef="Task_Conduct_Baseline_Blood_Work"/>
    <sequenceFlow id="Flow_BloodWork_To_ECG" sourceRef="Task_Conduct_Baseline_Blood_Work" targetRef="Task_Perform_Electrocardiogram"/>
    <sequenceFlow id="Flow_ECG_To_Join" sourceRef="Task_Perform_Electrocardiogram" targetRef="Gateway_Initial_Assessment_Join"/>
    <sequenceFlow id="Flow_Join_To_ABG_Gateway" sourceRef="Gateway_Initial_Assessment_Join" targetRef="Gateway_ABG_Indicated"/>
    <sequenceFlow id="Flow_ABG_Yes" sourceRef="Gateway_ABG_Indicated" targetRef="Task_Check_Arterial_Blood_Gases"/>
    <sequenceFlow id="Flow_ABG_No" sourceRef="Gateway_ABG_Indicated" targetRef="Gateway_Blood_Cultures_Indicated"/>
    <sequenceFlow id="Flow_ABG_Task_To_Blood_Cultures_Gateway" sourceRef="Task_Check_Arterial_Blood_Gases" targetRef="Gateway_Blood_Cultures_Indicated"/>
    <sequenceFlow id="Flow_Blood_Cultures_Yes" sourceRef="Gateway_Blood_Cultures_Indicated" targetRef="Task_Draw_Blood_Cultures"/>
    <sequenceFlow id="Flow_Blood_Cultures_No" sourceRef="Gateway_Blood_Cultures_Indicated" targetRef="Gateway_Cardiac_Markers_Indicated"/>
    <sequenceFlow id="Flow_Blood_Cultures_Task_To_Cardiac_Gateway" sourceRef="Task_Draw_Blood_Cultures" targetRef="Gateway_Cardiac_Markers_Indicated"/>
    <sequenceFlow id="Flow_Cardiac_Yes" sourceRef="Gateway_Cardiac_Markers_Indicated" targetRef="Task_Examine_Cardiac_Markers"/>
    <sequenceFlow id="Flow_Cardiac_No" sourceRef="Gateway_Cardiac_Markers_Indicated" targetRef="Gateway_Other_Diagnostics_Indicated"/>
    <sequenceFlow id="Flow_Cardiac_Task_To_Other_Gateway" sourceRef="Task_Examine_Cardiac_Markers" targetRef="Gateway_Other_Diagnostics_Indicated"/>
    <sequenceFlow id="Flow_Other_Yes" sourceRef="Gateway_Other_Diagnostics_Indicated" targetRef="Task_Perform_Other_Diagnostic_Interventions"/>
    <sequenceFlow id="Flow_Other_No" sourceRef="Gateway_Other_Diagnostics_Indicated" targetRef="Task_Assess_Level_Of_Care"/>
    <sequenceFlow id="Flow_Other_Task_To_Assess" sourceRef="Task_Perform_Other_Diagnostic_Interventions" targetRef="Task_Assess_Level_Of_Care"/>
    <sequenceFlow id="Flow_Assess_To_Admission_Gateway" sourceRef="Task_Assess_Level_Of_Care" targetRef="Gateway_Admission_Required"/>
    <sequenceFlow id="Flow_Admission_Yes" sourceRef="Gateway_Admission_Required" targetRef="Task_Admit_Patient_To_Hospital"/>
    <sequenceFlow id="Flow_Admission_No" sourceRef="Gateway_Admission_Required" targetRef="Gateway_Post_Disposition_Merge"/>
    <sequenceFlow id="Flow_Admit_Task_To_Disposition_Merge" sourceRef="Task_Admit_Patient_To_Hospital" targetRef="Gateway_Post_Disposition_Merge"/>
    <sequenceFlow id="Flow_Disposition_Merge_To_Spirometry_Gateway" sourceRef="Gateway_Post_Disposition_Merge" targetRef="Gateway_Spirometry_Indicated"/>
    <sequenceFlow id="Flow_Spirometry_Yes" sourceRef="Gateway_Spirometry_Indicated" targetRef="Task_Perform_Spirometry_Once_Stabilized"/>
    <sequenceFlow id="Flow_Spirometry_No" sourceRef="Gateway_Spirometry_Indicated" targetRef="EndEvent_Assessment_Completed"/>
    <sequenceFlow id="Flow_Spirometry_Task_To_End" sourceRef="Task_Perform_Spirometry_Once_Stabilized" targetRef="EndEvent_Assessment_Completed"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Module_1">
