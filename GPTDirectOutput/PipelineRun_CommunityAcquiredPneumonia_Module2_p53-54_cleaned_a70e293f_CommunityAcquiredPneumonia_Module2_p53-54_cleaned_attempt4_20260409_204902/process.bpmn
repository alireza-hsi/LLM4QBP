      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Sputum_Merge" bpmnElement="Gateway_Sputum_Merge">
        <dc:Bounds x="1710" y="815" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Urine_Antigen_Indication" bpmnElement="Gateway_Urine_Antigen_Indication">
        <dc:Bounds x="1020" y="935" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Perform_Urine_Antigen_Test" bpmnElement="Task_Perform_Urine_Antigen_Test">
        <dc:Bounds x="1120" y="920" width="190" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Urine_Antigen_Merge" bpmnElement="Gateway_Urine_Antigen_Merge">
        <dc:Bounds x="1350" y="935" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Intubated" bpmnElement="Gateway_Intubated">
        <dc:Bounds x="1020" y="1055" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Consider_Legionella_PCR" bpmnElement="Task_Consider_Legionella_PCR">
        <dc:Bounds x="1120" y="1040" width="220" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_PCR_Merge" bpmnElement="Gateway_PCR_Merge">
        <dc:Bounds x="1380" y="1055" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Admitted_Tests_Join" bpmnElement="Gateway_Admitted_Tests_Join">
        <dc:Bounds x="1850" y="695" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Admission_Tests_Complete" bpmnElement="EndEvent_Admission_Tests_Complete">
        <dc:Bounds x="1960" y="702" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="86" y="250"/>
        <di:waypoint x="120" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="270" y="250"/>
        <di:waypoint x="310" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="360" y="250"/>
        <di:waypoint x="400" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint x="360" y="250"/>
        <di:waypoint x="360" y="170"/>
        <di:waypoint x="655" y="170"/>
        <di:waypoint x="655" y="225"/>
      </bpmndi:BPMNEdge>
