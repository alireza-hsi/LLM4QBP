        <dc:Bounds x="1300" y="65" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Additional_Consult" bpmnElement="Task_Additional_Consult">
        <dc:Bounds x="1410" y="60" width="220" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_Consult_Merge" bpmnElement="Gateway_Consult_Merge" isMarkerVisible="true">
        <dc:Bounds x="1690" y="65" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Comprehensive_Assessment" bpmnElement="Task_Comprehensive_Assessment">
        <dc:Bounds x="760" y="250" width="340" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Diagnostics" bpmnElement="Task_Diagnostics">
        <dc:Bounds x="1160" y="250" width="220" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Medication_Reconciliation" bpmnElement="Task_Medication_Reconciliation">
        <dc:Bounds x="760" y="430" width="230" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ED_Management" bpmnElement="Task_ED_Management">
        <dc:Bounds x="1050" y="430" width="290" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_ED_Parallel_Join" bpmnElement="Gateway_ED_Parallel_Join" isMarkerVisible="true">
        <dc:Bounds x="1830" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Admit_Within_4_Hours" bpmnElement="Task_Admit_Within_4_Hours">
        <dc:Bounds x="1940" y="250" width="250" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Gateway_Transfer_Required" bpmnElement="Gateway_Transfer_Required" isMarkerVisible="true">
        <dc:Bounds x="2250" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_Onsite_Care" bpmnElement="EndEvent_Onsite_Care">
        <dc:Bounds x="2380" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Medical_Stabilization" bpmnElement="Task_Medical_Stabilization">
        <dc:Bounds x="2380" y="350" width="250" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_Transfer_To_Surgical_Hospital" bpmnElement="Task_Transfer_To_Surgical_Hospital">
        <dc:Bounds x="2690" y="350" width="360" height="60" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_Transferred" bpmnElement="EndEvent_Transferred">
        <dc:Bounds x="3110" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

