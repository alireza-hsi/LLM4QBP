<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://www.example.com/bpmn">
  <process id="Process_HipFracture_ED_Care" isExecutable="false">
    <startEvent id="StartEvent_Presentation" name="Suspected hip fracture patient presents to ED, outpatient clinic, or acute care setting">
      <outgoing>Flow_01</outgoing>
    </startEvent>

    <task id="Task_Apply_Care_Pathway" name="Use hospital hip fracture care pathway with perioperative day-of-stay goals">
      <incoming>Flow_01</incoming>
      <outgoing>Flow_02</outgoing>
    </task>

    <task id="Task_Physician_Assessment" name="Seen by physician">
      <incoming>Flow_02</incoming>
      <outgoing>Flow_03</outgoing>
    </task>

    <parallelGateway id="Gateway_ED_Parallel_Split" name="Perform ED assessment and early management">
      <incoming>Flow_03</incoming>
      <outgoing>Flow_04</outgoing>
      <outgoing>Flow_11</outgoing>
      <outgoing>Flow_14</outgoing>
    </parallelGateway>

    <task id="Task_Orthopedic_Consult" name="Consultation with orthopaedic surgeon">
      <incoming>Flow_04</incoming>
      <outgoing>Flow_05</outgoing>
    </task>

    <task id="Task_Notify_Consultants" name="Make anesthesiologist or internist aware of the patient">
      <incoming>Flow_05</incoming>
      <outgoing>Flow_06</outgoing>
    </task>

    <exclusiveGateway id="Gateway_Additional_Consult_Needed" name="Additional anesthesiologist or internist consultation needed?">
      <incoming>Flow_06</incoming>
      <outgoing>Flow_07</outgoing>
      <outgoing>Flow_08</outgoing>
    </exclusiveGateway>

    <task id="Task_Additional_Consult" name="Consultation with anesthesiologists">
      <incoming>Flow_07</incoming>
      <outgoing>Flow_09</outgoing>
    </task>

    <exclusiveGateway id="Gateway_Consult_Merge" name="Consultation path complete">
      <incoming>Flow_08</incoming>
      <incoming>Flow_09</incoming>
      <outgoing>Flow_10</outgoing>
    </exclusiveGateway>

    <task id="Task_Comprehensive_Assessment" name="Assess reason for fall">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </task>

    <task id="Task_Diagnostics" name="Issue appropriate blood work">
      <incoming>Flow_12</incoming>
      <outgoing>Flow_13</outgoing>
    </task>

    <task id="Task_Medication_Reconciliation" name="Perform medication reconciliation within the ED">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_15</outgoing>
    </task>

    <task id="Task_ED_Management" name="Manage patients pain, risk  within the ED">
      <incoming>Flow_15</incoming>
      <outgoing>Flow_16</outgoing>
    </task>

    <parallelGateway id="Gateway_ED_Parallel_Join" name="ED assessment and management complete">
      <incoming>Flow_10</incoming>
      <incoming>Flow_13</incoming>
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17</outgoing>
    </parallelGateway>

    <task id="Task_Admit_Within_4_Hours" name="Admit patient">
      <incoming>Flow_17</incoming>
      <outgoing>Flow_18</outgoing>
    </task>

    <exclusiveGateway id="Gateway_Transfer_Required" name="Transfer to surgical hospital required?">
      <incoming>Flow_18</incoming>
      <outgoing>Flow_19</outgoing>
      <outgoing>Flow_20</outgoing>
    </exclusiveGateway>

    <endEvent id="EndEvent_Onsite_Care" name="Patient admitted for on-site inpatient hip fracture care">
      <incoming>Flow_19</incoming>
    </endEvent>

    <task id="Task_Medical_Stabilization" name="Medically stabilize">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_21</outgoing>
    </task>

    <task id="Task_Transfer_To_Surgical_Hospital" name="expeditious transfer to a surgical hospital for operation based on formal protocol">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>

    <endEvent id="EndEvent_Transferred" name="Patient transferred to surgical hospital for surgery">
      <incoming>Flow_22</incoming>
    </endEvent>

    <sequenceFlow id="Flow_01" sourceRef="StartEvent_Presentation" targetRef="Task_Apply_Care_Pathway" />
    <sequenceFlow id="Flow_02" sourceRef="Task_Apply_Care_Pathway" targetRef="Task_Physician_Assessment" />
    <sequenceFlow id="Flow_03" sourceRef="Task_Physician_Assessment" targetRef="Gateway_ED_Parallel_Split" />
    <sequenceFlow id="Flow_04" sourceRef="Gateway_ED_Parallel_Split" targetRef="Task_Orthopedic_Consult" />
    <sequenceFlow id="Flow_05" sourceRef="Task_Orthopedic_Consult" targetRef="Task_Notify_Consultants" />
    <sequenceFlow id="Flow_06" sourceRef="Task_Notify_Consultants" targetRef="Gateway_Additional_Consult_Needed" />
    <sequenceFlow id="Flow_07" name="Needed" sourceRef="Gateway_Additional_Consult_Needed" targetRef="Task_Additional_Consult" />
    <sequenceFlow id="Flow_08" name="Not needed" sourceRef="Gateway_Additional_Consult_Needed" targetRef="Gateway_Consult_Merge" />
    <sequenceFlow id="Flow_09" sourceRef="Task_Additional_Consult" targetRef="Gateway_Consult_Merge" />
    <sequenceFlow id="Flow_10" sourceRef="Gateway_Consult_Merge" targetRef="Gateway_ED_Parallel_Join" />
    <sequenceFlow id="Flow_11" sourceRef="Gateway_ED_Parallel_Split" targetRef="Task_Comprehensive_Assessment" />
    <sequenceFlow id="Flow_12" sourceRef="Task_Comprehensive_Assessment" targetRef="Task_Diagnostics" />
    <sequenceFlow id="Flow_13" sourceRef="Task_Diagnostics" targetRef="Gateway_ED_Parallel_Join" />
    <sequenceFlow id="Flow_14" sourceRef="Gateway_ED_Parallel_Split" targetRef="Task_Medication_Reconciliation" />
    <sequenceFlow id="Flow_15" sourceRef="Task_Medication_Reconciliation" targetRef="Task_ED_Management" />
    <sequenceFlow id="Flow_16" sourceRef="Task_ED_Management" targetRef="Gateway_ED_Parallel_Join" />
    <sequenceFlow id="Flow_17" sourceRef="Gateway_ED_Parallel_Join" targetRef="Task_Admit_Within_4_Hours" />
    <sequenceFlow id="Flow_18" sourceRef="Task_Admit_Within_4_Hours" targetRef="Gateway_Transfer_Required" />
    <sequenceFlow id="Flow_19" name="No" sourceRef="Gateway_Transfer_Required" targetRef="EndEvent_Onsite_Care" />
    <sequenceFlow id="Flow_20" name="Yes" sourceRef="Gateway_Transfer_Required" targetRef="Task_Medical_Stabilization" />
    <sequenceFlow id="Flow_21" sourceRef="Task_Medical_Stabilization" targetRef="Task_Transfer_To_Surgical_Hospital" />
    <sequenceFlow id="Flow_22" sourceRef="Task_Transfer_To_Surgical_Hospital" targetRef="EndEvent_Transferred" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_HipFracture_ED_Care">
      <bpmndi:BPMNShape id="Shape_StartEvent_Presentation" bpmnElement="StartEvent_Presentation">
        <dc:Bounds x="80" y="262" width="36" height="36" />
