<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_23</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="Initiate acute heart failure episode of care (Role: emergency department clinician; Objects: patient presenting with suspected acute heart failure)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="Frequently measure heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: nursing staff; Objects: monitoring equipment)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="Apply standardized risk-stratification tool for acute heart failure and other conditions (Role: emergency department clinician; Objects: risk-stratification tool)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity4" name="Order initial investigations for responsiveness to diuresis (Role: emergency department clinician; Objects: serum creatinine, electrolyte levels, troponin, complete blood count, electrocardiogram, chest x-ray, echocardiogram (if no recent available))">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="Review results of investigations for responsiveness to diuresis (Role: emergency department clinician; Objects: investigation results)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity6" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG risk score tool)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_10" name="(dummy branch entry)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="Provide discharge instructions (Role: emergency department clinician; Objects: discharge instructions)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8" name="Complete discharge documentation (Role: emergency department clinician; Objects: discharge forms, electronic health record)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="Arrange follow-up visit with primary care provider within days of discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Admit patient to intensive care unit with high nurse-to-patient staffing (Role: emergency department clinician; Objects: ICU admission order)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="Admit patient to inpatient care with normal nurse-to-patient staffing (Role: emergency department clinician; Objects: inpatient admission order)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity12" name="Ensure standardized risk stratification assessment tool/process is used for all acute heart failure presentations (Role: hospital administration; Objects: hospital policy, risk stratification tool)">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity13" name="Maintain pathway/mechanism for transfer to higher level provider as needed (Role: hospital administration; Objects: transfer protocols)">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="activity1" targetRef="activity2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="activity2" targetRef="activity3" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="parallelgateway1" targetRef="activity4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="parallelgateway1" targetRef="activity5" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="activity4" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="activity5" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="activity3" targetRef="parallelgateway1" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="parallelgateway1Join" targetRef="activity6" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="dummy_Flow_10" targetRef="activity7" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="activity7" targetRef="activity8" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="activity8" targetRef="activity9" />
    <bpmn:sequenceFlow id="Flow_14" name="Low-risk (EHMRG quintiles 1-2), responded to initial ED treatment, no complicating factors" sourceRef="exclusivegateway1" targetRef="dummy_Flow_10">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2), responded to initial ED treatment, no complicating factors</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_15" sourceRef="activity9" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_16" name="High-risk (EHMRG quintiles 3-5) or complicating factors present AND high-intensity care required (ventilation/ICU)" sourceRef="exclusivegateway1" targetRef="activity10">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or complicating factors present AND high-intensity care required (ventilation/ICU)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_17" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_18" name="High-risk (EHMRG quintiles 3-5) or complicating factors present AND average-intensity care required (inpatient admission, normal staffing)" sourceRef="exclusivegateway1" targetRef="activity11">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or complicating factors present AND average-intensity care required (inpatient admission, normal staffing)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_19" sourceRef="activity11" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="activity6" targetRef="exclusivegateway1" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="exclusivegateway1Join" targetRef="activity12" />
    <bpmn:sequenceFlow id="Flow_22" sourceRef="activity12" targetRef="activity13" />
    <bpmn:sequenceFlow id="Flow_23" sourceRef="activity13" targetRef="EndEvent_1" />
  </bpmn:process>
