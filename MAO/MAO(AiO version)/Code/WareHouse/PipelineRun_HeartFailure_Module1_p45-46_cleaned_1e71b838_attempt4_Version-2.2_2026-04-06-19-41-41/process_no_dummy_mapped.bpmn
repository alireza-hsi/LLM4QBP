    <sequenceFlow id="Flow_16" name="High-risk (EHMRG quintiles 3-5) or complicating factors present AND high-intensity care required (ventilation/ICU)" sourceRef="exclusivegateway1" targetRef="activity10">
      <conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or complicating factors present AND high-intensity care required (ventilation/ICU)</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_17" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_18" name="High-risk (EHMRG quintiles 3-5) or complicating factors present AND average-intensity care required (inpatient admission, normal staffing)" sourceRef="exclusivegateway1" targetRef="activity11">
      <conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or complicating factors present AND average-intensity care required (inpatient admission, normal staffing)</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_19" sourceRef="activity11" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_20" sourceRef="activity6" targetRef="exclusivegateway1" />
