  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_23</incoming>
    </endEvent>
    <task id="activity1" name="Treat in ED">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="activity2" name="Monitor heart rate, blood pressure, oxygen saturation until stabilized">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="activity3" name="Risk stratification&#10;(e.g., EHMRG)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_4</outgoing>
      <outgoing>Flow_5</outgoing>
    </parallelGateway>
    <task id="activity4" name="Check responsiveness to Diuresis">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_6</outgoing>
    </task>
    <task id="activity5" name="Check responsiveness to Diuresis">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_6</incoming>
      <incoming>Flow_7</incoming>
      <outgoing>Flow_9</outgoing>
    </parallelGateway>
    <task id="activity6" name="Risk stratification&#10;(e.g., EHMRG)">
      <incoming>Flow_9</incoming>
      <outgoing>Flow_20</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_14</outgoing>
      <outgoing>Flow_16</outgoing>
      <outgoing>Flow_18</outgoing>
    </exclusiveGateway>
    <task id="activity7" name="Discharge home">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    <task id="activity8" name="Discharge home">
      <incoming>Flow_12</incoming>
      <outgoing>Flow_13</outgoing>
    </task>
    <task id="activity9" name="Arrange follow-up (within days) with primary care">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_15</outgoing>
    </task>
    <task id="activity10" name="Admit to ICU (high nurse-to-patient staffing)">
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
    <task id="activity11" name="Admit to inpatient care (normal nurse-to-patient staffing)">
      <incoming>Flow_18</incoming>
      <outgoing>Flow_19</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_15</incoming>
      <incoming>Flow_17</incoming>
      <incoming>Flow_19</incoming>
      <outgoing>Flow_21</outgoing>
    </exclusiveGateway>
    <task id="activity12" name="develop risk-stratification tools that can be used for multiple conditions">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>
    <task id="activity13" name="Maintain pathway/mechanism for transfer to higher level provider as needed (Role: hospital administration; Objects: transfer protocols)">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_23</outgoing>
    </task>
