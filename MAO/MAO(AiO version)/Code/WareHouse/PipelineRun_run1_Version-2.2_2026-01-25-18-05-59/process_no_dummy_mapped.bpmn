      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_ecginterp_1" name="interpret ECG immediately and communicate acute arrhythmias (e.g., atrial fibrillation) to the stroke/ED team (Role: ED physician/cardiology (as available); Objects: ECG tracing; interpretation note/alert)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_70</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_labinterp_1" name="interpret blood work results immediately as they become available and communicate critical values to the stroke/ED team (Role: qualified health care provider (ED physician/lab medicine); Objects: lab results; critical value notification)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_71</ns0:outgoing>
    </ns0:task>
