    <task id="activity1_combined" name="develop and consistently apply standardized risk-stratification tools across all Ontario hospitals (Role: Ontario hospitals; Objects: risk-stratification tool/process)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_28</outgoing>
    </task>
