      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_followup1" name="follow-up visit within days of discharge from the ED (Role: primary care provider)">
      <ns0:incoming>Flow_32</ns0:incoming>
      <ns0:outgoing>Flow_43</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_admit_and_assign_care_level1" name="admit/transfer patient to appropriate hospital care setting and staffing level (inpatient unit or ICU as indicated) (Role: clinical team; Objects: risk group, response to treatment, high-risk markers, ventilation need)">
      <ns0:incoming>Flow_34</ns0:incoming>
      <ns0:outgoing>Flow_41</ns0:outgoing>
