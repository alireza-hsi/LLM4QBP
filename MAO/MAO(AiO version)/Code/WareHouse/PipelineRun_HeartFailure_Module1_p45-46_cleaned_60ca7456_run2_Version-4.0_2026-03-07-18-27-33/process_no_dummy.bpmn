  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_47</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1_combined" name="develop and consistently apply standardized risk-stratification tools across all Ontario hospitals (Role: Ontario hospitals; Objects: risk-stratification tool/process)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_28</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
      <ns0:outgoing>Flow_19</ns0:outgoing>
      <ns0:outgoing>Flow_20</ns0:outgoing>
      <ns0:outgoing>Flow_21</ns0:outgoing>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity_bloodwork1" name="order blood work panel (Role: clinical team; Objects: serum creatinine, electrolytes, troponin, complete blood count)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_bloodwork_interpret1" name="interpret blood work results (Role: healthcare expert; Objects: creatinine/electrolytes/troponin/CBC results)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_ecg1" name="perform electrocardiogram (ECG) (Role: clinical team)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_ecg_interpret1" name="interpret ECG results (Role: healthcare expert; Objects: ECG tracing)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_cxr1" name="perform chest x-ray examination (Role: clinical team)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_cxr_interpret1" name="interpret chest x-ray results (Role: healthcare expert; Objects: chest x-ray images)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway_echo1" name="Exclusive Gateway">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
      <ns0:outgoing>Flow_16</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity_echo1" name="perform an echocardiogram (Role: clinical team)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_echo_interpret1" name="interpret echocardiogram results (Role: healthcare expert; Objects: echocardiogram images/report)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_echo_review1" name="review prior echocardiogram results (Role: healthcare expert; Objects: most recent echocardiogram report)">
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
