<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_23</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="Initiate standardized risk assessment/stratification for acute heart failure (Role: emergency department clinician; Objects: risk-stratification tool)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity2-1" name="Order initial investigations for acute heart failure (Role: emergency department clinician; Objects: serum creatinine, electrolyte levels, troponin, complete blood count, electrocardiogram, chest x-ray, echocardiogram (if no recent available))">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="Frequently measure and monitor heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: nursing staff; Objects: monitoring equipment)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity2-2" name="Review results of initial investigations for acute heart failure (Role: emergency department clinician; Objects: investigation reports)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="Assess responsiveness to diuresis and identify high-risk markers (respiratory distress, hypoxemia, pulmonary edema severity, poor response to furosemide, hemodynamic compromise, significant arrhythmias, positive troponin) (Role: emergency department clinician; Objects: clinical assessment, investigation results)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG calculator, patient data)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_10" name="(dummy branch entry)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-1" name="Provide discharge instructions to patient (Role: emergency department clinician; Objects: discharge instructions)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-2" name="Complete discharge documentation (Role: emergency department clinician; Objects: discharge paperwork)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="Arrange follow-up visit with primary care provider within days of discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity8" name="Admit patient to inpatient care with normal nurse-to-patient staffing (Role: emergency department clinician; Objects: admission order)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="Admit patient to intensive care unit with higher nurse-to-patient staffing and/or initiate ventilation (noninvasive or invasive) (Role: emergency department clinician; Objects: ICU admission order, ventilation equipment)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="parallelgateway1" targetRef="activity2-1" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="parallelgateway1" targetRef="activity3" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="activity2-1" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="activity3" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="activity1" targetRef="parallelgateway1" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="parallelgateway1Join" targetRef="activity2-2" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="activity2-2" targetRef="activity4" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="activity4" targetRef="activity5" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="dummy_Flow_10" targetRef="activity6-1" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="activity6-1" targetRef="activity6-2" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="activity6-2" targetRef="activity7" />
    <bpmn:sequenceFlow id="Flow_14" name="Requires normal nurse-to-patient staffing (average intensity)" sourceRef="exclusivegateway2" targetRef="activity8">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires normal nurse-to-patient staffing (average intensity)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_15" sourceRef="activity8" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_16" name="Requires ventilation and/or intensive care (high intensity)" sourceRef="exclusivegateway2" targetRef="activity9">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or intensive care (high intensity)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_17" sourceRef="activity9" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_18" name="Low-risk (EHMRG quintiles 1-2), responded to initial ED treatment, no other considerations" sourceRef="exclusivegateway1" targetRef="dummy_Flow_10">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2), responded to initial ED treatment, no other considerations</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_19" sourceRef="activity7" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_20" name="Average-risk (EHMRG quintile 3-5) OR high-risk markers present OR other considerations (e.g., advanced directives, severe dementia, estimated impact of admission on life-expectancy)" sourceRef="exclusivegateway1" targetRef="exclusivegateway2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Average-risk (EHMRG quintile 3-5) OR high-risk markers present OR other considerations (e.g., advanced directives, severe dementia, estimated impact of admission on life-expectancy)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_21" sourceRef="exclusivegateway2Join" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_22" sourceRef="activity5" targetRef="exclusivegateway1" />
    <bpmn:sequenceFlow id="Flow_23" sourceRef="exclusivegateway1Join" targetRef="EndEvent_1" />
  </bpmn:process>
