      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8-2" name="Complete discharge documentation (Role: emergency department clinician; Objects: discharge paperwork)">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
