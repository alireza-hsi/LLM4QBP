  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_36</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="Initiate standardized risk assessment/stratification using validated tool (Role: emergency department clinician; Objects: risk-stratification tool)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2-1" name="Order initial investigations (Role: emergency department clinician; Objects: serum creatinine, electrolyte levels, troponin, complete blood count, electrocardiogram, chest x-ray)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity3" name="Order and review echocardiogram (Role: emergency department clinician; Objects: echocardiogram)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="Skip echocardiogram order (Role: emergency department clinician)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity2-2" name="Review initial investigation results (Role: emergency department clinician; Objects: investigation results)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity5" name="Frequently measure and record heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: nursing staff; Objects: monitoring equipment)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dummy_Flow_9" name="(dummy branch entry)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-1" name="Administer diuretic (e.g., furosemide) (Role: emergency department clinician; Objects: furosemide)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-2" name="Assess clinical response to diuretic (Role: emergency department clinician; Objects: clinical response)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity7" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG risk score tool)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_33</bpmn:outgoing>
    </bpmn:task>
