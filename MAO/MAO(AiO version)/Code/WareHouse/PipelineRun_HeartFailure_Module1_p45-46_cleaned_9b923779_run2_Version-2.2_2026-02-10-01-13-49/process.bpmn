    </bpmn:exclusiveGateway>
    <bpmn:task id="activity10" name="Admit patient to intensive care unit with higher nurse-to-patient staffing (Role: emergency department clinician; Objects: ICU admission order)">
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="Admit patient to inpatient care (Role: emergency department clinician; Objects: inpatient admission order)">
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
    </bpmn:task>
