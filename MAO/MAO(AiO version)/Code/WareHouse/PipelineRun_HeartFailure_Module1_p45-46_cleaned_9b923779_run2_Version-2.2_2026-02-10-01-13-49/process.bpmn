    <bpmn:sequenceFlow id="Flow_24" sourceRef="parallelgateway2Join" targetRef="activity9" />
    <bpmn:sequenceFlow id="Flow_25" name="Requires ventilation and/or ICU admission (high intensity)" sourceRef="exclusivegateway3" targetRef="activity10">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or ICU admission (high intensity)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_26" sourceRef="activity10" targetRef="exclusivegateway3Join" />
    <bpmn:sequenceFlow id="Flow_27" name="Requires inpatient care with normal nurse-to-patient staffing (average intensity)" sourceRef="exclusivegateway3" targetRef="activity11">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires inpatient care with normal nurse-to-patient staffing (average intensity)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_28" sourceRef="activity11" targetRef="exclusivegateway3Join" />
    <bpmn:sequenceFlow id="Flow_29" name="Low-risk (EHMRG quintiles 1-2) AND responded to initial ED treatment AND no other considerations (e.g., advanced directives, severe dementia, etc.)" sourceRef="exclusivegateway2" targetRef="dummy_Flow_18">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2) AND responded to initial ED treatment AND no other considerations (e.g., advanced directives, severe dementia, etc.)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_30" sourceRef="activity9" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_31" name="Average-risk (EHMRG quintiles 3-5) OR high-risk markers present OR other considerations preclude discharge" sourceRef="exclusivegateway2" targetRef="exclusivegateway3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Average-risk (EHMRG quintiles 3-5) OR high-risk markers present OR other considerations preclude discharge</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_32" sourceRef="exclusivegateway3Join" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_33" sourceRef="activity7" targetRef="exclusivegateway2" />
