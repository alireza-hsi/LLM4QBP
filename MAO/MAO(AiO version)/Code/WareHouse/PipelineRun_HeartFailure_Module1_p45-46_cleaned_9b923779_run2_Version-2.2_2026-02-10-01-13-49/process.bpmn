      <bpmn:outgoing>Flow_34</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity12" name="Ensure use of standardized risk stratification assessment tool or process for all ED presentations (Role: hospital administration; Objects: risk stratification policy)">
      <bpmn:incoming>Flow_34</bpmn:incoming>
      <bpmn:outgoing>Flow_35</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity13" name="Maintain pathway or mechanism to transfer patients to higher level provider as needed (Role: hospital administration; Objects: transfer protocol)">
      <bpmn:incoming>Flow_35</bpmn:incoming>
      <bpmn:outgoing>Flow_36</bpmn:outgoing>
    </bpmn:task>
