<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_50</incoming></endEvent>
    <task id="activity1_1" name="identify suspected TIA or minor stroke presentation (Role: EMS or triage nurse; Objects: patient)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity1_2" name="initiate standardized stroke/TIA pathway (Role: EMS or triage nurse; Objects: triage tool, stroke/TIA pathway)">
      <incoming>Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="activity2" name="prenotify receiving hospital and stroke team when patient is arriving by ambulance (Role: EMS; Objects: stroke/TIA patient information)">
      <incoming>Flow_3</incoming><outgoing>Flow_4</outgoing></task>
    <task id="activity3_1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_4</incoming><outgoing>Flow_6</outgoing></task>
    <task id="activity4" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_6</incoming><outgoing>Flow_24</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_24</incoming><outgoing>Flow_19</outgoing><outgoing>merged_Flow_18_Flow_8</outgoing><outgoing>merged_Flow_20_Flow_12</outgoing></parallelGateway>
    <task id="activity5" name="Immediate brain imaging (CT or MRI)">
      <incoming>merged_Flow_18_Flow_8</incoming><outgoing>Flow_9</outgoing></task>
    <task id="activity6" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_9</incoming><outgoing>Flow_10</outgoing></task>
    <task id="activity6_1" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_10</incoming><outgoing>Flow_21</outgoing></task>
    <task id="activity7" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_19</incoming><outgoing>Flow_22</outgoing></task>
    <task id="activity8_1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>merged_Flow_20_Flow_12</incoming><outgoing>Flow_23</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_21</incoming><incoming>Flow_22</incoming><incoming>Flow_23</incoming><outgoing>Flow_47</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_47</incoming><outgoing>merged_Flow_43_Flow_26</outgoing><outgoing>merged_Flow_45_Flow_34</outgoing></exclusiveGateway>
    <task id="activity10" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_43_Flow_26</incoming><outgoing>Flow_32</outgoing></task>
    <inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <incoming>Flow_32</incoming><outgoing>Flow_28</outgoing><outgoing>Flow_30</outgoing></inclusiveGateway>
    <task id="activity12" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_28</incoming><outgoing>Flow_29</outgoing></task>
    <task id="activity13" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_30</incoming><outgoing>Flow_31</outgoing></task>
    <inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <incoming>Flow_29</incoming><incoming>Flow_31</incoming><outgoing>Flow_44</outgoing></inclusiveGateway>
    <task id="activity14_1" name="Use a standard triage tool to determine the appropriate location for the care of patients&#10;(Patients with TIA)">
      <incoming>merged_Flow_45_Flow_34</incoming><outgoing>Flow_42</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_42</incoming><outgoing>Flow_36</outgoing><outgoing>Flow_38</outgoing><outgoing>Flow_40</outgoing></exclusiveGateway>
    <task id="activity15" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_36</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity16" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_38</incoming><outgoing>Flow_39</outgoing></task>
    <task id="activity17" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_40</incoming><outgoing>Flow_41</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_37</incoming><incoming>Flow_39</incoming><incoming>Flow_41</incoming><outgoing>Flow_46</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_44</incoming><incoming>Flow_46</incoming><outgoing>Flow_48</outgoing></exclusiveGateway>
    <task id="activity18_1" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_48</incoming><outgoing>Flow_50</outgoing></task>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1_1" />
    <sequenceFlow id="Flow_2" sourceRef="activity1_1" targetRef="activity1_2" />
    <sequenceFlow id="Flow_3" sourceRef="activity1_2" targetRef="activity2" />
    <sequenceFlow id="Flow_4" sourceRef="activity2" targetRef="activity3_1" />
    <sequenceFlow id="Flow_6" sourceRef="activity3_1" targetRef="activity4" />
    <sequenceFlow id="Flow_9" sourceRef="activity5" targetRef="activity6" />
    <sequenceFlow id="Flow_10" sourceRef="activity6" targetRef="activity6_1" />
    <sequenceFlow id="Flow_19" sourceRef="parallelgateway1" targetRef="activity7" />
    <sequenceFlow id="Flow_21" sourceRef="activity6_1" targetRef="parallelgateway1Join" />
    <sequenceFlow id="Flow_22" sourceRef="activity7" targetRef="parallelgateway1Join" />
    <sequenceFlow id="Flow_23" sourceRef="activity8_1" targetRef="parallelgateway1Join" />
    <sequenceFlow id="Flow_24" sourceRef="activity4" targetRef="parallelgateway1" />
    <sequenceFlow id="Flow_28" name="patient is not alert within the first 24 hours" sourceRef="inclusivegateway1" targetRef="activity12">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient is not alert within the first 24 hours</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_29" sourceRef="activity12" targetRef="inclusivegateway1Join" />
    <sequenceFlow id="Flow_30" name="patient presents with features indicating dysphagia or pulmonary aspiration" sourceRef="inclusivegateway1" targetRef="activity13">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient presents with features indicating dysphagia or pulmonary aspiration</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_31" sourceRef="activity13" targetRef="inclusivegateway1Join" />
    <sequenceFlow id="Flow_32" sourceRef="activity10" targetRef="inclusivegateway1" />
    <sequenceFlow id="Flow_36" name="presentation within 48 hours of symptom onset or fluctuating motor or speech symptoms and patient is candidate for carotid artery revascularization" sourceRef="exclusivegateway2" targetRef="activity15">
      <conditionExpression xsi:type="bpmn:tFormalExpression">presentation within 48 hours of symptom onset or fluctuating motor or speech symptoms and patient is candidate for carotid artery revascularization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_37" sourceRef="activity15" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_38" name="presentation within 48 hours of symptom onset or fluctuating motor or speech symptoms and patient is clearly not a candidate for carotid artery revascularization" sourceRef="exclusivegateway2" targetRef="activity16">
      <conditionExpression xsi:type="bpmn:tFormalExpression">presentation within 48 hours of symptom onset or fluctuating motor or speech symptoms and patient is clearly not a candidate for carotid artery revascularization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_39" sourceRef="activity16" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_40" name="all other patients presenting beyond 48 hours with TIA or ischemic stroke" sourceRef="exclusivegateway2" targetRef="activity17">
      <conditionExpression xsi:type="bpmn:tFormalExpression">all other patients presenting beyond 48 hours with TIA or ischemic stroke</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_41" sourceRef="activity17" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_42" sourceRef="activity14_1" targetRef="exclusivegateway2" />
    <sequenceFlow id="Flow_44" sourceRef="inclusivegateway1Join" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_46" sourceRef="exclusivegateway2Join" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_47" sourceRef="parallelgateway1Join" targetRef="exclusivegateway1" />
    <sequenceFlow id="Flow_48" sourceRef="exclusivegateway1Join" targetRef="activity18_1" />
    <sequenceFlow id="Flow_50" sourceRef="activity18_1" targetRef="EndEvent_1" />
  <sequenceFlow id="merged_Flow_18_Flow_8" sourceRef="parallelgateway1" targetRef="activity5" /><sequenceFlow id="merged_Flow_20_Flow_12" sourceRef="parallelgateway1" targetRef="activity8_1" /><sequenceFlow id="merged_Flow_43_Flow_26" sourceRef="exclusivegateway1" targetRef="activity10" name="patient has stroke"><conditionExpression xsi:type="bpmn:tFormalExpression">patient has stroke</conditionExpression></sequenceFlow><sequenceFlow id="merged_Flow_45_Flow_34" sourceRef="exclusivegateway1" targetRef="activity14_1" name="patient has TIA or minor nondisabling stroke"><conditionExpression xsi:type="bpmn:tFormalExpression">patient has TIA or minor nondisabling stroke</conditionExpression></sequenceFlow></process>
