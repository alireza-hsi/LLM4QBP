    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_29" sourceRef="activity12" targetRef="inclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_30" name="patient presents with features indicating dysphagia or pulmonary aspiration" sourceRef="inclusivegateway1" targetRef="activity13">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">patient presents with features indicating dysphagia or pulmonary aspiration</ns0:conditionExpression>
    </ns0:sequenceFlow>
