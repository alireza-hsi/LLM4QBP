<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_50</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1_1" name="identify suspected TIA or minor stroke presentation (Role: EMS or triage nurse; Objects: patient)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_2" name="initiate standardized stroke/TIA pathway (Role: EMS or triage nurse; Objects: triage tool, stroke/TIA pathway)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2" name="prenotify receiving hospital and stroke team when patient is arriving by ambulance (Role: EMS; Objects: stroke/TIA patient information)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3_1" name="assess airway (Role: clinician; Objects: airway)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3_2" name="assess breathing and circulation (Role: clinician; Objects: breathing, circulation)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="perform neurological examination and assess stroke severity on a standardized stroke scale (Role: clinician; Objects: focal neurological deficits, NIHSS or CNS)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
      <ns0:outgoing>Flow_19</ns0:outgoing>
      <ns0:outgoing>Flow_20</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity5" name="perform brain imaging immediately (Role: imaging team; Objects: CT or MRI)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="interpret brain imaging immediately (Role: qualified imaging provider; Objects: CT or MRI results)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6_1" name="defer chest x-ray if needed so it does not delay thrombolysis assessment (Role: clinical staff; Objects: chest x-ray, thrombolysis assessment)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="perform electrocardiogram (Role: clinical staff; Objects: ECG)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8_1" name="obtain and process core blood work (Role: laboratory staff; Objects: CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity8_2" name="obtain and process troponin test (Role: laboratory staff; Objects: troponin test)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8_3" name="document that troponin test is not required (Role: clinical staff; Objects: clinical indication assessment)">
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_16</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_47</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_47</ns0:incoming>
      <ns0:outgoing>Flow_43</ns0:outgoing>
      <ns0:outgoing>Flow_45</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity10" name="make patient NPO initially (Role: clinical staff; Objects: oral medication, fluid, food restrictions)">
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11" name="screen swallowing ability during initial assessment and before initiating oral medication, fluid, or food (Role: clinical staff; Objects: bedside swallowing screening protocol)">
      <ns0:incoming>Flow_27</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <ns0:incoming>Flow_32</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
      <ns0:outgoing>Flow_30</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity12" name="monitor closely and screen swallowing ability when clinically appropriate (Role: clinical staff; Objects: neurological status, swallowing ability)">
      <ns0:incoming>Flow_28</ns0:incoming>
      <ns0:outgoing>Flow_29</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13" name="perform full clinical assessment of swallowing ability and advise required consistency of diet and fluids (Role: speech-language pathologist or appropriately trained specialist; Objects: swallowing ability, diet consistency, fluid consistency)">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <ns0:incoming>Flow_29</ns0:incoming>
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_44</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity14_1" name="apply standardized TIA triage criteria (Role: clinician; Objects: TIA triage tool)">
      <ns0:incoming>Flow_34</ns0:incoming>
      <ns0:outgoing>Flow_35</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity14_2" name="determine the appropriate location for care (Role: clinician; Objects: triage decision)">
      <ns0:incoming>Flow_35</ns0:incoming>
      <ns0:outgoing>Flow_42</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <ns0:incoming>Flow_42</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
      <ns0:outgoing>Flow_38</ns0:outgoing>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity15" name="perform immediate vascular imaging of the neck arteries (Role: imaging team; Objects: carotid ultrasound or CTA or MRA)">
      <ns0:incoming>Flow_36</ns0:incoming>
      <ns0:outgoing>Flow_37</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity16" name="document that immediate neck artery vascular imaging is not required because patient is clearly not a candidate for carotid artery revascularization (Role: clinician; Objects: revascularization candidacy assessment)">
      <ns0:incoming>Flow_38</ns0:incoming>
      <ns0:outgoing>Flow_39</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17" name="perform vascular imaging as soon as possible (Role: imaging team; Objects: brain and neck arteries imaging)">
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:outgoing>Flow_41</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:incoming>Flow_39</ns0:incoming>
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_46</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:incoming>Flow_46</ns0:incoming>
      <ns0:outgoing>Flow_48</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity18_1" name="provide secondary prevention assessments (Role: clinical team; Objects: cross-continuum secondary prevention assessment)">
      <ns0:incoming>Flow_48</ns0:incoming>
      <ns0:outgoing>Flow_49</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18_2" name="initiate secondary prevention therapies (Role: clinical team; Objects: cross-continuum secondary prevention therapies)">
      <ns0:incoming>Flow_49</ns0:incoming>
      <ns0:outgoing>Flow_50</ns0:outgoing>
    </ns0:task>
