      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="screen swallowing ability during initial assessment and before initiating oral medication, fluid, or food (Role: clinical staff; Objects: bedside swallowing screening protocol)">
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:outgoing>Flow_32</bpmn:outgoing>
