      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6_1" name="defer chest x-ray if needed so it does not delay thrombolysis assessment (Role: clinical staff; Objects: chest x-ray, thrombolysis assessment)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="perform electrocardiogram (Role: clinical staff; Objects: ECG)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
