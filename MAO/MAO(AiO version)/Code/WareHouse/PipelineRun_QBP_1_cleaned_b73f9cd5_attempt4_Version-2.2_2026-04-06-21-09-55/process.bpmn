  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_50</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1_1" name="identify suspected TIA or minor stroke presentation (Role: EMS or triage nurse; Objects: patient)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity1_2" name="initiate standardized stroke/TIA pathway (Role: EMS or triage nurse; Objects: triage tool, stroke/TIA pathway)">
