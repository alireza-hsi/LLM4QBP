      <bpmn:outgoing>Flow_37</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity16" name="document that immediate neck artery vascular imaging is not required because patient is clearly not a candidate for carotid artery revascularization (Role: clinician; Objects: revascularization candidacy assessment)">
