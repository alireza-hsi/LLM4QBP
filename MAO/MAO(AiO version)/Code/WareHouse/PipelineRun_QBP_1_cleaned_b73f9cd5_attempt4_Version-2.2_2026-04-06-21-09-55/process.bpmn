      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="prenotify receiving hospital and stroke team when patient is arriving by ambulance (Role: EMS; Objects: stroke/TIA patient information)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3_1" name="assess airway (Role: clinician; Objects: airway)">
