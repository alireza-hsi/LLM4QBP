      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3_2" name="assess breathing and circulation (Role: clinician; Objects: breathing, circulation)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="perform neurological examination and assess stroke severity on a standardized stroke scale (Role: clinician; Objects: focal neurological deficits, NIHSS or CNS)">
