<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_37</incoming>
    </endEvent>
    <task id="activity1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_36</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_36</incoming>
      <outgoing>Flow_18</outgoing>
      <outgoing>Flow_19</outgoing>
      <outgoing>Flow_20</outgoing>
      <outgoing>Flow_21</outgoing>
      <outgoing>Flow_22</outgoing>
      <outgoing>Flow_23</outgoing>
      <outgoing>Flow_24</outgoing>
      <outgoing>Flow_25</outgoing>
      <outgoing>Flow_26</outgoing>
    </parallelGateway>
    <task id="activity2" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_18</incoming>
      <outgoing>Flow_27</outgoing>
    </task>
    <task id="activity3-1" name="Determine imaging modality (CT or MRI) (Role: medical staff; Objects: patient)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
    </task>
    <task id="activity3-2" name="Transport patient to imaging suite (Role: medical staff; Objects: patient)">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <task id="activity3" name="Immediate brain imaging (CT or MRI)">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_6</outgoing>
    </task>
    <task id="activity4" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_28</outgoing>
    </task>
    <task id="activity5" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_29</outgoing>
    </task>
    <task id="activity6" name="Blood work: CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_30</outgoing>
    </task>
    <task id="activity7" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_31</outgoing>
    </task>
    <task id="activity8" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_13</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_9</outgoing>
      <outgoing>Flow_11</outgoing>
    </exclusiveGateway>
    <task id="activity9" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_9</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <task id="activity10" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_10</incoming>
      <incoming>Flow_12</incoming>
      <outgoing>Flow_32</outgoing>
    </exclusiveGateway>
    <task id="activity11" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies (All patients, whether admitted or discharged from the ED)">
      <incoming>Flow_24</incoming>
      <outgoing>Flow_33</outgoing>
    </task>
    <task id="activity12" name="Use a standard triage tool to determine the appropriate location for the care of patients (Patients with TIA)">
      <incoming>Flow_25</incoming>
      <outgoing>Flow_34</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_26</incoming>
      <outgoing>Flow_14</outgoing>
      <outgoing>Flow_16</outgoing>
    </exclusiveGateway>
    <task id="activity13" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_15</outgoing>
    </task>
    <task id="activity14" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_15</incoming>
      <incoming>Flow_17</incoming>
      <outgoing>Flow_35</outgoing>
    </exclusiveGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_27</incoming>
      <incoming>Flow_28</incoming>
      <incoming>Flow_29</incoming>
      <incoming>Flow_30</incoming>
      <incoming>Flow_31</incoming>
      <incoming>Flow_32</incoming>
      <incoming>Flow_33</incoming>
      <incoming>Flow_34</incoming>
      <incoming>Flow_35</incoming>
      <outgoing>Flow_37</outgoing>
    </parallelGateway>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <sequenceFlow id="Flow_4" sourceRef="activity3-1" targetRef="activity3-2" />
    <sequenceFlow id="Flow_5" sourceRef="activity3-2" targetRef="activity3" />
    <sequenceFlow id="Flow_6" sourceRef="activity3" targetRef="activity4" />
    <sequenceFlow id="Flow_9" name="Patient not alert within first 24 hours" sourceRef="exclusivegateway1" targetRef="activity9">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient not alert within first 24 hours</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_10" sourceRef="activity9" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_11" name="Patient presents with features indicating dysphagia or pulmonary aspiration" sourceRef="exclusivegateway1" targetRef="activity10">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents with features indicating dysphagia or pulmonary aspiration</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_12" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_13" sourceRef="activity8" targetRef="exclusivegateway1" />
    <sequenceFlow id="Flow_14" name="Patient with TIA or minor (nondisabling) stroke presents within 48 hours of symptom onset or with fluctuating motor or speech symptoms" sourceRef="exclusivegateway2" targetRef="activity13">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient with TIA or minor (nondisabling) stroke presents within 48 hours of symptom onset or with fluctuating motor or speech symptoms</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_15" sourceRef="activity13" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_16" name="Patient presents beyond 48 hours with TIA or ischemic stroke" sourceRef="exclusivegateway2" targetRef="activity14">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents beyond 48 hours with TIA or ischemic stroke</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_17" sourceRef="activity14" targetRef="exclusivegateway2Join" />
