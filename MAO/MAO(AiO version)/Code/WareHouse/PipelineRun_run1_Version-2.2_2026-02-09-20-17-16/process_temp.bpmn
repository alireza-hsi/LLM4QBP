<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="true" name="Stroke Process"><bpmn:startEvent id="StartEvent_1" name="Start"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:endEvent id="EndEvent_1" name="End"><bpmn:incoming>Flow_44</bpmn:incoming></bpmn:endEvent><bpmn:task id="activity1" name="Establish hip fracture care pathway specifying perioperative patient goals by day of stay (Role: hospital administration; Objects: hip fracture care pathway documentation)"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_43</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway"><bpmn:outgoing>Flow_37</bpmn:outgoing><bpmn:outgoing>Flow_39</bpmn:outgoing><bpmn:outgoing>Flow_41</bpmn:outgoing><bpmn:incoming>Flow_43</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="dummy_Flow_2" name="(dummy branch entry)"><bpmn:outgoing>Flow_3</bpmn:outgoing><bpmn:incoming>Flow_37</bpmn:incoming></bpmn:task><bpmn:task id="activity2" name="Assess suspected hip fracture patient within 1 hour of arrival (Role: ED physician; Objects: patient, assessment tools)"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:task><bpmn:task id="activity3" name="Notify orthopedic surgeon for consultation within 2 hours of arrival (Role: ED staff; Objects: patient, orthopedic consultation request)"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway"><bpmn:outgoing>Flow_5</bpmn:outgoing><bpmn:outgoing>Flow_7</bpmn:outgoing><bpmn:incoming>Flow_9</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="activity4" name="Notify anesthesiologist/internist for consultation as needed (Role: ED staff; Objects: patient, consultation request)"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="activity4-2" name="No notification to anesthesiologist/internist required (Role: ED staff; Objects: patient)"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_20</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:parallelGateway id="parallelgateway2a" name="Parallel Gateway"><bpmn:outgoing>Flow_10</bpmn:outgoing><bpmn:outgoing>Flow_11</bpmn:outgoing><bpmn:outgoing>Flow_12</bpmn:outgoing><bpmn:outgoing>Flow_13</bpmn:outgoing><bpmn:outgoing>Flow_14</bpmn:outgoing><bpmn:incoming>Flow_20</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity5-1a" name="Assess and document clinical factors (reason for fall, fluid balance, pressure sore risk, hydration, nutrition, pain, temperature, collateral injuries) (Role: ED clinical staff; Objects: assessment forms, diagnostic tools)"><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:outgoing>Flow_15</bpmn:outgoing></bpmn:task><bpmn:task id="activity5-2a" name="Order and review diagnostics (blood work, X-rays) (Role: ED clinical staff; Objects: order forms, diagnostic results)"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_16</bpmn:outgoing></bpmn:task><bpmn:task id="activity5-3a" name="Assess and document comorbid conditions and current drug therapy (including anticoagulants) (Role: ED clinical staff; Objects: assessment forms, medication list)"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_17</bpmn:outgoing></bpmn:task><bpmn:task id="activity5-4a" name="Assess and document functional, mental, and social status (continence, pre-fracture functional ability and mobility, physical and functional level, mental state, social circumstances) (Role: ED clinical staff; Objects: assessment forms, screening tools)"><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:outgoing>Flow_18</bpmn:outgoing></bpmn:task><bpmn:task id="activity6a" name="Complete medication reconciliation using standardized form (Role: ED clinical staff; Objects: medication list, standardized form)"><bpmn:incoming>Flow_14</bpmn:incoming><bpmn:outgoing>Flow_19</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway2aJoin" name="Parallel Merge"><bpmn:incoming>Flow_15</bpmn:incoming><bpmn:incoming>Flow_16</bpmn:incoming><bpmn:incoming>Flow_17</bpmn:incoming><bpmn:incoming>Flow_18</bpmn:incoming><bpmn:incoming>Flow_19</bpmn:incoming><bpmn:outgoing>Flow_27</bpmn:outgoing></bpmn:parallelGateway><bpmn:parallelGateway id="parallelgateway2b" name="Parallel Gateway"><bpmn:outgoing>Flow_21</bpmn:outgoing><bpmn:outgoing>Flow_22</bpmn:outgoing><bpmn:outgoing>Flow_23</bpmn:outgoing><bpmn:incoming>Flow_27</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity7-1b" name="Manage hydration and pain (Role: ED clinical staff; Objects: patient, management protocols)"><bpmn:incoming>Flow_21</bpmn:incoming><bpmn:outgoing>Flow_24</bpmn:outgoing></bpmn:task><bpmn:task id="activity7-2b" name="Implement delirium prevention measures (Role: ED clinical staff; Objects: patient, delirium prevention protocols)"><bpmn:incoming>Flow_22</bpmn:incoming><bpmn:outgoing>Flow_25</bpmn:outgoing></bpmn:task><bpmn:task id="activity7-3b" name="Implement pressure sore prevention measures (Role: ED clinical staff; Objects: patient, pressure sore prevention protocols)"><bpmn:incoming>Flow_23</bpmn:incoming><bpmn:outgoing>Flow_26</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway2bJoin" name="Parallel Merge"><bpmn:incoming>Flow_24</bpmn:incoming><bpmn:incoming>Flow_25</bpmn:incoming><bpmn:incoming>Flow_26</bpmn:incoming><bpmn:outgoing>Flow_28</bpmn:outgoing></bpmn:parallelGateway><bpmn:task id="activity8" name="Admit patient to inpatient care within 4 hours of ED arrival (target: 90% of patients) (Role: ED staff; Objects: admission documentation, patient)"><bpmn:incoming>Flow_28</bpmn:incoming><bpmn:outgoing>Flow_38</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_29" name="(dummy branch entry)"><bpmn:outgoing>Flow_30</bpmn:outgoing><bpmn:incoming>Flow_39</bpmn:incoming></bpmn:task><bpmn:task id="activity9" name="Medically stabilize patient while awaiting transfer to surgical hospital (Role: non-surgical hospital clinical staff; Objects: patient, stabilization protocols)"><bpmn:incoming>Flow_30</bpmn:incoming><bpmn:outgoing>Flow_31</bpmn:outgoing></bpmn:task><bpmn:task id="activity10" name="Initiate formal protocol for timely transfer to surgical hospital for operation (Role: non-surgical hospital administration; Objects: transfer protocol, patient)"><bpmn:incoming>Flow_31</bpmn:incoming><bpmn:outgoing>Flow_32</bpmn:outgoing></bpmn:task><bpmn:task id="activity11" name="Ensure surgery is performed within 48 hours of initial presentation (Role: surgical hospital staff; Objects: patient, surgical scheduling)"><bpmn:incoming>Flow_32</bpmn:incoming><bpmn:outgoing>Flow_33</bpmn:outgoing></bpmn:task><bpmn:task id="activity12" name="Ensure repatriation to local hospital post-surgery as per protocol (Role: LHINs and hospitals; Objects: patient, repatriation protocol)"><bpmn:incoming>Flow_33</bpmn:incoming><bpmn:outgoing>Flow_40</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_34" name="(dummy branch entry)"><bpmn:outgoing>Flow_35</bpmn:outgoing><bpmn:incoming>Flow_41</bpmn:incoming></bpmn:task><bpmn:task id="activity13" name="Follow same assessment, documentation, and management practices as ED pathway (Role: clinical staff; Objects: assessment forms, management protocols)"><bpmn:incoming>Flow_35</bpmn:incoming><bpmn:outgoing>Flow_36</bpmn:outgoing></bpmn:task><bpmn:task id="activity14" name="Ensure timely consultation and admission as per ED standards (Role: clinical staff; Objects: consultation request, admission documentation)"><bpmn:incoming>Flow_36</bpmn:incoming><bpmn:outgoing>Flow_42</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge"><bpmn:incoming>Flow_38</bpmn:incoming><bpmn:incoming>Flow_40</bpmn:incoming><bpmn:incoming>Flow_42</bpmn:incoming><bpmn:outgoing>Flow_44</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" /><bpmn:sequenceFlow id="Flow_3" sourceRef="dummy_Flow_2" targetRef="activity2" /><bpmn:sequenceFlow id="Flow_4" sourceRef="activity2" targetRef="activity3" /><bpmn:sequenceFlow id="Flow_5" sourceRef="exclusivegateway2" targetRef="activity4" name="Anesthesiologist/internist consultation is needed"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Anesthesiologist/internist consultation is needed</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_6" sourceRef="activity4" targetRef="exclusivegateway2Join" /><bpmn:sequenceFlow id="Flow_7" sourceRef="exclusivegateway2" targetRef="activity4-2" name="Anesthesiologist/internist consultation is not needed"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Anesthesiologist/internist consultation is not needed</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_8" sourceRef="activity4-2" targetRef="exclusivegateway2Join" /><bpmn:sequenceFlow id="Flow_9" sourceRef="activity3" targetRef="exclusivegateway2" /><bpmn:sequenceFlow id="Flow_10" sourceRef="parallelgateway2a" targetRef="activity5-1a" /><bpmn:sequenceFlow id="Flow_11" sourceRef="parallelgateway2a" targetRef="activity5-2a" /><bpmn:sequenceFlow id="Flow_12" sourceRef="parallelgateway2a" targetRef="activity5-3a" /><bpmn:sequenceFlow id="Flow_13" sourceRef="parallelgateway2a" targetRef="activity5-4a" /><bpmn:sequenceFlow id="Flow_14" sourceRef="parallelgateway2a" targetRef="activity6a" /><bpmn:sequenceFlow id="Flow_15" sourceRef="activity5-1a" targetRef="parallelgateway2aJoin" /><bpmn:sequenceFlow id="Flow_16" sourceRef="activity5-2a" targetRef="parallelgateway2aJoin" /><bpmn:sequenceFlow id="Flow_17" sourceRef="activity5-3a" targetRef="parallelgateway2aJoin" /><bpmn:sequenceFlow id="Flow_18" sourceRef="activity5-4a" targetRef="parallelgateway2aJoin" /><bpmn:sequenceFlow id="Flow_19" sourceRef="activity6a" targetRef="parallelgateway2aJoin" /><bpmn:sequenceFlow id="Flow_20" sourceRef="exclusivegateway2Join" targetRef="parallelgateway2a" /><bpmn:sequenceFlow id="Flow_21" sourceRef="parallelgateway2b" targetRef="activity7-1b" /><bpmn:sequenceFlow id="Flow_22" sourceRef="parallelgateway2b" targetRef="activity7-2b" /><bpmn:sequenceFlow id="Flow_23" sourceRef="parallelgateway2b" targetRef="activity7-3b" /><bpmn:sequenceFlow id="Flow_24" sourceRef="activity7-1b" targetRef="parallelgateway2bJoin" /><bpmn:sequenceFlow id="Flow_25" sourceRef="activity7-2b" targetRef="parallelgateway2bJoin" /><bpmn:sequenceFlow id="Flow_26" sourceRef="activity7-3b" targetRef="parallelgateway2bJoin" /><bpmn:sequenceFlow id="Flow_27" sourceRef="parallelgateway2aJoin" targetRef="parallelgateway2b" /><bpmn:sequenceFlow id="Flow_28" sourceRef="parallelgateway2bJoin" targetRef="activity8" /><bpmn:sequenceFlow id="Flow_30" sourceRef="dummy_Flow_29" targetRef="activity9" /><bpmn:sequenceFlow id="Flow_31" sourceRef="activity9" targetRef="activity10" /><bpmn:sequenceFlow id="Flow_32" sourceRef="activity10" targetRef="activity11" /><bpmn:sequenceFlow id="Flow_33" sourceRef="activity11" targetRef="activity12" /><bpmn:sequenceFlow id="Flow_35" sourceRef="dummy_Flow_34" targetRef="activity13" /><bpmn:sequenceFlow id="Flow_36" sourceRef="activity13" targetRef="activity14" /><bpmn:sequenceFlow id="Flow_37" sourceRef="exclusivegateway1" targetRef="dummy_Flow_2" name="Patient presents to ED"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to ED</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_38" sourceRef="activity8" targetRef="exclusivegateway1Join" /><bpmn:sequenceFlow id="Flow_39" sourceRef="exclusivegateway1" targetRef="dummy_Flow_29" name="Patient presents to non-surgical hospital"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to non-surgical hospital</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_40" sourceRef="activity12" targetRef="exclusivegateway1Join" /><bpmn:sequenceFlow id="Flow_41" sourceRef="exclusivegateway1" targetRef="dummy_Flow_34" name="Patient presents to outpatient clinic or is directly admitted to acute care"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to outpatient clinic or is directly admitted to acute care</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_42" sourceRef="activity14" targetRef="exclusivegateway1Join" /><bpmn:sequenceFlow id="Flow_43" sourceRef="activity1" targetRef="exclusivegateway1" /><bpmn:sequenceFlow id="Flow_44" sourceRef="exclusivegateway1Join" targetRef="EndEvent_1" /></bpmn:process></bpmn:definitions>