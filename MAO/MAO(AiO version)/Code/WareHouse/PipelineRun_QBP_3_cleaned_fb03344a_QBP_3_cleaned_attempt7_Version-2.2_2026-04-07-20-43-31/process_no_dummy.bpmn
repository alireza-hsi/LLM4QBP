      <ns0:outgoing>Flow_70</ns0:outgoing>
      <ns0:outgoing>Flow_72</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity5" name="forward ED screening and assessment results for diabetes, dental issues, cognitive impairment, and depression to the TIA clinic for follow-up (Role: emergency department clinicians; Objects: screening results, TIA clinic referral information)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
