  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_75</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="identify patient with stroke or TIA presentation and determine care pathway (Role: emergency department clinicians; Objects: admission decision, stroke or TIA presentation)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="screen upon ED presentation for diabetes, dental issues, cognitive impairment, and depression (Role: emergency department clinicians; Objects: screening results)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_74</ns0:outgoing>
    </ns0:task>
