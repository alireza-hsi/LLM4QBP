      <incoming>Flow_56</incoming><incoming>Flow_58</incoming><outgoing>Flow_61</outgoing></exclusiveGateway>
    <task id="activity23" name="continue routine nutrition and hydration monitoring (Role: stroke unit team; Objects: nutrition and hydration monitoring plan)">
      <incoming>Flow_62</incoming><outgoing>Flow_63</outgoing></task>
