    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_63</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="identify patient as acute stroke admission candidate and confirm that Module 3a pathway applies rather than TIA or minor nondisabling stroke pathway (Role: emergency department clinician; Objects: stroke diagnosis, admission criteria)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity2" name="admit patient to a specialized geographically defined stroke unit (Role: admitting team; Objects: co-located stroke unit bed)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13" name="screen or assess for diabetes, dental issues, cognitive impairment, and depression upon presentation and forward results to the TIA clinic for follow-up (Role: emergency department clinician; Objects: screening results, TIA clinic communication)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="redirect patient to applicable TIA or minor stroke process because Module 3a recommendations are not applicable (Role: clinical team; Objects: alternative care pathway)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
