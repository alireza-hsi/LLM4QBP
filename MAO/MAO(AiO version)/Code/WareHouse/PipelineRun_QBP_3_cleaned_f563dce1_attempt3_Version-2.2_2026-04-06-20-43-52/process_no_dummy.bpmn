      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity4_1" name="assign patient to stroke medicine and nursing coverage (Role: stroke unit coordinator; Objects: stroke unit bed assignment, medicine coverage, nursing coverage)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4_2" name="arrange access to allied health and nutrition members of the stroke team (Role: stroke unit coordinator; Objects: occupational therapy, physiotherapy, speech-language pathology, social work, dietitian services, 7 day access)">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="ensure core stroke unit team members spend the vast majority of their time treating stroke patients and regularly complete stroke care education (Role: stroke unit leadership; Objects: staffing model, stroke education records)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
