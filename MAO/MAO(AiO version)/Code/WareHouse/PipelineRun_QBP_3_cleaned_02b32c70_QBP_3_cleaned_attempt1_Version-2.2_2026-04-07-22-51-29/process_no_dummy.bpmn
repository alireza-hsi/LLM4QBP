      <ns0:outgoing>Flow_4</ns0:outgoing>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="act17_1" name="screen the patient upon ED presentation for diabetes (Role: ED clinicians; Objects: diabetes screening result)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act17_2" name="screen the patient upon ED presentation for dental issues (Role: ED clinicians; Objects: dental screening result)">
