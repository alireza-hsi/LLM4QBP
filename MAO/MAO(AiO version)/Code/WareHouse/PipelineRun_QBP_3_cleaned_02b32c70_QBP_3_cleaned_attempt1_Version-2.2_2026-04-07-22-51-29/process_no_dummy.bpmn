  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_83</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="act1" name="identify the admitted patient as acute stroke, admitted TIA, or minor nondisabling stroke and initiate acute care admission (Role: ED and admitting clinician; Objects: admission data, stroke diagnosis, severity information)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="pg2" name="Parallel Gateway">
