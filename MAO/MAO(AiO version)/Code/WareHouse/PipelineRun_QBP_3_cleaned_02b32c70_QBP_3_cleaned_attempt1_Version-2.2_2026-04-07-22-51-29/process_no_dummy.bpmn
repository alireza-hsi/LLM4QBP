    </ns0:exclusiveGateway>
    <ns0:task id="act2" name="admit the patient to a specialized geographically defined stroke unit dedicated to stroke management (Role: admitting clinician and bed manager; Objects: co located stroke unit beds occupied by stroke patients at least 75 percent of the time)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_69</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="pg1" name="Parallel Gateway">
      <ns0:incoming>Flow_69</ns0:incoming>
      <ns0:outgoing>Flow_59</ns0:outgoing>
      <ns0:outgoing>Flow_60</ns0:outgoing>
      <ns0:outgoing>Flow_61</ns0:outgoing>
      <ns0:outgoing>Flow_62</ns0:outgoing>
      <ns0:outgoing>Flow_63</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="act3" name="assign the core stroke unit team with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech language pathology, social work, and clinical nutrition (Role: stroke unit coordinator; Objects: stroke unit team roster)">
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_16</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act4" name="ensure core team members spend the vast majority of their time treating stroke patients and regularly complete stroke care education (Role: stroke unit coordinator; Objects: staff competency and education records)">
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act5" name="ensure access to the specialized interprofessional stroke team and adequate staffing 7 days per week (Role: hospital and stroke unit manager; Objects: 7 day staffing schedule)">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_64</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act6" name="use standardized valid assessment tools, preferably electronic tools linked to the EHR, to evaluate stroke related impairments and functional status (Role: clinicians; Objects: standardized assessment tools, EHR)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act7" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day as day 1 (Role: clinicians; Objects: AlphaFIM assessment)">
      <ns0:incoming>Flow_20</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act8" name="assess the patient for risk of developing venous thromboembolism (Role: clinicians; Objects: venous thromboembolism risk assessment)">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:outgoing>Flow_65</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="pg_act9_1" name="Parallel Gateway">
      <ns0:incoming>Flow_29</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
      <ns0:outgoing>Flow_24</ns0:outgoing>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="act9_1" name="perform a physiotherapy assessment within 48 hours of hospital admission (Role: physiotherapist; Objects: physiotherapy assessment findings)">
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act9_2" name="perform a speech language pathology assessment within 48 hours of hospital admission (Role: speech language pathologist; Objects: speech language pathology assessment findings)">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act9_3" name="perform an occupational therapy assessment within 48 hours of hospital admission (Role: occupational therapist; Objects: occupational therapy assessment findings)">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
    </ns0:task>
