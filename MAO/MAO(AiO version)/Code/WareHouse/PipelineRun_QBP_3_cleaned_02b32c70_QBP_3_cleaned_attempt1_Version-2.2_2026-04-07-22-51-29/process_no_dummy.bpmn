      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act17_3" name="screen the patient upon ED presentation for cognitive impairment (Role: ED clinicians; Objects: cognitive screening result)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="act17_4" name="screen the patient upon ED presentation for depression (Role: ED clinicians; Objects: depression screening result)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
