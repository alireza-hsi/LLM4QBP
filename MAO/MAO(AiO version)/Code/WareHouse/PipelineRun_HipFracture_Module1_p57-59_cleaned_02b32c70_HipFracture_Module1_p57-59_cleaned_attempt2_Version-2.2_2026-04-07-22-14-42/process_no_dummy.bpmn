      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17_2" name="reconcile and document medications within the ED using a standardized form (Role: pharmacist and ED nurse; Objects: standardized medication reconciliation form)">
      <ns0:incoming>Flow_18</ns0:incoming>
      <ns0:outgoing>Flow_35</ns0:outgoing>
    </ns0:task>
