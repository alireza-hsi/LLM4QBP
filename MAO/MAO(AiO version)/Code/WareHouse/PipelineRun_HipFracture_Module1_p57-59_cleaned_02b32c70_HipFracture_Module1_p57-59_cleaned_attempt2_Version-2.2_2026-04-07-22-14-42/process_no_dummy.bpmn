    </ns0:inclusiveGateway>
    <ns0:task id="activity14" name="assess and document fluid balance, hydration and nutrition, pain, temperature, continence, and pressure sore risk while the patient is in the ED (Role: ED nurse; Objects: nursing assessment record)">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15_1" name="perform appropriate blood work tests while the patient is in the ED (Role: laboratory staff; Objects: blood specimens and laboratory requests)">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
