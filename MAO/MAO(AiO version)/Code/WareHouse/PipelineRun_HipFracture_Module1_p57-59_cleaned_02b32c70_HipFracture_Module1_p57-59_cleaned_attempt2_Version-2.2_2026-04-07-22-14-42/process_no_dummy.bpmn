    </ns0:exclusiveGateway>
    <ns0:task id="activity20" name="admit 90% of patients to inpatient care within 4 hours spent in the ED or equivalent acute presentation period (Role: admitting team; Objects: inpatient bed and admission orders)">
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_42</ns0:outgoing>
    </ns0:task>
