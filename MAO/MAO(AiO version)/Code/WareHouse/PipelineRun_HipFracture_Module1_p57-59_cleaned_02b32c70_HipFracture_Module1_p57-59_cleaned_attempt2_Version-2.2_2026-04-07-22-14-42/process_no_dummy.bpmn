      <ns0:outgoing>Flow_60</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity22" name="medically stabilize the patient while waiting for expeditious transfer to a surgical hospital for operation (Role: ED and medical team; Objects: stabilization measures)">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:outgoing>Flow_56</ns0:outgoing>
