    <ns0:task id="activity4" name="see 90% of suspected hip fracture patients within 1 hour of arrival or presentation (Role: emergency physician; Objects: patient)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="assess and document reason for the fall, other collateral injuries, comorbid conditions, and current drug therapy including any anticoagulants while the patient is in the ED (Role: emergency physician; Objects: assessment record)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="make anesthesiology and internal medicine services aware of the patient (Role: emergency physician; Objects: consultation notification)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:task>
