    </ns0:endEvent>
    <ns0:task id="activity1" name="maintain a hip fracture care pathway that clearly specifies perioperative patient goals by day of stay (Role: hospital; Objects: hip fracture care pathway)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2" name="ensure all non-surgical hospitals have formal protocols for timely transfer to surgical hospitals for surgery followed by repatriation to local hospitals (Role: LHINs and hospitals; Objects: transfer and repatriation protocols)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3_1" name="receive suspected hip fracture patient presenting through the ED, outpatient clinic, or direct acute admission and document presentation details (Role: triage nurse; Objects: patient record)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3_2" name="activate the hip fracture care pathway and notify the ED team (Role: triage nurse; Objects: hip fracture care pathway and care team notification)">
