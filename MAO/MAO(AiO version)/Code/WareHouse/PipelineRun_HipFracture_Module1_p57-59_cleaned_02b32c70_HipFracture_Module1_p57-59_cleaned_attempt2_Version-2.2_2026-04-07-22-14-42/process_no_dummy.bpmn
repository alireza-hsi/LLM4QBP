    <ns0:task id="activity13" name="provide consultation for 90% of suspected hip fracture patients within 2 hours of arrival or presentation once x-rays and key initial ED assessment data are available (Role: orthopedic surgeon; Objects: patient, x-rays, and key initial ED assessment data)">
      <ns0:incoming>Flow_38</ns0:incoming>
      <ns0:outgoing>Flow_39</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity19" name="integrate and document all ED assessment and diagnostic findings to inform treatment decisions, pathway trajectory, discharge planning to the most appropriate setting, and baseline performance measurement (Role: ED team; Objects: consolidated ED assessment record)">
      <ns0:incoming>Flow_39</ns0:incoming>
      <ns0:outgoing>Flow_63</ns0:outgoing>
    </ns0:task>
