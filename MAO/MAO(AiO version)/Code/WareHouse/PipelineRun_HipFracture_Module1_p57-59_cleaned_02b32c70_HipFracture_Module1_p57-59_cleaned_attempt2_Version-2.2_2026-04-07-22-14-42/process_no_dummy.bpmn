      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18_2" name="implement measures to reduce the risk of delirium and pressure sores within the ED (Role: ED team; Objects: delirium prevention measures and pressure sore prevention measures)">
