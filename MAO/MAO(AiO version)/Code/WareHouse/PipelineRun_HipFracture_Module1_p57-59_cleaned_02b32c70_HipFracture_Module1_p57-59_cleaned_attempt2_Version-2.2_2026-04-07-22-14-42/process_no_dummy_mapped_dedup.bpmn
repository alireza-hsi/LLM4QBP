    <task id="activity24_1" name="expeditious transfer to a surgical hospital for operation based on formal protocol">
      <incoming>Flow_47</incoming><outgoing>Flow_53</outgoing></task>
    <task id="activity24_3" name="expeditious transfer to a surgical hospital for operation based on formal protocol">
