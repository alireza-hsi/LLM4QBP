  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_64</incoming></endEvent>
    <task id="activity1" name="maintain a hip fracture care pathway that clearly specifies perioperative patient goals by day of stay (Role: hospital; Objects: hip fracture care pathway)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2" name="ensure all non-surgical hospitals have formal protocols for timely transfer to surgical hospitals for surgery followed by repatriation to local hospitals (Role: LHINs and hospitals; Objects: transfer and repatriation protocols)">
      <incoming>Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="activity3_1" name="receive suspected hip fracture patient presenting through the ED, outpatient clinic, or direct acute admission and document presentation details (Role: triage nurse; Objects: patient record)">
      <incoming>Flow_3</incoming><outgoing>Flow_4</outgoing></task>
    <task id="activity3_2" name="activate the hip fracture care pathway and notify the ED team (Role: triage nurse; Objects: hip fracture care pathway and care team notification)">
      <incoming>Flow_4</incoming><outgoing>Flow_37</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_37</incoming><outgoing>Flow_24</outgoing><outgoing>Flow_25</outgoing><outgoing>Flow_26</outgoing><outgoing>Flow_27</outgoing><outgoing>Flow_29</outgoing><outgoing>merged_Flow_23_Flow_6</outgoing><outgoing>merged_Flow_28_Flow_17</outgoing></parallelGateway>
    <task id="activity4" name="Seen by physician">
      <incoming>merged_Flow_23_Flow_6</incoming><outgoing>Flow_7</outgoing></task>
    <task id="activity5" name="assess and document reason for the fall, other collateral injuries, comorbid conditions, and current drug therapy including any anticoagulants while the patient is in the ED (Role: emergency physician; Objects: assessment record)">
      <incoming>Flow_7</incoming><outgoing>Flow_8</outgoing></task>
    <task id="activity6" name="make anesthesiology and internal medicine services aware of the patient (Role: emergency physician; Objects: consultation notification)">
      <incoming>Flow_8</incoming><outgoing>Flow_15</outgoing></task>
    <inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <incoming>Flow_15</incoming><outgoing>Flow_9</outgoing><outgoing>Flow_11</outgoing><outgoing>Flow_13</outgoing></inclusiveGateway>
    <task id="activity10" name="Consultation with anesthesiologists">
      <incoming>Flow_9</incoming><outgoing>Flow_10</outgoing></task>
    <task id="activity11" name="Consultation with internist">
      <incoming>Flow_11</incoming><outgoing>Flow_12</outgoing></task>
    <task id="activity12" name="document that no immediate additional anesthesiology or internal medicine consultation is required (Role: emergency physician; Objects: consultation record)">
      <incoming>Flow_13</incoming><outgoing>Flow_14</outgoing></task>
    <inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <incoming>Flow_10</incoming><incoming>Flow_12</incoming><incoming>Flow_14</incoming><outgoing>Flow_30</outgoing></inclusiveGateway>
    <task id="activity14" name="assess and document fluid balance, hydration and nutrition, pain, temperature, continence, and pressure sore risk while the patient is in the ED (Role: ED nurse; Objects: nursing assessment record)">
      <incoming>Flow_24</incoming><outgoing>Flow_31</outgoing></task>
    <task id="activity15_1" name="Issue appropriate blood work">
      <incoming>Flow_25</incoming><outgoing>Flow_32</outgoing></task>
    <task id="activity15_2" name="Perform x-ray">
      <incoming>Flow_26</incoming><outgoing>Flow_33</outgoing></task>
    <task id="activity16" name="assess and document pre-fracture functional ability and mobility, physical and functional level, mental state using a validated screening tool such as MMSE, MOCA, or CAM based on premorbid functioning, and social circumstances including caregiver status, existing community supports, and family involvement (Role: ED allied health team; Objects: functional, cognitive, and social assessment record)">
      <incoming>Flow_27</incoming><outgoing>Flow_34</outgoing></task>
    <task id="activity17_1" name="obtain and verify the best possible medication history including anticoagulants (Role: pharmacist and ED nurse; Objects: medication history)">
      <incoming>merged_Flow_28_Flow_17</incoming><outgoing>Flow_18</outgoing></task>
    <task id="activity17_2" name="Perform medication reconciliation within the ED">
      <incoming>Flow_18</incoming><outgoing>Flow_35</outgoing></task>
    <parallelGateway id="parallelgateway18_1" name="Parallel Gateway">
      <incoming>Flow_29</incoming><outgoing>Flow_19</outgoing><outgoing>Flow_20</outgoing></parallelGateway>
    <task id="activity18_1" name="manage hydration and pain within the ED (Role: ED team; Objects: hydration plan and analgesia)">
      <incoming>Flow_19</incoming><outgoing>Flow_21</outgoing></task>
    <task id="activity18_2" name="implement measures to reduce the risk of delirium and pressure sores within the ED (Role: ED team; Objects: delirium prevention measures and pressure sore prevention measures)">
      <incoming>Flow_20</incoming><outgoing>Flow_22</outgoing></task>
    <parallelGateway id="parallelgateway18_1Join" name="Parallel Merge">
      <incoming>Flow_21</incoming><incoming>Flow_22</incoming><outgoing>Flow_36</outgoing></parallelGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
