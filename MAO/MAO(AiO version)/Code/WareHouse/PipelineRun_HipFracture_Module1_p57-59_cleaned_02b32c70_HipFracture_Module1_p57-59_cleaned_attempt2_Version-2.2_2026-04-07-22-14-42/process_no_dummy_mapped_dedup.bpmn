      <incoming>Flow_53</incoming><incoming>Flow_55</incoming><outgoing>Flow_57</outgoing></exclusiveGateway>
    <task id="activity25" name="perform surgery within 48 hours of the initial presentation (Role: surgical hospital team; Objects: operative plan)">
      <incoming>Flow_57</incoming><outgoing>Flow_58</outgoing></task>
    <task id="activity26" name="repatriate the patient to the local hospital according to the formal protocol after surgery (Role: surgical hospital and local hospital teams; Objects: repatriation plan)">
      <incoming>Flow_58</incoming><outgoing>Flow_62</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
