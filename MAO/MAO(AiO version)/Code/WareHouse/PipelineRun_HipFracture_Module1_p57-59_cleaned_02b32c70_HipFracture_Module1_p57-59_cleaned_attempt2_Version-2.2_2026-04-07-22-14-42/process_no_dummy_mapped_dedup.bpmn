    <task id="activity13" name="Consultation with orthopaedic surgeon">
      <incoming>Flow_38</incoming><outgoing>Flow_39</outgoing></task>
    <task id="activity19" name="integrate and document all ED assessment and diagnostic findings to inform treatment decisions, pathway trajectory, discharge planning to the most appropriate setting, and baseline performance measurement (Role: ED team; Objects: consolidated ED assessment record)">
      <incoming>Flow_39</incoming><outgoing>Flow_63</outgoing></task>
