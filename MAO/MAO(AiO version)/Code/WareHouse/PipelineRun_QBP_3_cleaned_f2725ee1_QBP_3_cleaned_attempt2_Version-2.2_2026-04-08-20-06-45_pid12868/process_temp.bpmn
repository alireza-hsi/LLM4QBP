<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="true" name="Stroke Process"><bpmn:startEvent id="StartEvent_1" name="Start"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:endEvent id="EndEvent_1" name="End"><bpmn:incoming>Flow_91</bpmn:incoming></bpmn:endEvent><bpmn:task id="a1_1" name="confirm whether the presentation is (Role: admitting clinician; Objects: acute stroke or TIA/minor nondisabling stroke)"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:task id="a1_2" name="determine and document (Role: admitting clinician; Objects: stroke severity and Module 3a applicability)"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_90</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="eg1" name="Exclusive Gateway"><bpmn:outgoing>Flow_86</bpmn:outgoing><bpmn:outgoing>Flow_88</bpmn:outgoing><bpmn:incoming>Flow_90</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="dummy_Flow_3" name="(dummy branch entry)"><bpmn:outgoing>Flow_4</bpmn:outgoing><bpmn:incoming>Flow_86</bpmn:incoming></bpmn:task><bpmn:task id="a2" name="admit patient to a specialized geographically defined stroke unit (Role: hospital; Objects: identifiable co-located stroke unit beds occupied by stroke patients most of the time)"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task><bpmn:task id="a3" name="assemble the core stroke unit team with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (Role: stroke unit manager; Objects: interprofessional stroke unit team roster)"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="a4" name="verify that core stroke unit professionals spend the vast majority of their time treating stroke patients and regularly complete stroke care education (Role: stroke program; Objects: team expertise and stroke education records)"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:task id="a5" name="provide access to the specialized interprofessional stroke team 7 days a week (Role: hospital; Objects: 7 day stroke unit coverage)"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_70</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="pg1" name="Parallel Gateway"><bpmn:outgoing>Flow_60</bpmn:outgoing><bpmn:outgoing>Flow_61</bpmn:outgoing><bpmn:outgoing>Flow_62</bpmn:outgoing><bpmn:outgoing>Flow_63</bpmn:outgoing><bpmn:outgoing>Flow_64</bpmn:outgoing><bpmn:incoming>Flow_70</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="dummy_Flow_8" name="(dummy branch entry)"><bpmn:outgoing>Flow_15</bpmn:outgoing><bpmn:incoming>Flow_60</bpmn:incoming></bpmn:task><bpmn:parallelGateway id="pg1_1" name="Parallel Gateway"><bpmn:outgoing>Flow_9</bpmn:outgoing><bpmn:outgoing>Flow_10</bpmn:outgoing><bpmn:outgoing>Flow_11</bpmn:outgoing><bpmn:incoming>Flow_15</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="a6_1" name="assess patient within 48 hours of hospital admission (Role: physiotherapist; Objects: physiotherapy needs)"><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task><bpmn:task id="a6_2" name="assess patient within 48 hours of hospital admission (Role: speech-language pathologist; Objects: speech-language pathology needs)"><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:task><bpmn:task id="a6_3" name="assess patient within 48 hours of hospital admission (Role: occupational therapist; Objects: occupational therapy needs)"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_14</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="pg1_1Join" name="Parallel Merge"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:incoming>Flow_14</bpmn