      <incoming>Flow_48</incoming><outgoing>Flow_43</outgoing><outgoing>merged_Flow_41_Flow_28</outgoing></exclusiveGateway>
    <task id="activity14" name="patients be referred for evaluation at a specialized TIA/minor stroke clinic or alternatively an outpatient clinic with stroke-prevention servicesd within 24 hours of initial presentation">
      <incoming>merged_Flow_41_Flow_28</incoming><outgoing>Flow_29</outgoing></task>
    <task id="activity15" name="Brain CT scan">
      <incoming>Flow_29</incoming><outgoing>Flow_42</outgoing></task>
    <exclusiveGateway id="exclusivegateway6" name="Exclusive Gateway">
      <incoming>Flow_43</incoming><outgoing>merged_Flow_37_Flow_31</outgoing><outgoing>merged_Flow_39_Flow_34</outgoing></exclusiveGateway>
    <task id="activity16" name="such immediate care be provided at a specialized TIA/minor stroke clinic">
