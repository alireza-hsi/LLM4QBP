    <task id="activity1" name="activate standardized priority protocol for suspected TIA or minor stroke (Role: ED staff; Objects: suspected stroke pathway)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2" name="perform initial assessment and identify TIA or minor (nondisabling) stroke presentation (Role: ED staff; Objects: clinical history and examination)">
      <incoming>Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="activity3" name="measure random blood glucose (Role: ED staff; Objects: blood glucose value)">
      <incoming>Flow_3</incoming><outgoing>Flow_8</outgoing></task>
