    <task id="activity23" name="should be evaluated in the ED to be considered for admission to hospital">
      <incoming>Flow_53</incoming><outgoing>Flow_54</outgoing></task>
    <task id="activity24" name="continue ambulatory TIA or minor stroke management pathway (Role: ED physician; Objects: ongoing care plan)">
      <incoming>Flow_55</incoming><outgoing>Flow_56</outgoing></task>
