      <incoming>Flow_74</incoming><incoming>Flow_76</incoming><outgoing>Flow_78</outgoing></exclusiveGateway>
    <task id="activity33" name="Evaluate temperature as part of routine vital signs every 4 hours for first 48 hours">
      <incoming>Flow_78</incoming><outgoing>Flow_79</outgoing></task>
