      <incoming>Flow_14</incoming><outgoing>Flow_15</outgoing></task>
    <task id="activity9" name="document temperature in routine vital signs record (Role: ED staff; Objects: temperature and vital signs record)">
      <incoming>Flow_15</incoming><outgoing>Flow_26</outgoing></task>
