      <incoming>Flow_8</incoming><outgoing>Flow_4</outgoing><outgoing>Flow_6</outgoing></exclusiveGateway>
    <task id="activity4" name="Correct hypoglycemia immediately">
      <incoming>Flow_4</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity5" name="continue glucose management (Role: ED staff; Objects: blood glucose result)">
      <incoming>Flow_6</incoming><outgoing>Flow_7</outgoing></task>
