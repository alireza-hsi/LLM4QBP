    <task id="activity21" name="Brain CT scan">
      <incoming>merged_Flow_50_Flow_46</incoming><outgoing>Flow_47</outgoing></task>
    <task id="activity22" name="referral to an outpatient clinic with stroke-prevention servicesd for comprehensive evaluation and management within 1 month of symptom onset">
      <incoming>Flow_47</incoming><outgoing>Flow_51</outgoing></task>
