      <incoming>Flow_32</incoming><outgoing>Flow_38</outgoing></task>
    <task id="activity18" name="Brain CT scan">
      <incoming>merged_Flow_39_Flow_34</incoming><outgoing>Flow_35</outgoing></task>
    <task id="activity19" name="evaluation (as follows) occur at an appropriately resourced ED, and further consideration be given to inpatient evaluation and management for stroke prevention. OHTAC further recommends the establishment of accreditation standards for TIA/minor stroke care to ensure equitable access to appropriate, high-quality care, irrespective of the location of initial presentation">
      <incoming>Flow_35</incoming><outgoing>Flow_40</outgoing></task>
    <exclusiveGateway id="exclusivegateway6Join" name="Exclusive Merge">
      <incoming>Flow_38</incoming><incoming>Flow_40</incoming><outgoing>Flow_44</outgoing></exclusiveGateway>
