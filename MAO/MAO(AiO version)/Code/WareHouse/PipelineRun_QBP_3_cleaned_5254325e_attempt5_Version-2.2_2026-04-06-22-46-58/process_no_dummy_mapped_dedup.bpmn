<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_48</incoming></endEvent>
    <task id="activity1" name="Patients should be screened/assessed for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED, and the results should be forwarded to the TIA clinic for follow-up">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2" name="Determine eligibility for acute inpatient admission per recommendation 2.4.2 (Role: admitting physician; Objects: patient, clinical criteria)">
      <incoming>Flow_2</incoming><outgoing>Flow_47</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_47</incoming><outgoing>Flow_45</outgoing><outgoing>merged_Flow_43_Flow_4</outgoing></exclusiveGateway>
    <task id="activity3" name="Admit the patient to a specialized, geographically defined hospital unit dedicated to the management of stroke patients with the following requirements:&#10;&#10;&#10;1- The core stroke unit team should consist of health care professionals with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (a dietitian).&#10;&#10;2- To have the necessary stroke expertise, the health care professionals on the core stroke unit team should be individuals who spend the vast majority of their time treating stroke patients and regularly complete education about stroke care.&#10;&#10;3- Patients should have access to a specialized interprofessional team 7 days a week">
      <incoming>merged_Flow_43_Flow_4</incoming><outgoing>Flow_39</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_39</incoming><outgoing>Flow_21</outgoing><outgoing>Flow_22</outgoing><outgoing>Flow_24</outgoing><outgoing>Flow_25</outgoing><outgoing>Flow_26</outgoing><outgoing>Flow_27</outgoing><outgoing>Flow_29</outgoing><outgoing>merged_Flow_23_Flow_8</outgoing><outgoing>merged_Flow_28_Flow_15</outgoing></parallelGateway>
    <task id="activity6" name="Admit the patient to a specialized, geographically defined hospital unit dedicated to the management of stroke patients with the following requirements:&#10;&#10;&#10;1- The core stroke unit team should consist of health care professionals with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (a dietitian).&#10;&#10;2- To have the necessary stroke expertise, the health care professionals on the core stroke unit team should be individuals who spend the vast majority of their time treating stroke patients and regularly complete education about stroke care.&#10;&#10;3- Patients should have access to a specialized interprofessional team 7 days a week">
      <incoming>Flow_21</incoming><outgoing>Flow_30</outgoing></task>
    <task id="activity7-1" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_22</incoming><outgoing>Flow_31</outgoing></task>
    <task id="activity8-1" name="Determine if early mobilization is contraindicated (Role: stroke unit clinicians; Objects: patient, clinical judgement)">
      <incoming>merged_Flow_23_Flow_8</incoming><outgoing>Flow_13</outgoing></task>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_13</incoming><outgoing>Flow_9</outgoing><outgoing>Flow_11</outgoing></exclusiveGateway>
    <task id="activity8-2" name="Mobilize patient">
      <incoming>Flow_9</incoming><outgoing>Flow_10</outgoing></task>
    <task id="activity8-3" name="Delay mobilization and monitor patient status (Role: stroke unit clinicians; Objects: patient, monitoring tools)">
      <incoming>Flow_11</incoming><outgoing>Flow_12</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_10</incoming><incoming>Flow_12</incoming><outgoing>Flow_32</outgoing></exclusiveGateway>
    <task id="activity9-1" name="Use standardized, valid assessment tools to evaluate patients’ stroke-related impairments and functional status&#10;where possible, these tools should be in electronic format linked to the EHR">
      <incoming>Flow_24</incoming><outgoing>Flow_33</outgoing></task>
    <task id="activity10" name="Complete AlphaFIM on or by day 3 after admission(target day 3, admission day is day 1)">
      <incoming>Flow_25</incoming><outgoing>Flow_34</outgoing></task>
    <task id="activity11" name="Assess patient for risk of developing venous thromboembolism">
      <incoming>Flow_26</incoming><outgoing>Flow_35</outgoing></task>
    <task id="activity12" name="Encourage early mobilization and adequate hydration for all acute stroke patients to help prevent venous thromboembolism">
      <incoming>Flow_27</incoming><outgoing>Flow_36</outgoing></task>
    <task id="activity13" name="The nutrition and hydration status of stroke patients should be assessed within the first 48 hours of admission using a valid screening tool.">
      <incoming>merged_Flow_28_Flow_15</incoming><outgoing>Flow_20</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_20</incoming><outgoing>Flow_16</outgoing><outgoing>Flow_18</outgoing></exclusiveGateway>
    <task id="activity14" name="Give patient a referral to a dietitian within 7 days of admission">
      <incoming>Flow_16</incoming><outgoing>Flow_17</outgoing></task>
    <task id="activity15" name="Continue standard nutrition monitoring (Role: stroke unit clinicians; Objects: patient)">
      <incoming>Flow_18</incoming><outgoing>Flow_19</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_17</incoming><incoming>Flow_19</incoming><outgoing>Flow_37</outgoing></exclusiveGateway>
    <task id="activity16-1" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>Flow_29</incoming><outgoing>Flow_38</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
