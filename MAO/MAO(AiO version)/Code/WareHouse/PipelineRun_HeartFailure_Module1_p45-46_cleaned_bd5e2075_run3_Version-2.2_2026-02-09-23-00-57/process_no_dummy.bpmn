    <ns0:parallelGateway id="parallelgateway2" name="Parallel Gateway">
      <ns0:incoming>Flow_35</ns0:incoming>
      <ns0:outgoing>Flow_29</ns0:outgoing>
      <ns0:outgoing>Flow_30</ns0:outgoing>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity11_1" name="assess respiratory status and oxygenation for high-risk markers (Role: ED clinician; Objects: respiratory exam, oxygen saturation, work of breathing)">
      <ns0:incoming>Flow_29</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11_2" name="assess hemodynamics and rhythm for high-risk markers (Role: ED clinician; Objects: blood pressure trends, perfusion signs, ECG rhythm assessment)">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:outgoing>Flow_33</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11_3" name="review biomarkers/imaging and diuresis response for high-risk markers (Role: ED clinician; Objects: troponin result, chest x-ray findings, diuresis response)">
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_34</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway2Join" name="Parallel Merge">
      <ns0:incoming>Flow_32</ns0:incoming>
      <ns0:incoming>Flow_33</ns0:incoming>
      <ns0:incoming>Flow_34</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity11_4" name="consolidate findings and screen for presence of any high-risk markers (Role: ED clinician; Objects: clinical exam, ECG/troponin/imaging results, response to diuresis)">
      <ns0:incoming>Flow_36</ns0:incoming>
      <ns0:outgoing>Flow_37</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity12" name="calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk and support clinical decision-making (Role: ED clinician; Objects: EHMRG inputs, calculator)">
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:outgoing>Flow_67</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway4_moved" name="Exclusive Gateway">
      <ns0:incoming>Flow_67</ns0:incoming>
      <ns0:outgoing>Flow_63</ns0:outgoing>
      <ns0:outgoing>Flow_65</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity19_1_moved" name="identify transfer trigger and contact receiving service/provider to accept patient (Role: ED clinician/transfer coordinator; Objects: transfer protocol, receiving service contact)">
      <ns0:incoming>Flow_39</ns0:incoming>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity19_2_moved" name="stabilize patient for transport and prepare transfer documentation (Role: ED clinician/nurse; Objects: stabilization checklist, transfer summary, copies of results)">
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:outgoing>Flow_41</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity19_3_moved" name="arrange transport and complete clinical handover to receiving team (Role: transfer coordinator/paramedics; Objects: transport booking, handover report)">
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_64</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1_riskDisposition" name="Exclusive Gateway">
      <ns0:incoming>Flow_61</ns0:incoming>
      <ns0:outgoing>Flow_57</ns0:outgoing>
      <ns0:outgoing>Flow_59</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity13" name="assess other considerations before discharge (e.g., advanced-directives, severe dementia, estimated impact of admission on life-expectancy) (Role: ED clinician; Objects: patient history, goals-of-care documentation)">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:outgoing>Flow_52</ns0:outgoing>
    </ns0:task>
