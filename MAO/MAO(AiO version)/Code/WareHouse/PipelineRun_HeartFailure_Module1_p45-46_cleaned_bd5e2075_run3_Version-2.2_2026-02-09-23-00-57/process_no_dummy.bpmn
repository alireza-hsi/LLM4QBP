      <ns0:outgoing>Flow_50</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity14" name="treat in ED or outpatient setting and discharge home without inpatient admission (low intensity) (Role: ED clinician; Objects: discharge instructions)">
      <ns0:incoming>Flow_46</ns0:incoming>
      <ns0:outgoing>Flow_47</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="arrange follow-up visit with primary care provider within days of ED discharge (Role: ED clinician/care coordinator; Objects: follow-up appointment details)">
      <ns0:incoming>Flow_47</ns0:incoming>
      <ns0:outgoing>Flow_49</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity16" name="admit to hospital despite low-risk score (Role: ED clinician; Objects: admission order)">
      <ns0:incoming>Flow_50</ns0:incoming>
      <ns0:outgoing>Flow_51</ns0:outgoing>
    </ns0:task>
