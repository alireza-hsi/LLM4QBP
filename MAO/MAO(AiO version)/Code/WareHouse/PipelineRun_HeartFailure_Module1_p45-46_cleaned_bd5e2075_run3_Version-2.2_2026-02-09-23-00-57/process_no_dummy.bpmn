      <ns0:outgoing>Flow_7</ns0:outgoing>
      <ns0:outgoing>Flow_8</ns0:outgoing>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity3" name="measure heart rate, blood pressure, and oxygen saturation frequently until patient is stabilized (Role: nurse; Objects: vital signs, pulse oximetry)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="order serum creatinine and electrolyte levels (Role: ED clinician; Objects: blood sample, lab requisition)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="order troponin measurements (Role: ED clinician; Objects: blood sample, lab requisition)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="order complete blood count (Role: ED clinician; Objects: blood sample, lab requisition)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="perform electrocardiogram (Role: ED clinician; Objects: ECG machine, leads)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8" name="perform chest x-ray examination (Role: radiology; Objects: x-ray imaging order)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1_fixedJoin" name="Parallel Merge">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity2_1" name="administer initial diuretic therapy (e.g., IV furosemide) and begin monitoring response (Role: ED clinician; Objects: diuretic order, medication administration record)">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2_2" name="reassess responsiveness to diuresis (urine output, symptoms, weight if available) (Role: ED clinician; Objects: urine output, clinical response)">
      <ns0:incoming>Flow_18</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway0_diuresisResponse" name="Inclusive Gateway">
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity2_3_modified" name="continue ED management plan based on current diuresis response (Role: ED clinician; Objects: treatment plan)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2_4" name="escalate treatment and flag poor diuretic response as high-risk marker (Role: ED clinician; Objects: escalation plan, high-risk marker flag)">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:task>
