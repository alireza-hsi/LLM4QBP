    <ns0:task id="activity17" name="admit to intensive care unit with higher nurse-to-patient staffing (high intensity) and initiate ventilation as needed (Role: ED clinician/ICU team; Objects: ICU bed request, ventilatory support)">
      <ns0:incoming>Flow_53</ns0:incoming>
      <ns0:outgoing>Flow_54</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18" name="admit to inpatient care with normal nurse-to-patient staffing (average intensity) (Role: ED clinician/inpatient team; Objects: inpatient bed request)">
      <ns0:incoming>Flow_55</ns0:incoming>
      <ns0:outgoing>Flow_56</ns0:outgoing>
    </ns0:task>
