<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="true" name="Stroke Process"><bpmn:startEvent id="StartEvent_1" name="Start"><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:startEvent><bpmn:endEvent id="EndEvent_1" name="End"><bpmn:incoming>Flow_76</bpmn:incoming></bpmn:endEvent><bpmn:parallelGateway id="parallelgateway1_1" name="Parallel Gateway"><bpmn:outgoing>Flow_1</bpmn:outgoing><bpmn:outgoing>Flow_2</bpmn:outgoing><bpmn:incoming>Flow_5</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity1_1" name="screen the patient for diabetes and dental issues upon presentation (Role: emergency department clinicians; Objects: diabetes screening results,dental assessment results)"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task><bpmn:task id="activity1_2" name="assess the patient for cognitive impairment and depression upon presentation (Role: emergency department clinicians; Objects: cognitive impairment assessment results,depression screening results)"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1_1Join" name="Parallel Merge"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:parallelGateway><bpmn:task id="activity1_3" name="document screening and assessment results in standardized validated tools linked to the EHR where possible (Role: emergency department clinicians; Objects: screening results,EHR)"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_75</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway"><bpmn:outgoing>Flow_71</bpmn:outgoing><bpmn:outgoing>Flow_73</bpmn:outgoing><bpmn:incoming>Flow_75</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="dummy_Flow_7" name="(dummy branch entry)"><bpmn:outgoing>Flow_8</bpmn:outgoing><bpmn:incoming>Flow_71</bpmn:incoming></bpmn:task><bpmn:task id="activity2" name="admit the patient to a specialized geographically defined stroke unit dedicated to stroke management with identifiable co-located beds (Role: admitting team; Objects: stroke unit bed)"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:task id="activity3" name="provide care through a core interprofessional team with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (Role: stroke unit; Objects: stroke unit team)"><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_55</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway2" name="Parallel Gateway"><bpmn:outgoing>Flow_45</bpmn:outgoing><bpmn:outgoing>Flow_46</bpmn:outgoing><bpmn:outgoing>Flow_47</bpmn:outgoing><bpmn:outgoing>Flow_48</bpmn:outgoing><bpmn:outgoing>Flow_49</bpmn:outgoing><bpmn:incoming>Flow_55</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="dummy_Flow_10" name="(dummy branch entry)"><bpmn:outgoing>Flow_11</bpmn:outgoing><bpmn:incoming>Flow_45</bpmn:incoming></bpmn:task><bpmn:task id="activity5_1" name="evaluate stroke-related impairments using standardized valid assessment tools (Role: clinicians; Objects: standardized assessment tools)"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task><bpmn:task id="activity5_2" name="evaluate functional status using standardized valid assessment tools (Role: clinicians; Objects: standardized assessment tools)"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:task><bpmn:task id="activity6" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day counted as day 1 (Role: clinicians; Objects: AlphaFIM)"><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:outgoing>Flow_50</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_14" name="(dummy branch entry)"><bpmn:outgoing>Flow_21</bpmn:outgoing><bpmn:incoming>Flow_46</bpmn:incoming></bpmn:task><bpmn:parallelGateway id="parallelgateway1_2" name="Parallel Gateway"><bpmn:outgoing>Flow_15</bpmn:outgoing><bpmn:outgoing>Flow_16</bpmn:outgoing><bpmn:outgoing>Flow_17</bpmn:outgoing><bpmn:incoming>Flow_21</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity7_1" name="assess the patient within 48 hours of hospital admission (Role: physiotherapist; Objects: physiotherapy assessment)"><bpmn:incoming>Flow_15</bpmn:incoming><bpmn:outgoing>Flow_18</bpmn:outgoing></bpmn:task><bpmn:task id="activity7_2" name="assess the patient within 48 hours of hospital admission (Role: speech-language pathologist; Objects: speech-language pathology assessment)"><bpmn:incoming>Flow_16</bpmn:incoming><bpmn:outgoing>Flow_19</bpmn:outgoing></bpmn:task><bpmn:task id="activity7_3" name="assess the patient within 48 hours of hospital admission (Role: occupational therapist; Objects: occupational therapy assessment)"><bpmn:incoming>Flow_17</bpmn:incoming><bpmn:outgoing>Flow_20</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1_2Join" name="Parallel Merge"><bpmn:incoming>Flow_18</bpmn:incoming><bpmn:incoming>Flow_19</bpmn:incoming><bpmn:incoming>Flow_20</bpmn:incoming><bpmn:outgoing>Flow_22</bpmn:outgoing></bpmn:parallelGateway><bpmn:task id="activity7_4" name="formulate an interprofessional management plan based on the assessments (Role: physiotherapist, speech-language pathologist, and occupational therapist; Objects: management plan)"><bpmn:incoming>Flow_22</bpmn:incoming><bpmn:outgoing>Flow_51</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_23" name="(dummy branch entry)"><bpmn:outgoing>Flow_24</bpmn:outgoing><bpmn:incoming>Flow_47</bpmn:incoming></bpmn:task><bpmn:task id="activity8" name="assess the patient for risk of developing venous thromboembolism (Role: clinicians; Objects: venous thromboembolism risk assessment)"><bpmn:incoming>Flow_24</bpmn:incoming><bpmn:outgoing>Flow_25</bpmn:outgoing></bpmn:task><bpmn:task id="activity9" name="encourage adequate hydration to help prevent venous thromboembolism (Role: stroke unit team; Objects: hydration plan)"><bpmn:incoming>Flow_25</bpmn:incoming><bpmn:outgoing>Flow_52</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_26" name="(dummy branch entry)"><bpmn:outgoing>Flow_27</bpmn:outgoing><bpmn:incoming>Flow_48</bpmn:incoming></bpmn:task><bpmn:task id="activity10" name="assess nutrition and hydration status within the first 48 hours of admission using a valid screening tool (Role: nursing or designated clinician; Objects: nutrition and hydration screening tool)"><bpmn:incoming>Flow_27</bpmn:incoming><bpmn:outgoing>Flow_40</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway"><bpmn:outgoing>Flow_36</bpmn:outgoing><bpmn:outgoing>Flow_38</bpmn:outgoing><bpmn:incoming>Flow_40</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="dummy_Flow_28" name="(dummy branch entry)"><bpmn:outgoing>Flow_29</bpmn:outgoing><bpmn:incoming>Flow_36</bpmn:incoming></bpmn:task><bpmn:task id="activity11_1" name="refer the patient to a dietitian within 7 days of admission (Role: stroke unit team; Objects: dietitian referral)"><bpmn:incoming>Flow_29</bpmn:incoming><bpmn:outgoing>Flow_30</bpmn:outgoing></bpmn:task><bpmn:task id="activity11_2" name="assess nutritional and fluid requirements and provide recommendations (Role: dietitian; Objects: dietitian recommendations,nutritional and fluid requirements assessment)"><bpmn:incoming>Flow_30</bpmn:incoming><bpmn:outgoing>Flow_35</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2_1" name="Exclusive Gateway"><bpmn:outgoing>Flow_31</bpmn:outgoing><bpmn:outgoing>Flow_33</bpmn:outgoing><bpmn:incoming>Flow_35</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="activity11_3" name="recommend and plan enteral nutrition support (Role: dietitian and stroke unit team; Objects: enteral nutrition support plan)"><bpmn:incoming>Flow_31</bpmn:incoming><bpmn:outgoing>Flow_32</bpmn:outgoing></bpmn:task><bpmn:task id="activity11_4" name="continue nutrition and hydration management without enteral nutrition support (Role: dietitian and stroke unit team; Objects: nutrition and hydration management plan)"><bpmn:incoming>Flow_33</bpmn:incoming><bpmn:outgoing>Flow_34</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2_1Join" name="Exclusive Merge"><bpmn:incoming>Flow_32</bpmn:incoming><bpmn:incoming>Flow_34</bpmn:incoming><bpmn:outgoing>Flow_37</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="activity12" name="continue routine nutrition and hydration monitoring (Role: stroke unit team; Objects: nutrition and hydration status)"><bpmn:incoming>Flow_38</bpmn:incoming><bpmn:outgoing>Flow_39</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge"><bpmn:incoming>Flow_37</bpmn:incoming><bpmn:incoming>Flow_39</bpmn:incoming><bpmn:outgoing>Flow_53</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway"><bpmn:outgoing>Flow_41</bpmn:outgoing><bpmn:outgoing>Flow_43</bpmn:outgoing><bpmn:incoming>Flow_49</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="activity13" name="mobilize the patient early between 24 hours and 48 hours of stroke onset and encourage out-of-bed activity as appropriate (Role: stroke unit team; Objects: early mobilization plan)"><bpmn:incoming>Flow_41</bpmn:incoming><bpmn:outgoing>Flow_42</bpmn:outgoing></bpmn:task><bpmn:task id="activity14" name="defer or individualize mobilization and use clinical judgement to determine safe activity level and timing while avoiding routine frequent out-of-bed activity before eligibility (Role: stroke unit team; Objects: clinical judgement,mobilization precautions,individualized mobilization plan)"><bpmn:incoming>Flow_43</bpmn:incoming><bpmn:outgoing>Flow_44</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge"><bpmn:incoming>Flow_42</bpmn:incoming><bpmn:incoming>Flow_44</bpmn:incoming><bpmn:outgoing>Flow_54</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:parallelGateway id="parallelgateway2Join" name="Parallel Merge"><bpmn:incoming>Flow_50</bpmn:incoming><bpmn:incoming>Flow_51</bpmn:incoming><bpmn:incoming>Flow_52</bpmn:incoming><bpmn:incoming>Flow_53</bpmn:incoming><bpmn:incoming>Flow_54</bpmn:incoming><bpmn:outgoing>Flow_66</bpmn:outgoing></bpmn:parallelGateway><bpmn:inclusiveGateway id="inclusivegateway4" name="Inclusive Gateway"><bpmn:outgoing>Flow_62</bpmn:outgoing><bpmn:outgoing>Flow_64</bpmn:outgoing><bpmn:incoming>Flow_66</bpmn:incoming></bpmn:inclusiveGateway><bpmn:task id="dummy_Flow_56" name="(dummy branch entry)"><bpmn:outgoing>Flow_57</bpmn:outgoing><bpmn:incoming>Flow_62</bpmn:incoming></bpmn:task><bpmn:task id="activity15_1" name="perform cross-continuum secondary prevention assessments for the patient transferred to in-hospital rehabilitation (Role: stroke unit team; Objects: Modules 5 and 10 prevention assessments)"><bpmn:incoming>Flow_57</bpmn:incoming><bpmn:outgoing>Flow_58</bpmn:outgoing></bpmn:task><bpmn:task id="activity15_2" name="initiate appropriate cross-continuum secondary prevention therapies for the patient transferred to in-hospital rehabilitation (Role: stroke unit team; Objects: Modules 5 and 10 prevention therapies)"><bpmn:incoming>Flow_58</bpmn:incoming><bpmn:outgoing>Flow_63</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_59" name="(dummy branch entry)"><bpmn:outgoing>Flow_60</bpmn:outgoing><bpmn:incoming>Flow_64</bpmn:incoming></bpmn:task><bpmn:task id="activity16_1" name="perform cross-continuum secondary prevention assessments at discharge from acute care (Role: stroke unit team; Objects: Modules 5 and 10 prevention assessments)"><bpmn:incoming>Flow_60</bpmn:incoming><bpmn:outgoing>Flow_61</bpmn:outgoing></bpmn:task><bpmn:task id="activity16_2" name="provide and document appropriate cross-continuum secondary prevention therapies in the discharge plan (Role: stroke unit team; Objects: Modules 5 and 10 prevention therapies,discharge plan)"><bpmn:incoming>Flow_61</bpmn:incoming><bpmn:outgoing>Flow_65</bpmn:outgoing></bpmn:task><bpmn:inclusiveGateway id="inclusivegateway4Join" name="Inclusive Merge"><bpmn:incoming>Flow_63</bpmn:incoming><bpmn:incoming>Flow_65</bpmn:incoming><bpmn:outgoing>Flow_72</bpmn:outgoing></bpmn:inclusiveGateway><bpmn:task id="dummy_Flow_67" name="(dummy branch entry)"><bpmn:outgoing>Flow_68</bpmn:outgoing><bpmn:incoming>Flow_73</bpmn:incoming></bpmn:task><bpmn:task id="activity17" name="document that acute care treatment recommendations in this module are not applicable to TIA or minor nondisabling stroke (Role: emergency department or admitting clinicians; Objects: clinical record)"><bpmn:incoming>Flow_68</bpmn:incoming><bpmn:outgoing>Flow_69</bpmn:outgoing></bpmn:task><bpmn:task id="activity18" name="forward ED screening and assessment results to the TIA clinic for follow-up (Role: clinicians; Objects: diabetes,dental,cognitive impairment,depression screening results)"><bpmn:incoming>Flow_69</bpmn:incoming><bpmn:outgoing>Flow_70</bpmn:outgoing></bpmn:task><bpmn:task id="activity19" name="provide appropriate cross-continuum secondary prevention assessments and therapies (Role: clinicians; Objects: Modules 5 and 10 prevention assessments and therapies)"><bpmn:incoming>Flow_70</bpmn:incoming><bpmn:outgoing>Flow_74</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge"><bpmn:incoming>Flow_72</bpmn:incoming><bpmn:incoming>Flow_74</bpmn:incoming><bpmn:outgoing>Flow_76</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:sequenceFlow id="Flow_1" sourceRef="parallelgateway1_1" targetRef="activity1_1" /><bpmn:sequenceFlow id="Flow_2" sourceRef="parallelgateway1_1" targetRef="activity1_2" /><bpmn:sequenceFlow id="Flow_3" sourceRef="activity1_1" targetRef="parallelgat