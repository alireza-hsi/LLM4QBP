    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_67</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="initiate early assessment pathway for patient presenting to the ED, outpatient clinic, or direct acute care admission with suspected stroke (Role: triage clinician; Objects: suspected stroke patient)">
