  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_8</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_72</incoming></endEvent>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_8</incoming><outgoing>Flow_6</outgoing><outgoing>merged_Flow_4_Flow_2</outgoing></exclusiveGateway>
    <task id="activity1" name="prenotify receiving hospital and divert patient to regional or district stroke centre where feasible (Role: EMS; Objects: suspected stroke/TIA patient information)">
      <incoming>merged_Flow_4_Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="activity2" name="contact acute stroke team and call team to the ED for appropriate patients (Role: receiving hospital; Objects: EMS prenotification details)">
      <incoming>Flow_3</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity3" name="register and triage patient for immediate stroke/TIA assessment (Role: triage staff; Objects: suspected stroke/TIA patient)">
      <incoming>Flow_6</incoming><outgoing>Flow_7</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_5</incoming><incoming>Flow_7</incoming><outgoing>Flow_15</outgoing></exclusiveGateway>
    <task id="activity21" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_15</incoming><outgoing>Flow_29</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_29</incoming><outgoing>Flow_24</outgoing><outgoing>Flow_25</outgoing><outgoing>merged_Flow_23_Flow_17</outgoing></parallelGateway>
    <task id="activity24" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>merged_Flow_23_Flow_17</incoming><outgoing>Flow_26</outgoing></task>
    <task id="activity8" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_24</incoming><outgoing>Flow_27</outgoing></task>
    <task id="activity26" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_25</incoming><outgoing>Flow_28</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_26</incoming><incoming>Flow_27</incoming><incoming>Flow_28</incoming><outgoing>Flow_30</outgoing></parallelGateway>
    <task id="activity6" name="Immediate brain imaging (CT or MRI)">
      <incoming>Flow_30</incoming><outgoing>Flow_31</outgoing></task>
    <task id="activity7" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_31</incoming><outgoing>Flow_32</outgoing></task>
    <task id="activity11" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_32</incoming><outgoing>Flow_40</outgoing></task>
    <exclusiveGateway id="exclusivegateway7" name="Exclusive Gateway">
      <incoming>Flow_40</incoming><outgoing>Flow_38</outgoing><outgoing>merged_Flow_36_Flow_34</outgoing></exclusiveGateway>
    <task id="activity30" name="Use a standard triage tool to determine the appropriate location for the care of patients&#10;(Patients with TIA)">
      <incoming>merged_Flow_36_Flow_34</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity34" name="continue pathway determination based on assessment findings (Role: clinical staff; Objects: initial assessment and examination results)">
      <incoming>Flow_38</incoming><outgoing>Flow_39</outgoing></task>
    <exclusiveGateway id="exclusivegateway7Join" name="Exclusive Merge">
      <incoming>Flow_37</incoming><incoming>Flow_39</incoming><outgoing>Flow_66</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_66</incoming><outgoing>Flow_64</outgoing><outgoing>merged_Flow_62_Flow_42</outgoing></exclusiveGateway>
    <task id="activity28" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_62_Flow_42</incoming><outgoing>Flow_48</outgoing></task>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_48</incoming><outgoing>Flow_44</outgoing><outgoing>Flow_46</outgoing></exclusiveGateway>
    <task id="activity12" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_44</incoming><outgoing>Flow_45</outgoing></task>
    <task id="activity13" name="continue stroke assessment after initial swallowing screen (Role: clinical staff; Objects: stroke patient assessment findings)">
      <incoming>Flow_46</incoming><outgoing>Flow_47</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_45</incoming><incoming>Flow_47</incoming><outgoing>Flow_53</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_53</incoming><outgoing>Flow_49</outgoing><outgoing>Flow_51</outgoing></exclusiveGateway>
    <task id="activity14" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_49</incoming><outgoing>Flow_50</outgoing></task>
    <task id="activity15" name="continue standard stroke management (Role: clinical staff; Objects: initial assessment results)">
      <incoming>Flow_51</incoming><outgoing>Flow_52</outgoing></task>
