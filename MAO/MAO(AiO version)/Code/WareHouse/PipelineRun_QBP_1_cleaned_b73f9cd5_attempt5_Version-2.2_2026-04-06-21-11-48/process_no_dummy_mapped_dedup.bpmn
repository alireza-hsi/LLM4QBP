    </sequenceFlow>
    <sequenceFlow id="Flow_57" sourceRef="activity18" targetRef="exclusivegateway6Join" />
    <sequenceFlow id="Flow_58" name="presentation is within 48 hours of symptom onset or motor or speech symptoms are fluctuating" sourceRef="exclusivegateway5" targetRef="exclusivegateway6">
