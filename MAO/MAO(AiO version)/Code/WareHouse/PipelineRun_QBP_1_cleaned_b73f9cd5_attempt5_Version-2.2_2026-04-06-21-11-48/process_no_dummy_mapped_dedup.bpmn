    <task id="activity17" name="document that immediate neck artery vascular imaging is not required under carotid revascularization criterion and continue pathway (Role: clinician; Objects: revascularization candidacy assessment)">
      <incoming>Flow_54</incoming><outgoing>Flow_55</outgoing></task>
    <task id="activity18" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_56</incoming><outgoing>Flow_57</outgoing></task>
    <exclusiveGateway id="exclusivegateway6Join" name="Exclusive Merge">
      <incoming>Flow_55</incoming><incoming>Flow_57</incoming><outgoing>Flow_59</outgoing></exclusiveGateway>
    <task id="activity19" name="Vascular imaging of the brain and neck arteries ASAP">
