      <incoming>Flow_63</incoming><incoming>Flow_65</incoming><outgoing>Flow_71</outgoing></exclusiveGateway>
    <task id="activity32" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_71</incoming><outgoing>Flow_72</outgoing></task>
