    <ns0:sequenceFlow id="Flow_20" name="Patient requires ventilation and/or intensive care" sourceRef="exclusivegateway2" targetRef="activity9">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Patient requires ventilation and/or intensive care</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_21" sourceRef="activity9" targetRef="exclusivegateway2Join" />
    <ns0:sequenceFlow id="Flow_22" name="Patient requires inpatient care but not intensive care" sourceRef="exclusivegateway2" targetRef="activity10">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Patient requires inpatient care but not intensive care</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_23" sourceRef="activity10" targetRef="exclusivegateway2Join" />
    <ns0:sequenceFlow id="Flow_25" sourceRef="activity8" targetRef="exclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_26" name="High-risk (EHMRG quintiles 3-5) or other considerations (advanced directives, severe dementia, etc.)" sourceRef="exclusivegateway1" targetRef="exclusivegateway2">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or other considerations (advanced directives, severe dementia, etc.)</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_27" sourceRef="exclusivegateway2Join" targetRef="exclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_28" sourceRef="activity6" targetRef="exclusivegateway1" />
    <ns0:sequenceFlow id="Flow_29" sourceRef="exclusivegateway1Join" targetRef="EndEvent_1" />
