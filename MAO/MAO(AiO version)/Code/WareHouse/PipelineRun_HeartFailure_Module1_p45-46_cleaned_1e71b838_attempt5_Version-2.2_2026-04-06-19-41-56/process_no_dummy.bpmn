<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_29</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity11" name="Ensure standardized risk stratification tool/process is implemented and consistently applied (Role: hospital administration; Objects: hospital policy, risk stratification tool)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity12" name="Maintain pathway/mechanism for transfer to higher level provider as needed (Role: hospital administration; Objects: transfer protocols)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1" name="Initiate acute heart failure episode of care (Role: emergency department clinician; Objects: patient presenting with suspected acute heart failure)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2-1" name="Select appropriate risk-stratification tool (Role: emergency department clinician; Objects: risk-stratification tool options)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2-2" name="Complete risk assessment using selected tool (Role: emergency department clinician; Objects: selected risk-stratification tool)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity3-1" name="Order initial investigations (Role: emergency department clinician; Objects: laboratory and imaging requisitions)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3-2" name="Review results of investigations (Role: emergency department clinician; Objects: laboratory and imaging results)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="Frequently measure heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: emergency department nurse; Objects: vital sign monitoring equipment)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity5" name="Assess responsiveness to diuresis (Role: emergency department clinician; Objects: clinical response to diuretic therapy)">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG or equivalent risk score tool)">
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_28</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity7-1" name="Provide discharge instructions (Role: emergency department clinician; Objects: discharge instructions)">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7-2" name="Document discharge in medical record (Role: emergency department clinician; Objects: medical record)">
      <ns0:incoming>Flow_18</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8" name="Arrange follow-up visit with primary care provider within days of ED discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity9" name="Admit patient to intensive care unit with high nurse-to-patient staffing (Role: emergency department clinician; Objects: ICU admission order)">
      <ns0:incoming>Flow_20</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10" name="Admit patient to inpatient unit with normal nurse-to-patient staffing (Role: emergency department clinician; Objects: inpatient admission order)">
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
