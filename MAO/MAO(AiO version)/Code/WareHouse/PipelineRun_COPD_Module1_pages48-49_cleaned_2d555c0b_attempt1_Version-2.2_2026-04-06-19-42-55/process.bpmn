      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity9" name="Perform chest x-ray (posteroanterior and lateral) (Role: medical staff; Objects: patient)">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Perform portable chest x-ray (Role: medical staff; Objects: patient)">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="Perform expiratory view chest x-ray (Role: medical staff; Objects: patient)">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
