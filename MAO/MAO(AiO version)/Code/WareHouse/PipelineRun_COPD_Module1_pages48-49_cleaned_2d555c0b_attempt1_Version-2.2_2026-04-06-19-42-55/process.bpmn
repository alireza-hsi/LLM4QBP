      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity6" name="Collect blood sample (Role: medical staff; Objects: patient blood samples)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="activity7" name="Order laboratory tests (CBC, electrolytes, creatinine, BUN if available) (Role: medical staff; Objects: patient blood samples)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14" name="Draw blood cultures (Role: medical staff; Objects: patient blood samples)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity16" name="Examine cardiac markers (Role: medical staff; Objects: patient blood samples)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:task id="activity8" name="Perform electrocardiogram (ECG) to check for arrhythmias, myocardial ischemia, right ventricular strain (Role: medical staff; Objects: patient)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:task>
