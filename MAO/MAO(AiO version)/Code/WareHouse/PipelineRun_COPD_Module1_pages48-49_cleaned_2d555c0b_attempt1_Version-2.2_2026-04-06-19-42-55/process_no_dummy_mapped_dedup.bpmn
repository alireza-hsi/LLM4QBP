    <sequenceFlow id="Flow_34" sourceRef="activity19" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_35" name="Prior spirometry documentation exists or patient not stabilized" sourceRef="exclusivegateway3" targetRef="activity20">
