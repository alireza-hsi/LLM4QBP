    <task id="activity1" name="Receive patient with suspected COPD exacerbation (Role: medical staff; Objects: patient)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
