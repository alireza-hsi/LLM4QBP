      <incoming>Flow_62</incoming>
      <outgoing>Flow_64</outgoing>
    </inclusiveGateway>
    <task id="activity25" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_64</incoming>
      <outgoing>Flow_65</outgoing>
    </task>
