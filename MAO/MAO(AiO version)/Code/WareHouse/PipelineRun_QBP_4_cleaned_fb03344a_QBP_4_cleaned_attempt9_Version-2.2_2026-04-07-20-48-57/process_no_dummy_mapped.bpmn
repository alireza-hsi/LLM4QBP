      <incoming>Flow_48</incoming>
      <incoming>Flow_50</incoming>
      <outgoing>Flow_53</outgoing>
    </exclusiveGateway>
    <task id="activity18" name="continue stroke assessment and management outside the acute reperfusion pathway (Role: clinical team; Objects: patient-specific diagnostic and treatment plan within 48 hours)">
      <incoming>Flow_54</incoming>
      <outgoing>Flow_55</outgoing>
    </task>
    <task id="activity20" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_56</incoming>
      <outgoing>Flow_57</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_53</incoming>
      <incoming>Flow_55</incoming>
      <incoming>Flow_57</incoming>
      <outgoing>Flow_63</outgoing>
