  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_65</incoming>
    </endEvent>
    <task id="activity1" name="present to ED, outpatient clinic, or acute care with suspected stroke symptoms (Role: patient; Objects: suspected stroke presentation)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="activity2.1" name="assign high-acuity stroke triage priority and activate acute stroke protocol (Role: triage nurse; Objects: suspected stroke pathway, urgent triage status)">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="activity2.2" name="notify acute stroke team for immediate assessment (Role: triage nurse; Objects: stroke team activation)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_4</outgoing>
      <outgoing>Flow_5</outgoing>
      <outgoing>Flow_6</outgoing>
    </parallelGateway>
    <task id="activity3" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <task id="activity4" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
    <task id="activity5" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_9</outgoing>
    </task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_7</incoming>
      <incoming>Flow_8</incoming>
      <incoming>Flow_9</incoming>
      <outgoing>Flow_11</outgoing>
    </parallelGateway>
    <task id="activity22" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_58</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_58</incoming>
      <outgoing>Flow_52</outgoing>
      <outgoing>Flow_54</outgoing>
      <outgoing>Flow_56</outgoing>
    </exclusiveGateway>
    <parallelGateway id="parallelgateway2" name="Parallel Gateway">
      <incoming>Flow_31</incoming>
      <outgoing>Flow_23</outgoing>
      <outgoing>Flow_24</outgoing>
      <outgoing>Flow_25</outgoing>
      <outgoing>Flow_26</outgoing>
    </parallelGateway>
