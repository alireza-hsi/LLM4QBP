    <inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <incoming>Flow_63</incoming>
      <outgoing>Flow_59</outgoing>
      <outgoing>Flow_61</outgoing>
    </inclusiveGateway>
    <task id="activity23" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_59</incoming>
      <outgoing>Flow_60</outgoing>
    </task>
    <task id="activity24" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_61</incoming>
      <outgoing>Flow_62</outgoing>
    </task>
    <inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
