      <incoming>Flow_47</incoming>
      <outgoing>Flow_35</outgoing>
      <outgoing>Flow_37</outgoing>
    </exclusiveGateway>
    <task id="activity12" name="Consideration of advanced CT imaging including CT and multiphase CTA or Perfusion CT">
      <incoming>Flow_33</incoming>
      <outgoing>Flow_34</outgoing>
    </task>
    <task id="activity11" name="Evaluate patients for endovascular therapy">
      <incoming>Flow_34</incoming>
      <outgoing>Flow_36</outgoing>
    </task>
    <task id="activity13" name="continue acute ischemic stroke management without EVT pathway (Role: stroke physician; Objects: ischemic stroke treatment plan)">
      <incoming>Flow_37</incoming>
      <outgoing>Flow_38</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_36</incoming>
      <incoming>Flow_38</incoming>
      <outgoing>Flow_48</outgoing>
    </exclusiveGateway>
    <task id="activity14" name="Treat patient as a medical emergency. ICH should be promptly recognized, and patients should be evaluated&#10;immediately by physicians with expertise in stroke management">
      <incoming>Flow_40</incoming>
      <outgoing>Flow_41</outgoing>
    </task>
    <task id="activity15" name="Evaluation should include questions&#10;about anticoagulant therapy, measurement of platelet count, PTT, and&#10;INR">
      <incoming>Flow_41</incoming>
      <outgoing>Flow_46</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_46</incoming>
      <outgoing>Flow_42</outgoing>
      <outgoing>Flow_44</outgoing>
    </exclusiveGateway>
    <task id="activity16" name="CTA or MRA ASAP">
      <incoming>Flow_42</incoming>
      <outgoing>Flow_43</outgoing>
    </task>
    <task id="activity17" name="continue urgent ICH management (Role: stroke team; Objects: ICH treatment plan)">
      <incoming>Flow_44</incoming>
      <outgoing>Flow_45</outgoing>
