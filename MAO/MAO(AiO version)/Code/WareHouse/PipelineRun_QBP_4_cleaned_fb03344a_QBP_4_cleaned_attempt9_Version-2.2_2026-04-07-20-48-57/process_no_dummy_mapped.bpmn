      <incoming>Flow_18</incoming>
      <outgoing>Flow_14</outgoing>
      <outgoing>Flow_15</outgoing>
    </parallelGateway>
    <task id="activity6.1" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_16</outgoing>
    </task>
    <task id="activity6.2" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>Flow_15</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
    <parallelGateway id="parallelgateway2.1Join" name="Parallel Merge">
      <incoming>Flow_16</incoming>
      <incoming>Flow_17</incoming>
      <outgoing>Flow_19</outgoing>
    </parallelGateway>
    <task id="activity7" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_19</incoming>
      <outgoing>Flow_27</outgoing>
    </task>
    <task id="activity8" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_24</incoming>
      <outgoing>Flow_28</outgoing>
    </task>
    <task id="activity9.1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>
    <task id="activity9.2" name="prioritize rapid laboratory processing and reporting (Role: laboratory staff; Objects: urgent stroke blood work results)">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_29</outgoing>
    </task>
    <task id="activity10" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_26</incoming>
      <outgoing>Flow_30</outgoing>
    </task>
