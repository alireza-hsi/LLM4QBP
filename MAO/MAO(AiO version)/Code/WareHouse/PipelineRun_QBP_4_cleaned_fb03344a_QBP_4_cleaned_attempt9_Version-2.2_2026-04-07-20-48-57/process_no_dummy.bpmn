      <ns0:incoming>Flow_48</ns0:incoming>
      <ns0:incoming>Flow_50</ns0:incoming>
      <ns0:outgoing>Flow_53</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity18" name="continue stroke assessment and management outside the acute reperfusion pathway (Role: clinical team; Objects: patient-specific diagnostic and treatment plan within 48 hours)">
      <ns0:incoming>Flow_54</ns0:incoming>
      <ns0:outgoing>Flow_55</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity20" name="perform vascular imaging as soon as possible (Role: imaging team; Objects: brain and neck artery vascular imaging)">
      <ns0:incoming>Flow_56</ns0:incoming>
      <ns0:outgoing>Flow_57</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <ns0:incoming>Flow_53</ns0:incoming>
