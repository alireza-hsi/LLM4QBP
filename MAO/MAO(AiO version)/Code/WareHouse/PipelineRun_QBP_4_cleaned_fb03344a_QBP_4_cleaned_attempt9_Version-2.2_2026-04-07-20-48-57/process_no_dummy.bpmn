      <ns0:outgoing>Flow_61</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity23" name="monitor closely and screen swallowing ability when clinically appropriate (Role: clinical team; Objects: level of alertness, swallowing ability within first 24 hours)">
      <ns0:incoming>Flow_59</ns0:incoming>
      <ns0:outgoing>Flow_60</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity24" name="perform full clinical swallowing assessment and advise required consistency of diet and fluids (Role: speech-language pathologist or trained specialist; Objects: swallowing ability, diet consistency, fluid consistency)">
      <ns0:incoming>Flow_61</ns0:incoming>
      <ns0:outgoing>Flow_62</ns0:outgoing>
    </ns0:task>
