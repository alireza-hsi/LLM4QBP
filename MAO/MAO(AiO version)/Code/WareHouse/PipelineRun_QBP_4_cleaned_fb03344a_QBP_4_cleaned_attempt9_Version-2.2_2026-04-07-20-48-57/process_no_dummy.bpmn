      <ns0:outgoing>Flow_37</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity12" name="consider advanced CT imaging for clinically eligible acute stroke treatment patients (Role: imaging team; Objects: CT, multiphase CTA, or Perfusion CT)">
      <ns0:incoming>Flow_33</ns0:incoming>
      <ns0:outgoing>Flow_34</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11" name="consider endovascular therapy (Role: stroke physician; Objects: EVT eligibility based on clinical and imaging criteria)">
      <ns0:incoming>Flow_34</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13" name="continue acute ischemic stroke management without EVT pathway (Role: stroke physician; Objects: ischemic stroke treatment plan)">
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <ns0:incoming>Flow_36</ns0:incoming>
      <ns0:incoming>Flow_38</ns0:incoming>
      <ns0:outgoing>Flow_48</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity14" name="treat ICH as a medical emergency and evaluate immediately (Role: stroke physician; Objects: acute ICH patient)">
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:outgoing>Flow_41</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="review anticoagulant therapy history and assess coagulation and platelet results (Role: stroke physician; Objects: anticoagulant use, platelet count, PTT, INR)">
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_46</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <ns0:incoming>Flow_46</ns0:incoming>
      <ns0:outgoing>Flow_42</ns0:outgoing>
      <ns0:outgoing>Flow_44</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity16" name="perform vascular imaging as soon as possible (Role: imaging team; Objects: CTA or MRA)">
      <ns0:incoming>Flow_42</ns0:incoming>
      <ns0:outgoing>Flow_43</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17" name="continue urgent ICH management (Role: stroke team; Objects: ICH treatment plan)">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:outgoing>Flow_45</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <ns0:incoming>Flow_43</ns0:incoming>
