      <ns0:outgoing>Flow_64</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity25" name="provide appropriate cross-continuum secondary prevention assessments and therapies whether patient is admitted or discharged from the ED (Role: clinical team; Objects: secondary prevention assessments and therapies from Modules 5 and 10)">
      <ns0:incoming>Flow_64</ns0:incoming>
      <ns0:outgoing>Flow_65</ns0:outgoing>
    </ns0:task>
