      <incoming>Flow_30</incoming>
      <outgoing>Flow_15</outgoing>
      <outgoing>Flow_17</outgoing>
    </exclusiveGateway>
    <task id="activity7-1" name="Do not mobilize patient early; document contraindication (Role: clinical team; Objects: patient, medical record)">
      <incoming>Flow_15</incoming>
      <outgoing>Flow_16</outgoing>
    </task>
    <task id="activity7-2" name="Patient should be mobilized">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_14</outgoing>
    </task>
    <task id="activity7-3" name="Avoid frequent out-of-bed activity within first 24 hours unless clinically justified (Role: clinical team; Objects: patient)">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_18</outgoing>
    </task>
