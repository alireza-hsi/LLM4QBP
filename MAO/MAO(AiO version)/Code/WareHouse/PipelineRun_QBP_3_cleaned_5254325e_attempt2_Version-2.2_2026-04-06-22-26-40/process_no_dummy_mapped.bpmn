    <task id="activity15-1" name="Determine patient discharge plan (in-hospital rehabilitation or discharge) (Role: clinical team; Objects: patient, care plan)">
      <incoming>Flow_44</incoming>
      <outgoing>Flow_45</outgoing>
    </task>
    <task id="activity15-2" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>Flow_45</incoming>
      <outgoing>Flow_47</outgoing>
    </task>
    <task id="activity18" name="Proceed with alternative care pathway as per TIA/minor stroke protocol (Role: clinician; Objects: patient, TIA protocol)">
