    <task id="activity8" name="Use standardized, valid assessment tools to evaluate patients’ stroke-related impairments and functional status&#10;where possible, these tools should be in electronic format linked to the EHR">
      <incoming>Flow_31</incoming>
      <outgoing>Flow_38</outgoing>
    </task>
    <task id="activity9" name="Complete AlphaFIM on or by day 3 after admission(target day 3, admission day is day 1)">
      <incoming>Flow_32</incoming>
      <outgoing>Flow_39</outgoing>
    </task>
    <task id="activity10-1" name="Assess patient for risk of developing venous thromboembolism">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_21</outgoing>
    </task>
    <task id="activity10-2" name="Document risk level in patient record (Role: clinicians; Objects: patient, medical record)">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_40</outgoing>
    </task>
    <task id="activity11" name="Encourage early mobilization and adequate hydration for all acute stroke patients to help prevent venous thromboembolism">
      <incoming>Flow_34</incoming>
      <outgoing>Flow_41</outgoing>
    </task>
    <task id="activity12" name="The nutrition and hydration status of stroke patients should be assessed within the first 48 hours of admission using a valid screening tool.">
      <incoming>Flow_23</incoming>
      <outgoing>Flow_28</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_28</incoming>
      <outgoing>Flow_24</outgoing>
      <outgoing>Flow_26</outgoing>
    </exclusiveGateway>
    <task id="activity13" name="Give patient a referral to a dietitian within 7 days of admission">
      <incoming>Flow_24</incoming>
      <outgoing>Flow_25</outgoing>
    </task>
    <task id="activity14" name="Continue standard nutritional monitoring (Role: clinicians; Objects: patient)">
      <incoming>Flow_26</incoming>
      <outgoing>Flow_27</outgoing>
    </task>
