    <task id="activity6-1" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    <task id="activity6-2" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_36</outgoing>
    </task>
