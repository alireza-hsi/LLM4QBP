    <sequenceFlow id="Flow_4" name="Patient presents with potentially disabling, acute neurological symptoms suggestive of acute stroke within 6.0 hours of symptom onset and may be eligible for treatment within 12 hours" sourceRef="exclusivegateway1" targetRef="activity3">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents with potentially disabling, acute neurological symptoms suggestive of acute stroke within 6.0 hours of symptom onset and may be eligible for treatment within 12 hours</conditionExpression>
