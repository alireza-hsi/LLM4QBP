      <incoming>Flow_37</incoming><incoming>Flow_39</incoming><outgoing>Flow_65</outgoing></exclusiveGateway>
    <task id="activity17" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies (All patients, whether admitted or discharged from the ED">
      <incoming>Flow_60</incoming><outgoing>Flow_66</outgoing></task>
