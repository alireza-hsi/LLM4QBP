      <incoming>Flow_41</incoming><outgoing>Flow_42</outgoing></task>
    <task id="activity19" name="Continue with appropriate clinical pathway (Role: Healthcare Provider; Objects: patient)">
      <incoming>Flow_43</incoming><outgoing>Flow_44</outgoing></task>
