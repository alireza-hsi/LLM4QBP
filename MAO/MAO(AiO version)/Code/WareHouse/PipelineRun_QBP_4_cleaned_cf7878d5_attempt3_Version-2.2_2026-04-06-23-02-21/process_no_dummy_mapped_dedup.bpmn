      <incoming>Flow_40</incoming><outgoing>Flow_36</outgoing><outgoing>Flow_38</outgoing></exclusiveGateway>
    <task id="activity15" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_36</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity16" name="Continue monitoring swallowing status as per protocol (Role: Healthcare Provider; Objects: patient)">
      <incoming>Flow_38</incoming><outgoing>Flow_39</outgoing></task>
