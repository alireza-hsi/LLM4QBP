  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_70</incoming></endEvent>
    <task id="activity1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_2</incoming><outgoing>Flow_69</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_69</incoming><outgoing>Flow_60</outgoing><outgoing>Flow_61</outgoing><outgoing>Flow_62</outgoing><outgoing>merged_Flow_57_Flow_8</outgoing><outgoing>merged_Flow_58_Flow_21</outgoing><outgoing>merged_Flow_59_Flow_29</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>merged_Flow_57_Flow_8</incoming><outgoing>Flow_4</outgoing><outgoing>Flow_6</outgoing></exclusiveGateway>
    <task id="activity3" name="Evaluate patients for endovascular therapy">
      <incoming>Flow_4</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity4" name="Proceed with standard acute stroke assessment (Role: Healthcare Provider; Objects: patient)">
      <incoming>Flow_6</incoming><outgoing>Flow_7</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_5</incoming><incoming>Flow_7</incoming><outgoing>Flow_13</outgoing></exclusiveGateway>
    <task id="activity5-1" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>Flow_13</incoming><outgoing>Flow_18</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_18</incoming><outgoing>Flow_14</outgoing><outgoing>Flow_16</outgoing></exclusiveGateway>
    <task id="activity6" name="Consideration of advanced CT imaging including CT and multiphase CTA or Perfusion CT">
      <incoming>Flow_14</incoming><outgoing>Flow_15</outgoing></task>
    <task id="activity7" name="Continue with standard imaging interpretation (Role: Healthcare Provider; Objects: patient)">
      <incoming>Flow_16</incoming><outgoing>Flow_17</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_15</incoming><incoming>Flow_17</incoming><outgoing>Flow_19</outgoing></exclusiveGateway>
    <task id="activity8" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_19</incoming><outgoing>Flow_63</outgoing></task>
    <task id="activity9" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>merged_Flow_58_Flow_21</incoming><outgoing>Flow_22</outgoing></task>
    <task id="activity10" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_22</incoming><outgoing>Flow_27</outgoing></task>
    <task id="activity11-1" name="Blood work: CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_27</incoming><outgoing>Flow_64</outgoing></task>
    <task id="activity12-1" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_59_Flow_29</incoming><outgoing>Flow_35</outgoing></task>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_35</incoming><outgoing>Flow_31</outgoing><outgoing>Flow_33</outgoing></exclusiveGateway>
    <task id="activity13" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_31</incoming><outgoing>Flow_32</outgoing></task>
    <task id="activity14" name="Proceed with standard care (Role: Healthcare Provider; Objects: patient)">
      <incoming>Flow_33</incoming><outgoing>Flow_34</outgoing></task>
