      <incoming>Flow_52</incoming><outgoing>Flow_48</outgoing><outgoing>Flow_50</outgoing></exclusiveGateway>
    <task id="activity22" name="CTA or MRA ASAP">
      <incoming>Flow_48</incoming><outgoing>Flow_49</outgoing></task>
