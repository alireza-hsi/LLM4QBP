      <incoming>Flow_62</incoming><outgoing>Flow_55</outgoing><outgoing>merged_Flow_53_Flow_46</outgoing></exclusiveGateway>
    <task id="activity20" name="Treat patient as a medical emergency. ICH should be promptly recognized, and patients should be evaluated immediately by physicians with expertise in stroke management">
      <incoming>merged_Flow_53_Flow_46</incoming><outgoing>Flow_47</outgoing></task>
    <task id="activity21" name="Evaluation should include questions about anticoagulant therapy, measurement of platelet count, PTT, and INR">
      <incoming>Flow_47</incoming><outgoing>Flow_52</outgoing></task>
