      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2" name="initiate pathway/mechanism to transfer patient to a higher level provider when needed (Role: ED clinician; Objects: transfer criteria, receiving service contacts)">
