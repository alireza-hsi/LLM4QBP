    <ns0:task id="activity14" name="screen for high-risk marker: respiratory distress (Role: ED clinician; Objects: clinical exam findings)">
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_42</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="screen for high-risk marker: hypoxemia (Role: ED clinician; Objects: oxygen saturation readings)">
      <ns0:incoming>Flow_42</ns0:incoming>
      <ns0:outgoing>Flow_53</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity16" name="screen for high-risk marker: severity of pulmonary edema (Role: ED clinician; Objects: chest x-ray, clinical exam)">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:outgoing>Flow_45</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17" name="screen for high-risk marker: hemodynamic compromise (Role: ED clinician; Objects: blood pressure, perfusion signs)">
      <ns0:incoming>Flow_45</ns0:incoming>
      <ns0:outgoing>Flow_54</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18" name="screen for high-risk marker: significant arrhythmias (Role: ED clinician; Objects: ECG, telemetry)">
