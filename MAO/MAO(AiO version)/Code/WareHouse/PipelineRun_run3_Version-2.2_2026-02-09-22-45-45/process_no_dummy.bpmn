  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_78</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity0" name="apply standardized risk assessment/stratification tool consistently (HF-capable, used across hospitals) (Role: ED clinician; Objects: risk stratification tool, patient presentation data)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_1" name="activate acute heart failure episode-of-care pathway at triage/arrival (Role: ED clinician; Objects: HF pathway criteria, triage note)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_2" name="collect key risk-stratification inputs (history, comorbidities, vitals, ED course) (Role: ED clinician; Objects: patient history, vitals, presenting symptoms)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_3" name="document standardized risk category and initial care setting recommendation (Role: ED clinician; Objects: risk stratification result, EHR documentation)">
