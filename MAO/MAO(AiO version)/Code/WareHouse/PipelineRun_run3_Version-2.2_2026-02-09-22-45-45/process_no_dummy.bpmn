    <ns0:task id="activity13_3" name="escalate/adjust diuretic strategy per protocol and plan reassessment (Role: ED clinician; Objects: diuretic protocol, orders, reassessment time)">
      <ns0:incoming>Flow_35</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13_4" name="continue current diuretic strategy and proceed with risk classification (Role: ED clinician; Objects: current orders, monitoring plan)">
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:task>
