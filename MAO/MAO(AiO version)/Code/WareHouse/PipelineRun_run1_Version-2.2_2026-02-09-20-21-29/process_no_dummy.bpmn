    <ns0:task id="activity18-1" name="Monitor and manage vital signs (Role: non-surgical hospital staff; Objects: patient, monitoring equipment)">
      <ns0:incoming>Flow_29</ns0:incoming>
      <ns0:outgoing>Flow_30</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18-2" name="Provide pain management and prevent complications (hydration, delirium, pressure sores) (Role: non-surgical hospital staff; Objects: patient, management protocols)">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity19" name="Initiate formal protocol for timely transfer to surgical hospital (Role: non-surgical hospital staff; Objects: patient, transfer protocol)">
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity20" name="Ensure surgery occurs within 48 hours of initial presentation (Role: non-surgical hospital staff; Objects: patient, surgery scheduling)">
      <ns0:incoming>Flow_32</ns0:incoming>
      <ns0:outgoing>Flow_33</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity21" name="Ensure formal protocols for transfer and repatriation are in place and followed (Role: LHINs and hospital administration; Objects: protocol documentation)">
      <ns0:incoming>Flow_33</ns0:incoming>
      <ns0:outgoing>Flow_39</ns0:outgoing>
    </ns0:task>
