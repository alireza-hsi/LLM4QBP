  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_41</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="Establish hip fracture care pathway specifying perioperative patient goals by day of stay (Role: hospital administration; Objects: hip fracture care pathway documentation)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:outgoing>Flow_34</ns0:outgoing>
      <ns0:outgoing>Flow_36</ns0:outgoing>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity2" name="Register and triage suspected hip fracture patient (Role: ED triage nurse; Objects: patient, triage documentation)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="See patient within 1 hour of arrival (target: 90%) (Role: ED physician; Objects: patient, triage notes)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="Request orthopedic surgeon consultation (within 2 hours, target: 90%) (Role: ED physician; Objects: patient, consultation request)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="Notify anesthesiologist/internist for consultation as needed (Role: ED physician; Objects: patient, consultation request)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-1" name="Assess and document clinical status (reason for fall, fluid balance, pressure sore risk, hydration/nutrition, pain, temperature, collateral injuries) (Role: ED clinical staff; Objects: patient, assessment forms)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-2" name="Order and review diagnostics (blood work, X-rays) (Role: ED clinical staff; Objects: patient, diagnostic orders, results)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-3-4" name="Assess and document comorbid conditions, current drug therapy (including anticoagulants), functional, mental, and social status (continence, pre-fracture functional ability/mobility, physical/functional level, mental state (MMSE/MOCA/CAM), social circumstances) (Role: ED clinical staff; Objects: patient, medication list, validated screening tools, assessment forms)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="Complete medication reconciliation using standardized form (Role: ED clinical staff; Objects: patient, medication list, standardized form)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8" name="Manage hydration, pain, risk of delirium, and risk of pressure sores within ED (Role: ED clinical staff; Objects: patient, management protocols)">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity9" name="Determine need for inpatient admission (Role: ED physician; Objects: patient, assessment findings)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity10" name="Admit patient within 4 hours of ED stay (target: 90%) (Role: ED staff; Objects: patient, admission documentation)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11" name="Plan discharge to most appropriate setting based on assessment (Role: ED staff; Objects: patient, discharge plan)">
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_16</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_35</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity12" name="Follow same early assessment and documentation practices as ED pathway (Role: clinical staff; Objects: patient, assessment forms, validated screening tools)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13" name="Notify orthopedic surgeon and anesthesiologist/internist for consultation as needed (Role: clinical staff; Objects: patient, consultation request)">
      <ns0:incoming>Flow_20</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity14" name="Complete medication reconciliation and manage hydration, pain, delirium, and pressure sore risk (Role: clinical staff; Objects: patient, management protocols)">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="Determine need for inpatient admission or discharge (Role: clinical staff; Objects: patient, assessment findings)">
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <ns0:incoming>Flow_27</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity16" name="Admit patient to inpatient care (Role: clinical staff; Objects: patient, admission documentation)">
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17" name="Plan discharge to most appropriate setting (Role: clinical staff; Objects: patient, discharge plan)">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:task>
