<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_51</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="screen and assess the patient for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED (Role: emergency department clinicians; Objects: diabetes screening,dental assessment,cognitive assessment,depression screening)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_50</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_50</ns0:incoming>
      <ns0:outgoing>Flow_46</ns0:outgoing>
      <ns0:outgoing>Flow_48</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity2" name="admit the patient to a specialized geographically defined stroke unit dedicated to stroke management (Role: admitting team; Objects: stroke unit bed)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="assign the core stroke unit team with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (Role: stroke unit coordinator; Objects: core stroke unit team)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3_1" name="ensure 7-day access to the specialized interprofessional team (Role: stroke unit coordinator; Objects: 7-day interprofessional team coverage)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="use standardized validated assessment tools linked to the EHR where possible to evaluate stroke-related impairments and functional status (Role: interprofessional stroke team; Objects: standardized assessment tools,EHR)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
      <ns0:outgoing>Flow_12</ns0:outgoing>
      <ns0:outgoing>Flow_13</ns0:outgoing>
      <ns0:outgoing>Flow_14</ns0:outgoing>
      <ns0:outgoing>Flow_15</ns0:outgoing>
      <ns0:outgoing>Flow_16</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity5" name="assess the patient within 48 hours of admission and formulate a physiotherapy management plan (Role: physiotherapist; Objects: physiotherapy assessment)">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="assess the patient within 48 hours of admission and formulate an occupational therapy management plan (Role: occupational therapist; Objects: occupational therapy assessment)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="assess the patient within 48 hours of admission and formulate a speech-language pathology management plan (Role: speech-language pathologist; Objects: speech-language assessment)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day as day 1 (Role: clinical team; Objects: AlphaFIM)">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity9" name="assess the patient for risk of developing venous thromboembolism (Role: clinical team; Objects: VTE risk assessment)">
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway2" name="Parallel Gateway">
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity10" name="assess nutrition status within the first 48 hours of admission using a valid screening tool (Role: nursing staff; Objects: nutrition screening tool)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10_1" name="assess hydration status within the first 48 hours of admission using a valid screening tool (Role: nursing staff; Objects: hydration screening tool)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway2Join" name="Parallel Merge">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:parallelGateway>
