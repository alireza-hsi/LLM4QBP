      <ns0:incoming>Flow_20</ns0:incoming>
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_30</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
      <ns0:outgoing>Flow_26</ns0:outgoing>
      <ns0:outgoing>Flow_28</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity11" name="document contraindication to early mobilization and continue monitoring for later mobilization readiness (Role: stroke physician; Objects: contraindication record)">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity12" name="use clinical judgement to consider limited mobilization within 24 hours of stroke onset and avoid frequent out-of-bed activity (Role: interprofessional stroke team; Objects: early mobilization plan)">
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity14" name="mobilize the patient early between 24 hours and 48 hours of stroke onset (Role: interprofessional stroke team; Objects: mobilization plan)">
      <ns0:incoming>Flow_28</ns0:incoming>
      <ns0:outgoing>Flow_29</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:incoming>Flow_27</ns0:incoming>
      <ns0:incoming>Flow_29</ns0:incoming>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity15_new" name="encourage adequate hydration to help prevent venous thromboembolism (Role: nursing staff; Objects: hydration plan)">
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <ns0:incoming>Flow_36</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
      <ns0:outgoing>Flow_34</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity16_new" name="refer the patient to a dietitian within 7 days of admission for recommendations (Role: clinical team; Objects: dietitian referral)">
      <ns0:incoming>Flow_32</ns0:incoming>
      <ns0:outgoing>Flow_33</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity20_1" name="consider enteral nutrition support within 7 days of admission (Role: dietitian; Objects: enteral nutrition support plan)">
      <ns0:incoming>Flow_34</ns0:incoming>
      <ns0:outgoing>Flow_35</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <ns0:incoming>Flow_33</ns0:incoming>
      <ns0:incoming>Flow_35</ns0:incoming>
      <ns0:outgoing>Flow_41</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_37</ns0:outgoing>
      <ns0:outgoing>Flow_39</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity21" name="provide appropriate cross-continuum secondary prevention assessments and therapies for patients transferred to in-hospital rehabilitation (Role: stroke team; Objects: secondary prevention assessments and therapies)">
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity21_1" name="provide appropriate cross-continuum secondary prevention assessments and therapies for patients being discharged (Role: stroke team; Objects: secondary prevention assessments and therapies)">
      <ns0:incoming>Flow_39</ns0:incoming>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <ns0:incoming>Flow_38</ns0:incoming>
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:outgoing>Flow_47</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity22" name="recognize that Module 3a acute care treatment recommendations are not applicable to TIA or minor nondisabling stroke (Role: clinical team; Objects: applicability determination)">
      <ns0:incoming>Flow_43</ns0:incoming>
      <ns0:outgoing>Flow_44</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_1" name="forward the screening and assessment results to the TIA clinic for follow-up (Role: emergency department clinicians; Objects: screening results)">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:outgoing>Flow_45</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity23" name="provide appropriate cross-continuum secondary prevention assessments and therapies and arrange follow-up with the TIA clinic as appropriate (Role: clinical team; Objects: secondary prevention assessments and therapies,TIA clinic follow-up)">
      <ns0:incoming>Flow_45</ns0:incoming>
      <ns0:outgoing>Flow_49</ns0:outgoing>
    </ns0:task>
