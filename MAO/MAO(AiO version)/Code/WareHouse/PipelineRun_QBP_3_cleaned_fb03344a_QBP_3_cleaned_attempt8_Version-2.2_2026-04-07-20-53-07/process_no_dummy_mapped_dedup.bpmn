    <sequenceFlow id="Flow_32" name="nutrition concerns, hydration deficits, dysphagia, other comorbidities affecting nutrition or hydration, or inability to meet nutritional and fluid requirements are identified" sourceRef="inclusivegateway1" targetRef="activity16_new">
      <conditionExpression xsi:type="bpmn:tFormalExpression">nutrition concerns, hydration deficits, dysphagia, other comorbidities affecting nutrition or hydration, or inability to meet nutritional and fluid requirements are identified</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_33" sourceRef="activity16_new" targetRef="inclusivegateway1Join" />
    <sequenceFlow id="Flow_34" name="patient is unable to meet nutritional and fluid requirements" sourceRef="inclusivegateway1" targetRef="activity20_1">
