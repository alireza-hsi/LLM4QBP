    </sequenceFlow>
    <sequenceFlow id="Flow_25" sourceRef="activity11" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_26" name="within 24 hours of stroke onset, mobilization is not contraindicated, and limited mobilization may be reasonable based on clinical judgement" sourceRef="exclusivegateway2" targetRef="activity12">
      <conditionExpression xsi:type="bpmn:tFormalExpression">within 24 hours of stroke onset, mobilization is not contraindicated, and limited mobilization may be reasonable based on clinical judgement</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_27" sourceRef="activity12" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_28" name="between 24 hours and 48 hours of stroke onset and not contraindicated" sourceRef="exclusivegateway2" targetRef="activity14">
      <conditionExpression xsi:type="bpmn:tFormalExpression">between 24 hours and 48 hours of stroke onset and not contraindicated</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_29" sourceRef="activity14" targetRef="exclusivegateway2Join" />
