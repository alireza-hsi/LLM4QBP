<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_51</incoming></endEvent>
    <task id="activity1" name="Patients should be screened/assessed for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED, and the results should be forwarded to the TIA clinic for follow-up">
      <incoming>Flow_1</incoming><outgoing>Flow_50</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_50</incoming><outgoing>merged_Flow_46_Flow_3</outgoing><outgoing>merged_Flow_48_Flow_43</outgoing></exclusiveGateway>
    <task id="activity2" name="Admit the patient to a specialized, geographically&#10;defined hospital unit dedicated to the management of stroke patients with the following requirements:&#10;&#10;&#10;1- The core stroke unit team should consist of health care professionals with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (a dietitian).&#10;&#10;2- To have the necessary stroke expertise, the health care professionals on the core stroke unit team should be individuals who spend the vast majority of their time treating stroke patients and regularly complete education about stroke care.&#10;&#10;3- Patients should have access to a specialized interprofessional team 7 days a week">
      <incoming>merged_Flow_46_Flow_3</incoming><outgoing>Flow_6</outgoing></task>
    <task id="activity4" name="Use standardized, valid assessment tools to evaluate patients’ stroke-related impairments and functional status&#10;where possible, these tools should be in electronic format linked to the EHR">
      <incoming>Flow_6</incoming><outgoing>Flow_23</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_23</incoming><outgoing>Flow_11</outgoing><outgoing>Flow_12</outgoing><outgoing>Flow_13</outgoing><outgoing>Flow_14</outgoing><outgoing>Flow_15</outgoing><outgoing>Flow_16</outgoing></parallelGateway>
    <task id="activity5" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_11</incoming><outgoing>Flow_17</outgoing></task>
    <task id="activity6" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_12</incoming><outgoing>Flow_18</outgoing></task>
    <task id="activity7" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_13</incoming><outgoing>Flow_19</outgoing></task>
    <task id="activity8" name="Complete AlphaFIM on or by day 3 after admission(target day 3, admission day is day 1)">
      <incoming>Flow_14</incoming><outgoing>Flow_20</outgoing></task>
    <task id="activity9" name="Assess patient for risk of developing venous thromboembolism">
      <incoming>Flow_15</incoming><outgoing>Flow_21</outgoing></task>
    <task id="activity10" name="The nutrition and hydration status of stroke patients should be assessed within the first 48 hours of admission using a valid screening tool.">
      <incoming>Flow_16</incoming><outgoing>Flow_22</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_17</incoming><incoming>Flow_18</incoming><incoming>Flow_19</incoming><incoming>Flow_20</incoming><incoming>Flow_21</incoming><incoming>Flow_22</incoming><outgoing>Flow_30</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_30</incoming><outgoing>Flow_24</outgoing><outgoing>Flow_26</outgoing><outgoing>Flow_28</outgoing></exclusiveGateway>
    <task id="activity11" name="document contraindication to early mobilization and continue monitoring for later mobilization readiness (Role: stroke physician; Objects: contraindication record)">
      <incoming>Flow_24</incoming><outgoing>Flow_25</outgoing></task>
    <task id="activity12" name="Patient should be mobilized">
      <incoming>Flow_26</incoming><outgoing>Flow_27</outgoing></task>
    <task id="activity14" name="Mobilize patient">
      <incoming>Flow_28</incoming><outgoing>Flow_29</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_25</incoming><incoming>Flow_27</incoming><incoming>Flow_29</incoming><outgoing>Flow_31</outgoing></exclusiveGateway>
    <task id="activity15_new" name="Encourage early mobilization and adequate hydration for all acute stroke patients to help prevent venous thromboembolism">
      <incoming>Flow_31</incoming><outgoing>Flow_36</outgoing></task>
    <inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <incoming>Flow_36</incoming><outgoing>Flow_32</outgoing><outgoing>Flow_34</outgoing></inclusiveGateway>
    <task id="activity16_new" name="Give patient a referral to a dietitian within 7 days of admission">
      <incoming>Flow_32</incoming><outgoing>Flow_33</outgoing></task>
    <task id="activity20_1" name="consider enteral nutrition support within 7 days of admission (Role: dietitian; Objects: enteral nutrition support plan)">
      <incoming>Flow_34</incoming><outgoing>Flow_35</outgoing></task>
    <inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <incoming>Flow_33</incoming><incoming>Flow_35</incoming><outgoing>Flow_41</outgoing></inclusiveGateway>
    <task id="activity21" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>Flow_41</incoming><outgoing>Flow_47</outgoing></task>
    <task id="activity22" name="recognize that Module 3a acute care treatment recommendations are not applicable to TIA or minor nondisabling stroke (Role: clinical team; Objects: applicability determination)">
      <incoming>merged_Flow_48_Flow_43</incoming><outgoing>Flow_44</outgoing></task>
    <task id="activity1_1" name="Patients should be screened/assessed for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED, and the results should be forwarded to the TIA clinic for follow-up">
      <incoming>Flow_44</incoming><outgoing>Flow_45</outgoing></task>
    <task id="activity23" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>Flow_45</incoming><outgoing>Flow_49</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_47</incoming><incoming>Flow_49</incoming><outgoing>Flow_51</outgoing></exclusiveGateway>
