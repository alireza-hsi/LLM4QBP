      <ns0:outgoing>Flow_30</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity14" name="mobilize patient early between 24 hours and 48 hours of stroke onset (Role: clinical team; Objects: early mobilization plan)">
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="use clinical judgement for limited mobilization within 24 hours and avoid frequent out-of-bed activity in the very early time frame (Role: clinical team; Objects: very early mobilization plan)">
      <ns0:incoming>Flow_28</ns0:incoming>
      <ns0:outgoing>Flow_29</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity16" name="defer mobilization and document contraindications while continuing other preventive care (Role: clinical team; Objects: contraindications documentation, preventive care plan)">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:task>
