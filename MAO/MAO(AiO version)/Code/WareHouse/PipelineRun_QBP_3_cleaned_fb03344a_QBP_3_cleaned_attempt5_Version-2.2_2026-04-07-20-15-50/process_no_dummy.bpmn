    <ns0:task id="activity12" name="refer patient to a dietitian within 7 days of admission for recommendations and consideration of enteral nutrition support if unable to meet nutritional and fluid requirements (Role: clinical team; Objects: dietitian referral, nutrition recommendations, enteral nutrition support plan)">
      <ns0:incoming>Flow_47</ns0:incoming>
      <ns0:outgoing>Flow_48</ns0:outgoing>
    </ns0:task>
