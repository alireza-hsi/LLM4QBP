    <ns0:task id="activity18a" name="complete cross-continuum secondary prevention assessment for all patients whether transferred to in-hospital rehabilitation or discharged (Role: stroke team; Objects: secondary prevention assessment, Modules 5 and 10 assessment elements)">
      <ns0:incoming>Flow_52</ns0:incoming>
      <ns0:outgoing>Flow_53</ns0:outgoing>
    </ns0:task>
