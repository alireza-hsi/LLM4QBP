  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_62</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity17a" name="screen or assess patient for diabetes upon presentation (Role: ED team; Objects: diabetes screen)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17b" name="screen or assess patient for dental issues upon presentation (Role: ED team; Objects: dental assessment)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17c" name="screen or assess patient for cognitive impairment upon presentation (Role: ED team; Objects: cognitive assessment)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity17d" name="screen or assess patient for depression upon presentation (Role: ED team; Objects: depression assessment)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1" name="identify admitted patient diagnosis and determine whether Module 3a acute care treatment applies (Role: ED and admitting team; Objects: stroke severity, TIA status, admission information)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_61</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_61</ns0:incoming>
      <ns0:outgoing>Flow_57</ns0:outgoing>
      <ns0:outgoing>Flow_59</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity2" name="admit patient to a specialized geographically defined stroke unit dedicated to stroke management (Role: admitting team; Objects: co-located stroke unit bed)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="assign a core stroke unit team with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (Role: stroke program; Objects: interprofessional stroke unit team)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="ensure team members spend the vast majority of their time treating stroke patients and regularly complete stroke care education (Role: stroke unit leadership; Objects: stroke expertise, stroke education records)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="provide access to the specialized interprofessional stroke team 7 days a week (Role: hospital; Objects: 7-day stroke unit staffing)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
      <ns0:outgoing>Flow_33</ns0:outgoing>
      <ns0:outgoing>Flow_34</ns0:outgoing>
      <ns0:outgoing>Flow_35</ns0:outgoing>
    </ns0:parallelGateway>
