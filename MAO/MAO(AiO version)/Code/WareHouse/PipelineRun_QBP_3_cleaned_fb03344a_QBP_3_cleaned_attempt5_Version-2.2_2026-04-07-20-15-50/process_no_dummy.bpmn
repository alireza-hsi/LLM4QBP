      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6b" name="evaluate functional status using standardized valid assessment tools (Role: clinicians; Objects: standardized functional status assessment tools)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:task>
