      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity8a" name="assess patient within 48 hours of hospital admission (Role: physiotherapy team member; Objects: physiotherapy assessment)">
      <ns0:incoming>Flow_15</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
