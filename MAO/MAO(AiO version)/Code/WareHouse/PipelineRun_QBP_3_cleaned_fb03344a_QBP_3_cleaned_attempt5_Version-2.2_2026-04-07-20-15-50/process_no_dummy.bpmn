    </ns0:parallelGateway>
    <ns0:task id="activity8d" name="formulate an interprofessional management plan (Role: physiotherapy occupational therapy and speech-language pathology team members; Objects: therapy assessments, management plan)">
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_37</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity9" name="assess risk of developing venous thromboembolism (Role: clinicians; Objects: venous thromboembolism risk assessment)">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10" name="encourage adequate hydration to help prevent venous thromboembolism (Role: clinical team; Objects: hydration plan)">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:task>
