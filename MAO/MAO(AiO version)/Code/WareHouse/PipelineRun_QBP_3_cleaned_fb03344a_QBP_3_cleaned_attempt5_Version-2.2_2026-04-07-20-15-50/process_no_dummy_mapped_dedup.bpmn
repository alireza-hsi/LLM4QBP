      <incoming>Flow_56</incoming><outgoing>Flow_60</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_58</incoming><incoming>Flow_60</incoming><outgoing>Flow_62</outgoing></exclusiveGateway>
