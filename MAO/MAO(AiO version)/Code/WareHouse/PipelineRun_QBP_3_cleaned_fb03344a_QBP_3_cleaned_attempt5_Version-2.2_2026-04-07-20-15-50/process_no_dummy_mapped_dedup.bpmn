  <sequenceFlow id="merged_Flow_57_Flow_7" sourceRef="exclusivegateway1" targetRef="activity2" name="patient has acute stroke requiring inpatient acute care treatment"><conditionExpression xsi:type="bpmn:tFormalExpression">patient has acute stroke requiring inpatient acute care treatment</conditionExpression></sequenceFlow><sequenceFlow id="merged_Flow_32_Flow_12" sourceRef="parallelgateway1" targetRef="activity6a" /><sequenceFlow id="merged_Flow_33_Flow_21" sourceRef="parallelgateway1" targetRef="activity8a" /><sequenceFlow id="merged_Flow_34_Flow_24" sourceRef="parallelgateway1" targetRef="activity9" /><sequenceFlow id="merged_Flow_59_Flow_55" sourceRef="exclusivegateway1" targetRef="activity19" name="patient has TIA or minor nondisabling stroke so Module 3a recommendations are not applicable"><conditionExpression xsi:type="bpmn:tFormalExpression">patient has TIA or minor nondisabling stroke so Module 3a recommendations are not applicable</conditionExpression></sequenceFlow></process>
