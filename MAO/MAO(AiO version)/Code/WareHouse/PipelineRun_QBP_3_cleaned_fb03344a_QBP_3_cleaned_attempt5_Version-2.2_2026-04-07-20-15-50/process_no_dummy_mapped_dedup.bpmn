    <sequenceFlow id="Flow_25" sourceRef="activity9" targetRef="activity10" />
    <sequenceFlow id="Flow_26" name="24 to 48 hours since stroke onset and no contraindication to mobilization" sourceRef="exclusivegateway3" targetRef="activity14">
      <conditionExpression xsi:type="bpmn:tFormalExpression">24 to 48 hours since stroke onset and no contraindication to mobilization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_27" sourceRef="activity14" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_28" name="within 24 hours of stroke onset and mobilization is considered reasonable based on clinical judgement" sourceRef="exclusivegateway3" targetRef="activity15">
      <conditionExpression xsi:type="bpmn:tFormalExpression">within 24 hours of stroke onset and mobilization is considered reasonable based on clinical judgement</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_29" sourceRef="activity15" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_30" name="mobilization is contraindicated" sourceRef="exclusivegateway3" targetRef="activity16">
      <conditionExpression xsi:type="bpmn:tFormalExpression">mobilization is contraindicated</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_31" sourceRef="activity16" targetRef="exclusivegateway3Join" />
