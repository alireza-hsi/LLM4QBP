  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_62</incoming></endEvent>
    <task id="activity17a" name="Patients should be screened/assessed for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED, and the results should be forwarded to the TIA clinic for follow-up">
      <incoming>Flow_1</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity1" name="identify admitted patient diagnosis and determine whether Module 3a acute care treatment applies (Role: ED and admitting team; Objects: stroke severity, TIA status, admission information)">
      <incoming>Flow_5</incoming><outgoing>Flow_61</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_61</incoming><outgoing>merged_Flow_57_Flow_7</outgoing><outgoing>merged_Flow_59_Flow_55</outgoing></exclusiveGateway>
    <task id="activity2" name="Admit the patient to a specialized, geographically&#10;defined hospital unit dedicated to the management of stroke patients with the following requirements:&#10;&#10;&#10;1- The core stroke unit team should consist of health care professionals with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (a dietitian).&#10;&#10;2- To have the necessary stroke expertise, the health care professionals on the core stroke unit team should be individuals who spend the vast majority of their time treating stroke patients and regularly complete education about stroke care.&#10;&#10;3- Patients should have access to a specialized interprofessional team 7 days a week">
      <incoming>merged_Flow_57_Flow_7</incoming><outgoing>Flow_40</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_40</incoming><outgoing>Flow_35</outgoing><outgoing>merged_Flow_32_Flow_12</outgoing><outgoing>merged_Flow_33_Flow_21</outgoing><outgoing>merged_Flow_34_Flow_24</outgoing></parallelGateway>
    <task id="activity6a" name="Use standardized, valid assessment tools to evaluate patients’ stroke-related impairments and functional status&#10;where possible, these tools should be in electronic format linked to the EHR">
      <incoming>merged_Flow_32_Flow_12</incoming><outgoing>Flow_36</outgoing></task>
    <task id="activity8a" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>merged_Flow_33_Flow_21</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity9" name="Assess patient for risk of developing venous thromboembolism">
      <incoming>merged_Flow_34_Flow_24</incoming><outgoing>Flow_25</outgoing></task>
    <task id="activity10" name="Encourage early mobilization and adequate hydration for all acute stroke patients to help prevent venous thromboembolism">
      <incoming>Flow_25</incoming><outgoing>Flow_38</outgoing></task>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_35</incoming><outgoing>Flow_26</outgoing><outgoing>Flow_28</outgoing><outgoing>Flow_30</outgoing></exclusiveGateway>
    <task id="activity14" name="Patient should be mobilized">
      <incoming>Flow_26</incoming><outgoing>Flow_27</outgoing></task>
    <task id="activity15" name="use clinical judgement for limited mobilization within 24 hours and avoid frequent out-of-bed activity in the very early time frame (Role: clinical team; Objects: very early mobilization plan)">
      <incoming>Flow_28</incoming><outgoing>Flow_29</outgoing></task>
    <task id="activity16" name="defer mobilization and document contraindications while continuing other preventive care (Role: clinical team; Objects: contraindications documentation, preventive care plan)">
      <incoming>Flow_30</incoming><outgoing>Flow_31</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_27</incoming><incoming>Flow_29</incoming><incoming>Flow_31</incoming><outgoing>Flow_39</outgoing></exclusiveGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_36</incoming><incoming>Flow_37</incoming><incoming>Flow_38</incoming><incoming>Flow_39</incoming><outgoing>Flow_41</outgoing></parallelGateway>
    <task id="activity7" name="Complete AlphaFIM on or by day 3 after admission(target day 3, admission day is day 1)">
      <incoming>Flow_41</incoming><outgoing>Flow_46</outgoing></task>
    <task id="activity11a" name="The nutrition and hydration status of stroke patients should be assessed within the first 48 hours of admission using a valid screening tool.">
      <incoming>Flow_46</incoming><outgoing>Flow_51</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_51</incoming><outgoing>Flow_47</outgoing><outgoing>Flow_49</outgoing></exclusiveGateway>
    <task id="activity12" name="Give patient a referral to a dietitian within 7 days of admission">
      <incoming>Flow_47</incoming><outgoing>Flow_48</outgoing></task>
    <task id="activity13" name="continue routine nutrition and hydration monitoring (Role: clinical team; Objects: nutrition and hydration status)">
      <incoming>Flow_49</incoming><outgoing>Flow_50</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_48</incoming><incoming>Flow_50</incoming><outgoing>Flow_52</outgoing></exclusiveGateway>
    <task id="activity18a" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>Flow_52</incoming><outgoing>Flow_58</outgoing></task>
    <task id="activity19" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>merged_Flow_59_Flow_55</incoming><outgoing>Flow_56</outgoing></task>
