      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10" name="measure heart rate, blood pressure, and oxygen saturation frequently until the patient is stabilized (Role: ED nurse; Objects: vital signs and oxygen saturation)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
