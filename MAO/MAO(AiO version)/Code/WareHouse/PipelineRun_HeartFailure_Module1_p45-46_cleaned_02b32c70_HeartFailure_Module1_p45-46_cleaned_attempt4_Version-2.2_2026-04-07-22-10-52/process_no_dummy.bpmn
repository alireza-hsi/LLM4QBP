    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_72</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1_1" name="collect presenting symptoms, vital status, and relevant comorbidity and disposition information (Role: ED clinician; Objects: initial presentation data for standardized risk stratification)">
