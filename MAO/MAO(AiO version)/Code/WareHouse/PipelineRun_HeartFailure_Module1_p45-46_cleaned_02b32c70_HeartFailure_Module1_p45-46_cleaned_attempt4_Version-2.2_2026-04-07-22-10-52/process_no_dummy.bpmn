      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2_1" name="perform immediate clinical assessment of airway, breathing, circulation, and congestion status (Role: ED clinician; Objects: patient with suspected acute heart failure)">
