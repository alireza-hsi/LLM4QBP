    <sequenceFlow id="Flow_51" name="clinical judgment and local resources support hospital admission using NICE and or GOLD criteria such as failure to respond to initial medical management, insufficient home support, inability to cope at home, marked breathlessness or resting dyspnea, severe underlying COPD or poor general condition, decreased level of activity, cyanosis, worsening peripheral edema or new physical signs, decreased level of consciousness, long-term oxygen therapy, social circumstances or older age, acute confusion, rapid onset or frequent exacerbations, significant comorbidity, SaO2 less than 90 percent, abnormal pH or PaO2, or changes on chest x-ray" sourceRef="exclusivegateway2" targetRef="activity18">
      <conditionExpression xsi:type="bpmn:tFormalExpression">clinical judgment and local resources support hospital admission using NICE and or GOLD criteria such as failure to respond to initial medical management, insufficient home support, inability to cope at home, marked breathlessness or resting dyspnea, severe underlying COPD or poor general condition, decreased level of activity, cyanosis, worsening peripheral edema or new physical signs, decreased level of consciousness, long-term oxygen therapy, social circumstances or older age, acute confusion, rapid onset or frequent exacerbations, significant comorbidity, SaO2 less than 90 percent, abnormal pH or PaO2, or changes on chest x-ray</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_52" sourceRef="activity18" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_53" name="clinical judgment and local resources support no hospital admission after re-evaluation" sourceRef="exclusivegateway2" targetRef="activity19">
      <conditionExpression xsi:type="bpmn:tFormalExpression">clinical judgment and local resources support no hospital admission after re-evaluation</conditionExpression>
    </sequenceFlow>
