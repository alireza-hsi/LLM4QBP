    <bpmn:sequenceFlow id="Flow_30" sourceRef="activity1" targetRef="exclusivegateway1" />
    <bpmn:sequenceFlow id="Flow_31" sourceRef="exclusivegateway1Join" targetRef="EndEvent_1" />
  </bpmn:process>
