<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_31</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="Establish hip fracture care pathway specifying perioperative patient goals by day of stay (Role: hospital administration; Objects: hip fracture care pathway documentation)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_30</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_30</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_2" name="(dummy branch entry)">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="See patient within 1 hour of arrival (target: 90% of patients) (Role: ED physician; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="Assess and document clinical factors (reason for fall, fluid balance, pressure sore risk, hydration and nutrition, pain, temperature, other collateral injuries) (Role: ED clinical staff; Objects: assessment forms, patient)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="Order and review diagnostic tests (blood work, X-rays) (Role: ED clinical staff; Objects: diagnostic orders, results)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="Assess and document comorbid conditions and current drug therapy (including anticoagulants) (Role: ED clinical staff; Objects: patient chart, medication list)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6" name="Assess and document functional, mental, and social status (continence, pre-fracture functional ability and mobility, physical and functional level, mental state using MMSE/MOCA/CAM, social circumstances) (Role: ED clinical staff; Objects: assessment forms, validated screening tools)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Notify orthopedic surgeon for consultation within 2 hours of arrival (target: 90% of patients) (Role: ED staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="Complete medication reconciliation using standardized form (Role: ED clinical staff; Objects: patient medication list, standardized form)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8" name="Manage hydration and pain (Role: ED clinical staff; Objects: patient, clinical protocols)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="Manage risk of delirium and risk of pressure sores (Role: ED clinical staff; Objects: patient, clinical protocols)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="Notify anesthesiologist/internist for consultation as needed (Role: ED staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity12" name="Admit patient to inpatient care within 4 hours of ED stay (target: 90% of patients) (Role: ED staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dummy_Flow_14" name="(dummy branch entry)">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity13" name="Follow same early assessment and documentation practices as ED (Role: clinical staff; Objects: suspected hip fracture patient, assessment forms)">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14" name="Notify orthopedic surgeon and anesthesiologist/internist for consultation as needed (Role: clinical staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity15" name="Admit patient to inpatient care as appropriate (Role: clinical staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dummy_Flow_18" name="(dummy branch entry)">
      <bpmn:incoming>Flow_28</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity16" name="Monitor vital signs and initiate supportive care (Role: non-surgical hospital staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity17" name="Communicate with receiving surgical hospital regarding patient status (Role: non-surgical hospital staff; Objects: patient, communication records)">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity18" name="Initiate formal protocol for timely transfer to surgical hospital (Role: non-surgical hospital staff; Objects: transfer protocol, patient)">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity19" name="Ensure patient receives surgery within 48 hours of initial presentation (Role: surgical hospital staff; Objects: suspected hip fracture patient)">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity20" name="Ensure repatriation to patient’s local hospital after surgery (Role: LHINs and hospitals; Objects: patient, transfer documentation)">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_29</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:incoming>Flow_29</bpmn:incoming>
      <bpmn:outgoing>Flow_31</bpmn:outgoing>
    </bpmn:exclusiveGateway>
