      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to ED</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_25" sourceRef="activity12" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_26" name="Patient presents to outpatient clinic or is directly admitted to acute care" sourceRef="exclusivegateway1" targetRef="dummy_Flow_14">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to outpatient clinic or is directly admitted to acute care</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_27" sourceRef="activity15" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_28" name="Patient presents to non-surgical hospital" sourceRef="exclusivegateway1" targetRef="dummy_Flow_18">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to non-surgical hospital</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
