  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_88</incoming></endEvent>
    <task id="activity1" name="identify suspected stroke presentation and initiate early assessment pathway (Role: triage clinician; Objects: suspected stroke patient at ED outpatient clinic or direct acute care admission)">
      <incoming>Flow_1</incoming><outgoing>Flow_8</outgoing></task>
    <task id="activity2_1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_8</incoming><outgoing>Flow_9</outgoing></task>
    <task id="activity3" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_9</incoming><outgoing>Flow_10</outgoing></task>
    <task id="activity4" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_10</incoming><outgoing>Flow_40</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_40</incoming><outgoing>Flow_32</outgoing><outgoing>Flow_33</outgoing><outgoing>Flow_34</outgoing><outgoing>Flow_35</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_32</incoming><outgoing>Flow_26</outgoing><outgoing>merged_Flow_24_Flow_17</outgoing></exclusiveGateway>
    <task id="activity5_1" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>merged_Flow_24_Flow_17</incoming><outgoing>Flow_22</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_22</incoming><outgoing>Flow_18</outgoing><outgoing>Flow_20</outgoing></exclusiveGateway>
    <task id="activity6" name="Consideration of advanced CT imaging including CT and multiphase CTA or Perfusion CT">
      <incoming>Flow_18</incoming><outgoing>Flow_19</outgoing></task>
    <task id="activity7" name="continue standard imaging pathway (Role: acute stroke team; Objects: initial brain imaging results)">
      <incoming>Flow_20</incoming><outgoing>Flow_21</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_19</incoming><incoming>Flow_21</incoming><outgoing>Flow_23</outgoing></exclusiveGateway>
    <task id="activity9" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_23</incoming><outgoing>Flow_25</outgoing></task>
    <task id="activity8" name="continue non-hyperacute assessment pathway (Role: acute stroke team; Objects: clinical history and examination findings)">
      <incoming>Flow_26</incoming><outgoing>Flow_27</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_25</incoming><incoming>Flow_27</incoming><outgoing>Flow_36</outgoing></exclusiveGateway>
    <task id="activity10" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_33</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity11_1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_34</incoming><outgoing>Flow_38</outgoing></task>
    <task id="activity17" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_35</incoming><outgoing>Flow_39</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_36</incoming><incoming>Flow_37</incoming><incoming>Flow_38</incoming><incoming>Flow_39</incoming><outgoing>Flow_48</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway5" name="Exclusive Gateway">
      <incoming>Flow_48</incoming><outgoing>Flow_46</outgoing><outgoing>merged_Flow_44_Flow_42</outgoing></exclusiveGateway>
    <task id="activity18_1" name="Evaluate patients for endovascular therapy">
      <incoming>merged_Flow_44_Flow_42</incoming><outgoing>Flow_45</outgoing></task>
    <task id="activity19" name="continue with non-EVT acute stroke management decision-making (Role: stroke physician; Objects: clinical assessment and imaging findings)">
      <incoming>Flow_46</incoming><outgoing>Flow_47</outgoing></task>
    <exclusiveGateway id="exclusivegateway5Join" name="Exclusive Merge">
      <incoming>Flow_45</incoming><incoming>Flow_47</incoming><outgoing>Flow_66</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway6" name="Exclusive Gateway">
      <incoming>Flow_66</incoming><outgoing>Flow_64</outgoing><outgoing>merged_Flow_62_Flow_50</outgoing></exclusiveGateway>
    <task id="activity20" name="Treat patient as a medical emergency. ICH should be promptly recognized, and patients should be evaluated&#10;immediately by physicians with expertise in stroke management">
      <incoming>merged_Flow_62_Flow_50</incoming><outgoing>Flow_51</outgoing></task>
    <task id="activity21_1" name="Evaluation should include questions&#10;about anticoagulant therapy, measurement of platelet count, PTT, and&#10;INR">
      <incoming>Flow_51</incoming><outgoing>Flow_57</outgoing></task>
    <exclusiveGateway id="exclusivegateway7" name="Exclusive Gateway">
      <incoming>Flow_57</incoming><outgoing>Flow_53</outgoing><outgoing>Flow_55</outgoing></exclusiveGateway>
    <task id="activity22" name="CTA or MRA ASAP">
      <incoming>Flow_53</incoming><outgoing>Flow_54</outgoing></task>
    <task id="activity23" name="continue ICH management without additional CTA or MRA (Role: stroke physician; Objects: ICH assessment findings)">
      <incoming>Flow_55</incoming><outgoing>Flow_56</outgoing></task>
    <exclusiveGateway id="exclusivegateway7Join" name="Exclusive Merge">
      <incoming>Flow_54</incoming><incoming>Flow_56</incoming><outgoing>Flow_63</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway8" name="Exclusive Gateway">
      <incoming>Flow_64</incoming><outgoing>Flow_58</outgoing><outgoing>Flow_60</outgoing></exclusiveGateway>
    <task id="activity24" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_58</incoming><outgoing>Flow_59</outgoing></task>
    <task id="activity25" name="continue pathway according to stroke subtype and timing (Role: acute stroke team; Objects: assessment and imaging results)">
      <incoming>Flow_60</incoming><outgoing>Flow_61</outgoing></task>
    <exclusiveGateway id="exclusivegateway8Join" name="Exclusive Merge">
      <incoming>Flow_59</incoming><incoming>Flow_61</incoming><outgoing>Flow_65</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway6Join" name="Exclusive Merge">
      <incoming>Flow_63</incoming><incoming>Flow_65</incoming><outgoing>Flow_71</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_71</incoming><outgoing>Flow_67</outgoing><outgoing>Flow_69</outgoing></exclusiveGateway>
    <task id="activity13" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_67</incoming><outgoing>Flow_68</outgoing></task>
    <task id="activity14" name="continue routine swallowing precautions after initial screen (Role: acute care team; Objects: swallowing status)">
      <incoming>Flow_69</incoming><outgoing>Flow_70</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_68</incoming><incoming>Flow_70</incoming><outgoing>Flow_76</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_76</incoming><outgoing>Flow_72</outgoing><outgoing>Flow_74</outgoing></exclusiveGateway>
    <task id="activity15" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_72</incoming><outgoing>Flow_73</outgoing></task>
    <task id="activity16" name="proceed according to bedside swallowing screen result (Role: acute care team; Objects: oral intake plan)">
      <incoming>Flow_74</incoming><outgoing>Flow_75</outgoing></task>
    <exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <incoming>Flow_73</incoming><incoming>Flow_75</incoming><outgoing>Flow_87</outgoing></exclusiveGateway>
    <task id="activity26_1" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_87</incoming><outgoing>Flow_88</outgoing></task>
