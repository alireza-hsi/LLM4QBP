    <sequenceFlow id="Flow_14" sourceRef="activity8-2" targetRef="activity8-3" />
    <sequenceFlow id="Flow_15" name="Patient not alert within first 24 hours" sourceRef="exclusivegateway1" targetRef="activity9">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient not alert within first 24 hours</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_16" sourceRef="activity9" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_17" name="Patient presents with features indicating dysphagia or pulmonary aspiration" sourceRef="exclusivegateway1" targetRef="activity10">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents with features indicating dysphagia or pulmonary aspiration</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_18" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_19" sourceRef="activity8-3" targetRef="exclusivegateway1" />
    <sequenceFlow id="Flow_20" name="Patient is candidate for carotid artery revascularization" sourceRef="exclusivegateway3" targetRef="activity13">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient is candidate for carotid artery revascularization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_21" sourceRef="activity13" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_22" name="Patient is clearly not a candidate for carotid artery revascularization" sourceRef="exclusivegateway3" targetRef="activity14">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient is clearly not a candidate for carotid artery revascularization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_23" sourceRef="activity14" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_24" name="Patient presents within 48 hours of symptom onset or with fluctuating motor or speech symptoms" sourceRef="exclusivegateway2" targetRef="exclusivegateway3">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents within 48 hours of symptom onset or with fluctuating motor or speech symptoms</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_25" sourceRef="exclusivegateway3Join" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_26" name="Patient presents beyond 48 hours of symptom onset" sourceRef="exclusivegateway2" targetRef="activity15">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents beyond 48 hours of symptom onset</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_27" sourceRef="activity15" targetRef="exclusivegateway2Join" />
