  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_45</incoming></endEvent>
    <task id="activity1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_2</incoming><outgoing>Flow_44</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_44</incoming><outgoing>Flow_29</outgoing><outgoing>Flow_30</outgoing><outgoing>Flow_31</outgoing><outgoing>Flow_33</outgoing><outgoing>Flow_34</outgoing><outgoing>Flow_35</outgoing><outgoing>merged_Flow_28_Flow_4</outgoing><outgoing>merged_Flow_32_Flow_12</outgoing></parallelGateway>
    <task id="activity3-1" name="Immediate brain imaging (CT or MRI)">
      <incoming>merged_Flow_28_Flow_4</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity3-2" name="Transport patient to imaging suite (Role: medical staff; Objects: patient)">
      <incoming>Flow_5</incoming><outgoing>Flow_6</outgoing></task>
    <task id="activity4" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_6</incoming><outgoing>Flow_36</outgoing></task>
    <task id="activity5" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_29</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity6-1" name="Blood work: CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_30</incoming><outgoing>Flow_38</outgoing></task>
    <task id="activity7" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_31</incoming><outgoing>Flow_39</outgoing></task>
    <task id="activity8-1" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_32_Flow_12</incoming><outgoing>Flow_13</outgoing></task>
    <task id="activity8-2" name="Select appropriate bedside swallowing screening protocol (Role: medical staff; Objects: patient)">
      <incoming>Flow_13</incoming><outgoing>Flow_14</outgoing></task>
    <task id="activity8-3" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_14</incoming><outgoing>Flow_19</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_19</incoming><outgoing>Flow_15</outgoing><outgoing>Flow_17</outgoing></exclusiveGateway>
    <task id="activity9" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_15</incoming><outgoing>Flow_16</outgoing></task>
    <task id="activity10" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_17</incoming><outgoing>Flow_18</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_16</incoming><incoming>Flow_18</incoming><outgoing>Flow_40</outgoing></exclusiveGateway>
    <task id="activity11" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies (All patients, whether admitted or discharged from the ED)">
      <incoming>Flow_33</incoming><outgoing>Flow_41</outgoing></task>
    <task id="activity12" name="Use a standard triage tool to determine the appropriate location for the care of patients (Patients with TIA)">
      <incoming>Flow_34</incoming><outgoing>Flow_42</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_35</incoming><outgoing>Flow_24</outgoing><outgoing>Flow_26</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_24</incoming><outgoing>Flow_20</outgoing><outgoing>Flow_22</outgoing></exclusiveGateway>
    <task id="activity13" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_20</incoming><outgoing>Flow_21</outgoing></task>
    <task id="activity14" name="Skip immediate vascular imaging of neck arteries (Role: medical staff; Objects: patient)">
      <incoming>Flow_22</incoming><outgoing>Flow_23</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_21</incoming><incoming>Flow_23</incoming><outgoing>Flow_25</outgoing></exclusiveGateway>
    <task id="activity15" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_26</incoming><outgoing>Flow_27</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_25</incoming><incoming>Flow_27</incoming><outgoing>Flow_43</outgoing></exclusiveGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_36</incoming><incoming>Flow_37</incoming><incoming>Flow_38</incoming><incoming>Flow_39</incoming><incoming>Flow_40</incoming><incoming>Flow_41</incoming><incoming>Flow_42</incoming><incoming>Flow_43</incoming><outgoing>Flow_45</outgoing></parallelGateway>
