    <ns0:task id="activity6_consolidated" name="complete comprehensive ED assessment and document findings while patient is in the ED to inform treatment and discharge decisions (Role: clinical staff; Objects: reason for the fall; fluid balance; pressure sore risk; hydration and nutrition; pain; temperature; other collateral injuries; appropriate blood work tests; X-rays; comorbid conditions; current drug therapy (including any anticoagulants); continence; pre-fracture functional ability and mobility; physical and functional level; mental state (MMSE/MOCA/CAM); social circumstances (caregiver status, existing community supports, family involvement))">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity_interpret_tests1" name="immediately interpret ED diagnostic tests results (Role: radiologist/physician; Objects: X-rays; blood work results)">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="complete medication reconciliation within the ED using a standardized form (Role: clinical staff; Objects: standardized form)">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
