    <bpmn:sequenceFlow id="Flow_19" sourceRef="activity9" targetRef="activity10" />
    <bpmn:sequenceFlow id="Flow_20" name="Requires ventilation and/or intensive care" sourceRef="exclusivegateway2" targetRef="activity11">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or intensive care</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_21" sourceRef="activity11" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_22" name="Does not require ventilation or intensive care" sourceRef="exclusivegateway2" targetRef="activity12">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Does not require ventilation or intensive care</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_23" sourceRef="activity12" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_24" name="Low-risk (EHMRG quintiles 1-2) and responded to initial ED treatment, with no other considerations" sourceRef="exclusivegateway1" targetRef="dummy_Flow_17">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2) and responded to initial ED treatment, with no other considerations</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_25" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_26" name="High-risk (EHMRG quintiles 3-5) or other considerations (e.g., advanced directives, severe dementia, estimated impact of admission on life-expectancy)" sourceRef="exclusivegateway1" targetRef="exclusivegateway2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or other considerations (e.g., advanced directives, severe dementia, estimated impact of admission on life-expectancy)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_27" sourceRef="exclusivegateway2Join" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_28" sourceRef="activity8" targetRef="exclusivegateway1" />
    <bpmn:sequenceFlow id="Flow_29" sourceRef="exclusivegateway1Join" targetRef="EndEvent_1" />
  </bpmn:process>
