<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_29</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:parallelGateway id="parallelgateway_admin1" name="Parallel Gateway">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity13" name="Ensure standardized risk stratification assessment tool/process is used for all acute heart failure patients in ED (Role: hospital administration; Objects: hospital policy, risk stratification tool)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14" name="Maintain pathway/mechanism to transfer patients to higher level provider as needed (Role: hospital administration; Objects: transfer protocol)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway_admin1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity1" name="Initiate acute heart failure episode of care for presenting patient (Role: emergency department clinician; Objects: patient with suspected acute heart failure)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="Apply standardized risk-stratification tool for multiple conditions (including HF) (Role: emergency department clinician; Objects: risk-stratification tool)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity3" name="Order laboratory and imaging tests: serum creatinine, electrolyte levels, troponin, complete blood count, electrocardiogram, chest x-ray, echocardiogram (if no recent available) (Role: emergency department clinician; Objects: laboratory and imaging test orders)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="Frequently measure heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: emergency department clinician; Objects: vital sign monitoring equipment)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity5" name="Review laboratory and imaging test results (Role: emergency department clinician; Objects: laboratory and imaging test results)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6" name="Administer diuretic therapy (Role: emergency department clinician; Objects: diuretic medication)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="Evaluate patient response to diuretic therapy (Role: emergency department clinician; Objects: patient response data)">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG or equivalent risk score tool)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_28</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_17" name="(dummy branch entry)">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="Discharge patient home (Role: emergency department clinician; Objects: discharge instructions)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Arrange follow-up visit with primary care provider within days of discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity11" name="Admit patient to intensive care unit with higher nurse-to-patient staffing (Role: emergency department clinician; Objects: ICU admission order)">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity12" name="Admit patient to inpatient care with normal nurse-to-patient staffing (Role: emergency department clinician; Objects: inpatient admission order)">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
