    <sequenceFlow id="Flow_19" name="Temperature &gt; 37.5°C" sourceRef="exclusivegateway2" targetRef="parallelgateway2">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Temperature &gt; 37.5°C</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_20" sourceRef="parallelgateway2Join" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_21" name="Temperature ≤ 37.5°C" sourceRef="exclusivegateway2" targetRef="activity10">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Temperature ≤ 37.5°C</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_22" sourceRef="activity10" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_23" sourceRef="activity6" targetRef="exclusivegateway2" />
    <sequenceFlow id="Flow_26" sourceRef="exclusivegateway1Join" targetRef="parallelgateway1Join" />
    <sequenceFlow id="Flow_27" sourceRef="exclusivegateway2Join" targetRef="parallelgateway1Join" />
