    <sequenceFlow id="Flow_39" sourceRef="activity12-2" targetRef="inclusivegateway1" />
    <sequenceFlow id="Flow_40" name="TIA with high-risk features OR minor (nondisabling) stroke" sourceRef="exclusivegateway4" targetRef="activity16">
