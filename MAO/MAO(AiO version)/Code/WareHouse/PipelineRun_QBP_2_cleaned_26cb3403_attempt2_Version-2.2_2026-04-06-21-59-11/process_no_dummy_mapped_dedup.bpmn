    <sequenceFlow id="Flow_29" sourceRef="parallelgateway1Join" targetRef="activity12-1" />
    <sequenceFlow id="Flow_30" sourceRef="activity12-1" targetRef="activity12-2" />
    <sequenceFlow id="Flow_31" name="Patient can swallow" sourceRef="exclusivegateway3" targetRef="activity14">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient can swallow</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_32" sourceRef="activity14" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_33" name="Patient cannot swallow (fails swallowing screening)" sourceRef="exclusivegateway3" targetRef="activity15">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient cannot swallow (fails swallowing screening)</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_34" sourceRef="activity15" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_35" name="TIA patient with fluctuating or crescendo hemibody motor weakness, sensory loss, or speech difficulty" sourceRef="inclusivegateway1" targetRef="activity13">
      <conditionExpression xsi:type="bpmn:tFormalExpression">TIA patient with fluctuating or crescendo hemibody motor weakness, sensory loss, or speech difficulty</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_36" sourceRef="activity13" targetRef="inclusivegateway1Join" />
    <sequenceFlow id="Flow_37" name="TIA or minor stroke patient not on antiplatelet agent at presentation" sourceRef="inclusivegateway1" targetRef="exclusivegateway3">
      <conditionExpression xsi:type="bpmn:tFormalExpression">TIA or minor stroke patient not on antiplatelet agent at presentation</conditionExpression>
