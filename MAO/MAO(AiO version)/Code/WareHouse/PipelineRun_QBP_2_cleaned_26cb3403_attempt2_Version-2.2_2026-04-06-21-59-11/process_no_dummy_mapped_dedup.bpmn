  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_46</incoming>
    </endEvent>
    <task id="activity1" name="evaluation (as follows) occur at an appropriately resourced ED, and further consideration be given to inpatient evaluation and management for stroke prevention. OHTAC further recommends the establishment of accreditation standards for TIA/minor stroke care to ensure equitable access to appropriate, high-quality care, irrespective of the location of initial presentation">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_28</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_28</incoming>
      <outgoing>Flow_24</outgoing>
      <outgoing>Flow_25</outgoing>
    </parallelGateway>
    <task id="activity2" name="Measure blood glucose (Role: ED medical staff; Objects: patient, glucometer)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_4</outgoing>
      <outgoing>Flow_6</outgoing>
      <outgoing>Flow_8</outgoing>
    </exclusiveGateway>
    <task id="activity3" name="Correct hypoglycemia immediately">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <task id="activity4" name="Repeat blood glucose measurement">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <task id="activity5" name="Proceed to next assessment (Role: ED medical staff; Objects: patient)">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_9</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_5</incoming>
      <incoming>Flow_7</incoming>
      <incoming>Flow_9</incoming>
      <outgoing>Flow_26</outgoing>
    </exclusiveGateway>
    <task id="activity6" name="Evaluate temperature as part of routine vital signs every 4 hours for first 48 hours">
      <incoming>Flow_12</incoming>
      <outgoing>Flow_23</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_23</incoming>
      <outgoing>Flow_19</outgoing>
      <outgoing>Flow_21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="parallelgateway2" name="Parallel Gateway">
      <incoming>Flow_19</incoming>
      <outgoing>Flow_13</outgoing>
      <outgoing>Flow_14</outgoing>
      <outgoing>Flow_15</outgoing>
    </parallelGateway>
    <task id="activity7" name="initiate temperature-reducing measures">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_16</outgoing>
    </task>
    <task id="activity8" name="investigate potential infection">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
    <task id="activity9" name="initiate antipyretic and antimicrobial therapy">
      <incoming>Flow_15</incoming>
      <outgoing>Flow_18</outgoing>
    </task>
    <parallelGateway id="parallelgateway2Join" name="Parallel Merge">
      <incoming>Flow_16</incoming>
      <incoming>Flow_17</incoming>
      <incoming>Flow_18</incoming>
      <outgoing>Flow_20</outgoing>
    </parallelGateway>
    <task id="activity10" name="Continue routine monitoring (Role: ED medical staff; Objects: patient)">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_20</incoming>
      <incoming>Flow_22</incoming>
      <outgoing>Flow_27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_26</incoming>
      <incoming>Flow_27</incoming>
      <outgoing>Flow_29</outgoing>
    </parallelGateway>
    <task id="activity12-1" name="Brain CT scan">
      <incoming>Flow_29</incoming>
      <outgoing>Flow_30</outgoing>
    </task>
    <task id="activity12-2" name="Review CT scan results and assess for contraindications to antiplatelet therapy (Role: ED medical staff; Objects: patient, CT scan results)">
      <incoming>Flow_30</incoming>
      <outgoing>Flow_39</outgoing>
    </task>
    <inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <incoming>Flow_39</incoming>
      <outgoing>Flow_35</outgoing>
      <outgoing>Flow_37</outgoing>
    </inclusiveGateway>
    <task id="activity13" name="should be evaluated in the ED to be considered for admission to hospital">
      <incoming>Flow_35</incoming>
      <outgoing>Flow_36</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_37</incoming>
      <outgoing>Flow_31</outgoing>
      <outgoing>Flow_33</outgoing>
    </exclusiveGateway>
    <task id="activity14" name="initiation of antiplatelet therapy ASAP and no later than 24 hours after symptom onset">
      <incoming>Flow_31</incoming>
      <outgoing>Flow_32</outgoing>
    </task>
    <task id="activity15" name="Rectal or gastric ASA should be offered">
      <incoming>Flow_33</incoming>
      <outgoing>Flow_34</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_32</incoming>
      <incoming>Flow_34</incoming>
      <outgoing>Flow_38</outgoing>
    </exclusiveGateway>
    <inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <incoming>Flow_36</incoming>
      <incoming>Flow_38</incoming>
      <outgoing>Flow_44</outgoing>
    </inclusiveGateway>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_44</incoming>
      <outgoing>Flow_40</outgoing>
      <outgoing>Flow_42</outgoing>
    </exclusiveGateway>
    <task id="activity16" name="Select care location and timing based on risk and clinic access (Role: ED medical staff; Objects: patient, care plan)">
      <incoming>Flow_40</incoming>
      <outgoing>Flow_41</outgoing>
    </task>
    <task id="activity17" name="referral to an outpatient clinic with stroke-prevention servicesd for comprehensive evaluation and management within 1 month of symptom onset">
      <incoming>Flow_42</incoming>
      <outgoing>Flow_43</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <incoming>Flow_41</incoming>
      <incoming>Flow_43</incoming>
      <outgoing>Flow_45</outgoing>
    </exclusiveGateway>
    <task id="activity11" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies">
      <incoming>Flow_45</incoming>
      <outgoing>Flow_46</outgoing>
    </task>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <sequenceFlow id="Flow_4" name="Blood glucose &lt; normal range (hypoglycemia)" sourceRef="exclusivegateway1" targetRef="activity3">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Blood glucose &lt; normal range (hypoglycemia)</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_5" sourceRef="activity3" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_6" name="Blood glucose &gt; 11 mmol/L" sourceRef="exclusivegateway1" targetRef="activity4">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Blood glucose &gt; 11 mmol/L</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_7" sourceRef="activity4" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_8" name="Blood glucose within normal range" sourceRef="exclusivegateway1" targetRef="activity5">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Blood glucose within normal range</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_9" sourceRef="activity5" targetRef="exclusivegateway1Join" />
