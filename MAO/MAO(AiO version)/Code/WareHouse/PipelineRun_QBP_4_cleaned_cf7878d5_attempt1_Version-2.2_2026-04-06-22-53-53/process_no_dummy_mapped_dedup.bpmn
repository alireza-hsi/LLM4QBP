      <incoming>Flow_17</incoming><outgoing>Flow_13</outgoing><outgoing>Flow_15</outgoing></exclusiveGateway>
    <task id="activity7" name="Consideration of advanced CT imaging including CT and multiphase CTA or Perfusion CT">
      <incoming>Flow_13</incoming><outgoing>Flow_14</outgoing></task>
    <task id="activity8" name="Proceed with standard imaging interpretation (Role: medical staff; Objects: patient, imaging)">
      <incoming>Flow_15</incoming><outgoing>Flow_16</outgoing></task>
