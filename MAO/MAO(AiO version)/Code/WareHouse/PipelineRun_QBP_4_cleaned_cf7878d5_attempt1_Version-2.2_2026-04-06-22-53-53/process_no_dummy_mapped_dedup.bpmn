      <incoming>Flow_60</incoming><outgoing>Flow_67</outgoing></task>
    <task id="activity16" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_61_Flow_30</incoming><outgoing>Flow_36</outgoing></task>
