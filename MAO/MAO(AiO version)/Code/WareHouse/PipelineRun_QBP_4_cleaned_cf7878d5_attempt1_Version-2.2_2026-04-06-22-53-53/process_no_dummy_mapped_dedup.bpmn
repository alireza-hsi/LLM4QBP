    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_73</incoming></endEvent>
    <task id="activity1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_2</incoming><outgoing>Flow_11</outgoing></task>
    <task id="activity3" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>Flow_11</incoming><outgoing>Flow_12</outgoing></task>
    <task id="activity6" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_12</incoming><outgoing>Flow_17</outgoing></task>
