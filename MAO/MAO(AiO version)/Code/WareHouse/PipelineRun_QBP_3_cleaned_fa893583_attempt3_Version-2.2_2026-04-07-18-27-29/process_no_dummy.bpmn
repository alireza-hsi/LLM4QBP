      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">clinical judgement supports selected mobilization and no contraindication</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_40" sourceRef="activity17" targetRef="exclusivegateway3Join" />
    <ns0:sequenceFlow id="Flow_41" name="frequent out-of-bed activity not appropriate or contraindicated" sourceRef="exclusivegateway3" targetRef="activity18">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">frequent out-of-bed activity not appropriate or contraindicated</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_42" sourceRef="activity18" targetRef="exclusivegateway3Join" />
    <ns0:sequenceFlow id="Flow_43" name="24 to 48 hours from stroke onset and no contraindication to mobilization" sourceRef="exclusivegateway2" targetRef="activity16">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">24 to 48 hours from stroke onset and no contraindication to mobilization</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_44" sourceRef="activity16" targetRef="exclusivegateway2Join" />
    <ns0:sequenceFlow id="Flow_45" name="within 24 hours of stroke onset" sourceRef="exclusivegateway2" targetRef="exclusivegateway3">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">within 24 hours of stroke onset</ns0:conditionExpression>
    </ns0:sequenceFlow>
