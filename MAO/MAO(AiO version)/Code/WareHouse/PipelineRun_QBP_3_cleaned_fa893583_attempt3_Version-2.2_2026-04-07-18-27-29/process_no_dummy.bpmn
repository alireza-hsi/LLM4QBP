    <ns0:sequenceFlow id="Flow_54" name="patient has non-admitted TIA or minor nondisabling stroke not applicable to Module 3a recommendations" sourceRef="exclusivegateway1" targetRef="activity21">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">patient has non-admitted TIA or minor nondisabling stroke not applicable to Module 3a recommendations</ns0:conditionExpression>
