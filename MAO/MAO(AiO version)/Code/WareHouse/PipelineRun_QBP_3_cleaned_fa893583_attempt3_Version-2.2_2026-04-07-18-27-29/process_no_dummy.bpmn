<?xml version='1.0' encoding='UTF-8'?>
<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_57</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="determine applicability of acute care admission pathway (Role: admitting clinician; Objects: acute stroke diagnosis, admitted TIA status, minor nondisabling stroke status)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_56</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_56</ns0:incoming>
      <ns0:outgoing>Flow_52</ns0:outgoing>
      <ns0:outgoing>Flow_54</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity15_1" name="screen or assess for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED (Role: ED or admitting clinicians; Objects: diabetes screening, dental assessment, cognitive impairment screening, depression screening)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15_2" name="forward screening and assessment results to the TIA clinic for follow-up (Role: ED or admitting clinicians; Objects: screening results, TIA clinic follow-up information)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2_1" name="verify stroke unit bed availability (Role: admitting team; Objects: co-located stroke unit bed availability status)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2_2" name="complete admission to a specialized geographically defined stroke unit (Role: admitting team; Objects: co-located stroke unit bed, stroke admission order)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="assign specialized interprofessional stroke team with 7 day per week access and stroke expertise maintained through regular stroke education (Role: stroke unit leadership; Objects: medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, dietitian staffing)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_38</ns0:incoming>
      <ns0:outgoing>Flow_30</ns0:outgoing>
      <ns0:outgoing>Flow_31</ns0:outgoing>
      <ns0:outgoing>Flow_32</ns0:outgoing>
      <ns0:outgoing>Flow_33</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity4_1" name="select standardized valid assessment tools (Role: clinicians; Objects: standardized validated assessment tools)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4_2" name="document stroke-related impairments and functional status findings in EHR-linked format when available (Role: clinicians; Objects: assessment findings, electronic EHR-linked tools when available)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day counted as day 1 (Role: clinicians; Objects: AlphaFIM assessment)">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_34</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: physiotherapist, occupational therapist, and speech-language pathologist; Objects: therapy assessments, management plan)">
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_35</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="assess risk of developing venous thromboembolism (Role: clinical team; Objects: venous thromboembolism risk assessment)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8" name="encourage adequate hydration to help prevent venous thromboembolism (Role: clinical team; Objects: hydration plan)">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity9" name="assess nutrition and hydration status within the first 48 hours of admission using a valid screening tool (Role: nursing or designated clinician; Objects: nutrition screening tool, hydration screening tool)">
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_29</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <ns0:incoming>Flow_29</ns0:incoming>
      <ns0:outgoing>Flow_25</ns0:outgoing>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity10" name="refer patient to a dietitian within 7 days of admission for recommendations (Role: clinical team; Objects: dietitian referral)">
      <ns0:incoming>Flow_18</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity23" name="review patient nutrition and fluid requirements and provide recommendations (Role: dietitian; Objects: dietitian assessment, nutrition and fluid recommendations)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity14" name="consider enteral nutrition support (Role: dietitian; Objects: enteral nutrition support recommendation)">
      <ns0:incoming>Flow_20</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity22" name="document nutrition and fluid management recommendations without enteral nutrition support (Role: dietitian; Objects: nutrition and fluid management plan)">
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity24" name="document no dietitian referral required and continue routine monitoring (Role: nursing or designated clinician; Objects: nutrition and hydration monitoring record)">
      <ns0:incoming>Flow_27</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1Join" name="Inclusive Merge">
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:incoming>Flow_28</ns0:incoming>
      <ns0:outgoing>Flow_37</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <ns0:incoming>Flow_34</ns0:incoming>
      <ns0:incoming>Flow_35</ns0:incoming>
      <ns0:incoming>Flow_36</ns0:incoming>
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:outgoing>Flow_49</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <ns0:incoming>Flow_49</ns0:incoming>
      <ns0:outgoing>Flow_43</ns0:outgoing>
      <ns0:outgoing>Flow_45</ns0:outgoing>
      <ns0:outgoing>Flow_47</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity16" name="mobilize patient early between 24 hours and 48 hours of stroke onset (Role: clinical team; Objects: early mobilization intervention)">
      <ns0:incoming>Flow_43</ns0:incoming>
      <ns0:outgoing>Flow_44</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <ns0:incoming>Flow_45</ns0:incoming>
      <ns0:outgoing>Flow_39</ns0:outgoing>
      <ns0:outgoing>Flow_41</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity17" name="provide limited very early mobilization based on clinical judgement (Role: clinical team; Objects: selected mobilization intervention)">
      <ns0:incoming>Flow_39</ns0:incoming>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18" name="defer frequent out-of-bed activity within 24 hours of stroke onset and continue monitoring for later mobilization (Role: clinical team; Objects: monitoring plan)">
      <ns0:incoming>Flow_41</ns0:incoming>
      <ns0:outgoing>Flow_42</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <ns0:incoming>Flow_40</ns0:incoming>
      <ns0:incoming>Flow_42</ns0:incoming>
      <ns0:outgoing>Flow_46</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity19" name="withhold mobilization and document contraindications while reassessing readiness (Role: clinical team; Objects: contraindication documentation, reassessment plan)">
      <ns0:incoming>Flow_47</ns0:incoming>
      <ns0:outgoing>Flow_48</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <ns0:incoming>Flow_44</ns0:incoming>
      <ns0:incoming>Flow_46</ns0:incoming>
      <ns0:incoming>Flow_48</ns0:incoming>
      <ns0:outgoing>Flow_50</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity20_1" name="initiate cross-continuum secondary prevention assessment (Role: stroke team; Objects: secondary prevention assessment plan, Modules 5 and 10 inputs)">
      <ns0:incoming>Flow_50</ns0:incoming>
      <ns0:outgoing>Flow_51</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity20_2" name="provide or arrange cross-continuum secondary prevention therapies and follow-up plan whether patient is transferred to in-hospital rehabilitation or discharged (Role: stroke team; Objects: secondary prevention therapies, follow-up plan, Modules 5 and 10 plans)">
      <ns0:incoming>Flow_51</ns0:incoming>
      <ns0:outgoing>Flow_53</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity21" name="exclude patient from Module 3a acute care treatment recommendations and route to appropriate TIA or minor stroke management pathway (Role: clinical team; Objects: alternative pathway referral)">
      <ns0:incoming>Flow_54</ns0:incoming>
      <ns0:outgoing>Flow_55</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <ns0:incoming>Flow_53</ns0:incoming>
      <ns0:incoming>Flow_55</ns0:incoming>
      <ns0:outgoing>Flow_57</ns0:outgoing>
    </ns0:exclusiveGateway>
