    <ns0:sequenceFlow id="Flow_24" sourceRef="activity23" targetRef="exclusivegateway4" />
    <ns0:sequenceFlow id="Flow_26" sourceRef="exclusivegateway4Join" targetRef="inclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_27" name="no nutritional or hydration-related concerns identified" sourceRef="inclusivegateway1" targetRef="activity24">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">no nutritional or hydration-related concerns identified</ns0:conditionExpression>
    </ns0:sequenceFlow>
