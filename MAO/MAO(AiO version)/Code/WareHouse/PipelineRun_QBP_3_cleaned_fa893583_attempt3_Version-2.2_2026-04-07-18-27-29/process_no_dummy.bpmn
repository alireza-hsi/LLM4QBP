      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">patient is unable to meet nutritional and fluid requirements</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_21" sourceRef="activity14" targetRef="exclusivegateway4Join" />
    <ns0:sequenceFlow id="Flow_22" name="patient can meet nutritional and fluid requirements" sourceRef="exclusivegateway4" targetRef="activity22">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">patient can meet nutritional and fluid requirements</ns0:conditionExpression>
    </ns0:sequenceFlow>
