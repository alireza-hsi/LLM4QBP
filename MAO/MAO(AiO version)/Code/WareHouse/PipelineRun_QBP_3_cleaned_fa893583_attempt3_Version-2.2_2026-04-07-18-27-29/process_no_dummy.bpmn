  <ns0:sequenceFlow id="merged_Flow_52_Flow_3" sourceRef="exclusivegateway1" targetRef="activity15_1" name="patient has acute stroke or admitted TIA meeting criteria for acute inpatient admission"><ns0:conditionExpression xsi:type="bpmn:tFormalExpression">patient has acute stroke or admitted TIA meeting criteria for acute inpatient admission</ns0:conditionExpression></ns0:sequenceFlow><ns0:sequenceFlow id="merged_Flow_30_Flow_9" sourceRef="parallelgateway1" targetRef="activity4_1" /><ns0:sequenceFlow id="merged_Flow_32_Flow_13" sourceRef="parallelgateway1" targetRef="activity7" /><ns0:sequenceFlow id="merged_Flow_33_Flow_16" sourceRef="parallelgateway1" targetRef="activity9" /><ns0:sequenceFlow id="merged_Flow_25_Flow_18" sourceRef="inclusivegateway1" targetRef="activity10" name="nutritional concerns and or hydration deficits and or dysphagia and or other comorbidities affecting nutrition or fluids identified"><ns0:conditionExpression xsi:type="bpmn:tFormalExpression">nutritional concerns and or hydration deficits and or dysphagia and or other comorbidities affecting nutrition or fluids identified</ns0:conditionExpression></ns0:sequenceFlow></ns0:process>
