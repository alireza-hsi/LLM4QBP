    <bpmn:sequenceFlow id="Flow_7" sourceRef="parallelgateway1" targetRef="activity4-2" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="parallelgateway1" targetRef="activity2-2" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="activity3" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="activity3-2" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="activity4-1" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="activity4-2" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="activity2-2" targetRef="parallelgateway1Join" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="activity2-1" targetRef="parallelgateway1" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="parallelgateway1Join" targetRef="activity5" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="dummy_Flow_16" targetRef="activity6" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="activity6" targetRef="activity7" />
    <bpmn:sequenceFlow id="Flow_19" name="Requires ventilation and/or intensive care" sourceRef="exclusivegateway2" targetRef="activity8">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or intensive care</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_20" sourceRef="activity8" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_21" name="Requires inpatient admission but not intensive care" sourceRef="exclusivegateway2" targetRef="activity9">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires inpatient admission but not intensive care</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_22" sourceRef="activity9" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_23" name="Low-risk (EHMRG quintiles 1-2) and responded to initial treatment, no complicating factors" sourceRef="exclusivegateway1" targetRef="dummy_Flow_16">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2) and responded to initial treatment, no complicating factors</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_24" sourceRef="activity7" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_25" name="High-risk (EHMRG quintiles 3-5) or presence of high-risk markers or complicating factors" sourceRef="exclusivegateway1" targetRef="exclusivegateway2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) or presence of high-risk markers or complicating factors</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_26" sourceRef="exclusivegateway2Join" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_27" sourceRef="activity5" targetRef="exclusivegateway1" />
    <bpmn:sequenceFlow id="Flow_28" sourceRef="exclusivegateway1Join" targetRef="activity10" />
    <bpmn:sequenceFlow id="Flow_29" sourceRef="activity10" targetRef="activity11" />
    <bpmn:sequenceFlow id="Flow_30" sourceRef="activity11" targetRef="EndEvent_1" />
  </bpmn:process>
