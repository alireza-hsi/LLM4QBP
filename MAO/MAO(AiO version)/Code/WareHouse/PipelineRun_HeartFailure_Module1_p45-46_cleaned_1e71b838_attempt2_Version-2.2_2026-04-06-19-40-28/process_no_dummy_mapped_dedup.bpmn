  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_30</incoming>
    </endEvent>
    <task id="activity1-1" name="Obtain patient history and presenting symptoms (Role: emergency department clinician; Objects: patient medical record, patient interview)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="activity1-2" name="Risk stratification&#10;(e.g., EHMRG)">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="activity2-1" name="Order laboratory and imaging tests (Role: emergency department clinician; Objects: laboratory and imaging test requisitions)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_14</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_4</outgoing>
      <outgoing>Flow_5</outgoing>
      <outgoing>Flow_6</outgoing>
      <outgoing>Flow_7</outgoing>
      <outgoing>Flow_8</outgoing>
    </parallelGateway>
    <task id="activity3" name="Monitor heart rate, blood pressure, oxygen saturation until stabilized">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_9</outgoing>
    </task>
    <task id="activity3-2" name="Monitor patient for any acute changes during stabilization (Role: nursing staff; Objects: clinical observation tools)">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <task id="activity4-1" name="Treat in ED">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    <task id="activity4-2" name="Check responsiveness to Diuresis">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    <task id="activity2-2" name="Review results of laboratory and imaging tests (Role: emergency department clinician; Objects: laboratory and imaging test reports)">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_13</outgoing>
    </task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_9</incoming>
      <incoming>Flow_10</incoming>
      <incoming>Flow_11</incoming>
      <incoming>Flow_12</incoming>
      <incoming>Flow_13</incoming>
      <outgoing>Flow_15</outgoing>
    </parallelGateway>
    <task id="activity5" name="Risk stratification&#10;(e.g., EHMRG)">
