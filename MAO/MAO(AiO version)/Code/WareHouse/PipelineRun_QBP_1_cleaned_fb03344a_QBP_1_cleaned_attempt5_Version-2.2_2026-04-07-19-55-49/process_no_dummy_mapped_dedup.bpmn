    <sequenceFlow id="Flow_19" name="troponin test is clinically indicated" sourceRef="exclusivegateway_troponin" targetRef="activity8">
      <conditionExpression xsi:type="bpmn:tFormalExpression">troponin test is clinically indicated</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_20" sourceRef="activity8" targetRef="exclusivegateway_troponinJoin" />
    <sequenceFlow id="Flow_21" name="troponin test is not clinically indicated" sourceRef="exclusivegateway_troponin" targetRef="activity9">
      <conditionExpression xsi:type="bpmn:tFormalExpression">troponin test is not clinically indicated</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_22" sourceRef="activity9" targetRef="exclusivegateway_troponinJoin" />
    <sequenceFlow id="Flow_23" sourceRef="activity7_1" targetRef="exclusivegateway_troponin" />
    <sequenceFlow id="Flow_29" name="patient is alert within the first 24 hours" sourceRef="exclusivegateway2_revised" targetRef="activity11_revised">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient is alert within the first 24 hours</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_30" sourceRef="activity11_revised" targetRef="exclusivegateway2_revisedJoin" />
    <sequenceFlow id="Flow_32" sourceRef="activity14" targetRef="exclusivegateway2_revisedJoin" />
    <sequenceFlow id="Flow_33" sourceRef="activity10" targetRef="exclusivegateway2_revised" />
