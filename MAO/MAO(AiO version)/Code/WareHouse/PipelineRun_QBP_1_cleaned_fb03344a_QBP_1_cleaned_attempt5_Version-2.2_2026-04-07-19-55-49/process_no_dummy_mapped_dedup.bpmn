    <sequenceFlow id="Flow_51" name="features indicate dysphagia or pulmonary aspiration" sourceRef="exclusivegateway3" targetRef="activity17">
      <conditionExpression xsi:type="bpmn:tFormalExpression">features indicate dysphagia or pulmonary aspiration</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_52" sourceRef="activity17" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_53" name="no features indicate dysphagia or pulmonary aspiration" sourceRef="exclusivegateway3" targetRef="activity18">
      <conditionExpression xsi:type="bpmn:tFormalExpression">no features indicate dysphagia or pulmonary aspiration</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_54" sourceRef="activity18" targetRef="exclusivegateway3Join" />
