<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_84</incoming></endEvent>
    <task id="activity1" name="identify suspected TIA or minor (nondisabling) stroke presentation (Role: EMS or triage nurse; Objects: patient)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity1_1" name="initiate stroke/TIA pathway and notify receiving stroke team as appropriate (Role: EMS or triage nurse; Objects: stroke/TIA pathway activation, prenotification information)">
      <incoming>Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="activity2" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_3</incoming><outgoing>Flow_50</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_50</incoming><outgoing>Flow_40</outgoing><outgoing>Flow_43</outgoing><outgoing>merged_Flow_38_Flow_7</outgoing><outgoing>merged_Flow_39_Flow_14</outgoing><outgoing>merged_Flow_41_Flow_17</outgoing><outgoing>merged_Flow_42_Flow_25</outgoing></parallelGateway>
    <task id="activity3" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>merged_Flow_38_Flow_7</incoming><outgoing>Flow_44</outgoing></task>
    <task id="activity4" name="Immediate brain imaging (CT or MRI)">
      <incoming>merged_Flow_39_Flow_14</incoming><outgoing>Flow_15</outgoing></task>
    <task id="activity5" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_15</incoming><outgoing>Flow_45</outgoing></task>
    <task id="activity6" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_40</incoming><outgoing>Flow_46</outgoing></task>
    <task id="activity7" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>merged_Flow_41_Flow_17</incoming><outgoing>Flow_18</outgoing></task>
    <task id="activity7_1" name="send blood samples for urgent laboratory processing (Role: clinical staff; Objects: blood samples)">
      <incoming>Flow_18</incoming><outgoing>Flow_23</outgoing></task>
    <exclusiveGateway id="exclusivegateway_troponin" name="Exclusive Gateway">
      <incoming>Flow_23</incoming><outgoing>Flow_19</outgoing><outgoing>Flow_21</outgoing></exclusiveGateway>
    <task id="activity8" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_19</incoming><outgoing>Flow_20</outgoing></task>
    <task id="activity9" name="omit additional troponin testing (Role: clinical staff)">
      <incoming>Flow_21</incoming><outgoing>Flow_22</outgoing></task>
    <exclusiveGateway id="exclusivegateway_troponinJoin" name="Exclusive Merge">
      <incoming>Flow_20</incoming><incoming>Flow_22</incoming><outgoing>Flow_47</outgoing></exclusiveGateway>
    <task id="activity10" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_42_Flow_25</incoming><outgoing>Flow_33</outgoing></task>
    <exclusiveGateway id="exclusivegateway2_revised" name="Exclusive Gateway">
      <incoming>Flow_33</incoming><outgoing>Flow_29</outgoing><outgoing>merged_Flow_31_Flow_27</outgoing></exclusiveGateway>
    <task id="activity11_revised" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_29</incoming><outgoing>Flow_30</outgoing></task>
    <task id="activity14" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>merged_Flow_31_Flow_27</incoming><outgoing>Flow_32</outgoing></task>
    <exclusiveGateway id="exclusivegateway2_revisedJoin" name="Exclusive Merge">
      <incoming>Flow_30</incoming><incoming>Flow_32</incoming><outgoing>Flow_48</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway_chestxray" name="Exclusive Gateway">
      <incoming>Flow_43</incoming><outgoing>Flow_34</outgoing><outgoing>Flow_36</outgoing></exclusiveGateway>
    <task id="activity12" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_34</incoming><outgoing>Flow_35</outgoing></task>
    <task id="activity13" name="proceed without chest x-ray to avoid delay in thrombolysis assessment (Role: clinical staff)">
      <incoming>Flow_36</incoming><outgoing>Flow_37</outgoing></task>
    <exclusiveGateway id="exclusivegateway_chestxrayJoin" name="Exclusive Merge">
      <incoming>Flow_35</incoming><incoming>Flow_37</incoming><outgoing>Flow_49</outgoing></exclusiveGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_44</incoming><incoming>Flow_45</incoming><incoming>Flow_46</incoming><incoming>Flow_47</incoming><incoming>Flow_48</incoming><incoming>Flow_49</incoming><outgoing>Flow_55</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_55</incoming><outgoing>Flow_51</outgoing><outgoing>Flow_53</outgoing></exclusiveGateway>
    <task id="activity17" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_51</incoming><outgoing>Flow_52</outgoing></task>
    <task id="activity18" name="continue care according to bedside swallowing screen results (Role: clinical staff; Objects: swallowing screen results)">
      <incoming>Flow_53</incoming><outgoing>Flow_54</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_52</incoming><incoming>Flow_54</incoming><outgoing>Flow_63</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_63</incoming><outgoing>Flow_61</outgoing><outgoing>merged_Flow_59_Flow_57</outgoing></exclusiveGateway>
    <task id="activity19" name="Use a standard triage tool to determine the appropriate location for the care of patients&#10;(Patients with TIA)">
      <incoming>merged_Flow_59_Flow_57</incoming><outgoing>Flow_60</outgoing></task>
    <task id="activity20" name="determine stroke care location based on assessment findings (Role: clinician; Objects: clinical assessment findings)">
      <incoming>Flow_61</incoming><outgoing>Flow_62</outgoing></task>
    <exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <incoming>Flow_60</incoming><incoming>Flow_62</incoming><outgoing>Flow_78</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway5" name="Exclusive Gateway">
      <incoming>Flow_78</incoming><outgoing>Flow_74</outgoing><outgoing>Flow_76</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway6" name="Exclusive Gateway">
      <incoming>Flow_74</incoming><outgoing>Flow_70</outgoing><outgoing>Flow_72</outgoing></exclusiveGateway>
    <task id="activity21" name="document that immediate neck artery vascular imaging is not required under the carotid revascularization criterion and continue alternative assessment planning (Role: clinician; Objects: revascularization candidacy assessment)">
      <incoming>Flow_70</incoming><outgoing>Flow_71</outgoing></task>
    <task id="activity22" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_72</incoming><outgoing>Flow_73</outgoing></task>
    <exclusiveGateway id="exclusivegateway6Join" name="Exclusive Merge">
      <incoming>Flow_71</incoming><incoming>Flow_73</incoming><outgoing>Flow_75</outgoing></exclusiveGateway>
    <task id="activity23_revised" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_76</incoming><outgoing>Flow_77</outgoing></task>
    <exclusiveGateway id="exclusivegateway5Join" name="Exclusive Merge">
      <incoming>Flow_75</incoming><incoming>Flow_77</incoming><outgoing>Flow_83</outgoing></exclusiveGateway>
    <task id="activity24" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_83</incoming><outgoing>Flow_84</outgoing></task>
