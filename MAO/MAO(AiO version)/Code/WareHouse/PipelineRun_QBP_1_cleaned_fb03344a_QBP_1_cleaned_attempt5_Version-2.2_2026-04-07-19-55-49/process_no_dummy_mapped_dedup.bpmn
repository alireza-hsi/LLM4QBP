    <sequenceFlow id="Flow_61" name="patient has minor (nondisabling) stroke" sourceRef="exclusivegateway4" targetRef="activity20">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient has minor (nondisabling) stroke</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_62" sourceRef="activity20" targetRef="exclusivegateway4Join" />
    <sequenceFlow id="Flow_63" sourceRef="exclusivegateway3Join" targetRef="exclusivegateway4" />
    <sequenceFlow id="Flow_70" name="patient is clearly not a candidate for carotid artery revascularization" sourceRef="exclusivegateway6" targetRef="activity21">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient is clearly not a candidate for carotid artery revascularization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_71" sourceRef="activity21" targetRef="exclusivegateway6Join" />
    <sequenceFlow id="Flow_72" name="patient may be a candidate for carotid artery revascularization" sourceRef="exclusivegateway6" targetRef="activity22">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient may be a candidate for carotid artery revascularization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_73" sourceRef="activity22" targetRef="exclusivegateway6Join" />
    <sequenceFlow id="Flow_74" name="patient has TIA or minor (nondisabling) stroke and presents within 48 hours of symptom onset or has fluctuating motor or speech symptoms" sourceRef="exclusivegateway5" targetRef="exclusivegateway6">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient has TIA or minor (nondisabling) stroke and presents within 48 hours of symptom onset or has fluctuating motor or speech symptoms</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_75" sourceRef="exclusivegateway6Join" targetRef="exclusivegateway5Join" />
    <sequenceFlow id="Flow_76" name="patient has TIA or minor (nondisabling) stroke and presents beyond 48 hours" sourceRef="exclusivegateway5" targetRef="activity23_revised">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient has TIA or minor (nondisabling) stroke and presents beyond 48 hours</conditionExpression>
    </sequenceFlow>
