    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_16" sourceRef="activity14_reviewPriorEchocardiogram" targetRef="exclusivegateway2_echoAvailabilityJoin" />
    <ns0:sequenceFlow id="Flow_17" sourceRef="activity13a_checkRecentEchoAvailability" targetRef="exclusivegateway2_echoAvailability" />
    <ns0:sequenceFlow id="Flow_18" sourceRef="parallelgateway1_initialInvestigations" targetRef="activity8_obtainCreatinineElectrolytes" />
