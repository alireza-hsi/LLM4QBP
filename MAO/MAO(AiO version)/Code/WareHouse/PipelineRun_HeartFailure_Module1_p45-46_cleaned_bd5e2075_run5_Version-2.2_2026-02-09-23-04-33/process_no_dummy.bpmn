    <ns0:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1_applyRiskTool" />
    <ns0:sequenceFlow id="Flow_2" sourceRef="activity1_applyRiskTool" targetRef="activity2_captureRiskToolInputs" />
    <ns0:sequenceFlow id="Flow_3" sourceRef="activity2_captureRiskToolInputs" targetRef="activity3_generateRiskCategoryScore" />
    <ns0:sequenceFlow id="Flow_4" sourceRef="activity3_generateRiskCategoryScore" targetRef="activity4_documentCommunicateRiskResult" />
    <ns0:sequenceFlow id="Flow_5" sourceRef="activity4_documentCommunicateRiskResult" targetRef="activity5_initiateRiskWorkflowAssessTransferNeed" />
    <ns0:sequenceFlow id="Flow_6" name="transfer/consult needed for higher level provider/unit" sourceRef="exclusivegateway1_transferConsultDecision" targetRef="activity6_activateTransferConsultPathway">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">transfer/consult needed for higher level provider/unit</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_7" sourceRef="activity6_activateTransferConsultPathway" targetRef="exclusivegateway1_transferConsultDecisionJoin" />
    <ns0:sequenceFlow id="Flow_8" name="transfer/consult not needed at this time" sourceRef="exclusivegateway1_transferConsultDecision" targetRef="activity7_continueEDManagement">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">transfer/consult not needed at this time</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_9" sourceRef="activity7_continueEDManagement" targetRef="exclusivegateway1_transferConsultDecisionJoin" />
    <ns0:sequenceFlow id="Flow_10" sourceRef="activity5_initiateRiskWorkflowAssessTransferNeed" targetRef="exclusivegateway1_transferConsultDecision" />
    <ns0:sequenceFlow id="Flow_13" name="no recent echocardiogram available" sourceRef="exclusivegateway2_echoAvailability" targetRef="activity13_performEchocardiogram">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">no recent echocardiogram available</ns0:conditionExpression>
