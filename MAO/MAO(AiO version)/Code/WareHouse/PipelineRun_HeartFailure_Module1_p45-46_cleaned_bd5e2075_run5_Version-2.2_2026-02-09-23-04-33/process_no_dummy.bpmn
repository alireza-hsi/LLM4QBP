    <ns0:sequenceFlow id="Flow_22" sourceRef="parallelgateway1_initialInvestigations" targetRef="activity12_performCXR" />
    <ns0:sequenceFlow id="Flow_24" sourceRef="activity8_obtainCreatinineElectrolytes" targetRef="parallelgateway1_initialInvestigationsJoin" />
    <ns0:sequenceFlow id="Flow_25" sourceRef="activity9_obtainTroponin" targetRef="parallelgateway1_initialInvestigationsJoin" />
    <ns0:sequenceFlow id="Flow_26" sourceRef="activity10_obtainCBC" targetRef="parallelgateway1_initialInvestigationsJoin" />
    <ns0:sequenceFlow id="Flow_27" sourceRef="activity11_performECG" targetRef="parallelgateway1_initialInvestigationsJoin" />
    <ns0:sequenceFlow id="Flow_28" sourceRef="activity12_performCXR" targetRef="parallelgateway1_initialInvestigationsJoin" />
    <ns0:sequenceFlow id="Flow_29" sourceRef="exclusivegateway2_echoAvailabilityJoin" targetRef="parallelgateway1_initialInvestigationsJoin" />
    <ns0:sequenceFlow id="Flow_30" sourceRef="exclusivegateway1_transferConsultDecisionJoin" targetRef="parallelgateway1_initialInvestigations" />
    <ns0:sequenceFlow id="Flow_31" sourceRef="parallelgateway1_initialInvestigationsJoin" targetRef="activity15_initiateFrequentVitalsMonitoringUntilStabilized" />
    <ns0:sequenceFlow id="Flow_32" sourceRef="activity15_initiateFrequentVitalsMonitoringUntilStabilized" targetRef="activity16_assessDiuresisResponse" />
    <ns0:sequenceFlow id="Flow_33" name="diuretic not yet administered or additional dosing required" sourceRef="exclusivegateway3_diureticAdministrationDecision" targetRef="activity17_administerLoopDiureticRecordDose">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">diuretic not yet administered or additional dosing required</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_34" sourceRef="activity17_administerLoopDiureticRecordDose" targetRef="exclusivegateway3_diureticAdministrationDecisionJoin" />
    <ns0:sequenceFlow id="Flow_35" name="diuretic already administered and no additional dosing required now" sourceRef="exclusivegateway3_diureticAdministrationDecision" targetRef="activity18_confirmPriorDiureticDoseTiming">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">diuretic already administered and no additional dosing required now</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_36" sourceRef="activity18_confirmPriorDiureticDoseTiming" targetRef="exclusivegateway3_diureticAdministrationDecisionJoin" />
    <ns0:sequenceFlow id="Flow_37" sourceRef="activity16_assessDiuresisResponse" targetRef="exclusivegateway3_diureticAdministrationDecision" />
    <ns0:sequenceFlow id="Flow_38" sourceRef="exclusivegateway3_diureticAdministrationDecisionJoin" targetRef="activity19_monitorDiuresisCongestionResponse" />
    <ns0:sequenceFlow id="Flow_39" name="adequate response to diuresis" sourceRef="exclusivegateway4_diuresisAdequacyDecision" targetRef="activity20_recordAdequateDiuresisResponse">
