    <ns0:sequenceFlow id="Flow_14" sourceRef="activity13_performEchocardiogram" targetRef="exclusivegateway2_echoAvailabilityJoin" />
    <ns0:sequenceFlow id="Flow_15" name="recent echocardiogram available" sourceRef="exclusivegateway2_echoAvailability" targetRef="activity14_reviewPriorEchocardiogram">
