  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_60</incoming></endEvent>
    <task id="activity1-1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2-1" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_2</incoming><outgoing>Flow_4</outgoing></task>
    <task id="activity8-1-2" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>Flow_4</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity9" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_5</incoming><outgoing>Flow_59</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_59</incoming><outgoing>Flow_44</outgoing><outgoing>Flow_45</outgoing><outgoing>Flow_46</outgoing><outgoing>Flow_48</outgoing><outgoing>Flow_49</outgoing><outgoing>Flow_50</outgoing><outgoing>merged_Flow_43_Flow_7</outgoing><outgoing>merged_Flow_47_Flow_25</outgoing></parallelGateway>
    <task id="activity3" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_43_Flow_7</incoming><outgoing>Flow_19</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_19</incoming><outgoing>Flow_17</outgoing><outgoing>merged_Flow_15_Flow_9</outgoing></exclusiveGateway>
    <task id="activity4" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>merged_Flow_15_Flow_9</incoming><outgoing>Flow_14</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_14</incoming><outgoing>Flow_10</outgoing><outgoing>Flow_12</outgoing></exclusiveGateway>
    <task id="activity6" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_10</incoming><outgoing>Flow_11</outgoing></task>
    <task id="activity7" name="Continue standard care (Role: ED/Clinic/Acutecare staff; Objects: patient)">
      <incoming>Flow_12</incoming><outgoing>Flow_13</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_11</incoming><incoming>Flow_13</incoming><outgoing>Flow_16</outgoing></exclusiveGateway>
    <task id="activity5" name="Continue standard care (Role: ED/Clinic/Acutecare staff; Objects: patient)">
      <incoming>Flow_17</incoming><outgoing>Flow_18</outgoing></task>
