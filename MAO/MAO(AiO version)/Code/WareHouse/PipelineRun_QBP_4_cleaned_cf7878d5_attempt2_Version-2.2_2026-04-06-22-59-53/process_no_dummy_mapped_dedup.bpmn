    <task id="activity10" name="Consideration of advanced CT imaging including CT and multiphase CTA or Perfusion CT">
      <incoming>Flow_20</incoming><outgoing>Flow_21</outgoing></task>
    <task id="activity11" name="Continue standard imaging protocol (Role: ED/Clinic/Acutecare staff; Objects: patient)">
      <incoming>Flow_22</incoming><outgoing>Flow_23</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_21</incoming><incoming>Flow_23</incoming><outgoing>Flow_52</outgoing></exclusiveGateway>
    <task id="activity12" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_45</incoming><outgoing>Flow_53</outgoing></task>
    <task id="activity13" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_46</incoming><outgoing>Flow_54</outgoing></task>
    <task id="activity14-1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>merged_Flow_47_Flow_25</incoming><outgoing>Flow_55</outgoing></task>
    <task id="activity15" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_48</incoming><outgoing>Flow_56</outgoing></task>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_49</incoming><outgoing>Flow_27</outgoing><outgoing>Flow_29</outgoing></exclusiveGateway>
    <task id="activity16" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_27</incoming><outgoing>Flow_28</outgoing></task>
    <task id="activity17" name="Continue standard care (Role: ED/Clinic/Acutecare staff; Objects: patient)">
      <incoming>Flow_29</incoming><outgoing>Flow_30</outgoing></task>
