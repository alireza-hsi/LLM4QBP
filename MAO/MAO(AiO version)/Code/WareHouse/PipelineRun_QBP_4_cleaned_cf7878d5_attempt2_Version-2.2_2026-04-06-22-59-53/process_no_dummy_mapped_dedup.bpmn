    <task id="activity18" name="Treat patient as a medical emergency. ICH should be promptly recognized, and patients should be evaluated&#10;immediately by physicians with expertise in stroke management">
      <incoming>merged_Flow_39_Flow_32</incoming><outgoing>Flow_33</outgoing></task>
    <task id="activity19" name="Evaluation should include questions&#10;about anticoagulant therapy, measurement of platelet count, PTT, and&#10;INR">
      <incoming>Flow_33</incoming><outgoing>Flow_38</outgoing></task>
