  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_9</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_104</incoming></endEvent>
    <exclusiveGateway id="exg01" name="Exclusive Gateway">
      <incoming>Flow_9</incoming><outgoing>Flow_7</outgoing><outgoing>merged_Flow_5_Flow_2</outgoing></exclusiveGateway>
    <task id="act02" name="divert the patient to a regional or district stroke centre where feasible (Role: EMS; Objects: suspected stroke or TIA patient)">
      <incoming>merged_Flow_5_Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="act03" name="prenotify the receiving hospital with timely and detailed arrival information (Role: EMS; Objects: patient status and estimated arrival time)">
      <incoming>Flow_3</incoming><outgoing>Flow_4</outgoing></task>
    <task id="act04" name="attend the ED for appropriate patients (Role: receiving hospital acute stroke team; Objects: EMS prenotification alert)">
      <incoming>Flow_4</incoming><outgoing>Flow_6</outgoing></task>
    <task id="act05_0" name="identify the arrival as a presentation without EMS prenotification (Role: triage staff; Objects: self-presentation, outpatient presentation, or direct acute care admission)">
      <incoming>Flow_7</incoming><outgoing>Flow_8</outgoing></task>
    <exclusiveGateway id="exg01Join" name="Exclusive Merge">
      <incoming>Flow_6</incoming><incoming>Flow_8</incoming><outgoing>Flow_10</outgoing></exclusiveGateway>
    <task id="act01" name="receive and register the suspected stroke or TIA presentation (Role: triage staff; Objects: patient at ED, outpatient clinic, or direct acute care admission)">
      <incoming>Flow_10</incoming><outgoing>Flow_11</outgoing></task>
    <task id="act05" name="apply a standardized stroke or TIA assessment and treatment protocol (Role: triage staff; Objects: suspected stroke or TIA patient)">
      <incoming>Flow_11</incoming><outgoing>Flow_12</outgoing></task>
    <task id="act06_1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_12</incoming><outgoing>Flow_46</outgoing></task>
    <parallelGateway id="pg01" name="Parallel Gateway">
      <incoming>Flow_46</incoming><outgoing>Flow_38</outgoing><outgoing>Flow_40</outgoing><outgoing>merged_Flow_36_Flow_16</outgoing><outgoing>merged_Flow_37_Flow_23</outgoing><outgoing>merged_Flow_39_Flow_30</outgoing></parallelGateway>
    <task id="act07_1" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>merged_Flow_36_Flow_16</incoming><outgoing>Flow_41</outgoing></task>
    <task id="act08_1" name="Immediate brain imaging (CT or MRI)">
      <incoming>merged_Flow_37_Flow_23</incoming><outgoing>Flow_24</outgoing></task>
    <task id="act09" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_24</incoming><outgoing>Flow_42</outgoing></task>
    <task id="act10" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_38</incoming><outgoing>Flow_43</outgoing></task>
    <task id="act11_1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>merged_Flow_39_Flow_30</incoming><outgoing>Flow_35</outgoing></task>
    <exclusiveGateway id="exg02" name="Exclusive Gateway">
      <incoming>Flow_35</incoming><outgoing>Flow_31</outgoing><outgoing>Flow_33</outgoing></exclusiveGateway>
    <task id="act12" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_31</incoming><outgoing>Flow_32</outgoing></task>
    <task id="act13" name="proceed without troponin testing (Role: clinical team; Objects: initial blood work results)">
      <incoming>Flow_33</incoming><outgoing>Flow_34</outgoing></task>
    <exclusiveGateway id="exg02Join" name="Exclusive Merge">
      <incoming>Flow_32</incoming><incoming>Flow_34</incoming><outgoing>Flow_44</outgoing></exclusiveGateway>
    <task id="act14" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_40</incoming><outgoing>Flow_45</outgoing></task>
