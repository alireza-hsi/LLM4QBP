    <task id="act26_1" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_82</incoming><outgoing>Flow_83</outgoing></task>
    <task id="act27" name="document that carotid artery revascularization is not appropriate and continue the prevention pathway (Role: clinical team; Objects: revascularization candidacy assessment)">
      <incoming>Flow_84</incoming><outgoing>Flow_85</outgoing></task>
    <task id="act28" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_86</incoming><outgoing>Flow_87</outgoing></task>
