      <incoming>Flow_41</incoming><incoming>Flow_42</incoming><incoming>Flow_43</incoming><incoming>Flow_44</incoming><incoming>Flow_45</incoming><outgoing>Flow_47</outgoing></parallelGateway>
    <task id="act15" name="integrate assessment and investigation findings to determine the working diagnosis and pathway (Role: clinical team; Objects: neurological examination, brain imaging, ECG, and laboratory results)">
      <incoming>Flow_47</incoming><outgoing>Flow_95</outgoing></task>
    <exclusiveGateway id="exg03" name="Exclusive Gateway">
      <incoming>Flow_95</incoming><outgoing>merged_Flow_91_Flow_49</outgoing><outgoing>merged_Flow_93_Flow_75</outgoing></exclusiveGateway>
    <task id="act16" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_91_Flow_49</incoming><outgoing>Flow_60</outgoing></task>
    <exclusiveGateway id="exg04" name="Exclusive Gateway">
      <incoming>Flow_60</incoming><outgoing>merged_Flow_56_Flow_51</outgoing><outgoing>merged_Flow_58_Flow_54</outgoing></exclusiveGateway>
    <task id="act17_1" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_56_Flow_51</incoming><outgoing>Flow_52</outgoing></task>
    <task id="act17_2" name="document the swallowing screening result before initiating oral medication, fluid, or food (Role: clinical team; Objects: screening result and oral intake status)">
      <incoming>Flow_52</incoming><outgoing>Flow_57</outgoing></task>
    <task id="act18" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>merged_Flow_58_Flow_54</incoming><outgoing>Flow_59</outgoing></task>
    <exclusiveGateway id="exg04Join" name="Exclusive Merge">
      <incoming>Flow_57</incoming><incoming>Flow_59</incoming><outgoing>Flow_68</outgoing></exclusiveGateway>
    <exclusiveGateway id="exg05" name="Exclusive Gateway">
      <incoming>Flow_68</incoming><outgoing>Flow_66</outgoing><outgoing>merged_Flow_64_Flow_62</outgoing></exclusiveGateway>
    <task id="act20" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>merged_Flow_64_Flow_62</incoming><outgoing>Flow_65</outgoing></task>
    <task id="act22" name="continue stroke management according to bedside swallowing screening results (Role: clinical team; Objects: swallowing screening results and NPO status)">
      <incoming>Flow_66</incoming><outgoing>Flow_67</outgoing></task>
