      <incoming>Flow_70</incoming><incoming>Flow_72</incoming><outgoing>Flow_92</outgoing></exclusiveGateway>
    <task id="act25_1" name="Use a standard triage tool to determine the appropriate location for the care of patients&#10;(Patients with TIA)">
