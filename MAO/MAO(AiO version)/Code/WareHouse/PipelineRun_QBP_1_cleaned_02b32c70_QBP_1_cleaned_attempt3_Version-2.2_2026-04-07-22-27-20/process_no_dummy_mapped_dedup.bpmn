      <incoming>Flow_89</incoming><outgoing>Flow_90</outgoing></task>
    <task id="act29" name="record that the stroke-specific dysphagia recommendations in this module are not applicable (Role: clinical team; Objects: TIA or minor (nondisabling) stroke care plan)">
