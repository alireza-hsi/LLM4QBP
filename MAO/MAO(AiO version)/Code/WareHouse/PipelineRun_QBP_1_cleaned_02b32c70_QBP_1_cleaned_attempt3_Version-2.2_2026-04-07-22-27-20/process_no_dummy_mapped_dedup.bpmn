      <incoming>Flow_73</incoming><outgoing>Flow_69</outgoing><outgoing>Flow_71</outgoing></exclusiveGateway>
    <task id="act23" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_69</incoming><outgoing>Flow_70</outgoing></task>
    <task id="act24" name="continue the stroke pathway based on current imaging and clinical findings (Role: clinical team; Objects: current assessment results)">
