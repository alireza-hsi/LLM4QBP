      <ns0:outgoing>Flow_56</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity22_1" name="assess clinical response to initial medical management and respiratory severity (Role: clinical team; Objects: response to treatment, breathlessness, resting dyspnea, general condition, severe underlying COPD, decreased activity, cyanosis, decreased consciousness, arterial oxygen saturation, pH, PaO2)">
      <ns0:incoming>Flow_54</ns0:incoming>
      <ns0:outgoing>Flow_57</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity22_2" name="assess comorbidities, imaging findings, and exacerbation pattern (Role: clinical team; Objects: significant comorbidity, heart failure, newly occurring arrhythmias, chest x-ray changes, rapid onset, frequent exacerbations, worsening peripheral edema, new physical signs)">
      <ns0:incoming>Flow_55</ns0:incoming>
      <ns0:outgoing>Flow_58</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity22_3" name="assess home support, social circumstances, long-term oxygen therapy, older age, and ability to cope at home (Role: clinical team; Objects: home support status, social circumstances, long-term oxygen therapy use, age-related risk, coping capacity, acute confusion)">
      <ns0:incoming>Flow_56</ns0:incoming>
      <ns0:outgoing>Flow_59</ns0:outgoing>
