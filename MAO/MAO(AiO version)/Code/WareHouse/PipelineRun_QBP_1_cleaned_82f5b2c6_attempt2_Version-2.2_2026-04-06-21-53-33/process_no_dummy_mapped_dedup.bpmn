<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_47</incoming></endEvent>
    <task id="activity1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming><outgoing>Flow_46</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_46</incoming><outgoing>Flow_30</outgoing><outgoing>Flow_31</outgoing><outgoing>Flow_32</outgoing><outgoing>Flow_35</outgoing><outgoing>Flow_36</outgoing><outgoing>merged_Flow_28_Flow_3</outgoing><outgoing>merged_Flow_29_Flow_6</outgoing><outgoing>merged_Flow_33_Flow_14</outgoing><outgoing>merged_Flow_34_Flow_22</outgoing></parallelGateway>
    <task id="activity2-1" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>merged_Flow_28_Flow_3</incoming><outgoing>Flow_37</outgoing></task>
    <task id="activity3-1" name="Immediate brain imaging (CT or MRI)">
      <incoming>merged_Flow_29_Flow_6</incoming><outgoing>Flow_8</outgoing></task>
    <task id="activity4" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_8</incoming><outgoing>Flow_38</outgoing></task>
    <task id="activity5" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_30</incoming><outgoing>Flow_39</outgoing></task>
    <task id="activity6-1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_31</incoming><outgoing>Flow_40</outgoing></task>
    <task id="activity7" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_32</incoming><outgoing>Flow_41</outgoing></task>
    <task id="activity8-1" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_33_Flow_14</incoming><outgoing>Flow_20</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_20</incoming><outgoing>Flow_16</outgoing><outgoing>Flow_18</outgoing></exclusiveGateway>
    <task id="activity9" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_16</incoming><outgoing>Flow_17</outgoing></task>
    <task id="activity10" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_18</incoming><outgoing>Flow_19</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_17</incoming><incoming>Flow_19</incoming><outgoing>Flow_42</outgoing></exclusiveGateway>
    <task id="activity11-1" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>merged_Flow_34_Flow_22</incoming><outgoing>Flow_43</outgoing></task>
    <task id="activity12" name="Use a standard triage tool to determine the appropriate location for the care of patients&#10;(Patients with TIA)">
      <incoming>Flow_35</incoming><outgoing>Flow_44</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_36</incoming><outgoing>Flow_24</outgoing><outgoing>Flow_26</outgoing></exclusiveGateway>
    <task id="activity13" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_24</incoming><outgoing>Flow_25</outgoing></task>
    <task id="activity14" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_26</incoming><outgoing>Flow_27</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_25</incoming><incoming>Flow_27</incoming><outgoing>Flow_45</outgoing></exclusiveGateway>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_37</incoming><incoming>Flow_38</incoming><incoming>Flow_39</incoming><incoming>Flow_40</incoming><incoming>Flow_41</incoming><incoming>Flow_42</incoming><incoming>Flow_43</incoming><incoming>Flow_44</incoming><incoming>Flow_45</incoming><outgoing>Flow_47</outgoing></parallelGateway>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <sequenceFlow id="Flow_8" sourceRef="activity3-1" targetRef="activity4" />
    <sequenceFlow id="Flow_16" name="Patient not alert within first 24 hours" sourceRef="exclusivegateway1" targetRef="activity9">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient not alert within first 24 hours</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_17" sourceRef="activity9" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_18" name="Patient presents with features indicating dysphagia or pulmonary aspiration" sourceRef="exclusivegateway1" targetRef="activity10">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents with features indicating dysphagia or pulmonary aspiration</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_19" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_20" sourceRef="activity8-1" targetRef="exclusivegateway1" />
    <sequenceFlow id="Flow_24" name="Patient presents within 48 hours of symptom onset or has fluctuating motor/speech symptoms" sourceRef="exclusivegateway2" targetRef="activity13">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents within 48 hours of symptom onset or has fluctuating motor/speech symptoms</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_25" sourceRef="activity13" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_26" name="Patient presents beyond 48 hours" sourceRef="exclusivegateway2" targetRef="activity14">
      <conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents beyond 48 hours</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_27" sourceRef="activity14" targetRef="exclusivegateway2Join" />
