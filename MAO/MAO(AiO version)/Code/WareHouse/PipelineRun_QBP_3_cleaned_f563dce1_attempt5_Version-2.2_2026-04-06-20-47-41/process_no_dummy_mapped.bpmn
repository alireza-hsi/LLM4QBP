    <task id="activity1" name="identify acute stroke patients and the specific group of TIA patients who require acute inpatient admission (Role: emergency department clinicians; Objects: admission criteria, clinical findings)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="activity12_1" name="Patients should be screened/assessed for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED, and the results should be forwarded to the TIA clinic for follow-up">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
