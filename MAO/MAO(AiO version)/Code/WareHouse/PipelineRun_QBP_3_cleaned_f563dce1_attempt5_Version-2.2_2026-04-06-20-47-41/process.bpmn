      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity13" name="mobilize patient early between 24 hours and 48 hours of stroke onset (Role: stroke unit team; Objects: early mobilization plan)">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14" name="encourage early mobilization and adequate hydration to help prevent venous thromboembolism (Role: stroke unit team; Objects: mobilization activities, hydration plan)">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_29</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <bpmn:incoming>Flow_30</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity15" name="mobilize patient within 24 hours of stroke onset using clinical judgement and avoid frequent out-of-bed activity (Role: stroke unit team; Objects: individualized mobilization plan)">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity16" name="defer out-of-bed mobilization until 24 to 48 hours after stroke onset and maintain hydration (Role: stroke unit team; Objects: delayed mobilization plan, hydration plan)">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:task>
