      <bpmn:incoming>Flow_37</bpmn:incoming>
      <bpmn:incoming>Flow_39</bpmn:incoming>
      <bpmn:outgoing>Flow_41</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity5" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day counted as day 1 (Role: clinicians; Objects: AlphaFIM assessment)">
      <bpmn:incoming>Flow_41</bpmn:incoming>
      <bpmn:outgoing>Flow_42</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity18_1" name="verify the core stroke unit team includes medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition professionals (Role: stroke unit leadership; Objects: core stroke unit team composition)">
      <bpmn:incoming>Flow_42</bpmn:incoming>
      <bpmn:outgoing>Flow_43</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity18_2" name="verify team members have stroke expertise, spend the vast majority of their time treating stroke patients, and regularly complete stroke education (Role: stroke unit leadership; Objects: stroke expertise records, clinical assignment records, stroke education records)">
      <bpmn:incoming>Flow_43</bpmn:incoming>
      <bpmn:outgoing>Flow_44</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity19_1" name="perform appropriate cross-continuum secondary prevention assessment (Role: stroke team; Objects: secondary prevention assessments, Modules 5 and 10)">
      <bpmn:incoming>Flow_44</bpmn:incoming>
      <bpmn:outgoing>Flow_45</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity19_2" name="initiate or arrange appropriate cross-continuum secondary prevention therapies whether the patient is transferred to in-hospital rehabilitation or discharged (Role: stroke team; Objects: secondary prevention therapies, rehabilitation transfer plan, discharge plan)">
      <bpmn:incoming>Flow_45</bpmn:incoming>
      <bpmn:outgoing>Flow_47</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity20" name="do not apply Module 3a acute care treatment pathway and direct patient to appropriate TIA or minor stroke management pathway (Role: clinicians; Objects: alternative care pathway)">
