  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_51</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="identify acute stroke patients and the specific group of TIA patients who require acute inpatient admission (Role: emergency department clinicians; Objects: admission criteria, clinical findings)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity12_1" name="screen for diabetes and dental issues upon presentation (Role: emergency department clinicians; Objects: diabetes screening results, dental issue screening results)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity12_2" name="assess cognitive impairment and depression upon presentation and forward results to the TIA clinic for follow-up (Role: emergency department clinicians; Objects: cognitive assessment results, depression assessment results, TIA clinic follow-up information)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_50</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_50</bpmn:incoming>
