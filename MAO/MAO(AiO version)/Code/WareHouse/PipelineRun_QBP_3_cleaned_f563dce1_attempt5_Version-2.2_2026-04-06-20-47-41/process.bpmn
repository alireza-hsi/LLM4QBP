      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity11_1" name="assess patient within 48 hours of hospital admission (Role: physiotherapist; Objects: physiotherapy assessment)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11_2" name="assess patient within 48 hours of hospital admission (Role: occupational therapist; Objects: occupational therapy assessment)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11_3" name="assess patient within 48 hours of hospital admission (Role: speech-language pathologist; Objects: speech-language pathology assessment)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway2Join" name="Parallel Merge">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity11_4" name="formulate a management plan (Role: physiotherapist, occupational therapist, and speech-language pathologist; Objects: integrated therapy management plan)">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4_1" name="select standardized valid assessment tools to evaluate stroke-related impairments and functional status (Role: clinicians; Objects: standardized validated assessment tools)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4_2" name="document assessment findings in EHR-linked record (Role: clinicians; Objects: assessment findings, EHR-linked documentation)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6" name="assess risk of developing venous thromboembolism (Role: stroke unit team; Objects: venous thromboembolism risk assessment)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8_1" name="screen nutrition status within the first 48 hours of admission using a valid screening tool (Role: nursing staff and clinicians; Objects: nutrition screening tool)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8_2" name="assess hydration status within the first 48 hours of admission using a valid screening tool (Role: nursing staff and clinicians; Objects: hydration screening tool)">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_34</bpmn:outgoing>
    </bpmn:task>
