      <bpmn:outgoing>Flow_35</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity7" name="encourage adequate hydration to help prevent venous thromboembolism (Role: stroke unit team; Objects: hydration plan)">
      <bpmn:incoming>Flow_35</bpmn:incoming>
      <bpmn:outgoing>Flow_40</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <bpmn:incoming>Flow_40</bpmn:incoming>
      <bpmn:outgoing>Flow_36</bpmn:outgoing>
      <bpmn:outgoing>Flow_38</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity9" name="refer patient to a dietitian within 7 days of admission for recommendations and consideration of enteral nutrition support when unable to meet nutritional and fluid requirements (Role: stroke unit team; Objects: dietitian referral, enteral nutrition support consideration)">
      <bpmn:incoming>Flow_36</bpmn:incoming>
      <bpmn:outgoing>Flow_37</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="continue routine nutrition and hydration monitoring (Role: stroke unit team; Objects: nutrition and hydration status)">
      <bpmn:incoming>Flow_38</bpmn:incoming>
      <bpmn:outgoing>Flow_39</bpmn:outgoing>
    </bpmn:task>
