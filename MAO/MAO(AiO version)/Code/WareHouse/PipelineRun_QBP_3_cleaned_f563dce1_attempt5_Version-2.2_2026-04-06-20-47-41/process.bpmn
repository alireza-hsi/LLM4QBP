      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:outgoing>Flow_31</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity17" name="withhold early mobilization and document contraindications while maintaining alternative preventive care including hydration (Role: stroke unit team; Objects: contraindication documentation, preventive care plan)">
      <bpmn:incoming>Flow_32</bpmn:incoming>
      <bpmn:outgoing>Flow_33</bpmn:outgoing>
    </bpmn:task>
