      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2_1" name="confirm admission to a specialized stroke unit dedicated to stroke management (Role: admitting team; Objects: admission decision, stroke unit admission criteria)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2_2" name="allocate a geographically defined co-located stroke unit bed (Role: admitting team; Objects: co-located stroke unit bed)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="assign patient to a stroke unit staffed by a dedicated interprofessional team with stroke expertise available 7 days a week (Role: stroke unit manager; Objects: stroke unit team, staffing resources)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway2" name="Parallel Gateway">
