    <ns0:sequenceFlow id="Flow_14" sourceRef="activity4" targetRef="activity5" />
    <ns0:sequenceFlow id="Flow_17" sourceRef="activity6-1" targetRef="activity6-2" />
    <ns0:sequenceFlow id="Flow_18" sourceRef="activity6-2" targetRef="activity7" />
    <ns0:sequenceFlow id="Flow_19" name="Requires normal nurse-to-patient staffing (average intensity)" sourceRef="exclusivegateway2" targetRef="activity8">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Requires normal nurse-to-patient staffing (average intensity)</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_20" sourceRef="activity8" targetRef="exclusivegateway2Join" />
    <ns0:sequenceFlow id="Flow_21" name="Requires ventilation and/or intensive care (high intensity)" sourceRef="exclusivegateway2" targetRef="activity9">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or intensive care (high intensity)</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_22" sourceRef="activity9" targetRef="exclusivegateway2Join" />
    <ns0:sequenceFlow id="Flow_24" sourceRef="activity7" targetRef="exclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_25" name="Average-risk (EHMRG quintile 3) or high-risk (EHMRG quintiles 4-5) OR other considerations (advanced directives, severe dementia, estimated impact of admission on life-expectancy, etc.)" sourceRef="exclusivegateway1" targetRef="exclusivegateway2">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Average-risk (EHMRG quintile 3) or high-risk (EHMRG quintiles 4-5) OR other considerations (advanced directives, severe dementia, estimated impact of admission on life-expectancy, etc.)</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_26" sourceRef="exclusivegateway2Join" targetRef="exclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_27" sourceRef="activity5" targetRef="exclusivegateway1" />
    <ns0:sequenceFlow id="Flow_30" sourceRef="activity11" targetRef="parallelgateway0Join" />
    <ns0:sequenceFlow id="Flow_31" sourceRef="exclusivegateway1Join" targetRef="parallelgateway0Join" />
    <ns0:sequenceFlow id="Flow_32" sourceRef="StartEvent_1" targetRef="parallelgateway0" />
    <ns0:sequenceFlow id="Flow_33" sourceRef="parallelgateway0Join" targetRef="EndEvent_1" />
  <ns0:sequenceFlow id="merged_Flow_28_Flow_2" sourceRef="parallelgateway0" targetRef="activity10" /><ns0:sequenceFlow id="merged_Flow_29_Flow_5" sourceRef="parallelgateway0" targetRef="activity1-1" /><ns0:sequenceFlow id="merged_Flow_23_Flow_16" sourceRef="exclusivegateway1" targetRef="activity6-1" name="Low-risk (EHMRG quintiles 1-2) and responded to initial ED treatment, no other considerations"><ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2) and responded to initial ED treatment, no other considerations</ns0:conditionExpression></ns0:sequenceFlow></ns0:process>
