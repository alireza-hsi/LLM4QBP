<?xml version='1.0' encoding='UTF-8'?>
<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_33</ns0:incoming>
    </ns0:endEvent>
    <ns0:parallelGateway id="parallelgateway0" name="Parallel Gateway">
      <ns0:incoming>Flow_32</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
      <ns0:outgoing>Flow_29</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity10" name="Ensure standardized risk stratification tool/process is implemented and used for all acute heart failure presentations (Role: hospital administration; Objects: hospital policy, training materials)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11" name="Maintain pathway/mechanism to transfer patients to higher level provider as needed (Role: hospital administration; Objects: transfer protocols)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_30</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1-1" name="Collect patient history and presenting symptoms (Role: emergency department clinician; Objects: patient record, interview)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1-2" name="Apply standardized risk-stratification tool (Role: emergency department clinician; Objects: risk-stratification tool)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="Frequently measure heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: nursing staff; Objects: monitoring equipment)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity2-1" name="Order laboratory tests (serum creatinine, electrolyte levels, troponin, complete blood count) and diagnostic imaging (electrocardiogram, chest x-ray, echocardiogram if no recent available) (Role: emergency department clinician; Objects: laboratory requisition, imaging requisition)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2-2" name="Continue clinical assessment and review investigation results as available (Role: emergency department clinician; Objects: clinical assessment, investigation results)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity4" name="Assess responsiveness to diuresis and identify high-risk markers (respiratory distress, hypoxemia, severity of pulmonary edema, poor response to furosemide, hemodynamic compromise, significant arrhythmias, positive troponin) (Role: emergency department clinician; Objects: clinical assessment, investigation results)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG risk score tool)">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_27</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity6-1" name="Provide discharge instructions (Role: emergency department clinician; Objects: discharge instructions)">
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-2" name="Educate patient/caregiver on warning signs and when to return to ED (Role: emergency department clinician; Objects: education materials)">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="Arrange follow-up visit with primary care provider within days of discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <ns0:incoming>Flow_18</ns0:incoming>
      <ns0:outgoing>Flow_24</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity8" name="Admit patient to inpatient care with normal nurse-to-patient staffing (Role: emergency department clinician; Objects: admission order)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity9" name="Admit patient to intensive care unit with higher nurse-to-patient staffing and/or initiate ventilation (Role: emergency department clinician; Objects: ICU admission order, ventilation equipment)">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <ns0:incoming>Flow_20</ns0:incoming>
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:outgoing>Flow_31</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:parallelGateway id="parallelgateway0Join" name="Parallel Merge">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_33</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:sequenceFlow id="Flow_3" sourceRef="activity10" targetRef="activity11" />
    <ns0:sequenceFlow id="Flow_6" sourceRef="activity1-1" targetRef="activity1-2" />
    <ns0:sequenceFlow id="Flow_7" sourceRef="activity1-2" targetRef="activity3" />
    <ns0:sequenceFlow id="Flow_8" sourceRef="parallelgateway1" targetRef="activity2-1" />
    <ns0:sequenceFlow id="Flow_9" sourceRef="parallelgateway1" targetRef="activity2-2" />
