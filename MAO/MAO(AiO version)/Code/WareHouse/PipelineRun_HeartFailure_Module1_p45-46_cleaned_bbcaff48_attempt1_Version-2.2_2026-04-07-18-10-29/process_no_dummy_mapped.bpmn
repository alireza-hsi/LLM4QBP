      <outgoing>Flow_32</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_33</incoming>
    </endEvent>
    <parallelGateway id="parallelgateway0" name="Parallel Gateway">
      <incoming>Flow_32</incoming>
      <outgoing>Flow_28</outgoing>
      <outgoing>Flow_29</outgoing>
    </parallelGateway>
    <task id="activity10" name="develop risk-stratification tools that can be used for multiple conditions">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_3</outgoing>
    </task>
    <task id="activity11" name="Maintain pathway/mechanism to transfer patients to higher level provider as needed (Role: hospital administration; Objects: transfer protocols)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_30</outgoing>
    </task>
    <task id="activity1-1" name="Collect patient history and presenting symptoms (Role: emergency department clinician; Objects: patient record, interview)">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_6</outgoing>
    </task>
    <task id="activity1-2" name="Risk stratification (e.g., EHMRG)">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <task id="activity3" name="Monitor heart rate, blood pressure, oxygen saturation until stabilized">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_12</incoming>
      <outgoing>Flow_8</outgoing>
      <outgoing>Flow_9</outgoing>
    </parallelGateway>
    <task id="activity2-1" name="Order laboratory tests (serum creatinine, electrolyte levels, troponin, complete blood count) and diagnostic imaging (electrocardiogram, chest x-ray, echocardiogram if no recent available) (Role: emergency department clinician; Objects: laboratory requisition, imaging requisition)">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <task id="activity2-2" name="Continue clinical assessment and review investigation results as available (Role: emergency department clinician; Objects: clinical assessment, investigation results)">
      <incoming>Flow_9</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_10</incoming>
      <incoming>Flow_11</incoming>
      <outgoing>Flow_13</outgoing>
    </parallelGateway>
    <task id="activity4" name="Check responsiveness to Diuresis">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_14</outgoing>
    </task>
    <task id="activity5" name="Risk stratification (e.g., EHMRG)">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_27</outgoing>
