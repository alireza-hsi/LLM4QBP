      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires normal nurse-to-patient staffing (average intensity)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_20" sourceRef="activity8" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_21" name="Requires ventilation and/or intensive care (high intensity)" sourceRef="exclusivegateway2" targetRef="activity9">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or intensive care (high intensity)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_22" sourceRef="activity9" targetRef="exclusivegateway2Join" />
    <bpmn:sequenceFlow id="Flow_23" name="Low-risk (EHMRG quintiles 1-2) and responded to initial ED treatment, no other considerations" sourceRef="exclusivegateway1" targetRef="dummy_Flow_15">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2) and responded to initial ED treatment, no other considerations</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_24" sourceRef="activity7" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_25" name="Average-risk (EHMRG quintile 3) or high-risk (EHMRG quintiles 4-5) OR other considerations (advanced directives, severe dementia, estimated impact of admission on life-expectancy, etc.)" sourceRef="exclusivegateway1" targetRef="exclusivegateway2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Average-risk (EHMRG quintile 3) or high-risk (EHMRG quintiles 4-5) OR other considerations (advanced directives, severe dementia, estimated impact of admission on life-expectancy, etc.)</bpmn:conditionExpression>
