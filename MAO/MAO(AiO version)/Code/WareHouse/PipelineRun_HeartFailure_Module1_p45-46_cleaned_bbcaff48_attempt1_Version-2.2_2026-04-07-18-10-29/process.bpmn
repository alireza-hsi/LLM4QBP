  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_32</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_33</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:parallelGateway id="parallelgateway0" name="Parallel Gateway">
      <bpmn:incoming>Flow_32</bpmn:incoming>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
      <bpmn:outgoing>Flow_29</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="dummy_Flow_1" name="(dummy branch entry)">
      <bpmn:incoming>Flow_28</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Ensure standardized risk stratification tool/process is implemented and used for all acute heart failure presentations (Role: hospital administration; Objects: hospital policy, training materials)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="Maintain pathway/mechanism to transfer patients to higher level provider as needed (Role: hospital administration; Objects: transfer protocols)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_30</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dummy_Flow_4" name="(dummy branch entry)">
      <bpmn:incoming>Flow_29</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity1-1" name="Collect patient history and presenting symptoms (Role: emergency department clinician; Objects: patient record, interview)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity1-2" name="Apply standardized risk-stratification tool (Role: emergency department clinician; Objects: risk-stratification tool)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="Frequently measure heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: nursing staff; Objects: monitoring equipment)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity2-1" name="Order laboratory tests (serum creatinine, electrolyte levels, troponin, complete blood count) and diagnostic imaging (electrocardiogram, chest x-ray, echocardiogram if no recent available) (Role: emergency department clinician; Objects: laboratory requisition, imaging requisition)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2-2" name="Continue clinical assessment and review investigation results as available (Role: emergency department clinician; Objects: clinical assessment, investigation results)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity4" name="Assess responsiveness to diuresis and identify high-risk markers (respiratory distress, hypoxemia, severity of pulmonary edema, poor response to furosemide, hemodynamic compromise, significant arrhythmias, positive troponin) (Role: emergency department clinician; Objects: clinical assessment, investigation results)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG risk score tool)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_15" name="(dummy branch entry)">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-1" name="Provide discharge instructions (Role: emergency department clinician; Objects: discharge instructions)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-2" name="Educate patient/caregiver on warning signs and when to return to ED (Role: emergency department clinician; Objects: education materials)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="Arrange follow-up visit with primary care provider within days of discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity8" name="Admit patient to inpatient care with normal nurse-to-patient staffing (Role: emergency department clinician; Objects: admission order)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="Admit patient to intensive care unit with higher nurse-to-patient staffing and/or initiate ventilation (Role: emergency department clinician; Objects: ICU admission order, ventilation equipment)">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
