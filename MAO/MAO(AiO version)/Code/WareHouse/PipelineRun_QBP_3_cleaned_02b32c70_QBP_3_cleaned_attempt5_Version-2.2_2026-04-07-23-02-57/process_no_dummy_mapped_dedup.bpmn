      <incoming>Flow_40</incoming><outgoing>Flow_41</outgoing></task>
    <task id="activity17" name="defer mobilization and reassess readiness while avoiding inappropriate frequent out-of-bed activity (Role: stroke team; Objects: mobilization contraindication review)">
      <incoming>Flow_42</incoming><outgoing>Flow_43</outgoing></task>
