      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_2" name="approve and publish pathway and embed into local policies/EHR order sets (Role: hospital quality lead; Objects: approved pathway, EHR/order sets, staff communication)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2" name="triage suspected hip fracture patient on arrival (ED/outpatient clinic/direct acute admission) and start ED hip fracture pathway record (Role: triage nurse; Objects: patient, triage assessment, pathway record)">
