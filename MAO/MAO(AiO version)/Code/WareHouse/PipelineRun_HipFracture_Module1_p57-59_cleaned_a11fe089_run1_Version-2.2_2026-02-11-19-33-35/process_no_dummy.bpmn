    <ns0:task id="activity1_0" name="ensure hip fracture care pathway exists and clearly specifies perioperative patient goals by day of stay (Role: hospital quality lead; Objects: hip fracture care pathway document)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_1" name="define perioperative patient goals by day of stay and required documentation/metrics (Role: hospital quality lead; Objects: day-of-stay goals, pathway specification)">
