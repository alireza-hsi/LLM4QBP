<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="true" name="Stroke Process"><bpmn:startEvent id="StartEvent_1" name="Start"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:endEvent id="EndEvent_1" name="End"><bpmn:incoming>Flow_99</bpmn:incoming></bpmn:endEvent><bpmn:task id="activity1_1" name="confirm suspected hip fracture pathway trigger and record arrival time for KPI tracking (Role: ED triage nurse; Objects: triage assessment, arrival timestamp)"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:task id="activity1" name="register patient with suspected hip fracture and activate hip fracture care pathway (perioperative patient goals by day of stay) (Role: ED triage nurse; Objects: patient, hip fracture care pathway)"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task><bpmn:task id="activity1_2" name="initiate hip fracture order set and notify ED team per pathway (Role: ED triage nurse; Objects: order set, notifications)"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_27</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway"><bpmn:outgoing>Flow_21</bpmn:outgoing><bpmn:outgoing>Flow_22</bpmn:outgoing><bpmn:outgoing>Flow_23</bpmn:outgoing><bpmn:incoming>Flow_27</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="dummy_Flow_4" name="(dummy branch entry)"><bpmn:outgoing>Flow_5</bpmn:outgoing><bpmn:incoming>Flow_21</bpmn:incoming></bpmn:task><bpmn:task id="activity2" name="perform initial medical assessment (target: physician seen within 1 hour for 90% of arrivals) (Role: ED physician; Objects: patient)"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="activity2_1" name="assess airway/breathing/circulation and review vital signs; address immediate threats (Role: ED physician; Objects: vital signs, resuscitation equipment)"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:task id="activity2_2" name="perform focused history and physical exam for hip fracture and collateral injuries (Role: ED physician; Objects: history, physical exam findings)"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task><bpmn:task id="activity2_3" name="document working diagnosis and place immediate orders/precautions (Role: ED physician; Objects: ED note, initial orders)"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:task id="activity23" name="request orthopedic consultation early (target: orthopedic surgeon consultation within 2 hours for 90% of patients) (Role: ED physician; Objects: consult request, preliminary patient summary)"><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_24</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_10" name="(dummy branch entry)"><bpmn:outgoing>Flow_11</bpmn:outgoing><bpmn:incoming>Flow_22</bpmn:incoming></bpmn:task><bpmn:task id="activity3" name="initiate ED management to manage hydration, pain, risk of delirium, and risk of pressure sores (Role: ED nurse; Objects: IV/PO fluids plan, analgesia, delirium prevention measures, pressure sore prevention measures)"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_20</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1_1" name="Parallel Gateway"><bpmn:outgoing>Flow_12</bpmn:outgoing><bpmn:outgoing>Flow_13</bpmn:outgoing><bpmn:outgoing>Flow_14</bpmn:outgoing><bpmn:outgoing>Flow_15</bpmn:outgoing><bpmn:incoming>Flow_20</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity3_1" name="initiate hydration plan and monitor intake/output (Role: ED nurse; Objects: IV/PO fluids, I&amp;O chart)"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_16</bpmn:outgoing></bpmn:task><bpmn:task id="activi