    <task id="activity7" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    <task id="activity8" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
