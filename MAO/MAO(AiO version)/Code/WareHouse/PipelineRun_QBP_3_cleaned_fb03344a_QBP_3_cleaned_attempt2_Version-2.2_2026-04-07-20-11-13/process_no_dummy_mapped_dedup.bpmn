    <sequenceFlow id="Flow_64" name="no contraindication to mobilization is present" sourceRef="exclusivegateway3a" targetRef="exclusivegateway3b">
      <conditionExpression xsi:type="bpmn:tFormalExpression">no contraindication to mobilization is present</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_65" sourceRef="exclusivegateway3bJoin" targetRef="exclusivegateway3aJoin" />
    <sequenceFlow id="Flow_66" sourceRef="parallelgateway1Join" targetRef="exclusivegateway3a" />
    <sequenceFlow id="Flow_68" sourceRef="exclusivegateway3aJoin" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_69" name="patient has TIA or minor nondisabling stroke to which Module 3a recommendations are not applicable" sourceRef="exclusivegateway1" targetRef="activity17">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient has TIA or minor nondisabling stroke to which Module 3a recommendations are not applicable</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_70" sourceRef="activity17" targetRef="exclusivegateway1Join" />
