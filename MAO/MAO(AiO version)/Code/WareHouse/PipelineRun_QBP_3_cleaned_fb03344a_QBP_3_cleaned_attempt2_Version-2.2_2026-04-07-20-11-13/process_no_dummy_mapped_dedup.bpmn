    <sequenceFlow id="Flow_83" sourceRef="activity18_1" targetRef="EndEvent_1" />
  <sequenceFlow id="merged_Flow_67_Flow_13" sourceRef="exclusivegateway1" targetRef="activity2" name="patient has acute stroke requiring inpatient acute care treatment"><conditionExpression xsi:type="bpmn:tFormalExpression">patient has acute stroke requiring inpatient acute care treatment</conditionExpression></sequenceFlow><sequenceFlow id="merged_Flow_40_Flow_18" sourceRef="parallelgateway1" targetRef="activity5" /><sequenceFlow id="merged_Flow_41_Flow_27" sourceRef="parallelgateway1" targetRef="activity7_1" /><sequenceFlow id="merged_Flow_43_Flow_34" sourceRef="parallelgateway1" targetRef="activity10_1" /><sequenceFlow id="merged_Flow_62_Flow_50" sourceRef="exclusivegateway3a" targetRef="activity16" name="contraindication to mobilization is present"><conditionExpression xsi:type="bpmn:tFormalExpression">contraindication to mobilization is present</conditionExpression></sequenceFlow><sequenceFlow id="merged_Flow_58_Flow_53" sourceRef="exclusivegateway3b" targetRef="activity15" name="within 24 hours of stroke onset"><conditionExpression xsi:type="bpmn:tFormalExpression">within 24 hours of stroke onset</conditionExpression></sequenceFlow><sequenceFlow id="merged_Flow_60_Flow_56" sourceRef="exclusivegateway3b" targetRef="activity14" name="24 to 48 hours since stroke onset"><conditionExpression xsi:type="bpmn:tFormalExpression">24 to 48 hours since stroke onset</conditionExpression></sequenceFlow></process>
