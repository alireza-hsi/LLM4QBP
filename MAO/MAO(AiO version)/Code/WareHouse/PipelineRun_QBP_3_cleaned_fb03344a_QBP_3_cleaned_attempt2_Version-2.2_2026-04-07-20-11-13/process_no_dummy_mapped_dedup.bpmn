    <sequenceFlow id="Flow_19" sourceRef="activity5" targetRef="activity6" />
    <sequenceFlow id="Flow_35" name="nutritional concerns, hydration deficits, dysphagia, or other comorbidities are identified" sourceRef="exclusivegateway2" targetRef="activity11">
      <conditionExpression xsi:type="bpmn:tFormalExpression">nutritional concerns, hydration deficits, dysphagia, or other comorbidities are identified</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_36" sourceRef="activity11" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_37" name="no nutritional concerns, hydration deficits, dysphagia, or relevant comorbidities are identified" sourceRef="exclusivegateway2" targetRef="activity12">
      <conditionExpression xsi:type="bpmn:tFormalExpression">no nutritional concerns, hydration deficits, dysphagia, or relevant comorbidities are identified</conditionExpression>
    </sequenceFlow>
