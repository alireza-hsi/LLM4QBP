    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_65</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="identify suspected stroke presentation and activate early assessment pathway (Role: triage nurse or receiving clinician; Objects: patient with suspected stroke)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
