    <ns0:task id="activity3" name="perform neurological examination and assess stroke severity on a standardized stroke scale (Role: clinician; Objects: focal neurological deficits, NIHSS or CNS for stroke)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
