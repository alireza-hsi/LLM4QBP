      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5_2" name="perform CTA within the acute stroke treatment time window when indicated by the acute stroke imaging protocol (Role: imaging team; Objects: CTA, door to CT/CTA less than 25 minutes)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="interpret brain imaging immediately (Role: stroke physician or radiology expert; Objects: CT, CTA, and or MRI of the brain)">
