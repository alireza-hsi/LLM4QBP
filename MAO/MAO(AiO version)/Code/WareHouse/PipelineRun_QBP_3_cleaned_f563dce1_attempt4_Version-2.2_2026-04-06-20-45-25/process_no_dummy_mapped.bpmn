    <task id="activity1" name="determine applicability of acute care admission pathway (Role: admitting clinician; Objects: acute stroke diagnosis, admitted TIA criteria, minor nondisabling stroke status)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_16</outgoing>
    </task>
