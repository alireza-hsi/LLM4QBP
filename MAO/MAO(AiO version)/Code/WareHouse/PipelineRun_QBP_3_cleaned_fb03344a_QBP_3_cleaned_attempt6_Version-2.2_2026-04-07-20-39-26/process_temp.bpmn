<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="true" name="Stroke Process"><bpmn:startEvent id="StartEvent_1" name="Start"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:endEvent id="EndEvent_1" name="End"><bpmn:incoming>Flow_84</bpmn:incoming></bpmn:endEvent><bpmn:task id="activity4" name="assign the core stroke unit team with stroke expertise as a hospital readiness prerequisite (Role: hospital and stroke unit leadership; Objects: medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition staff)"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:task id="activity5" name="ensure core team members spend the vast majority of their time treating stroke patients and regularly complete stroke care education as a hospital readiness prerequisite (Role: hospital and stroke unit leadership; Objects: core stroke unit team)"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task><bpmn:task id="activity6" name="ensure patient access to the specialized interprofessional stroke team 7 days a week with adequate staffing as a hospital readiness prerequisite (Role: hospital and stroke unit leadership; Objects: 7-day stroke unit coverage)"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1_1" name="Parallel Gateway"><bpmn:outgoing>Flow_4</bpmn:outgoing><bpmn:outgoing>Flow_5</bpmn:outgoing><bpmn:outgoing>Flow_6</bpmn:outgoing><bpmn:outgoing>Flow_7</bpmn:outgoing><bpmn:incoming>Flow_12</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity1_1" name="screen patient for diabetes upon ED presentation using standardized, validated assessment tools linked to the EHR where possible (Role: ED and acute care team; Objects: stroke/TIA patient, diabetes status)"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task><bpmn:task id="activity1_2" name="assess patient for dental issues upon ED presentation using standardized, validated assessment tools linked to the EHR where possible (Role: ED and acute care team; Objects: stroke/TIA patient, dental issues)"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:task id="activity1_3" name="assess patient for cognitive impairment upon ED presentation using standardized, validated assessment tools linked to the EHR where possible (Role: ED and acute care team; Objects: stroke/TIA patient, cognitive impairment status)"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_10</bpmn:outgoing></bpmn:task><bpmn:task id="activity1_4" name="assess patient for depression status upon ED presentation using standardized, validated assessment tools linked to the EHR where possible (Role: ED and acute care team; Objects: stroke/TIA patient, depression status)"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1_1Join" name="Parallel Merge"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_83</bpmn:outgoing></bpmn:parallelGateway><bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway"><bpmn:outgoing>Flow_79</bpmn:outgoing><bpmn:outgoing>Flow_81</bpmn:outgoing><bpmn:incoming>Flow_83</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="dummy_Flow_13" name="(dummy branch entry)"><bpmn:outgoing>Flow_14</bpmn:outgoing><bpmn:incoming>Flow_79</bpmn:incoming></bpmn:task><bpmn:task id="activity3" name="admit patient to a specialized, geographically defined hospital stroke unit dedicated to stroke management (Role: bed management and stroke service; Objects: co-located stroke unit bed)"><bpmn:incoming>Flow_14</bpmn:incoming><bpmn:outgoing>Flow_63</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway"><bpmn:outgoing>Flow_51</bpmn:outgoing><bpmn:outgoing>Flow_52</bpmn:outgoing><bpmn:outgoing>Flow_53</bpmn:outgoing><bpmn:outgoing>Flow_54</bpmn:outgoing><bpmn:outgoing>Flow_55</bpmn:outgoing><bpmn:outgoing>Flow_56</bpmn:outgoing><bpmn:incoming>Flow_63</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity7" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: physiotherapy team; Objects: stroke patient functional and mobility needs)"><bpmn:incoming>Flow_51</bpmn:incoming><bpmn:outgoing>Flow_57</bpmn:outgoing></bpmn:task><bpmn:task id="activity8" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: occupational therapy team; Objects: stroke patient functional and occupational needs)"><bpmn:incoming>Flow_52</bpmn:incoming><bpmn:outgoing>Flow_58</bpmn:outgoing></bpmn:task><bpmn:task id="activity9" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: speech-language pathology team; Objects: stroke patient communication and swallowing needs)"><bpmn:incoming>Flow_53</bpmn:incoming><bpmn:outgoing>Flow_59</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_15" name="(dummy branch entry)"><bpmn:outgoing>Flow_20</bpmn:outgoing><bpmn:incoming>Flow_54</bpmn:incoming></bpmn:task><bpmn:parallelGateway id="parallelgateway10_1" name="Parallel Gateway"><bpmn:outgoing>Flow_16</bpmn:outgoing><bpmn:outgoing>Flow_17</bpmn:outgoing><bpmn:incoming>Flow_20</bpmn:incoming></bpmn:parallelGateway><bpmn:task id="activity10_1" name="evaluate stroke-related impairments using standardized, valid assessment tools (Role: clinicians; Objects: stroke-related impairment measures)"><bpmn:incoming>Flow_16</bpmn:incoming><bpmn:outgoing>Flow_18</bpmn:outgoing></bpmn:task><bpmn:task id="activity10_2" name="evaluate functional status using standardized, valid assessment tools (Role: clinicians; Objects: functional status measures)"><bpmn:incoming>Flow_17</bpmn:incoming><bpmn:outgoing>Flow_19</bpmn:outgoing></bpmn:task><bpmn:parallelGateway id="parallelgateway10_1Join" name="Parallel Merge"><bpmn:incoming>Flow_18</bpmn:incoming><bpmn:incoming>Flow_19</bpmn:incoming><bpmn:outgoing>Flow_21</bpmn:outgoing></bpmn:parallelGateway><bpmn:task id="activity11" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day counted as day 1 (Role: clinicians; Objects: AlphaFIM assessment)"><bpmn:incoming>Flow_21</bpmn:incoming><bpmn:outgoing>Flow_60</bpmn:outgoing></bpmn:task><bpmn:task id="dummy_Flow_22" name="(dummy branch entry)"><bpmn:outgoing>Flow_23</bpmn:outgoing><bpmn:incoming>Flow_55</bpmn:incoming></bpmn:task><bpmn:task id="activity12" name="assess risk of developing venous thromboembolism (Role: clinicians; Objects: venous thromboembolism risk factors)"><bpmn:incoming>Flow_23</bpmn:incoming><bpmn:outgoing>Flow_24</bpmn:outgoing></bpmn:task><bpmn:task id="activity13" name="avoid frequent out-of-bed activity within 24 hours of stroke onset and use clinical judgement for any very early mobilization (Role: clinicians; Objects: mobilization plan within first 24 hours)"><bpmn:incoming>Flow_24</bpmn:incoming><bpmn:outgoing>Flow_32</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway"><bpmn:outgoing>Flow_28</bpmn:outgoing><bpmn:outgoing>Flow_30</bpmn:outgoing><bpmn:incoming>Flow_32</bpmn:incoming></bpmn:exclusiveGateway><bpmn:task id="dummy_Flow_25" name="(dummy branch entry)"><bpmn:outgoing>Flow_26</bpmn:outgoing><bpmn:incoming>Flow_28</bpmn:incoming></bpmn:task><bpmn:task id="activity14" name="mobilize patient early between 24 hours and 48 hours of stroke onset (Role: clinicians and nursing staff; Objects: acute stroke patient)"><bpmn:incoming>Flow_26</bpmn:incoming><bpmn:outgoing>Flow_27</bpmn:outgoing></bpmn:task><b