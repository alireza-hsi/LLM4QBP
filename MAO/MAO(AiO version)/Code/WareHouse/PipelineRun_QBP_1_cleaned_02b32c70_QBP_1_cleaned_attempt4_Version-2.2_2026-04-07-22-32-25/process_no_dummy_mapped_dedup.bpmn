      <incoming>Flow_83</incoming><outgoing>Flow_81</outgoing><outgoing>merged_Flow_79_Flow_45</outgoing></exclusiveGateway>
    <task id="activity14_1" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_79_Flow_45</incoming><outgoing>Flow_53</outgoing></task>
    <inclusiveGateway id="inclusiveGateway1" name="Inclusive Gateway">
      <incoming>Flow_53</incoming><outgoing>Flow_47</outgoing><outgoing>Flow_49</outgoing><outgoing>Flow_51</outgoing></inclusiveGateway>
    <task id="activity15" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_47</incoming><outgoing>Flow_48</outgoing></task>
    <task id="activity16" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_49</incoming><outgoing>Flow_50</outgoing></task>
    <task id="activity17" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
