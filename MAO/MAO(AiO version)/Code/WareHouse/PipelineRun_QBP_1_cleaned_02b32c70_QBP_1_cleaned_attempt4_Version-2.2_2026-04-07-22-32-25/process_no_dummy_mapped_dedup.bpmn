    <task id="activity22" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>Flow_87</incoming><outgoing>Flow_88</outgoing></task>
    <task id="activity23" name="Give patients appropriate cross-continuum secondary prevention assessments and therapies&#10;(All patients, whether admitted or discharged from the ED">
      <incoming>merged_Flow_89_Flow_85</incoming><outgoing>Flow_86</outgoing></task>
    <task id="activity24" name="arrange referral to a rapid-assessment TIA or minor stroke unit, TIA clinic, or stroke-prevention clinic (Role: clinical team; Objects: referral)">
      <incoming>Flow_86</incoming><outgoing>Flow_90</outgoing></task>
    <exclusiveGateway id="exclusiveGateway5Join" name="Exclusive Merge">
