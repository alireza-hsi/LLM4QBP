    <exclusiveGateway id="exclusiveGateway18_0" name="Exclusive Gateway">
      <incoming>Flow_75</incoming><outgoing>Flow_59</outgoing><outgoing>merged_Flow_57_Flow_55</outgoing></exclusiveGateway>
    <task id="activity18_1" name="Use a standard triage tool to determine the appropriate location for the care of patients&#10;(Patients with TIA)">
      <incoming>merged_Flow_57_Flow_55</incoming><outgoing>Flow_58</outgoing></task>
    <task id="activity18_3" name="continue (Role: clinical team; Objects: the minor nondisabling ischemic stroke pathway without applying the standardized TIA triage tool)">
      <incoming>Flow_59</incoming><outgoing>Flow_60</outgoing></task>
    <exclusiveGateway id="exclusiveGateway18_0Join" name="Exclusive Merge">
      <incoming>Flow_58</incoming><incoming>Flow_60</incoming><outgoing>Flow_77</outgoing></exclusiveGateway>
