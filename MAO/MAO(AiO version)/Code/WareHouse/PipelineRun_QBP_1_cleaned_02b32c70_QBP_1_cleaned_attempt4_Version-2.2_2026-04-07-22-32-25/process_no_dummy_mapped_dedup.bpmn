    <exclusiveGateway id="exclusiveGateway4" name="Exclusive Gateway">
      <incoming>Flow_71</incoming><outgoing>Flow_67</outgoing><outgoing>Flow_69</outgoing></exclusiveGateway>
    <task id="activity19_1" name="Immediate vascular imaging of the neck arteries (carotid ultrasound, CTA, or MRA)">
      <incoming>Flow_67</incoming><outgoing>Flow_68</outgoing></task>
    <task id="activity20" name="document noncandidacy for carotid artery revascularization and continue the TIA or minor stroke pathway (Role: clinical team; Objects: revascularization candidacy assessment)">
