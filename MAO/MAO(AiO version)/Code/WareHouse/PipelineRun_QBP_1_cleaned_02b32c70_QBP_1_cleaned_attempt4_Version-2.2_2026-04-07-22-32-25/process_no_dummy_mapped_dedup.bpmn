  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_92</incoming></endEvent>
    <task id="activity1" name="identify a patient with suspected stroke or TIA and initiate the early assessment pathway (Role: EMS, outpatient clinic staff, or acute care intake staff; Objects: suspected stroke/TIA patient)">
      <incoming>Flow_1</incoming><outgoing>Flow_10</outgoing></task>
    <exclusiveGateway id="exclusiveGateway1" name="Exclusive Gateway">
      <incoming>Flow_10</incoming><outgoing>Flow_8</outgoing><outgoing>merged_Flow_6_Flow_3</outgoing></exclusiveGateway>
    <task id="activity2" name="divert the patient where feasible to a regional or district stroke centre (Role: EMS; Objects: suspected stroke/TIA patient)">
      <incoming>merged_Flow_6_Flow_3</incoming><outgoing>Flow_4</outgoing></task>
    <task id="activity3" name="prenotify the receiving hospital with timely and detailed information (Role: EMS; Objects: patient status and estimated arrival time)">
      <incoming>Flow_4</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity4" name="contact and call the acute stroke team to the ED for appropriate patients (Role: receiving hospital; Objects: EMS prenotification)">
      <incoming>Flow_5</incoming><outgoing>Flow_7</outgoing></task>
    <task id="activity5" name="activate the standardized stroke/TIA assessment protocol (Role: receiving team; Objects: suspected stroke/TIA patient)">
      <incoming>Flow_8</incoming><outgoing>Flow_9</outgoing></task>
    <exclusiveGateway id="exclusiveGateway1Join" name="Exclusive Merge">
      <incoming>Flow_7</incoming><incoming>Flow_9</incoming><outgoing>Flow_15</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusiveGateway20" name="Exclusive Gateway">
      <incoming>Flow_15</incoming><outgoing>Flow_11</outgoing><outgoing>Flow_13</outgoing></exclusiveGateway>
    <task id="activity6" name="provide CTAS I or CTAS II priority access to early assessment and diagnostic imaging (Role: triage team; Objects: suspected stroke/TIA patient)">
      <incoming>Flow_11</incoming><outgoing>Flow_12</outgoing></task>
    <task id="activity6_2" name="expedite urgent stroke/TIA assessment and diagnostic imaging (Role: receiving team; Objects: suspected stroke/TIA patient)">
      <incoming>Flow_13</incoming><outgoing>Flow_14</outgoing></task>
    <exclusiveGateway id="exclusiveGateway20Join" name="Exclusive Merge">
      <incoming>Flow_12</incoming><incoming>Flow_14</incoming><outgoing>Flow_16</outgoing></exclusiveGateway>
    <task id="activity7_1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_16</incoming><outgoing>Flow_38</outgoing></task>
    <parallelGateway id="parallelGateway1" name="Parallel Gateway">
      <incoming>Flow_38</incoming><outgoing>Flow_30</outgoing><outgoing>Flow_32</outgoing><outgoing>Flow_33</outgoing><outgoing>merged_Flow_31_Flow_24</outgoing></parallelGateway>
    <task id="activity8" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_30</incoming><outgoing>Flow_34</outgoing></task>
    <task id="activity9_1" name="Immediate brain imaging (CT or MRI)">
      <incoming>merged_Flow_31_Flow_24</incoming><outgoing>Flow_25</outgoing></task>
    <task id="activity10" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_25</incoming><outgoing>Flow_35</outgoing></task>
    <task id="activity11" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_32</incoming><outgoing>Flow_36</outgoing></task>
    <task id="activity12_1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_33</incoming><outgoing>Flow_37</outgoing></task>
    <parallelGateway id="parallelGateway1Join" name="Parallel Merge">
      <incoming>Flow_34</incoming><incoming>Flow_35</incoming><incoming>Flow_36</incoming><incoming>Flow_37</incoming><outgoing>Flow_43</outgoing></parallelGateway>
    <exclusiveGateway id="exclusiveGateway6" name="Exclusive Gateway">
      <incoming>Flow_43</incoming><outgoing>Flow_39</outgoing><outgoing>Flow_41</outgoing></exclusiveGateway>
    <task id="activity13_1" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_39</incoming><outgoing>Flow_40</outgoing></task>
    <task id="activity13_2" name="defer or skip chest x-ray and continue urgent stroke evaluation (Role: clinical team; Objects: chest x-ray, thrombolysis assessment)">
      <incoming>Flow_41</incoming><outgoing>Flow_42</outgoing></task>
