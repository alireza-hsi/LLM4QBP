  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_64</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="identify acute stroke patient requiring inpatient admission and confirm that recommendations are not applicable to TIA or minor nondisabling stroke (Role: admitting clinician; Objects: admission indication, stroke severity, TIA/minor stroke status)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="admit patient to a specialized geographically defined stroke unit dedicated to management of stroke patients (Role: admitting team; Objects: stroke unit bed, admission order)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3.1" name="assign core stroke unit team with stroke expertise (Role: stroke unit leadership; Objects: medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, dietitian staffing)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3.2" name="ensure access to the specialized interprofessional team 7 days a week (Role: stroke unit leadership; Objects: 7-day interprofessional coverage schedule)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="ensure core stroke unit professionals spend the vast majority of their time treating stroke patients and regularly complete stroke care education (Role: stroke unit leadership; Objects: staffing model, stroke education records)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_58</bpmn:outgoing>
    </bpmn:task>
