      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity14" name="mobilize patient early between 24 hours and 48 hours of stroke onset (Role: clinical team; Objects: early mobilization plan)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity15" name="mobilize patient cautiously within 24 hours of stroke onset using clinical judgement and avoid frequent out-of-bed activity (Role: clinical team; Objects: very early mobilization plan)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity16" name="defer mobilization until appropriate time because frequent out-of-bed activity within 24 hours is not recommended (Role: clinical team; Objects: mobilization timing plan)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
