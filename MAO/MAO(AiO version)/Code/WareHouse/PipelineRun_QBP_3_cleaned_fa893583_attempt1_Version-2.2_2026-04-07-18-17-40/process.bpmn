      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity17" name="withhold mobilization and document contraindication while continuing other preventive care (Role: clinical team; Objects: contraindication documentation, preventive care plan)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
