      <bpmn:incoming>Flow_30</bpmn:incoming>
      <bpmn:outgoing>Flow_31</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="encourage adequate hydration to help prevent venous thromboembolism (Role: clinical team; Objects: hydration plan)">
      <bpmn:incoming>Flow_31</bpmn:incoming>
      <bpmn:outgoing>Flow_55</bpmn:outgoing>
