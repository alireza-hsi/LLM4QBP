    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_61</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="maintain a hip fracture care pathway that clearly specifies perioperative patient goals by day of stay (Role: hospital; Objects: hip fracture care pathway, perioperative patient goals)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity2" name="identify suspected hip fracture presentation in the ED, outpatient clinic, or direct acute care admission (Role: triage nurse; Objects: patient presentation information)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="see the patient within 1 hour of arrival in 90% of cases (Role: emergency physician; Objects: patient with suspected hip fracture)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity21" name="order appropriate blood work tests (Role: emergency physician; Objects: blood work orders)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity21_2" name="order x-rays (Role: emergency physician; Objects: diagnostic imaging request)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4_1" name="notify the orthopedic surgeon of the suspected hip fracture (Role: emergency department staff; Objects: orthopedic consultation request)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4_2" name="arrange orthopedic consultation within 2 hours of arrival in 90% of cases (Role: emergency department staff; Objects: orthopedic consultation request)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="make the anesthesiologist or internist aware of the patient and request consultation as needed (Role: emergency department staff; Objects: patient status information)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_39</ns0:outgoing>
    </ns0:task>
