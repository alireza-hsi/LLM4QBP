<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_76</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1_1" name="identify suspected acute heart failure presentation and trigger AHF pathway (Role: ED triage nurse/ED physician; Objects: presenting symptoms, triage assessment)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_2</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_2" name="collect key history/medications/comorbidities and baseline function for risk stratification (Role: ED triage nurse/ED physician; Objects: medical history, medication list, comorbidities)">
      <ns0:incoming>Flow_2</ns0:incoming>
      <ns0:outgoing>Flow_3</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity1_3" name="apply standardized risk assessment/stratification tool for acute heart failure (used consistently across hospitals) and record initial risk level (Role: ED triage nurse/ED physician; Objects: risk stratification assessment tool)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_22</ns0:outgoing>
    </ns0:task>
