    <ns0:task id="activity19" name="treat in ED or outpatient setting and discharge home without inpatient admission (low intensity pathway) (Role: ED physician; Objects: discharge plan)">
      <ns0:incoming>Flow_54</ns0:incoming>
      <ns0:outgoing>Flow_55</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity19_1" name="provide discharge instructions and return precautions (Role: ED physician/ED nurse; Objects: discharge instructions, red-flag symptoms)">
