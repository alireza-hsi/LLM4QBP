      <ns0:outgoing>Flow_43</ns0:outgoing>
    </ns0:inclusiveGateway>
    <ns0:task id="activity11" name="document high-risk marker: respiratory distress (Role: ED physician; Objects: clinical assessment)">
      <ns0:incoming>Flow_31</ns0:incoming>
      <ns0:outgoing>Flow_32</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity12" name="document high-risk marker: hypoxemia (Role: ED physician; Objects: oxygen saturation/ABG if available)">
      <ns0:incoming>Flow_33</ns0:incoming>
      <ns0:outgoing>Flow_34</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13" name="document high-risk marker: severity of pulmonary edema (Role: ED physician; Objects: exam, chest x-ray)">
      <ns0:incoming>Flow_35</ns0:incoming>
      <ns0:outgoing>Flow_36</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity14" name="document high-risk marker: poor response to furosemide administered in ED (Role: ED physician; Objects: diuretic response data)">
      <ns0:incoming>Flow_37</ns0:incoming>
      <ns0:outgoing>Flow_38</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="document high-risk marker: hemodynamic compromise (Role: ED physician; Objects: blood pressure, perfusion assessment)">
      <ns0:incoming>Flow_39</ns0:incoming>
      <ns0:outgoing>Flow_40</ns0:outgoing>
    </ns0:task>
