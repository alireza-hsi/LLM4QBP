      <ns0:outgoing>Flow_49</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity18_4" name="perform clinical override risk assessment and document rationale (including high-risk markers and treatment response) (Role: ED physician; Objects: clinical judgment note, high-risk markers)">
      <ns0:incoming>Flow_50</ns0:incoming>
      <ns0:outgoing>Flow_51</ns0:outgoing>
    </ns0:task>
