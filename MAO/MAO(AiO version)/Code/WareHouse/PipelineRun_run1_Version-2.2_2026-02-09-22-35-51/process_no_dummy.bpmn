    <ns0:task id="activity10_1" name="administer IV diuretic (e.g., furosemide) per protocol and document time/dose (Role: ED physician/ED nurse; Objects: IV diuretic order, medication administration record)">
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10_2" name="monitor urine output/symptoms and reassess volume status after diuresis (Role: ED nurse/ED physician; Objects: urine output, symptom assessment, physical exam)">
      <ns0:incoming>Flow_24</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10_3" name="reassess renal function/electrolytes after diuresis as indicated (Role: ED clinician; Objects: repeat creatinine/electrolytes)">
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_28</ns0:outgoing>
    </ns0:task>
