      <ns0:outgoing>Flow_13</ns0:outgoing>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity2" name="measure heart rate, blood pressure, and oxygen saturation frequently until patient is stabilized (Role: ED nurse; Objects: vital signs, pulse oximetry)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_15</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="order and obtain serum creatinine and electrolyte levels (Role: ED clinician; Objects: blood sample, lab testing)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_16</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="order and obtain troponin measurements (Role: ED clinician; Objects: blood sample, troponin test)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="order and obtain complete blood count (Role: ED clinician; Objects: blood sample, CBC)">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6" name="perform electrocardiogram (Role: ED clinician; Objects: ECG)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="perform chest x-ray examination (Role: ED clinician/radiology; Objects: chest x-ray)">
