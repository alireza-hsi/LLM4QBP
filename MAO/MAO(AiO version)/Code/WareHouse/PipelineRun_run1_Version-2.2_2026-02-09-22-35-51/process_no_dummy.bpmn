      <ns0:outgoing>Flow_30</ns0:outgoing>
    </ns0:parallelGateway>
    <ns0:task id="activity10" name="assess responsiveness to diuresis, including response to furosemide administered in ED (Role: ED physician; Objects: diuretic response, urine output, symptoms, vitals)">
      <ns0:incoming>Flow_30</ns0:incoming>
      <ns0:outgoing>Flow_45</ns0:outgoing>
    </ns0:task>
    <ns0:inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <ns0:incoming>Flow_45</ns0:incoming>
