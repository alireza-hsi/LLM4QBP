      <incoming>Flow_84</incoming><outgoing>Flow_78</outgoing><outgoing>Flow_80</outgoing></exclusiveGateway>
    <task id="activity24" name="Vascular imaging of the brain and neck arteries ASAP">
      <incoming>Flow_78</incoming><outgoing>Flow_79</outgoing></task>
    <task id="activity25" name="continue pathway according to stroke or TIA subtype and timing (Role: clinician; Objects: clinical and imaging findings)">
      <incoming>Flow_80</incoming><outgoing>Flow_81</outgoing></task>
