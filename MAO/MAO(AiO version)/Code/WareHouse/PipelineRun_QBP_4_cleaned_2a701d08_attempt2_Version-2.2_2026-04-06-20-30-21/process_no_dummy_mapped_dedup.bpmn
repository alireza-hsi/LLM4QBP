  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_89</incoming></endEvent>
    <task id="activity1" name="identify suspected stroke presentation and activate early assessment pathway (Role: triage clinician; Objects: patient at ED outpatient clinic or direct acute care admission)">
      <incoming>Flow_1</incoming><outgoing>Flow_8</outgoing></task>
    <task id="activity27" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_8</incoming><outgoing>Flow_9</outgoing></task>
    <task id="activity3" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_9</incoming><outgoing>Flow_10</outgoing></task>
    <task id="activity4" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>Flow_10</incoming><outgoing>Flow_54</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_54</incoming><outgoing>Flow_47</outgoing><outgoing>Flow_48</outgoing><outgoing>Flow_49</outgoing><outgoing>merged_Flow_46_Flow_27</outgoing></parallelGateway>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>merged_Flow_46_Flow_27</incoming><outgoing>Flow_25</outgoing><outgoing>merged_Flow_23_Flow_17</outgoing></exclusiveGateway>
    <task id="activity30" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>merged_Flow_23_Flow_17</incoming><outgoing>Flow_22</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_22</incoming><outgoing>Flow_18</outgoing><outgoing>Flow_20</outgoing></exclusiveGateway>
    <task id="activity6" name="Consideration of advanced CT imaging including CT and multiphase CTA or Perfusion CT">
      <incoming>Flow_18</incoming><outgoing>Flow_19</outgoing></task>
    <task id="activity7" name="proceed without advanced CT imaging (Role: imaging team; Objects: standard completed imaging results)">
      <incoming>Flow_20</incoming><outgoing>Flow_21</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_19</incoming><incoming>Flow_21</incoming><outgoing>Flow_24</outgoing></exclusiveGateway>
    <task id="activity8" name="document that acute stroke treatment window has passed for immediate reperfusion imaging pathway (Role: clinician; Objects: time from symptom onset)">
      <incoming>Flow_25</incoming><outgoing>Flow_26</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_24</incoming><incoming>Flow_26</incoming><outgoing>Flow_28</outgoing></exclusiveGateway>
    <task id="activity9" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_28</incoming><outgoing>Flow_29</outgoing></task>
    <task id="activity38" name="Evaluate patients for endovascular therapy">
      <incoming>Flow_29</incoming><outgoing>Flow_38</outgoing></task>
    <exclusiveGateway id="exclusivegateway10" name="Exclusive Gateway">
      <incoming>Flow_38</incoming><outgoing>Flow_36</outgoing><outgoing>merged_Flow_34_Flow_32</outgoing></exclusiveGateway>
    <task id="activity44" name="Evaluate patients for endovascular therapy">
      <incoming>merged_Flow_34_Flow_32</incoming><outgoing>Flow_33</outgoing></task>
    <task id="activity45" name="contact EVT-capable stroke centre or stroke specialist immediately (Role: stroke team; Objects: EVT referral communication pathway)">
      <incoming>Flow_33</incoming><outgoing>Flow_35</outgoing></task>
    <task id="activity46" name="continue urgent stroke assessment without EVT escalation (Role: stroke team; Objects: clinical findings imaging findings and time from symptom onset)">
      <incoming>Flow_36</incoming><outgoing>Flow_37</outgoing></task>
    <exclusiveGateway id="exclusivegateway10Join" name="Exclusive Merge">
      <incoming>Flow_35</incoming><incoming>Flow_37</incoming><outgoing>Flow_50</outgoing></exclusiveGateway>
    <task id="activity10" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_47</incoming><outgoing>Flow_51</outgoing></task>
    <task id="activity34" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_48</incoming><outgoing>Flow_52</outgoing></task>
    <task id="activity13" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_49</incoming><outgoing>Flow_53</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_50</incoming><incoming>Flow_51</incoming><incoming>Flow_52</incoming><incoming>Flow_53</incoming><outgoing>Flow_63</outgoing></parallelGateway>
