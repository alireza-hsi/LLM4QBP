      <incoming>Flow_63</incoming><outgoing>Flow_61</outgoing><outgoing>merged_Flow_59_Flow_56</outgoing></exclusiveGateway>
    <task id="activity35" name="Make patient NPO (nothing by mouth) initially and screen their swallowing ability as part of their initial assessment and before initiating oral medication, fluid, or food.">
      <incoming>merged_Flow_59_Flow_56</incoming><outgoing>Flow_58</outgoing></task>
    <task id="activity17" name="continue standard swallowing precautions and assessment (Role: nursing staff; Objects: swallowing status)">
      <incoming>Flow_58</incoming><outgoing>Flow_60</outgoing></task>
    <task id="activity16" name="Monitor patient closely and swallowing ability screened when clinically appropriate">
      <incoming>Flow_61</incoming><outgoing>Flow_62</outgoing></task>
    <exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <incoming>Flow_60</incoming><incoming>Flow_62</incoming><outgoing>Flow_68</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway5" name="Exclusive Gateway">
      <incoming>Flow_68</incoming><outgoing>Flow_64</outgoing><outgoing>Flow_66</outgoing></exclusiveGateway>
    <task id="activity18" name="Full clinical assessment of the patient's swallowing ability by an expert (by a speech-language pathologist or appropriately trained specialist who would advise on swallowing ability and the required consistency of diet and fluids)">
      <incoming>Flow_64</incoming><outgoing>Flow_65</outgoing></task>
    <task id="activity19" name="continue care according to bedside swallowing screen result (Role: clinician; Objects: swallowing management plan)">
      <incoming>Flow_66</incoming><outgoing>Flow_67</outgoing></task>
    <exclusiveGateway id="exclusivegateway5Join" name="Exclusive Merge">
      <incoming>Flow_65</incoming><incoming>Flow_67</incoming><outgoing>Flow_86</outgoing></exclusiveGateway>
    <exclusiveGateway id="exclusivegateway6" name="Exclusive Gateway">
      <incoming>Flow_86</incoming><outgoing>Flow_84</outgoing><outgoing>merged_Flow_82_Flow_70</outgoing></exclusiveGateway>
    <task id="activity20" name="Treat patient as a medical emergency. ICH should be promptly recognized, and patients should be evaluated&#10;immediately by physicians with expertise in stroke management">
      <incoming>merged_Flow_82_Flow_70</incoming><outgoing>Flow_71</outgoing></task>
    <task id="activity40" name="Evaluation should include questions&#10;about anticoagulant therapy, measurement of platelet count, PTT, and&#10;INR">
      <incoming>Flow_71</incoming><outgoing>Flow_77</outgoing></task>
    <exclusiveGateway id="exclusivegateway7" name="Exclusive Gateway">
      <incoming>Flow_77</incoming><outgoing>Flow_73</outgoing><outgoing>Flow_75</outgoing></exclusiveGateway>
    <task id="activity22" name="CTA or MRA ASAP">
      <incoming>Flow_73</incoming><outgoing>Flow_74</outgoing></task>
    <task id="activity23" name="continue ICH management without additional CTA or MRA selection imaging (Role: stroke physician; Objects: ICH assessment results)">
      <incoming>Flow_75</incoming><outgoing>Flow_76</outgoing></task>
