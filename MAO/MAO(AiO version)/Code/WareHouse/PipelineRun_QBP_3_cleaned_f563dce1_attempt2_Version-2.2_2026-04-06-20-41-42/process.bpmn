<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_46</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="identify patient as acute stroke admission candidate (Role: ED clinician; Objects: stroke diagnosis, admission indication)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity1_1" name="confirm that Module 3a applies rather than TIA or minor nondisabling stroke pathway (Role: ED clinician; Objects: stroke severity determination, pathway applicability)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14" name="screen for diabetes, dental issues, cognitive impairment, and depression upon ED presentation (Role: ED clinician; Objects: diabetes screen, dental screen, cognitive screen, depression screen)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14_1" name="document and forward screening results for the admitting stroke unit team or inpatient follow-up team (Role: ED clinician; Objects: screening results, admitting team follow-up information)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity2" name="admit patient to a specialized geographically defined stroke unit with identifiable co-located beds dedicated to stroke management (Role: admitting team; Objects: stroke unit bed, admission order)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="redirect patient to applicable TIA or minor stroke pathway because Module 3a recommendations are not applicable (Role: stroke team; Objects: alternative pathway referral)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity4" name="assign core stroke unit professionals with stroke expertise (Role: stroke unit leadership; Objects: medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, clinical nutrition)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4_1" name="confirm 7-day access to the specialized interprofessional team (Role: stroke unit leadership; Objects: 7-day staffing coverage plan)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="ensure core stroke unit professionals spend the vast majority of their time treating stroke patients and regularly complete stroke care education (Role: stroke unit leadership; Objects: staffing plan, stroke education records)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6" name="use standardized valid assessment tools to evaluate patient stroke-related impairments and functional status (Role: interprofessional stroke team; Objects: validated assessment tools, assessment findings)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6_1" name="document stroke-related impairments and functional status in EHR-linked records (Role: interprofessional stroke team; Objects: assessment findings, EHR-linked documentation)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity8" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: physiotherapist; Objects: physiotherapy assessment, management plan)">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: speech-language pathologist; Objects: speech-language assessment, management plan)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="assess patient within 48 hours of hospital admission and formulate a management plan (Role: occupational therapist; Objects: occupational therapy assessment, management plan)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="assess venous thromboembolism risk for all stroke patients (Role: nursing staff; Objects: venous thromboembolism risk assessment)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity13" name="assess nutrition and hydration status within the first 48 hours of admission using a valid screening tool (Role: nursing staff; Objects: nutrition screening tool, hydration screening tool)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity7" name="complete AlphaFIM on or by day 3 after admission with target day 3 and admission day counted as day 1 (Role: rehabilitation team; Objects: AlphaFIM assessment)">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_31</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <bpmn:incoming>Flow_31</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
      <bpmn:outgoing>Flow_29</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity15" name="mobilize patient early between 24 hours and 48 hours of stroke onset (Role: stroke unit team; Objects: early mobilization intervention)">
      <bpmn:incoming>Flow_27</bpmn:incoming>
      <bpmn:outgoing>Flow_28</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity16" name="avoid frequent out-of-bed activity within 24 hours of stroke onset and use clinical judgement regarding any very early mobilization (Role: stroke unit team; Objects: clinical judgement, mobilization precautions)">
      <bpmn:incoming>Flow_29</bpmn:incoming>
      <bpmn:outgoing>Flow_30</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_28</bpmn:incoming>
      <bpmn:incoming>Flow_30</bpmn:incoming>
      <bpmn:outgoing>Flow_32</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity12_1" name="encourage adequate hydration to help prevent venous thromboembolism (Role: stroke unit team; Objects: hydration plan)">
      <bpmn:incoming>Flow_32</bpmn:incoming>
      <bpmn:outgoing>Flow_44</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <bpmn:incoming>Flow_44</bpmn:incoming>
      <bpmn:outgoing>Flow_40</bpmn:outgoing>
      <bpmn:outgoing>Flow_42</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_33" name="(dummy branch entry)">
      <bpmn:incoming>Flow_40</bpmn:incoming>
      <bpmn:outgoing>Flow_34</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity17" name="initiate dietitian referral within 7 days of admission (Role: stroke team; Objects: dietitian referral, nutrition consultation request)">
      <bpmn:incoming>Flow_34</bpmn:incoming>
      <bpmn:outgoing>Flow_39</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <bpmn:incoming>Flow_39</bpmn:incoming>
      <bpmn:outgoing>Flow_35</bpmn:outgoing>
      <bpmn:outgoing>Flow_37</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity17_1" name="consider enteral nutrition support (Role: dietitian; Objects: enteral nutrition support assessment, nutrition recommendations)">
      <bpmn:incoming>Flow_35</bpmn:incoming>
      <bpmn:outgoing>Flow_36</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity17_2" name="provide dietary recommendations without enteral nutrition support (Role: dietitian; Objects: dietary recommendations)">
      <bpmn:incoming>Flow_37</bpmn:incoming>
      <bpmn:outgoing>Flow_38</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_36</bpmn:incoming>
      <bpmn:incoming>Flow_38</bpmn:incoming>
      <bpmn:outgoing>Flow_41</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity18" name="continue routine nutrition and hydration monitoring (Role: stroke team; Objects: ongoing nutrition and hydration documentation)">
      <bpmn:incoming>Flow_42</bpmn:incoming>
      <bpmn:outgoing>Flow_43</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_41</bpmn:incoming>
      <bpmn:incoming>Flow_43</bpmn:incoming>
      <bpmn:outgoing>Flow_45</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity19" name="provide all patients with appropriate cross-continuum secondary prevention assessments and therapies whether transferred to in-hospital rehabilitation or discharged (Role: stroke team; Objects: Modules 5 and 10 prevention assessments and therapies)">
      <bpmn:incoming>Flow_45</bpmn:incoming>
      <bpmn:outgoing>Flow_46</bpmn:outgoing>
    </bpmn:task>
