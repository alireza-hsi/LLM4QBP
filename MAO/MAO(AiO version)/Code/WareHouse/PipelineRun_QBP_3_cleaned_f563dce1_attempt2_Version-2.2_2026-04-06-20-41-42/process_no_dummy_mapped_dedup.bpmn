<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_46</incoming></endEvent>
    <task id="activity1" name="identify patient as acute stroke admission candidate (Role: ED clinician; Objects: stroke diagnosis, admission indication)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity1_1" name="confirm that Module 3a applies rather than TIA or minor nondisabling stroke pathway (Role: ED clinician; Objects: stroke severity determination, pathway applicability)">
      <incoming>Flow_2</incoming><outgoing>Flow_3</outgoing></task>
    <task id="activity14" name="Patients should be screened/assessed for diabetes, dental issues, cognitive impairment, and depression upon presentation to the ED, and the results should be forwarded to the TIA clinic for follow-up">
      <incoming>Flow_3</incoming><outgoing>Flow_9</outgoing></task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_9</incoming><outgoing>Flow_5</outgoing><outgoing>Flow_7</outgoing></exclusiveGateway>
    <task id="activity2" name="Admit the patient to a specialized, geographically defined hospital unit dedicated to the management of stroke patients with the following requirements:&#10;&#10;&#10;1- The core stroke unit team should consist of health care professionals with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (a dietitian).&#10;&#10;2- To have the necessary stroke expertise, the health care professionals on the core stroke unit team should be individuals who spend the vast majority of their time treating stroke patients and regularly complete education about stroke care.&#10;&#10;3- Patients should have access to a specialized interprofessional team 7 days a week">
      <incoming>Flow_5</incoming><outgoing>Flow_6</outgoing></task>
    <task id="activity3" name="redirect patient to applicable TIA or minor stroke pathway because Module 3a recommendations are not applicable (Role: stroke team; Objects: alternative pathway referral)">
      <incoming>Flow_7</incoming><outgoing>Flow_8</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_6</incoming><incoming>Flow_8</incoming><outgoing>Flow_10</outgoing></exclusiveGateway>
    <task id="activity4" name="Admit the patient to a specialized, geographically defined hospital unit dedicated to the management of stroke patients with the following requirements:&#10;&#10;&#10;1- The core stroke unit team should consist of health care professionals with stroke expertise in medicine, nursing, occupational therapy, physiotherapy, speech-language pathology, social work, and clinical nutrition (a dietitian).&#10;&#10;2- To have the necessary stroke expertise, the health care professionals on the core stroke unit team should be individuals who spend the vast majority of their time treating stroke patients and regularly complete education about stroke care.&#10;&#10;3- Patients should have access to a specialized interprofessional team 7 days a week">
      <incoming>Flow_10</incoming><outgoing>Flow_13</outgoing></task>
    <task id="activity6" name="Use standardized, valid assessment tools to evaluate patients’ stroke-related impairments and functional status&#10;where possible, these tools should be in electronic format linked to the EHR">
      <incoming>Flow_13</incoming><outgoing>Flow_25</outgoing></task>
    <parallelGateway id="parallelgateway1" name="Parallel Gateway">
      <incoming>Flow_25</incoming><outgoing>Flow_15</outgoing><outgoing>Flow_16</outgoing><outgoing>Flow_17</outgoing><outgoing>Flow_18</outgoing><outgoing>Flow_19</outgoing></parallelGateway>
    <task id="activity8" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_15</incoming><outgoing>Flow_20</outgoing></task>
    <task id="activity9" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_16</incoming><outgoing>Flow_21</outgoing></task>
    <task id="activity10" name="Physiotherapy, speech-language pathology, and occupational therapy team members should assess stroke patients within 48 hours of admission to hospital and formulate a management plan">
      <incoming>Flow_17</incoming><outgoing>Flow_22</outgoing></task>
    <task id="activity11" name="Assess patient for risk of developing venous thromboembolism">
      <incoming>Flow_18</incoming><outgoing>Flow_23</outgoing></task>
    <task id="activity13" name="The nutrition and hydration status of stroke patients should be assessed within the first 48 hours of admission using a valid screening tool.">
      <incoming>Flow_19</incoming><outgoing>Flow_24</outgoing></task>
    <parallelGateway id="parallelgateway1Join" name="Parallel Merge">
      <incoming>Flow_20</incoming><incoming>Flow_21</incoming><incoming>Flow_22</incoming><incoming>Flow_23</incoming><incoming>Flow_24</incoming><outgoing>Flow_26</outgoing></parallelGateway>
    <task id="activity7" name="Complete AlphaFIM on or by day 3 after admission(target day 3, admission day is day 1)">
      <incoming>Flow_26</incoming><outgoing>Flow_31</outgoing></task>
    <exclusiveGateway id="exclusivegateway2" name="Exclusive Gateway">
      <incoming>Flow_31</incoming><outgoing>Flow_27</outgoing><outgoing>Flow_29</outgoing></exclusiveGateway>
    <task id="activity15" name="Encourage early mobilization and adequate hydration for all acute stroke patients to help prevent venous thromboembolism">
      <incoming>Flow_27</incoming><outgoing>Flow_28</outgoing></task>
    <task id="activity16" name="avoid frequent out-of-bed activity within 24 hours of stroke onset and use clinical judgement regarding any very early mobilization (Role: stroke unit team; Objects: clinical judgement, mobilization precautions)">
      <incoming>Flow_29</incoming><outgoing>Flow_30</outgoing></task>
    <exclusiveGateway id="exclusivegateway2Join" name="Exclusive Merge">
      <incoming>Flow_28</incoming><incoming>Flow_30</incoming><outgoing>Flow_32</outgoing></exclusiveGateway>
    <task id="activity12_1" name="Encourage early mobilization and adequate hydration for all acute stroke patients to help prevent venous thromboembolism">
      <incoming>Flow_32</incoming><outgoing>Flow_44</outgoing></task>
    <exclusiveGateway id="exclusivegateway3" name="Exclusive Gateway">
      <incoming>Flow_44</incoming><outgoing>Flow_42</outgoing><outgoing>merged_Flow_40_Flow_34</outgoing></exclusiveGateway>
    <task id="activity17" name="Give patient a referral to a dietitian within 7 days of admission">
      <incoming>merged_Flow_40_Flow_34</incoming><outgoing>Flow_39</outgoing></task>
    <exclusiveGateway id="exclusivegateway4" name="Exclusive Gateway">
      <incoming>Flow_39</incoming><outgoing>Flow_35</outgoing><outgoing>Flow_37</outgoing></exclusiveGateway>
    <task id="activity17_1" name="consider enteral nutrition support (Role: dietitian; Objects: enteral nutrition support assessment, nutrition recommendations)">
      <incoming>Flow_35</incoming><outgoing>Flow_36</outgoing></task>
    <task id="activity17_2" name="provide dietary recommendations without enteral nutrition support (Role: dietitian; Objects: dietary recommendations)">
      <incoming>Flow_37</incoming><outgoing>Flow_38</outgoing></task>
    <exclusiveGateway id="exclusivegateway4Join" name="Exclusive Merge">
      <incoming>Flow_36</incoming><incoming>Flow_38</incoming><outgoing>Flow_41</outgoing></exclusiveGateway>
    <task id="activity18" name="continue routine nutrition and hydration monitoring (Role: stroke team; Objects: ongoing nutrition and hydration documentation)">
      <incoming>Flow_42</incoming><outgoing>Flow_43</outgoing></task>
    <exclusiveGateway id="exclusivegateway3Join" name="Exclusive Merge">
      <incoming>Flow_41</incoming><incoming>Flow_43</incoming><outgoing>Flow_45</outgoing></exclusiveGateway>
    <task id="activity19" name="Patient should be given appropriate cross-continuum secondary prevention assessments and therapies (Modules 5 and 10)">
      <incoming>Flow_45</incoming><outgoing>Flow_46</outgoing></task>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <sequenceFlow id="Flow_2" sourceRef="activity1" targetRef="activity1_1" />
    <sequenceFlow id="Flow_3" sourceRef="activity1_1" targetRef="activity14" />
    <sequenceFlow id="Flow_5" name="patient has acute stroke requiring admission" sourceRef="exclusivegateway1" targetRef="activity2">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient has acute stroke requiring admission</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_6" sourceRef="activity2" targetRef="exclusivegateway1Join" />
    <sequenceFlow id="Flow_7" name="patient has TIA or minor nondisabling stroke" sourceRef="exclusivegateway1" targetRef="activity3">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient has TIA or minor nondisabling stroke</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_8" sourceRef="activity3" targetRef="exclusivegateway1Join" />
