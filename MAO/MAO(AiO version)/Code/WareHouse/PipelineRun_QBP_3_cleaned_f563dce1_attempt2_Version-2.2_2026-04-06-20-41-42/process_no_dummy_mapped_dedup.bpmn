    <sequenceFlow id="Flow_26" sourceRef="parallelgateway1Join" targetRef="activity7" />
    <sequenceFlow id="Flow_27" name="24 to 48 hours from stroke onset and no contraindication to mobilization" sourceRef="exclusivegateway2" targetRef="activity15">
      <conditionExpression xsi:type="bpmn:tFormalExpression">24 to 48 hours from stroke onset and no contraindication to mobilization</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_28" sourceRef="activity15" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_29" name="within 24 hours of stroke onset or contraindication present" sourceRef="exclusivegateway2" targetRef="activity16">
      <conditionExpression xsi:type="bpmn:tFormalExpression">within 24 hours of stroke onset or contraindication present</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_30" sourceRef="activity16" targetRef="exclusivegateway2Join" />
    <sequenceFlow id="Flow_31" sourceRef="activity7" targetRef="exclusivegateway2" />
    <sequenceFlow id="Flow_32" sourceRef="exclusivegateway2Join" targetRef="activity12_1" />
    <sequenceFlow id="Flow_35" name="patient is unable to meet nutritional and fluid requirements" sourceRef="exclusivegateway4" targetRef="activity17_1">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient is unable to meet nutritional and fluid requirements</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_36" sourceRef="activity17_1" targetRef="exclusivegateway4Join" />
    <sequenceFlow id="Flow_37" name="patient can meet nutritional and fluid requirements" sourceRef="exclusivegateway4" targetRef="activity17_2">
      <conditionExpression xsi:type="bpmn:tFormalExpression">patient can meet nutritional and fluid requirements</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_38" sourceRef="activity17_2" targetRef="exclusivegateway4Join" />
    <sequenceFlow id="Flow_39" sourceRef="activity17" targetRef="exclusivegateway4" />
    <sequenceFlow id="Flow_41" sourceRef="exclusivegateway4Join" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_42" name="no nutritional concerns or hydration deficits or dysphagia or other comorbidities identified" sourceRef="exclusivegateway3" targetRef="activity18">
      <conditionExpression xsi:type="bpmn:tFormalExpression">no nutritional concerns or hydration deficits or dysphagia or other comorbidities identified</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_43" sourceRef="activity18" targetRef="exclusivegateway3Join" />
    <sequenceFlow id="Flow_44" sourceRef="activity12_1" targetRef="exclusivegateway3" />
    <sequenceFlow id="Flow_45" sourceRef="exclusivegateway3Join" targetRef="activity19" />
    <sequenceFlow id="Flow_46" sourceRef="activity19" targetRef="EndEvent_1" />
