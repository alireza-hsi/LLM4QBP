  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_27</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="Ensure hip fracture care pathway exists specifying perioperative patient goals by day of stay (Role: hospital administration; Objects: hip fracture care pathway)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_2" name="(dummy branch entry)">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="Register and triage suspected hip fracture patient (Role: ED triage nurse; Objects: patient)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity3" name="See patient within 1 hour of arrival (target: 90%) (Role: ED physician; Objects: patient)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7" name="Order and perform appropriate blood work and X-rays (Role: ED clinical staff; Objects: blood work, X-rays)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8" name="Complete medication reconciliation in ED using standardized form (Role: ED clinical staff; Objects: medication reconciliation form)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="Notify orthopedic surgeon for consultation within 2 hours (target: 90%) (Role: ED staff; Objects: patient)">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="Notify anesthesiologist/internist for awareness and consultation as needed (Role: ED staff; Objects: patient)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-1" name="Assess and document physical health factors (reason for fall, fluid balance, pressure sore risk, hydration/nutrition, pain, temperature, collateral injuries) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-2" name="Assess and document comorbid conditions and current drug therapy (including anticoagulants) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-3" name="Assess and document functional and mental status (continence, pre-fracture functional ability/mobility, physical/functional level, mental state using MMSE/MOCA/CAM) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6-4" name="Assess and document social circumstances (caregiver status, community supports, family involvement) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity9" name="Manage hydration, pain, risk of delirium, and risk of pressure sores as part of comprehensive patient management (Role: ED clinical staff; Objects: patient)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Admit patient within 4 hours of ED arrival (target: 90%) (Role: ED staff; Objects: patient)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity11" name="Follow same early assessment and management practices as ED pathway (Role: clinical staff; Objects: patient)">
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dummy_Flow_15" name="(dummy branch entry)">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity12" name="Medically stabilize patient while awaiting transfer (Role: non-surgical hospital staff; Objects: patient)">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity13" name="Initiate formal protocol for timely transfer to surgical hospital (Role: non-surgical hospital staff; Objects: transfer protocol)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity14" name="Ensure patient receives surgery within 48 hours of initial presentation (Role: non-surgical hospital staff; Objects: patient)">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity15" name="Ensure formal protocols for timely transfer and repatriation are in place (Role: LHINs and hospital administration; Objects: transfer and repatriation protocols)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:exclusiveGateway>
