    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_21" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <bpmn:sequenceFlow id="Flow_22" name="Patient presents to outpatient clinic or is directly admitted to acute care" sourceRef="exclusivegateway1" targetRef="activity11">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to outpatient clinic or is directly admitted to acute care</bpmn:conditionExpression>
