<?xml version='1.0' encoding='UTF-8'?>
<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns3="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <ns0:process id="Process_1" name="Stroke Process" isExecutable="true">
    <ns0:startEvent id="StartEvent_1" name="Start">
      <ns0:outgoing>Flow_1</ns0:outgoing>
    </ns0:startEvent>
    <ns0:endEvent id="EndEvent_1" name="End">
      <ns0:incoming>Flow_27</ns0:incoming>
    </ns0:endEvent>
    <ns0:task id="activity1" name="Ensure hip fracture care pathway exists specifying perioperative patient goals by day of stay (Role: hospital administration; Objects: hip fracture care pathway)">
      <ns0:incoming>Flow_1</ns0:incoming>
      <ns0:outgoing>Flow_26</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <ns0:incoming>Flow_26</ns0:incoming>
      <ns0:outgoing>Flow_20</ns0:outgoing>
      <ns0:outgoing>Flow_22</ns0:outgoing>
      <ns0:outgoing>Flow_24</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:task id="activity2" name="Register and triage suspected hip fracture patient (Role: ED triage nurse; Objects: patient)">
      <ns0:incoming>Flow_3</ns0:incoming>
      <ns0:outgoing>Flow_4</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity3" name="See patient within 1 hour of arrival (target: 90%) (Role: ED physician; Objects: patient)">
      <ns0:incoming>Flow_4</ns0:incoming>
      <ns0:outgoing>Flow_5</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity7" name="Order and perform appropriate blood work and X-rays (Role: ED clinical staff; Objects: blood work, X-rays)">
      <ns0:incoming>Flow_5</ns0:incoming>
      <ns0:outgoing>Flow_6</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity8" name="Complete medication reconciliation in ED using standardized form (Role: ED clinical staff; Objects: medication reconciliation form)">
      <ns0:incoming>Flow_6</ns0:incoming>
      <ns0:outgoing>Flow_7</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity4" name="Notify orthopedic surgeon for consultation within 2 hours (target: 90%) (Role: ED staff; Objects: patient)">
      <ns0:incoming>Flow_7</ns0:incoming>
      <ns0:outgoing>Flow_8</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity5" name="Notify anesthesiologist/internist for awareness and consultation as needed (Role: ED staff; Objects: patient)">
      <ns0:incoming>Flow_8</ns0:incoming>
      <ns0:outgoing>Flow_9</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-1" name="Assess and document physical health factors (reason for fall, fluid balance, pressure sore risk, hydration/nutrition, pain, temperature, collateral injuries) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <ns0:incoming>Flow_9</ns0:incoming>
      <ns0:outgoing>Flow_10</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-2" name="Assess and document comorbid conditions and current drug therapy (including anticoagulants) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <ns0:incoming>Flow_10</ns0:incoming>
      <ns0:outgoing>Flow_11</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-3" name="Assess and document functional and mental status (continence, pre-fracture functional ability/mobility, physical/functional level, mental state using MMSE/MOCA/CAM) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <ns0:incoming>Flow_11</ns0:incoming>
      <ns0:outgoing>Flow_12</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity6-4" name="Assess and document social circumstances (caregiver status, community supports, family involvement) (Role: ED clinical staff; Objects: patient assessment documentation)">
      <ns0:incoming>Flow_12</ns0:incoming>
      <ns0:outgoing>Flow_13</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity9" name="Manage hydration, pain, risk of delirium, and risk of pressure sores as part of comprehensive patient management (Role: ED clinical staff; Objects: patient)">
      <ns0:incoming>Flow_13</ns0:incoming>
      <ns0:outgoing>Flow_14</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity10" name="Admit patient within 4 hours of ED arrival (target: 90%) (Role: ED staff; Objects: patient)">
      <ns0:incoming>Flow_14</ns0:incoming>
      <ns0:outgoing>Flow_21</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity11" name="Follow same early assessment and management practices as ED pathway (Role: clinical staff; Objects: patient)">
      <ns0:incoming>Flow_22</ns0:incoming>
      <ns0:outgoing>Flow_23</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity12" name="Medically stabilize patient while awaiting transfer (Role: non-surgical hospital staff; Objects: patient)">
      <ns0:incoming>Flow_16</ns0:incoming>
      <ns0:outgoing>Flow_17</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity13" name="Initiate formal protocol for timely transfer to surgical hospital (Role: non-surgical hospital staff; Objects: transfer protocol)">
      <ns0:incoming>Flow_17</ns0:incoming>
      <ns0:outgoing>Flow_18</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity14" name="Ensure patient receives surgery within 48 hours of initial presentation (Role: non-surgical hospital staff; Objects: patient)">
      <ns0:incoming>Flow_18</ns0:incoming>
      <ns0:outgoing>Flow_19</ns0:outgoing>
    </ns0:task>
    <ns0:task id="activity15" name="Ensure formal protocols for timely transfer and repatriation are in place (Role: LHINs and hospital administration; Objects: transfer and repatriation protocols)">
      <ns0:incoming>Flow_19</ns0:incoming>
      <ns0:outgoing>Flow_25</ns0:outgoing>
    </ns0:task>
    <ns0:exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <ns0:incoming>Flow_21</ns0:incoming>
      <ns0:incoming>Flow_23</ns0:incoming>
      <ns0:incoming>Flow_25</ns0:incoming>
      <ns0:outgoing>Flow_27</ns0:outgoing>
    </ns0:exclusiveGateway>
