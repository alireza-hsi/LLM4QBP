    <ns0:sequenceFlow id="Flow_21" sourceRef="activity10" targetRef="exclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_22" name="Patient presents to outpatient clinic or is directly admitted to acute care" sourceRef="exclusivegateway1" targetRef="activity11">
      <ns0:conditionExpression xsi:type="bpmn:tFormalExpression">Patient presents to outpatient clinic or is directly admitted to acute care</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_23" sourceRef="activity11" targetRef="exclusivegateway1Join" />
    <ns0:sequenceFlow id="Flow_25" sourceRef="activity15" targetRef="exclusivegateway1Join" />
