  <process id="Process_1" name="Stroke Process" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_27</incoming>
    </endEvent>
    <task id="activity1" name="Ensure hip fracture care pathway exists specifying perioperative patient goals by day of stay (Role: hospital administration; Objects: hip fracture care pathway)">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_26</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1" name="Exclusive Gateway">
      <incoming>Flow_26</incoming>
      <outgoing>Flow_20</outgoing>
      <outgoing>Flow_22</outgoing>
      <outgoing>Flow_24</outgoing>
    </exclusiveGateway>
    <task id="activity2" name="Register and triage suspected hip fracture patient (Role: ED triage nurse; Objects: patient)">
      <incoming>Flow_3</incoming>
      <outgoing>Flow_4</outgoing>
    </task>
    <task id="activity3" name="Seen by physician">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <task id="activity7" name="Issue appropriate blood work; Perform x-ray">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_6</outgoing>
    </task>
    <task id="activity8" name="Perform medication reconciliation within the ED">
      <incoming>Flow_6</incoming>
      <outgoing>Flow_7</outgoing>
    </task>
    <task id="activity4" name="Consultation with orthopaedic surgeon">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
    <task id="activity5" name="Consultation with anesthesiologists; Consultation with internist">
      <incoming>Flow_8</incoming>
      <outgoing>Flow_9</outgoing>
    </task>
    <task id="activity6-1" name="Assess reason for fall; Assess fluid balance; Assess pressure sore risk; Assess hydration and nutrition; Assess pain; Assess temperature; Assess other collateral injuries">
      <incoming>Flow_9</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <task id="activity6-2" name="Assess comorbid conditions; Assess current drug therapy">
      <incoming>Flow_10</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    <task id="activity6-3" name="Assess continence; Assess pre-fracture functional ability, mobility; Assess physical, functional level; Assess mental state based on pre-morbid functioning level">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    <task id="activity6-4" name="Assess social circumstances">
      <incoming>Flow_12</incoming>
      <outgoing>Flow_13</outgoing>
    </task>
    <task id="activity9" name="Manage patients hydration within the ED; Manage patients pain, risk  within the ED; Manage patients' risk of pressure sores within the ED; Manage patients delirium  within the ED">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_14</outgoing>
    </task>
    <task id="activity10" name="Admit patient">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_21</outgoing>
    </task>
    <task id="activity11" name="Follow same early assessment and management practices as ED pathway (Role: clinical staff; Objects: patient)">
      <incoming>Flow_22</incoming>
      <outgoing>Flow_23</outgoing>
    </task>
    <task id="activity12" name="Medically stabilize">
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
    <task id="activity13" name="expeditious transfer to a surgical hospital for operation based on formal protocol">
      <incoming>Flow_17</incoming>
      <outgoing>Flow_18</outgoing>
    </task>
    <task id="activity14" name="Ensure patient receives surgery within 48 hours of initial presentation (Role: non-surgical hospital staff; Objects: patient)">
      <incoming>Flow_18</incoming>
      <outgoing>Flow_19</outgoing>
    </task>
    <task id="activity15" name="Ensure formal protocols for timely transfer and repatriation are in place (Role: LHINs and hospital administration; Objects: transfer and repatriation protocols)">
      <incoming>Flow_19</incoming>
      <outgoing>Flow_25</outgoing>
    </task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
      <incoming>Flow_21</incoming>
      <incoming>Flow_23</incoming>
      <incoming>Flow_25</incoming>
      <outgoing>Flow_27</outgoing>
    </exclusiveGateway>
