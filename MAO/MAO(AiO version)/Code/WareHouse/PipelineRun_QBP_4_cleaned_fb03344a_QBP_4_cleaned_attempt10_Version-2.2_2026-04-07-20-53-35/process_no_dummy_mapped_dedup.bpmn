    <task id="activity1" name="triage patient with suspected stroke presenting to the ED, outpatient clinic, or acute care unit (Role: receiving clinician; Objects: patient)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></task>
    <task id="activity2.1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_2</incoming><outgoing>Flow_5</outgoing></task>
    <task id="activity3" name="Neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_5</incoming><outgoing>Flow_35</outgoing></task>
