    <task id="activity8" name="continue non-hyperacute stroke assessment and determine need for subsequent vascular imaging based on diagnosis and timing (Role: stroke clinician; Objects: clinical findings, onset time)">
      <incoming>Flow_20</incoming><outgoing>Flow_21</outgoing></task>
    <exclusiveGateway id="exclusivegateway1Join" name="Exclusive Merge">
