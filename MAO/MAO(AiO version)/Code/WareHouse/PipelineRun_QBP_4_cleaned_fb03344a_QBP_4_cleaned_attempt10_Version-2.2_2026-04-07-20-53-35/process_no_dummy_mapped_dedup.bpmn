    <task id="activity4.1" name="Rapid brain imaging (non-contrast CT or MRI) and CTA (Door to CT/CTA should be less than 25 minutes)">
      <incoming>merged_Flow_18_Flow_11</incoming><outgoing>Flow_12</outgoing></task>
    <task id="activity5" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_12</incoming><outgoing>Flow_17</outgoing></task>
