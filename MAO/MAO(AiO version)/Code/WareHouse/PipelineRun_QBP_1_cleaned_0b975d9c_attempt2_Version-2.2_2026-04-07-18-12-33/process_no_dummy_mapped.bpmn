    <task id="activity7-1" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_16</outgoing>
    </task>
    <task id="activity7-2" name="Blood work:&#10; CBC, electrolytes, creatinine, glucose, INR, partial thromboplastin time, and troponin test (if clinically indicated)">
      <incoming>Flow_15</incoming>
      <outgoing>Flow_17</outgoing>
    </task>
