    <task id="activity5" name="ECG to detect atrial fibrillation and other acute arrhythmias">
      <incoming>Flow_29</incoming>
      <outgoing>Flow_36</outgoing>
    </task>
    <task id="activity6" name="Chest x-ray without delay for for thrombolysis assessment">
      <incoming>Flow_30</incoming>
      <outgoing>Flow_37</outgoing>
