      <outgoing>Flow_1</outgoing>
    </startEvent>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_44</incoming>
    </endEvent>
    <task id="activity1" name="Rapid initial evaluation for airway, breathing, and circulation">
      <incoming>Flow_1</incoming>
      <outgoing>Flow_2</outgoing>
    </task>
    <task id="activity2" name="neurological examination to determine focal neurological deficits and assess stroke severity on a standardized stroke scale (NIHSS or CNS for stroke)">
      <incoming>Flow_2</incoming>
      <outgoing>Flow_13</outgoing>
    </task>
    <inclusiveGateway id="inclusivegateway1" name="Inclusive Gateway">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_9</outgoing>
      <outgoing>Flow_11</outgoing>
    </inclusiveGateway>
    <task id="activity3-1" name="Immediate brain imaging (CT or MRI)">
      <incoming>Flow_4</incoming>
      <outgoing>Flow_5</outgoing>
    </task>
    <task id="activity4-1" name="Immediate expert healthcare provider interpretation of the brain imaging">
      <incoming>Flow_5</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    <task id="activity3-2" name="Immediate brain imaging (CT or MRI)">
      <incoming>Flow_7</incoming>
      <outgoing>Flow_8</outgoing>
    </task>
