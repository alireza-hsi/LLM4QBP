<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" name="Stroke Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_24</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="activity1" name="Initiate acute heart failure episode of care (Role: emergency department clinician; Objects: patient presenting with suspected acute heart failure)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity2" name="Apply standardized risk-stratification tool for acute heart failure and other conditions (Role: emergency department clinician; Objects: risk-stratification tool)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1-1" name="Parallel Gateway">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity3-1" name="Order initial investigations (serum creatinine, electrolytes, troponin, CBC, ECG, chest x-ray, echocardiogram if no recent available) (Role: emergency department clinician; Objects: laboratory and imaging test orders)">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity4" name="Frequently measure heart rate, blood pressure, and oxygen saturation until patient is stabilized (Role: emergency department nurse; Objects: vital sign monitoring equipment)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="parallelgateway1-1Join" name="Parallel Merge">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="activity3-2" name="Review results of investigations (Role: emergency department clinician; Objects: laboratory and imaging test results)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity5" name="Assess responsiveness to diuresis (Role: emergency department clinician; Objects: patient response to furosemide and other interventions)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity6" name="Calculate acute heart failure risk score (e.g., EHMRG) to predict 7-day mortality risk (Role: emergency department clinician; Objects: EHMRG risk score calculator)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway1-1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="dummy_Flow_11" name="(dummy branch entry)">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7-1" name="Provide discharge instructions (Role: emergency department clinician; Objects: discharge instructions)">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity7-2" name="Complete discharge documentation (Role: emergency department clinician; Objects: discharge paperwork)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity8" name="Arrange follow-up visit with primary care provider within days of discharge (Role: emergency department clinician; Objects: follow-up appointment)">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2-1" name="Exclusive Gateway">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="activity9" name="Admit patient to intensive care unit with higher nurse-to-patient staffing (Role: emergency department clinician; Objects: ICU admission order)">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="activity10" name="Admit patient to inpatient care (Role: emergency department clinician; Objects: inpatient admission order)">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="exclusivegateway2-1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="exclusivegateway1-1Join" name="Exclusive Merge">
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="activity1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="activity1" targetRef="activity2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="parallelgateway1-1" targetRef="activity3-1" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="parallelgateway1-1" targetRef="activity4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="activity3-1" targetRef="parallelgateway1-1Join" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="activity4" targetRef="parallelgateway1-1Join" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="activity2" targetRef="parallelgateway1-1" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="parallelgateway1-1Join" targetRef="activity3-2" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="activity3-2" targetRef="activity5" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="activity5" targetRef="activity6" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="dummy_Flow_11" targetRef="activity7-1" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="activity7-1" targetRef="activity7-2" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="activity7-2" targetRef="activity8" />
    <bpmn:sequenceFlow id="Flow_15" name="Requires ventilation and/or intensive care" sourceRef="exclusivegateway2-1" targetRef="activity9">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires ventilation and/or intensive care</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_16" sourceRef="activity9" targetRef="exclusivegateway2-1Join" />
    <bpmn:sequenceFlow id="Flow_17" name="Requires inpatient care with normal nurse-to-patient staffing" sourceRef="exclusivegateway2-1" targetRef="activity10">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Requires inpatient care with normal nurse-to-patient staffing</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_18" sourceRef="activity10" targetRef="exclusivegateway2-1Join" />
    <bpmn:sequenceFlow id="Flow_19" name="Low-risk (EHMRG quintiles 1-2), responded to initial treatment, no other considerations" sourceRef="exclusivegateway1-1" targetRef="dummy_Flow_11">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">Low-risk (EHMRG quintiles 1-2), responded to initial treatment, no other considerations</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_20" sourceRef="activity8" targetRef="exclusivegateway1-1Join" />
    <bpmn:sequenceFlow id="Flow_21" name="High-risk (EHMRG quintiles 3-5) OR high-risk markers present OR other considerations (e.g., advanced directives, severe dementia)" sourceRef="exclusivegateway1-1" targetRef="exclusivegateway2-1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">High-risk (EHMRG quintiles 3-5) OR high-risk markers present OR other considerations (e.g., advanced directives, severe dementia)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_22" sourceRef="exclusivegateway2-1Join" targetRef="exclusivegateway1-1Join" />
    <bpmn:sequenceFlow id="Flow_23" sourceRef="activity6" targetRef="exclusivegateway1-1" />
    <bpmn:sequenceFlow id="Flow_24" sourceRef="exclusivegateway1-1Join" targetRef="EndEvent_1" />
  </bpmn:process>
